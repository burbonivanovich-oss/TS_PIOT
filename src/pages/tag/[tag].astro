---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES, SITE_TITLE } from '../../consts';
import { collectTags, pluralPosts } from '../../utils/tags';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);
	const tags = collectTags(posts);
	return Object.entries(tags).map(([slug, info]) => ({
		params: { tag: slug },
		props: { slug, displayName: info.name, posts: info.posts },
	}));
}

type Props = {
	slug: string;
	displayName: string;
	posts: CollectionEntry<'blog'>[];
};

const { slug, displayName, posts } = Astro.props as Props;
const sortedPosts = [...posts].sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const title = `Тег «${displayName}»`;
const description = `Материалы портала «${SITE_TITLE}» по теме «${displayName}»: ${sortedPosts.length} ${pluralPosts(sortedPosts.length)}.`;

const breadcrumbsJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Главная',
			item: new URL('/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Теги',
			item: new URL('/tags/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: displayName,
			item: new URL(`/tag/${slug}/`, Astro.site).toString(),
		},
	],
};

const collectionJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: title,
	description,
	url: new URL(`/tag/${slug}/`, Astro.site).toString(),
	inLanguage: 'ru-RU',
};
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead
			title={title}
			description={description}
			jsonLd={[collectionJsonLd, breadcrumbsJsonLd]}
		/>
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumbs" aria-label="Хлебные крошки">
				<a href="/">Главная</a>
				<span>›</span>
				<a href="/tags/">Теги</a>
				<span>›</span>
				<span aria-current="page">{displayName}</span>
			</nav>

			<header class="page-head">
				<h1>#{displayName}</h1>
				<p>
					{sortedPosts.length} {pluralPosts(sortedPosts.length)} по тегу «{displayName}».
				</p>
			</header>

			<ul class="post-list">
				{sortedPosts.map((post) => {
					const cat = post.data.categories[0] as keyof typeof CATEGORIES | undefined;
					const catMeta = cat ? CATEGORIES[cat] : null;
					return (
						<li class="post-card">
							<a href={`/blog/${post.id}/`}>
								{catMeta && <span class="post-cat">{catMeta.title}</span>}
								<h2>{post.data.title}</h2>
								<p class="post-desc">{post.data.description}</p>
								<p class="post-date">
									{post.data.updatedDate ? (
										<>обновлено <FormattedDate date={post.data.updatedDate} /></>
									) : (
										<FormattedDate date={post.data.pubDate} />
									)}
								</p>
							</a>
						</li>
					);
				})}
			</ul>
		</main>
		<Footer />

		<style>
			.breadcrumbs {
				font-size: 0.88rem;
				color: rgb(var(--gray));
				margin-top: 1rem;
			}
			.breadcrumbs a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumbs a:hover {
				color: var(--accent);
			}
			.breadcrumbs span {
				margin: 0 0.4em;
			}
			.page-head {
				padding: 1.5rem 0 1rem;
				max-width: 820px;
			}
			.page-head h1 {
				margin-bottom: 0.5rem;
			}
			.page-head p {
				color: rgb(var(--gray-dark));
				font-size: 1.05rem;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 1.5rem 0 0;
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 1rem;
			}
			.post-card a {
				display: block;
				padding: 1.4rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 10px;
				background: #fff;
				color: rgb(var(--gray-dark));
				text-decoration: none;
				height: 100%;
				transition: all 0.15s ease;
			}
			.post-card a:hover {
				border-color: var(--accent);
				box-shadow: var(--box-shadow);
			}
			.post-cat {
				display: inline-block;
				font-size: 0.8rem;
				font-weight: 600;
				color: var(--accent);
				background: var(--accent-soft);
				padding: 0.2em 0.7em;
				border-radius: 999px;
				margin-bottom: 0.6rem;
			}
			.post-card h2 {
				margin-top: 0;
				color: rgb(var(--black));
				font-size: 1.2rem;
			}
			.post-desc {
				font-size: 0.95rem;
				margin-bottom: 0.8rem;
			}
			.post-date {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				margin: 0;
			}
		</style>
	</body>
</html>
