---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import BlogFilter from '../../components/BlogFilter';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES } from '../../consts';
import { collectTags } from '../../utils/tags';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const pageTitle = 'Все статьи';
const pageDescription =
	'Архив материалов: ТС ПИоТ, маркировка «Честный знак», изменения в законодательстве для малого и среднего бизнеса.';

const postData = posts.map((p) => ({
	id: p.id,
	title: p.data.title,
	description: p.data.description,
	pubDate: p.data.pubDate.toISOString(),
	updatedDate: p.data.updatedDate?.toISOString(),
	categories: p.data.categories ?? [],
	tags: p.data.tags ?? [],
	previewImage: p.data.previewImage,
}));

const allTags = Object.values(collectTags(posts))
	.map((t) => t.name)
	.sort((a, b) => a.localeCompare(b, 'ru'));

const categoriesForFilter = Object.fromEntries(
	Object.entries(CATEGORIES).map(([k, v]) => [k, { title: v.title }]),
);
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<p class="page-eyebrow">Архив</p>
				<h1 class="page-title">{posts.length} материалов<br />о практике бизнеса</h1>
			</header>

			{posts.length === 0 ? (
				<p>Материалы появятся в ближайшее время.</p>
			) : (
				<BlogFilter
					client:load
					posts={postData}
					categories={categoriesForFilter}
					allTags={allTags}
				/>
			)}
		</main>
		<Footer />

		<style>
			.page-head {
				padding: 3rem 0 2.5rem;
				border-bottom: 1px solid var(--border);
				margin-bottom: 2.5rem;
			}
			.page-eyebrow {
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--muted);
				margin: 0 0 0.75rem;
			}
			.page-title {
				font-size: clamp(2rem, 5vw, 3.2rem);
				letter-spacing: -0.03em;
				margin: 0;
				line-height: 1.1;
			}
		</style>
	</body>
</html>
