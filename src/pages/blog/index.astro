---
import BaseHead from '../../components/BaseHead.astro';
import BlogFilter from '../../components/BlogFilter';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES } from '../../consts';
import { collectTags } from '../../utils/tags';
import { publishedPosts } from '../../utils/posts';

const posts = (await publishedPosts()).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const pageTitle = 'Все статьи';
const pageDescription =
	'Архив материалов: ТС ПИоТ, маркировка «Честный знак», изменения в законодательстве для малого и среднего бизнеса.';

const postData = posts.map((p) => ({
	id: p.id,
	title: p.data.title,
	description: p.data.description,
	pubDate: p.data.pubDate.toISOString(),
	updatedDate: p.data.updatedDate?.toISOString(),
	categories: p.data.categories ?? [],
	tags: p.data.tags ?? [],
	previewImage: p.data.previewImage,
	heroImage: p.data.heroImage,
}));

const allTags = Object.values(collectTags(posts))
	.map((t) => t.name)
	.sort((a, b) => a.localeCompare(b, 'ru'));

const categoriesForFilter = Object.fromEntries(
	Object.entries(CATEGORIES).map(([k, v]) => [k, { title: v.title }]),
);
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
	</head>
	<body>
		<Header />
		<main>
			<section class="blog-head">
				<div class="wrap">
					<nav class="breadcrumbs" aria-label="Хлебные крошки">
						<a href="/">Главная</a><span>›</span><span aria-current="page">Все материалы</span>
					</nav>
					<div class="blog-head-row">
						<div>
							<span class="eyebrow">Архив</span>
							<h1>Все материалы</h1>
							<p class="b-sub">
								Статьи о требованиях для МСБ: ТС ПИоТ, маркировка, налоги, ЭДО, кассы.
								Все факты со ссылками на первоисточники, дата актуализации — в шапке статьи.
							</p>
						</div>
						<div class="b-search-wrap">
							<input
								class="b-search"
								placeholder="Поиск по статьям…"
								type="search"
								onkeydown="if(event.key==='Enter')window.location='/search/?q='+encodeURIComponent(this.value)"
							/>
							<button
								class="b-search-go"
								onclick="window.location='/search/?q='+encodeURIComponent(this.previousElementSibling?.value||'')"
								type="button"
							>Найти →</button>
						</div>
					</div>
				</div>
			</section>

			<div class="wrap">
				{posts.length === 0 ? (
					<p>Материалы появятся в ближайшее время.</p>
				) : (
					<BlogFilter
						client:load
						posts={postData}
						categories={categoriesForFilter}
						allTags={allTags}
					/>
				)}
			</div>
		</main>
		<Footer />

		<style>
			main { padding: 0 0 80px; }
			.wrap { max-width: 1240px; margin: 0 auto; padding: 0 28px; }

			.blog-head {
				background: #fff;
				border-bottom: 1px solid var(--line, #E5E1D8);
				padding: 36px 0 32px;
				margin-bottom: 32px;
			}
			.breadcrumbs {
				font-size: .7rem;
				font-weight: 600;
				letter-spacing: .1em;
				text-transform: uppercase;
				color: var(--mute, #9a9a9a);
				margin-bottom: 18px;
			}
			.breadcrumbs a { color: inherit; text-decoration: none; }
			.breadcrumbs a:hover { color: #111; }
			.breadcrumbs span { margin: 0 .4em; }
			.blog-head-row {
				display: grid;
				grid-template-columns: 1fr auto;
				gap: 32px;
				align-items: end;
			}
			.eyebrow {
				display: block;
				font-size: .68rem;
				font-weight: 700;
				letter-spacing: .18em;
				text-transform: uppercase;
				color: var(--pink, #9E2B4F);
				margin-bottom: 10px;
			}
			.blog-head h1 {
				font-family: var(--f-display, 'Bebas Neue', sans-serif);
				font-size: clamp(2.6rem, 5vw, 4.4rem);
				line-height: .95;
				letter-spacing: .02em;
				color: #111;
				margin: 0 0 14px;
				text-transform: uppercase;
			}
			.b-sub {
				font-size: 1rem;
				color: var(--ink-3, #666);
				max-width: 540px;
				line-height: 1.55;
				margin: 0;
			}
			.b-search-wrap {
				display: flex;
				gap: 6px;
				align-items: stretch;
				min-width: 320px;
			}
			.b-search {
				flex: 1;
				padding: 12px 14px;
				border: 2px solid #111;
				font-size: .92rem;
				background: #fff;
				font-family: inherit;
				border-radius: 0;
				outline: none;
			}
			.b-search:focus { border-color: var(--pink, #9E2B4F); }
			.b-search-go {
				background: #111;
				color: var(--lime, #AFCC00);
				border: 0;
				padding: 12px 20px;
				font-size: .72rem;
				font-weight: 700;
				letter-spacing: .12em;
				text-transform: uppercase;
				cursor: pointer;
				font-family: inherit;
			}
			.b-search-go:hover { background: var(--pink, #9E2B4F); color: #fff; }

			@media (max-width: 820px) {
				.blog-head-row { grid-template-columns: 1fr; gap: 18px; }
				.b-search-wrap { min-width: 0; }
				.wrap { padding: 0 20px; }
			}
			@media (max-width: 560px) {
				.wrap { padding: 0 16px; }
			}
		</style>
	</body>
</html>
