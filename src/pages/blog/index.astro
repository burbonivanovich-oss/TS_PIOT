---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import BlogFilter from '../../components/BlogFilter';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES } from '../../consts';
import { collectTags } from '../../utils/tags';

const now = new Date();
const posts = (await getCollection('blog', ({ data }) => !data.draft && data.pubDate <= now)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const pageTitle = 'Все статьи';
const pageDescription =
	'Архив материалов: ТС ПИоТ, маркировка «Честный знак», изменения в законодательстве для малого и среднего бизнеса.';

const postData = posts.map((p) => ({
	id: p.id,
	title: p.data.title,
	description: p.data.description,
	pubDate: p.data.pubDate.toISOString(),
	updatedDate: p.data.updatedDate?.toISOString(),
	categories: p.data.categories ?? [],
	tags: p.data.tags ?? [],
	previewImage: p.data.previewImage,
	heroImage: p.data.heroImage,
}));

const allTags = Object.values(collectTags(posts))
	.map((t) => t.name)
	.sort((a, b) => a.localeCompare(b, 'ru'));

const categoriesForFilter = Object.fromEntries(
	Object.entries(CATEGORIES).map(([k, v]) => [k, { title: v.title }]),
);
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-title-block">
				<div class="breadcrumb">Главная / Статьи</div>
				<div class="page-search-wrap">
					<div>
						<div class="page-title">Статьи</div>
						<div class="page-subtitle">{posts.length} материалов о практике малого бизнеса</div>
					</div>
					<div class="page-search-right">
						<input class="search-input" placeholder="Поиск по статьям…" type="search" onkeydown="if(event.key==='Enter')window.location='/search/?q='+encodeURIComponent(this.value)" />
						<div>
							<button class="search-go" onclick="window.location='/search/?q='+encodeURIComponent(this.previousElementSibling?.value||'')" type="button">▶</button>
						</div>
					</div>
				</div>
			</div>

			{posts.length === 0 ? (
				<p>Материалы появятся в ближайшее время.</p>
			) : (
				<BlogFilter
					client:load
					posts={postData}
					categories={categoriesForFilter}
					allTags={allTags}
				/>
			)}
		</main>
		<Footer />

		<style>
			main {
				padding: 48px 32px 80px;
			}

			.page-title-block {
				padding-bottom: 32px;
				border-bottom: 1px solid rgba(0, 0, 0, .12);
				margin-bottom: 40px;
			}
			.breadcrumb {
				font-size: .7rem;
				font-weight: 600;
				letter-spacing: .12em;
				text-transform: uppercase;
				color: #999;
				margin-bottom: 8px;
			}
			.page-search-wrap {
				display: flex;
				justify-content: space-between;
				align-items: flex-end;
			}
			.page-title {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 7rem;
				line-height: .9;
				letter-spacing: .02em;
				color: #111;
				margin-bottom: 12px;
			}
			.page-title .dot {
				color: #9E2B4F;
			}
			.page-subtitle {
				font-size: .95rem;
				color: #666;
				max-width: 360px;
			}
			.page-search-right {
				display: flex;
				flex-direction: column;
				align-items: flex-end;
				gap: 4px;
			}
			.search-input {
				border: none;
				background: none;
				border-bottom: 2px solid #111;
				padding: 8px 0;
				font-size: .9rem;
				width: 220px;
				outline: none;
				font-family: 'Inter', sans-serif;
				color: #111;
			}
			.search-input::placeholder {
				color: #aaa;
			}
			.search-go {
				background: #111;
				color: #EDE8DF;
				border: none;
				padding: 8px 14px;
				cursor: pointer;
				font-weight: 700;
				font-size: .8rem;
			}
			.search-go:hover {
				background: #9E2B4F;
			}

			@media (max-width: 820px) {
				main {
					padding: 32px 20px 60px;
				}
				.page-title {
					font-size: 5rem;
				}
				.page-search-wrap {
					flex-direction: column;
					align-items: flex-start;
					gap: 16px;
				}
				.page-search-right {
					align-items: flex-start;
					width: 100%;
				}
				.search-input {
					width: 100%;
				}
			}
			@media (max-width: 560px) {
				main {
					padding: 24px 16px 48px;
				}
				.page-title {
					font-size: 4rem;
				}
			}
		</style>
	</body>
</html>
