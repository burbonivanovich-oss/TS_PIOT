---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { CATEGORIES } from '../../consts';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const cat = Astro.url.searchParams.get('cat') ?? '';
const posts = cat
	? allPosts.filter((p) => (p.data.categories ?? []).includes(cat))
	: allPosts;

const filters = [
	{ slug: '', label: 'Все' },
	{ slug: 'ts-piot', label: 'ТС ПИоТ' },
	{ slug: 'markirovka', label: 'Маркировка' },
	{ slug: 'zakonodatelstvo', label: 'Законодательство' },
];

const pageTitle = 'Все статьи';
const pageDescription =
	'Архив материалов: ТС ПИоТ, маркировка «Честный знак», изменения в законодательстве для малого и среднего бизнеса.';
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head">
				<h1 class="font-display page-title">Все статьи</h1>
				<p class="page-sub">{pageDescription}</p>
			</section>

			<section class="search-promo">
				<a href="/search/" class="search-input">
					<span class="search-icon" aria-hidden="true">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="11" cy="11" r="7" />
							<path d="m20 20-3.5-3.5" />
						</svg>
					</span>
					<span class="search-placeholder">Поиск по статьям…</span>
				</a>
			</section>

			<div class="blog-filters">
				<div class="filter-tabs">
					{filters.map((f) => (
						<a
							class:list={[
								'filter-tab',
								{ 'is-active': (cat || '') === f.slug },
							]}
							href={f.slug ? `/blog/?cat=${f.slug}` : '/blog/'}
						>
							{f.label}
						</a>
					))}
				</div>
				<div class="filter-meta">
					<a href="/tags/" class="tag-dropdown">Тег ▾</a>
					<span class="filter-count">{posts.length} материалов</span>
				</div>
			</div>

			{posts.length === 0 ? (
				<p class="empty">В этой категории пока нет материалов.</p>
			) : (
				<section class="post-grid">
					<ul>
						{posts.map((post) => {
							const c = (post.data.categories?.[0] as keyof typeof CATEGORIES | undefined) ?? 'ts-piot';
							const cTitle = CATEGORIES[c]?.title ?? '';
							return (
								<li class="post-card">
									<a href={`/blog/${post.id}/`} data-cat={c}>
										<div class="post-card-img">
											{post.data.previewImage ? (
												<img src={post.data.previewImage} alt="" loading="lazy" />
											) : (
												<div class="post-card-placeholder" data-cat={c} aria-hidden="true">
													<span class="font-display">
														{c === 'ts-piot'
															? 'ТС'
															: c === 'markirovka'
																? 'МЗ'
																: 'НА'}
													</span>
												</div>
											)}
										</div>
										<div class="post-card-body">
											<span class="cat-badge" data-cat={c}>{cTitle}</span>
											<h3>{post.data.title}</h3>
											<p class="post-desc">{post.data.description}</p>
											<p class="post-date">
												<FormattedDate date={post.data.pubDate} />
											</p>
										</div>
									</a>
								</li>
							);
						})}
					</ul>
				</section>
			)}

			<nav class="pagination" aria-label="Пагинация">
				<span class="pg-arrow pg-disabled">‹</span>
				<span class="pg-num pg-active">1</span>
				<span class="pg-arrow pg-disabled">›</span>
			</nav>
		</main>
		<Footer />

		<style>
			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 36px 28px var(--sp-8);
			}

			.page-head {
				padding: 24px 0 8px;
			}
			.page-title {
				font-size: clamp(2rem, 4vw, 3.4rem);
				margin: 0 0 12px;
				color: var(--text);
			}
			.page-sub {
				color: var(--text-2);
				font-size: 1rem;
				max-width: 720px;
				margin: 0;
			}

			.search-promo { margin: 28px 0 8px; }
			.search-input {
				display: flex;
				align-items: center;
				gap: 12px;
				width: 100%;
				padding: 14px 18px;
				background: var(--bg-muted);
				border: 1px solid var(--border);
				color: var(--text-3);
				text-decoration: none;
				transition: border-color var(--ease), color var(--ease);
			}
			.search-input:hover {
				border-color: var(--accent);
				color: var(--text);
				text-decoration: none;
			}
			.search-icon { display: inline-flex; }
			.search-placeholder { font-size: 0.95rem; }

			.blog-filters {
				display: flex;
				align-items: center;
				justify-content: space-between;
				flex-wrap: wrap;
				gap: var(--sp-3);
				margin: 28px 0 24px;
				padding-bottom: 14px;
				border-bottom: 1px solid var(--border);
			}
			.filter-tabs {
				display: flex;
				flex-wrap: wrap;
				gap: 4px;
			}
			.filter-tab {
				padding: 8px 16px;
				font-size: 0.72rem;
				font-weight: 800;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--text-3);
				background: transparent;
				border: 1px solid transparent;
				text-decoration: none;
				transition: background var(--ease), color var(--ease), border-color var(--ease);
			}
			.filter-tab:hover {
				color: var(--text);
				border-color: var(--border);
				text-decoration: none;
			}
			.filter-tab.is-active {
				background: var(--accent);
				color: #fff;
				border-color: var(--accent);
			}
			.filter-meta {
				display: flex;
				align-items: center;
				gap: 16px;
				font-size: 0.78rem;
				color: var(--text-3);
				letter-spacing: 0.04em;
			}
			.tag-dropdown {
				font-size: 0.72rem;
				font-weight: 800;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--text);
				padding: 8px 14px;
				border: 1px solid var(--border);
				text-decoration: none;
			}
			.tag-dropdown:hover {
				border-color: var(--text);
				text-decoration: none;
			}

			.post-grid ul {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 24px;
			}
			.post-card a {
				display: flex;
				flex-direction: column;
				height: 100%;
				background: var(--bg);
				border: 1px solid var(--border);
				color: var(--text);
				text-decoration: none;
				transition: border-color var(--ease), background var(--ease);
				overflow: hidden;
			}
			.post-card a:hover {
				border-color: var(--accent);
				background: var(--bg-muted);
				text-decoration: none;
			}
			.post-card-img {
				aspect-ratio: 16 / 9;
				overflow: hidden;
				background: var(--bg-subtle);
			}
			.post-card-img img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
				border-radius: 0;
			}
			.post-card-placeholder {
				width: 100%;
				height: 100%;
				display: flex;
				align-items: center;
				justify-content: center;
				background: linear-gradient(135deg, var(--cat-ts-piot-bg) 0%, var(--cat-ts-piot-fg) 100%);
			}
			.post-card-placeholder[data-cat="markirovka"] {
				background: linear-gradient(135deg, var(--cat-mark-bg) 0%, var(--cat-mark-fg) 100%);
			}
			.post-card-placeholder[data-cat="zakonodatelstvo"] {
				background: linear-gradient(135deg, var(--cat-zakon-bg) 0%, var(--cat-zakon-fg) 100%);
			}
			.post-card-placeholder span {
				font-size: 4rem;
				color: rgba(255, 255, 255, 0.22);
			}
			.post-card-body {
				padding: 18px 20px;
				display: flex;
				flex-direction: column;
				flex: 1;
			}
			.post-card-body .cat-badge { align-self: flex-start; margin-bottom: 10px; }
			.post-card h3 {
				font-size: 1.05rem;
				line-height: 1.3;
				margin: 0 0 8px;
				color: var(--text);
				letter-spacing: -0.01em;
			}
			.post-desc {
				font-size: 0.875rem;
				color: var(--text-2);
				margin: 0 0 12px;
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.post-date {
				margin: auto 0 0;
				font-size: 0.78rem;
				color: var(--text-3);
				letter-spacing: 0.04em;
			}

			.pagination {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 6px;
				margin-top: 48px;
			}
			.pg-num,
			.pg-arrow {
				width: 36px;
				height: 36px;
				display: inline-flex;
				align-items: center;
				justify-content: center;
				font-size: 0.85rem;
				font-weight: 700;
				border: 1px solid var(--border);
				color: var(--text);
				text-decoration: none;
			}
			.pg-active {
				background: var(--accent);
				color: #fff;
				border-color: var(--accent);
			}
			.pg-disabled { color: var(--text-4); }

			.empty {
				padding: 32px 0;
				color: var(--text-3);
			}

			@media (max-width: 900px) {
				main { padding: 24px 20px var(--sp-7); }
				.post-grid ul { grid-template-columns: 1fr 1fr; }
			}
			@media (max-width: 560px) {
				.post-grid ul { grid-template-columns: 1fr; }
			}
		</style>
	</body>
</html>
