---
// Алиасы для старых URL без даты в slug. Раньше статьи лежали по
// `/blog/chto-takoe-ts-piot/`, потом мы перешли на формат
// `/blog/2026-MM-DD-chto-takoe-ts-piot/`. Google проиндексировал
// старые URL — отдаём meta-refresh редирект, чтобы перенаправить
// и индекс, и пользователя.
import { getCollection } from 'astro:content';
import { SITE_URL } from '../../consts';

export async function getStaticPaths() {
	const now = new Date();
	const posts = await getCollection(
		'blog',
		({ data }) => !data.draft && data.pubDate <= now,
	);

	// Для каждой статьи с slug вида YYYY-MM-DD-<short> создаём alias
	// со <short>. Если несколько статей дают один alias (коллизия) —
	// берём самую свежую по pubDate; остальные пропускаем.
	const aliasMap = new Map<string, { full: string; pubDate: Date }>();
	for (const p of posts) {
		const m = p.id.match(/^\d{4}-\d{2}-\d{2}-(.+)$/);
		if (!m) continue;
		const short = m[1];
		const existing = aliasMap.get(short);
		if (!existing || p.data.pubDate > existing.pubDate) {
			aliasMap.set(short, { full: p.id, pubDate: p.data.pubDate });
		}
	}

	return Array.from(aliasMap.entries()).map(([short, { full }]) => ({
		params: { legacy: short },
		props: { fullSlug: full },
	}));
}

const { fullSlug } = Astro.props as { fullSlug: string };
const canonical = `${SITE_URL}/blog/${fullSlug}/`;
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="utf-8" />
		<title>Страница переехала — Этикетка</title>
		<link rel="canonical" href={canonical} />
		<meta http-equiv="refresh" content={`0; url=${canonical}`} />
		<meta name="robots" content="noindex, follow" />
		<style>
			body {
				font-family: system-ui, sans-serif;
				max-width: 540px;
				margin: 4rem auto;
				padding: 0 1rem;
				line-height: 1.55;
				color: #333;
			}
			a { color: #ff4d8f; font-weight: 600; }
		</style>
	</head>
	<body>
		<h1>Страница переехала</h1>
		<p>
			Этот материал доступен по новому адресу.
			Если переход не произошёл автоматически —
			<a href={canonical}>откройте {canonical}</a>.
		</p>
	</body>
</html>
