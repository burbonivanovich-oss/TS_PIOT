---
import BaseHead from '../../components/BaseHead.astro';
import BlogFilter from '../../components/BlogFilter';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES } from '../../consts';
import { collectTags } from '../../utils/tags';
import { publishedPosts } from '../../utils/posts';
import { u } from '../../utils/url';

const PAGE_SIZE = 12;

export async function getStaticPaths({ paginate }: { paginate: Function }) {
	const posts = (await publishedPosts()).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);
	return paginate(posts, { pageSize: 12 });
}

const { page } = Astro.props;
const isFirstPage = page.currentPage === 1;

// All posts passed to BlogFilter for client-side filtering
const allPosts = (await publishedPosts()).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const pageTitle = isFirstPage
	? 'Все статьи'
	: `Все статьи — страница ${page.currentPage}`;
const pageDescription =
	'Архив материалов: ТС ПИоТ, маркировка «Честный знак», изменения в законодательстве для малого и среднего бизнеса.';

const allPostData = allPosts.map((p) => ({
	id: p.id,
	title: p.data.title,
	description: p.data.description,
	pubDate: p.data.pubDate.toISOString(),
	updatedDate: p.data.updatedDate?.toISOString(),
	categories: p.data.categories ?? [],
	tags: p.data.tags ?? [],
	previewImage: p.data.previewImage,
}));

const allTags = Object.values(collectTags(allPosts))
	.map((t) => t.name)
	.sort((a, b) => a.localeCompare(b, 'ru'));

const categoriesForFilter = Object.fromEntries(
	Object.entries(CATEGORIES).map(([k, v]) => [k, { title: v.title }]),
);

const itemListJsonLd = isFirstPage
	? {
			'@context': 'https://schema.org',
			'@type': 'CollectionPage',
			name: 'Все статьи',
			description: pageDescription,
			url: new URL('/blog/', Astro.site).toString(),
			mainEntity: {
				'@type': 'ItemList',
				itemListElement: allPosts.map((p, i) => ({
					'@type': 'ListItem',
					position: i + 1,
					url: new URL(`/blog/${p.id}/`, Astro.site).toString(),
					name: p.data.title,
				})),
			},
		}
	: undefined;
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead
			title={pageTitle}
			description={pageDescription}
			jsonLd={itemListJsonLd}
		/>
		{page.url.prev && <link rel="prev" href={new URL(page.url.prev, Astro.site).toString()} />}
		{page.url.next && <link rel="next" href={new URL(page.url.next, Astro.site).toString()} />}
	</head>
	<body>
		<Header />
		<main>
			<section class="blog-head">
				<div class="wrap">
					<nav class="breadcrumbs" aria-label="Хлебные крошки">
						<a href={u('/')}>Главная</a><span>›</span><span aria-current="page">Все материалы</span>
					</nav>
					<div class="blog-head-row">
						<div>
							<span class="eyebrow">Архив</span>
							<h1>{isFirstPage ? 'Все материалы' : `Все материалы — страница ${page.currentPage}`}</h1>
							{isFirstPage && (
								<p class="b-sub">
									Статьи о требованиях для МСБ: ТС ПИоТ, маркировка, налоги, ЭДО, кассы.
									Все факты со ссылками на первоисточники, дата актуализации — в шапке статьи.
								</p>
							)}
						</div>
						<div class="b-search-wrap">
							<input
								class="b-search"
								placeholder="Поиск по статьям…"
								type="search"
								onkeydown="if(event.key==='Enter')window.location='/search/?q='+encodeURIComponent(this.value)"
							/>
							<button
								class="b-search-go"
								onclick="window.location='/search/?q='+encodeURIComponent(this.previousElementSibling?.value||'')"
								type="button"
							>Найти →</button>
						</div>
					</div>
				</div>
			</section>

			{allPosts.length === 0 ? (
				<p>Материалы появятся в ближайшее время.</p>
			) : (
				<>
					<!-- Фильтр + результаты фильтрации (React, client-side) -->
					<BlogFilter
						client:idle
						posts={allPostData}
						categories={categoriesForFilter}
						allTags={allTags}
						withServerPagination={true}
					/>

					<!-- Статический список текущей страницы: виден краулеру и при отсутствии фильтра -->
					<div id="static-posts">
						<ul class="s-list">
							{page.data.map((post) => {
								const cat = post.data.categories[0] as string | undefined;
								const catMeta = cat
									? CATEGORIES[cat as keyof typeof CATEGORIES]
									: null;
								const date = post.data.updatedDate ?? post.data.pubDate;
								const isUpdated = !!post.data.updatedDate;
								return (
									<li class="s-card">
										<a href={`/blog/${post.id}/`}>
											{post.data.previewImage && (
												<div class="s-card-img">
													<img
														src={post.data.previewImage}
														alt={post.data.title}
														loading="lazy"
														width="800"
														height="420"
													/>
												</div>
											)}
											<div class="s-card-body">
												{catMeta && (
													<span class="s-card-cat">{catMeta.title}</span>
												)}
												<h2 class="s-card-title">{post.data.title}</h2>
												<p class="s-card-desc">{post.data.description}</p>
												<p class="s-card-date">
													{isUpdated ? 'обновлено ' : ''}
													<FormattedDate date={date} />
												</p>
											</div>
										</a>
									</li>
								);
							})}
						</ul>

						{page.lastPage > 1 && (
							<nav class="s-pages" aria-label="Страницы блога">
								{page.url.prev && (
									<a href={page.url.prev} class="s-page-btn" rel="prev">
										← Предыдущая
									</a>
								)}
								<span class="s-page-info">
									Страница {page.currentPage} из {page.lastPage}
								</span>
								{page.url.next && (
									<a href={page.url.next} class="s-page-btn" rel="next">
										Следующая →
									</a>
								)}
							</nav>
						)}
					</div>
				</>
			)}
		</main>
		<Footer />

		<style>
			.wrap { max-width: var(--maxw, 1400px); margin: 0 auto; padding: 0 32px; }
			.blog-head {
				background: #fff;
				border-bottom: 1px solid var(--line, #E5E1D8);
				padding: 36px 0 32px;
				margin-bottom: 32px;
			}
			.breadcrumbs {
				font-size: .7rem; font-weight: 600; letter-spacing: .1em;
				text-transform: uppercase; color: var(--mute, #9a9a9a); margin-bottom: 18px;
			}
			.breadcrumbs a { color: inherit; text-decoration: none; }
			.breadcrumbs a:hover { color: #111; }
			.breadcrumbs span { margin: 0 .4em; }
			.blog-head-row { display: grid; grid-template-columns: 1fr auto; gap: 32px; align-items: end; }
			.eyebrow {
				display: block; font-size: .68rem; font-weight: 700; letter-spacing: .18em;
				text-transform: uppercase; color: var(--pink, #9E2B4F); margin-bottom: 10px;
			}
			.blog-head h1 {
				font-family: var(--f-display, 'Bebas Neue', sans-serif);
				font-size: clamp(2.6rem, 5vw, 4.4rem); line-height: .95; letter-spacing: .02em;
				color: #111; margin: 0 0 14px; text-transform: uppercase;
			}
			.b-sub { font-size: 1rem; color: var(--ink-3, #666); max-width: 540px; line-height: 1.55; margin: 0; }
			.b-search-wrap { display: flex; gap: 6px; align-items: stretch; min-width: 320px; }
			.b-search {
				flex: 1; padding: 12px 14px; border: 2px solid #111; font-size: .92rem;
				background: #fff; font-family: inherit; border-radius: 0; outline: none;
			}
			.b-search:focus { border-color: var(--pink, #9E2B4F); }
			.b-search-go {
				background: #111; color: var(--lime, #AFCC00); border: 0; padding: 12px 20px;
				font-size: .72rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
				cursor: pointer; font-family: inherit;
			}
			.b-search-go:hover { background: var(--pink, #9E2B4F); color: #fff; }
			@media (max-width: 820px) {
				.blog-head-row { grid-template-columns: 1fr; gap: 18px; }
				.b-search-wrap { min-width: 0; }
				.wrap { padding: 0 20px; }
			}
			@media (max-width: 560px) { .wrap { padding: 0 16px; } }
			.s-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 1rem;
			}
			.s-card a {
				display: flex;
				flex-direction: column;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 10px;
				background: #fff;
				color: rgb(var(--gray-dark));
				text-decoration: none;
				height: 100%;
				overflow: hidden;
				transition: all 0.15s ease;
			}
			.s-card a:hover {
				border-color: var(--accent);
				box-shadow: var(--box-shadow);
			}
			.s-card-img {
				width: 100%;
				aspect-ratio: 16 / 9;
				overflow: hidden;
				flex-shrink: 0;
			}
			.s-card-img img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
				transition: transform 0.3s ease;
			}
			.s-card a:hover .s-card-img img {
				transform: scale(1.03);
			}
			.s-card-body {
				padding: 1.2rem 1.4rem 1.4rem;
				display: flex;
				flex-direction: column;
				flex: 1;
			}
			.s-card-cat {
				display: inline-block;
				font-size: 0.78rem;
				font-weight: 600;
				color: var(--accent);
				background: var(--accent-soft);
				padding: 0.2em 0.7em;
				border-radius: 999px;
				margin-bottom: 0.5rem;
			}
			.s-card-title {
				margin: 0 0 0.5rem;
				font-size: 1.15rem;
				color: rgb(var(--black));
				line-height: 1.3;
			}
			.s-card-desc {
				font-size: 0.93rem;
				margin-bottom: 0.8rem;
			}
			.s-card-date {
				font-size: 0.83rem;
				color: rgb(var(--gray));
				margin: 0;
			}
			.s-pages {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 1.2rem;
				margin-top: 2.5rem;
				padding: 1rem 0;
			}
			.s-page-btn {
				display: inline-block;
				padding: 0.6em 1.3em;
				border: 1.5px solid rgb(var(--gray-light));
				border-radius: 8px;
				text-decoration: none;
				color: rgb(var(--gray-dark));
				font-size: 0.95rem;
				font-weight: 600;
				transition: all 0.15s ease;
			}
			.s-page-btn:hover {
				border-color: var(--accent);
				color: var(--accent);
				background: var(--accent-soft);
			}
			.s-page-info {
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}
		</style>
	</body>
</html>
