---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import KonturLeadForm from '../../components/KonturLeadForm.astro';
import { u } from '../../utils/url';
import { CATEGORIES } from '../../consts';
import {
	CATALOG_GROUPS,
	PRODUCT_CATALOG,
	CPA_BANNERS,
} from '../../data/cpa-banners';

export function getStaticPaths() {
	return PRODUCT_CATALOG.map(product => ({
		params: { slug: product.slug },
		props: { product },
	}));
}

const { product } = Astro.props;
const banner = CPA_BANNERS[product.bannerId];
const group = CATALOG_GROUPS.find(g => g.id === product.group);

// Кластеры с человекочитаемыми названиями и ссылками на категории.
const clusters = product.clusters
	.map(id => ({ id, meta: CATEGORIES[id as keyof typeof CATEGORIES] }))
	.filter(c => c.meta);

// Другие продукты того же раздела — для перелинковки.
const siblings = PRODUCT_CATALOG.filter(
	p => p.group === product.group && p.slug !== product.slug
).map(p => ({ ...p, banner: CPA_BANNERS[p.bannerId] }));

const title = `${banner.title.split('—')[0].trim()} — сервис Контура`;
const description = banner.description;
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		<main class="product">
			<nav class="crumbs" aria-label="Хлебные крошки">
				<a href={u('/produkty/')}>Продукты</a>
				<span>›</span>
				{group && <a href={u(`/produkty/#${group.id}`)}>{group.title}</a>}
			</nav>

			<header class="product-hero">
				<div class="hero-visual" style={`background:${banner.visual.bg}`}>
					<span>{banner.visual.abbrev}</span>
				</div>
				<div class="hero-text">
					<h1>{banner.title}</h1>
					<p class="hero-lead">{banner.description}</p>
					{clusters.length > 0 && (
						<div class="hero-tags">
							{clusters.map(c => (
								<a href={u(`/category/${c.id}/`)}>{c.meta.title}</a>
							))}
						</div>
					)}
				</div>
			</header>

			<section class="product-section">
				<h2>Что внутри</h2>
				<ul class="bullets">
					{product.bullets.map(b => <li>{b}</li>)}
				</ul>
			</section>

			<section class="product-section">
				<h2>Кому подходит</h2>
				<p>{product.audience}</p>
			</section>

			<KonturLeadForm id={product.bannerId} />

			{clusters.length > 0 && (
				<section class="product-section">
					<h2>Читайте по теме</h2>
					<ul class="links">
						{clusters.map(c => (
							<li>
								<a href={u(`/category/${c.id}/`)}>{c.meta.fullTitle}</a>
							</li>
						))}
					</ul>
				</section>
			)}

			{siblings.length > 0 && (
				<section class="product-section">
					<h2>{group?.title}: другие сервисы</h2>
					<div class="siblings">
						{siblings.map(s => (
							<a href={u(`/produkty/${s.slug}/`)} class="sibling">
								<span
									class="sibling-visual"
									style={`background:${s.banner.visual.bg}`}
								>{s.banner.visual.abbrev}</span>
								<span class="sibling-title">{s.banner.title}</span>
							</a>
						))}
					</div>
				</section>
			)}

			<p class="back"><a href={u('/produkty/')}>← Все сервисы</a></p>
		</main>

		<Footer />

		<style>
			.product {
				max-width: 820px;
				margin: 0 auto;
				padding: 2rem 1rem 4rem;
			}
			.crumbs {
				display: flex;
				gap: 0.5rem;
				align-items: center;
				font-size: 0.82rem;
				color: #888;
				margin-bottom: 1.5rem;
			}
			.crumbs a { color: var(--pink, #ff4d8f); text-decoration: none; font-weight: 600; }

			.product-hero {
				display: grid;
				grid-template-columns: 120px 1fr;
				gap: 1.5rem;
				align-items: start;
				margin-bottom: 2.5rem;
			}
			.hero-visual {
				display: flex;
				align-items: center;
				justify-content: center;
				aspect-ratio: 1;
				border-radius: 12px;
				color: #fff;
				font-family: 'Bebas Neue', sans-serif;
				font-size: 2.4rem;
				letter-spacing: 0.04em;
			}
			.hero-text h1 {
				font-family: 'Bebas Neue', sans-serif;
				font-size: clamp(1.7rem, 4vw, 2.6rem);
				line-height: 1;
				text-transform: uppercase;
				letter-spacing: 0.02em;
				margin: 0 0 0.75rem;
				color: #111;
			}
			.hero-lead { margin: 0 0 1rem; font-size: 1.02rem; line-height: 1.55; color: #444; }
			.hero-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
			.hero-tags a {
				font-size: 0.75rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				text-decoration: none;
				color: #111;
				background: var(--lime, #afcc00);
				padding: 0.3em 0.7em;
				border-radius: 4px;
			}

			.product-section { margin-bottom: 2rem; }
			.product-section h2 {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.5rem;
				letter-spacing: 0.02em;
				text-transform: uppercase;
				margin: 0 0 0.75rem;
				color: #111;
			}
			.product-section p { margin: 0; font-size: 1rem; line-height: 1.6; color: #444; }
			.bullets { margin: 0; padding-left: 1.25rem; }
			.bullets li { font-size: 1rem; line-height: 1.7; color: #333; }
			.links { margin: 0; padding-left: 1.25rem; }
			.links a { color: var(--pink, #ff4d8f); font-weight: 600; }

			.siblings { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
			.sibling {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				padding: 0.75rem;
				border: 1.5px solid rgba(0, 0, 0, 0.1);
				border-radius: 10px;
				text-decoration: none;
				color: #111;
				transition: border-color 0.15s ease;
			}
			.sibling:hover { border-color: #111; }
			.sibling-visual {
				flex: 0 0 auto;
				width: 44px;
				height: 44px;
				display: flex;
				align-items: center;
				justify-content: center;
				border-radius: 6px;
				color: #fff;
				font-family: 'Bebas Neue', sans-serif;
				font-size: 0.95rem;
			}
			.sibling-title { font-size: 0.9rem; line-height: 1.3; }

			.back { margin-top: 2rem; }
			.back a { color: var(--pink, #ff4d8f); font-weight: 600; text-decoration: none; }

			@media (max-width: 640px) {
				.product-hero { grid-template-columns: 80px 1fr; gap: 1rem; }
				.hero-visual { font-size: 1.6rem; }
				.siblings { grid-template-columns: 1fr; }
			}
		</style>
	</body>
</html>
