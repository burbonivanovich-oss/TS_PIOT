---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { u } from '../../utils/url';
import { CATALOG_GROUPS, PRODUCT_CATALOG, CPA_BANNERS } from '../../data/cpa-banners';

const title = 'Сервисы Контура для бизнеса';
const description =
	'Каталог сервисов Контура под задачи МСБ: касса и ТС ПИоТ, маркировка, бухгалтерия и отчётность, ЭДО, проверка контрагентов. Подберите решение и оставьте заявку.';

// Карточки, сгруппированные по разделам витрины.
const groups = CATALOG_GROUPS.map(group => ({
	...group,
	products: PRODUCT_CATALOG.filter(p => p.group === group.id).map(p => ({
		...p,
		banner: CPA_BANNERS[p.bannerId],
	})),
})).filter(group => group.products.length > 0);
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		<main class="catalog">
			<header class="catalog-hero">
				<p class="catalog-eyebrow">Сервисы для бизнеса</p>
				<h1>Подберите сервис Контура под задачу</h1>
				<p class="catalog-lead">
					Касса с ТС ПИоТ, маркировка, бухгалтерия, ЭДО и проверка
					контрагентов. Выберите продукт под свою задачу — заявку обработает
					Контур, договор вы заключаете с ним напрямую.
				</p>
				<div class="catalog-nav">
					{groups.map(group => (
						<a href={`#${group.id}`}>{group.title}</a>
					))}
				</div>
			</header>

			{groups.map(group => (
				<section class="catalog-group" id={group.id}>
					<div class="group-head">
						<h2>{group.title}</h2>
						<p>{group.description}</p>
					</div>
					<div class="group-grid">
						{group.products.map(product => (
							<a href={u(`/produkty/${product.slug}/`)} class="product-card">
								<div
									class="product-visual"
									style={`background:${product.banner.visual.bg}`}
								>
									<span>{product.banner.visual.abbrev}</span>
								</div>
								<div class="product-body">
									<h3>{product.banner.title}</h3>
									<p class="product-audience">{product.audience}</p>
									<span class="product-cta">Подробнее →</span>
								</div>
							</a>
						))}
					</div>
				</section>
			))}

			<aside class="catalog-note">
				<p>
					Не знаете, что выбрать? Начните с
					<a href={u('/instrumenty/')}>интерактивных тестов и сценариев</a> —
					например, проверьте готовность к ТС ПИоТ или соберите набор сервисов
					под открытие точки. Все материалы по темам — в
					<a href={u('/blog/')}>статьях</a>.
				</p>
			</aside>
		</main>

		<Footer />

		<style>
			.catalog {
				max-width: 1080px;
				margin: 0 auto;
				padding: 2.5rem 1rem 4rem;
			}
			.catalog-hero { margin-bottom: 2.5rem; max-width: 760px; }
			.catalog-eyebrow {
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--pink, #ff4d8f);
				margin: 0 0 0.5rem;
				font-weight: 700;
			}
			.catalog-hero h1 {
				font-family: 'Bebas Neue', sans-serif;
				font-size: clamp(2rem, 5vw, 3.2rem);
				line-height: 0.95;
				margin: 0 0 1rem;
				text-transform: uppercase;
				letter-spacing: 0.02em;
				color: #111;
			}
			.catalog-lead {
				margin: 0 0 1.25rem;
				font-size: 1.05rem;
				color: #555;
				line-height: 1.55;
			}
			.catalog-nav {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
			}
			.catalog-nav a {
				font-size: 0.82rem;
				font-weight: 600;
				text-decoration: none;
				color: #111;
				padding: 0.4em 0.9em;
				border: 1.5px solid rgba(0, 0, 0, 0.15);
				border-radius: 999px;
				transition: border-color 0.15s ease, background 0.15s ease;
			}
			.catalog-nav a:hover { border-color: #111; background: #111; color: #fff; }

			.catalog-group { margin-bottom: 2.75rem; scroll-margin-top: 1.5rem; }
			.group-head { margin-bottom: 1.25rem; }
			.group-head h2 {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.8rem;
				letter-spacing: 0.02em;
				text-transform: uppercase;
				margin: 0 0 0.35rem;
				color: #111;
			}
			.group-head p { margin: 0; color: #666; font-size: 0.95rem; line-height: 1.5; }

			.group-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1rem;
			}
			.product-card {
				display: grid;
				grid-template-columns: 88px 1fr;
				gap: 1.25rem;
				padding: 1.25rem;
				background: #fff;
				border: 2px solid rgba(0, 0, 0, 0.08);
				border-radius: 12px;
				text-decoration: none;
				color: #111;
				transition: border-color 0.15s ease, transform 0.15s ease;
			}
			.product-card:hover { border-color: #111; transform: translateY(-2px); }
			.product-visual {
				display: flex;
				align-items: center;
				justify-content: center;
				border-radius: 8px;
				color: #fff;
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.4rem;
				letter-spacing: 0.04em;
			}
			.product-body { min-width: 0; }
			.product-body h3 {
				margin: 0 0 0.4rem;
				font-size: 1.05rem;
				line-height: 1.3;
				color: #111;
			}
			.product-audience {
				margin: 0 0 0.75rem;
				font-size: 0.88rem;
				line-height: 1.45;
				color: #555;
			}
			.product-cta { font-weight: 600; color: var(--pink, #ff4d8f); font-size: 0.88rem; }

			.catalog-note {
				margin-top: 1rem;
				padding: 1.25rem 1.5rem;
				background: var(--sand, #f4ebd9);
				border-radius: 12px;
				font-size: 0.95rem;
				line-height: 1.55;
				color: #444;
			}
			.catalog-note a { color: var(--pink, #ff4d8f); font-weight: 600; }

			@media (max-width: 720px) {
				.group-grid { grid-template-columns: 1fr; }
				.product-card { grid-template-columns: 64px 1fr; gap: 1rem; }
				.product-visual { font-size: 1.1rem; }
			}
		</style>
	</body>
</html>
