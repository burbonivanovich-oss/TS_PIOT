---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { u } from '../../utils/url';
import { SHOP_SECTIONS } from '../../data/shop-catalog';
import RecentViewed from '../../components/RecentViewed.astro';

const title = 'Магазин Контура — кассы, ФН, ОФД, ЭДО и сервисы';
const description =
	'Кассы и POS-терминалы, фискальные накопители, ОФД, ЭДО и сервисы Контура для бизнеса. Готовые кассовые комплекты со скидкой. Подберём и оформим заявку.';

// Короткие подписи табов (eyebrow «ФН и ОФД» повторяется у двух секций).
const TAB_LABELS: Record<string, string> = {
	'kasses': 'Кассы',
	'kits': 'Комплекты',
	'fn-ofd': 'Накопители',
	'ofd': 'ОФД',
	'edo': 'ЭДО',
	'periphery': 'Периферия',
	'servisy': 'Сервисы',
};

const SITE = Astro.site ?? new URL('https://etiketka-media.ru');
const allItems = SHOP_SECTIONS.flatMap(s => s.items);

// Бренды — извлекаем из названий товаров (для фильтра).
const BRANDS = ['Атол', 'MSPOS', 'PayTor', 'EdPOS', 'аQsi', 'Mindeo', 'NEO', 'Эвотор'];
const brandOf = (name: string): string => {
	const n = name.toLowerCase();
	return BRANDS.find(b => n.includes(b.toLowerCase())) ?? '';
};
const usedBrands = [...new Set(allItems.map(i => brandOf(i.name)).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'ru'));
const itemListLd = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: 'Каталог Контура',
	itemListElement: allItems
		.filter(it => it.slug && it.price != null)
		.map((it, i) => ({
			'@type': 'ListItem',
			position: i + 1,
			item: {
				'@type': 'Product',
				name: it.name,
				url: new URL(`/produkty/tovar/${it.slug}/`, SITE).href,
				...(it.img ? { image: it.img } : {}),
				offers: { '@type': 'Offer', price: it.price, priceCurrency: 'RUB', availability: 'https://schema.org/InStock' },
			},
		})),
};

// FAQ — честные ответы о процессе покупки (согласованы с условиями на сайте).
const faq: [string, string][] = [
	['Сколько идёт доставка?', 'По Москве — 48 часов, по России — от 3 рабочих дней транспортной компанией. Самовывоз со склада — бесплатно.'],
	['Кто регистрирует кассу в ФНС?', 'Контур помогает с настройкой и регистрацией кассы в налоговой онлайн — обычно за 1 день.'],
	['Как происходит оплата?', 'Оплата и договор — на стороне Контура. После заявки менеджер подтверждает состав и выставляет счёт. Доступна рассрочка 0% до 12 месяцев.'],
	['Нужны ли фискальный накопитель и ОФД?', 'Да, для работы кассы по 54-ФЗ нужны фискальный накопитель и договор с ОФД. Соберите комплект «касса под ключ» на странице товара.'],
	['Какая гарантия на оборудование?', 'На оборудование действует гарантия производителя — 12 месяцев.'],
	['Подойдёт ли касса для маркировки и алкоголя?', 'Кассы с Контур.Маркет работают с обязательной маркировкой «Честный знак» и продажей алкоголя через ЕГАИС.'],
];
const faqLd = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faq.map(([q, a]) => ({
		'@type': 'Question',
		name: q,
		acceptedAnswer: { '@type': 'Answer', text: a },
	})),
};

const advantages = [
	{ ic: '🚚', t: 'Доставка по РФ', s: 'в Москву за 48 часов' },
	{ ic: '🛡️', t: 'Гарантия', s: 'от производителя' },
	{ ic: '⚡', t: 'Регистрация в ФНС', s: 'онлайн за 1 день' },
	{ ic: '💬', t: 'Поддержка 24/7', s: 'на всех тарифах' },
	{ ic: '💳', t: 'Рассрочка 0%', s: 'до 12 месяцев' },
];
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		<script type="application/ld+json" set:html={JSON.stringify(itemListLd)} />
		<script type="application/ld+json" set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'BreadcrumbList',
			itemListElement: [
				{ '@type': 'ListItem', position: 1, name: 'Главная', item: new URL('/', SITE).href },
				{ '@type': 'ListItem', position: 2, name: 'Магазин', item: new URL('/produkty/', SITE).href },
			],
		})} />
		<script type="application/ld+json" set:html={JSON.stringify(faqLd)} />

		<main class="shop">
			<section class="shop-hero">
				<div class="shop-hero-in">
					<nav class="shop-crumbs" aria-label="Хлебные крошки">
						<a href={u('/')}>Главная</a><span>/</span><span>Магазин</span>
					</nav>
					<p class="shop-eyebrow">Магазин для бизнеса</p>
					<h1>Кассы, ФН, ОФД, ЭДО и сервисы Контура</h1>
					<p class="shop-lead">
						Онлайн-кассы и POS-терминалы, фискальные накопители, ОФД, ЭДО и
						цифровые сервисы. Соберите готовый комплект под свою точку — Контур
						подберёт тариф и оформит регистрацию в ФНС.
					</p>
					<div class="shop-hero-actions">
						<a class="sbtn sbtn-primary" href={u('/podbor/')}>Подобрать за 3 вопроса →</a>
						<a class="sbtn sbtn-ghost" href={u('/sravneniya/')}>Сравнить варианты</a>
					</div>
					<nav class="shop-tabs" aria-label="Категории">
						{SHOP_SECTIONS.map(s => (
							<a href={`#sec-${s.id}`}>{TAB_LABELS[s.id] ?? s.eye ?? s.title}</a>
						))}
					</nav>
				</div>
			</section>

			<div class="shop-adv">
				<div class="shop-adv-in">
					{advantages.map(a => (
						<div class="adv">
							<span class="adv-ic">{a.ic}</span>
							<div>
								<div class="adv-t">{a.t}</div>
								<div class="adv-s">{a.s}</div>
							</div>
						</div>
					))}
				</div>
			</div>

			<div class="shop-filters">
				<div class="shop-filters-in">
					<input class="sf-search" type="search" data-search-input placeholder="Поиск по каталогу: касса, сканер, ОФД…" aria-label="Поиск по каталогу" />
					<label class="sf-field">Цена, ₽
						<span class="sf-range">
							<input type="number" data-price-min placeholder="от" min="0" aria-label="Цена от" />
							<input type="number" data-price-max placeholder="до" min="0" aria-label="Цена до" />
						</span>
					</label>
					<label class="sf-field">Сортировка
						<select data-sort>
							<option value="default">по разделам</option>
							<option value="price-asc">сначала дешёвые</option>
							<option value="price-desc">сначала дорогие</option>
							<option value="name">по названию</option>
						</select>
					</label>
					<button class="sf-reset" data-reset hidden>Сбросить</button>
				</div>
				{usedBrands.length > 0 && (
					<div class="sf-brands" data-brands>
						<button class="bchip is-active" data-brand-filter="">Все бренды</button>
						{usedBrands.map(br => <button class="bchip" data-brand-filter={br}>{br}</button>)}
					</div>
				)}
				<div class="sf-empty" data-empty hidden>Ничего не найдено. Измените запрос или сбросьте фильтры.</div>
			</div>

			<div class="shop-body">
				{SHOP_SECTIONS.map(s => (
					<section class="sec" id={`sec-${s.id}`}>
						<div class="sec-hd">
							<div class="sec-eye" style={`color:${s.color}`}>{s.eye}</div>
							<h2>{s.title}</h2>
						</div>
						<div class="grid">
							{s.items.map(it => {
								const detail = it.href ?? (it.slug ? `/produkty/tovar/${it.slug}/` : null);
								return (
								<article class="card" data-name={it.name} data-price={it.price ?? ''} data-brand={brandOf(it.name)} data-search={`${it.name} ${it.desc} ${it.cat ?? ''}`.toLowerCase()}>
									<div class="card-img">
										{it.badge && <span class="card-sale">{it.badge}</span>}
										{it.img ? (
											<img src={it.img} alt={it.name} loading="lazy" />
										) : (
											<span class="card-tile" style={`background:${it.visual?.bg ?? '#111'}`}>{it.visual?.abbrev}</span>
										)}
									</div>
									<div class="card-body">
										{it.cat && <div class="card-cat">{it.cat}</div>}
										{detail ? (
											<a class="card-name" href={u(detail)}>{it.name}</a>
										) : (
											<div class="card-name">{it.name}</div>
										)}
										<p class="card-desc">{it.desc}</p>
										<div class="card-foot">
											<div class="card-price">
												{it.oldLabel && <span class="old">{it.oldLabel}</span>}
												<span class="now">{it.priceLabel}</span>
											</div>
											<div class="card-btns">
												{detail && <a class="b-detail" href={u(detail)}>Подробнее</a>}
												{it.price != null ? (
													<button
														class={it.kit ? 'b-kit' : 'b-cart'}
														data-add
														data-id={it.id}
														data-name={it.name}
														data-price={it.price}
													>{it.kit ? 'Купить комплект' : 'В корзину'}</button>
												) : (
													!detail && <a class="b-detail" href={u('/podbor/')}>Оставить заявку</a>
												)}
											</div>
											{it.price != null && (
												<button class="card-quick" data-quick data-id={it.id} data-name={it.name}>Купить в 1 клик</button>
											)}
											{it.slug && it.price != null && (
												<button class="card-compare" data-compare data-id={it.id} data-slug={it.slug} data-name={it.name} aria-pressed="false"><span data-compare-label>Сравнить</span></button>
											)}
										</div>
									</div>
								</article>
								);
							})}
						</div>
					</section>
				))}
			</div>

			<section class="shop-faq">
				<h2>Частые вопросы</h2>
				<div class="faq-list">
					{faq.map(([q, a]) => (
						<details class="faq-item">
							<summary>{q}</summary>
							<p>{a}</p>
						</details>
					))}
				</div>
			</section>

			<section class="shop-cta">
				<div class="shop-cta-in">
					<div>
						<h2>Готовы начать? Поможем выбрать.</h2>
						<p>Бесплатная консультация — подберём кассу и тариф за 10 минут.</p>
						<a class="sbtn sbtn-primary" href={u('/podbor/')}>Подобрать кассу →</a>
					</div>
					<div class="shop-cta-shapes" aria-hidden="true">
						<span style="background:#FF6B35"></span>
						<span style="background:#00C896"></span>
						<span style="background:#3D7FFF"></span>
						<span style="background:#7B61FF"></span>
					</div>
				</div>
			</section>
			<RecentViewed />
		</main>

		<Footer />

		<script>
			// Корзина — в глобальном компоненте src/components/CartDrawer.astro.
			// Здесь только фолбэк фото и фильтры каталога.

			// Фолбэк для фото товаров (если изображение с kontur.ru не загрузилось).
			document.querySelectorAll<HTMLImageElement>('.card-img img').forEach(img => {
				const fail = () => {
					const wrap = img.closest('.card-img');
					if (wrap && !wrap.querySelector('.imgfb')) {
						const fb = document.createElement('span');
						fb.className = 'imgfb';
						fb.textContent = (img.alt || 'Контур').slice(0, 2).toUpperCase();
						wrap.appendChild(fb);
					}
					img.style.display = 'none';
				};
				if (img.complete && img.naturalWidth === 0) fail();
				else img.addEventListener('error', fail);
			});

			// Поиск, сортировка и фильтр по цене.
			(() => {
				const searchEl = document.querySelector<HTMLInputElement>('[data-search-input]');
				const minEl = document.querySelector<HTMLInputElement>('[data-price-min]');
				const maxEl = document.querySelector<HTMLInputElement>('[data-price-max]');
				const sortEl = document.querySelector<HTMLSelectElement>('[data-sort]');
				const resetEl = document.querySelector<HTMLElement>('[data-reset]');
				const emptyEl = document.querySelector<HTMLElement>('[data-empty]');
				const brandBtns = Array.from(document.querySelectorAll<HTMLElement>('[data-brand-filter]'));
				let brand = '';
				const sections = Array.from(document.querySelectorAll<HTMLElement>('.shop-body .sec'));
				if (!sections.length) return;
				const original = new Map<HTMLElement, HTMLElement[]>();
				sections.forEach(sec => {
					const grid = sec.querySelector('.grid') as HTMLElement;
					original.set(sec, Array.from(grid.querySelectorAll<HTMLElement>('.card')));
				});

				function apply() {
					const q = (searchEl?.value || '').trim().toLowerCase();
					const min = minEl?.value ? Number(minEl.value) : null;
					const max = maxEl?.value ? Number(maxEl.value) : null;
					const sort = sortEl?.value || 'default';
					const active = !!q || min != null || max != null || sort !== 'default' || brand !== '';
					if (resetEl) resetEl.hidden = !active;

					let totalVisible = 0;
					sections.forEach(sec => {
						const grid = sec.querySelector('.grid') as HTMLElement;
						let cards = original.get(sec)!.slice();
						if (sort === 'price-asc' || sort === 'price-desc') {
							cards.sort((a, b) => {
								const pa = Number(a.dataset.price) || Infinity;
								const pb = Number(b.dataset.price) || Infinity;
								return sort === 'price-asc' ? pa - pb : pb - pa;
							});
						} else if (sort === 'name') {
							cards.sort((a, b) => (a.dataset.name || '').localeCompare(b.dataset.name || '', 'ru'));
						}
						cards.forEach(c => grid.appendChild(c));

						let shown = 0;
						cards.forEach(card => {
							const text = card.dataset.search || '';
							const price = card.dataset.price ? Number(card.dataset.price) : null;
							let ok = !q || text.includes(q);
							if (ok && brand && card.dataset.brand !== brand) ok = false;
							if (ok && min != null && (price == null || price < min)) ok = false;
							if (ok && max != null && (price == null || price > max)) ok = false;
							card.hidden = !ok;
							if (ok) shown++;
						});
						sec.hidden = shown === 0;
						totalVisible += shown;
					});
					if (emptyEl) emptyEl.hidden = totalVisible > 0;
				}

				searchEl?.addEventListener('input', apply);
				minEl?.addEventListener('input', apply);
				maxEl?.addEventListener('input', apply);
				sortEl?.addEventListener('change', apply);
				brandBtns.forEach(btn => btn.addEventListener('click', () => {
					brand = btn.dataset.brandFilter || '';
					brandBtns.forEach(b => b.classList.toggle('is-active', b === btn));
					apply();
				}));
				resetEl?.addEventListener('click', () => {
					if (searchEl) searchEl.value = '';
					if (minEl) minEl.value = '';
					if (maxEl) maxEl.value = '';
					if (sortEl) sortEl.value = 'default';
					brand = '';
					brandBtns.forEach(b => b.classList.toggle('is-active', b.dataset.brandFilter === ''));
					apply();
				});
			})();
		</script>

		<style>
			.shop { background: #f4f5f7; }

			/* Hero */
			.shop-hero { background: #11141a; color: #fff; }
			.shop-hero-in { max-width: 1180px; margin: 0 auto; padding: 2.6rem 1rem 2rem; }
			.shop-crumbs { font-size: 0.78rem; color: #9aa1b1; margin-bottom: 1rem; display: flex; gap: 0.4rem; }
			.shop-crumbs a { color: #9aa1b1; text-decoration: none; }
			.shop-crumbs a:hover { color: #fff; }
			.shop-eyebrow {
				font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em;
				color: var(--lime, #afcc00); font-weight: 700; margin: 0 0 0.5rem;
			}
			.shop-hero h1 {
				font-family: 'Bebas Neue', sans-serif;
				font-size: clamp(2.2rem, 5vw, 3.6rem); line-height: 0.95; margin: 0 0 0.9rem;
				text-transform: uppercase; letter-spacing: 0.02em;
			}
			.shop-lead { max-width: 720px; margin: 0 0 1.3rem; color: #c4c9d4; font-size: 1.02rem; line-height: 1.55; }
			.shop-hero-actions { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-bottom: 1.6rem; }
			.sbtn {
				display: inline-block; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.03em;
				text-decoration: none; padding: 0.75em 1.25em; border-radius: 9px; transition: all 0.15s ease;
			}
			.sbtn-primary { background: var(--lime, #afcc00); color: #11141a; }
			.sbtn-primary:hover { background: #fff; }
			.sbtn-ghost { color: #fff; border: 1.5px solid rgba(255,255,255,0.35); }
			.sbtn-ghost:hover { border-color: #fff; background: rgba(255,255,255,0.08); }
			.shop-tabs { display: flex; flex-wrap: wrap; gap: 0.5rem; }
			.shop-tabs a {
				font-size: 0.8rem; font-weight: 600; color: #d4d8e0; text-decoration: none;
				padding: 0.45em 0.9em; border-radius: 999px; background: rgba(255,255,255,0.08);
				transition: all 0.15s ease;
			}
			.shop-tabs a:hover { background: var(--lime, #afcc00); color: #11141a; }

			/* Advantages */
			.shop-adv { background: #1b1f29; border-top: 1px solid rgba(255,255,255,0.06); }
			.shop-adv-in {
				max-width: 1180px; margin: 0 auto; padding: 0.9rem 1rem;
				display: flex; flex-wrap: wrap; gap: 1.5rem 2rem;
			}
			.adv { display: flex; align-items: center; gap: 0.6rem; }
			.adv-ic { font-size: 1.3rem; }
			.adv-t { color: #fff; font-size: 0.85rem; font-weight: 700; }
			.adv-s { color: #9aa1b1; font-size: 0.75rem; }

			/* Body */
			/* Панель фильтров */
			.shop-filters { max-width: 1180px; margin: 1.5rem auto 0; padding: 0 1rem; }
			.shop-filters-in {
				display: flex; flex-wrap: wrap; align-items: center; gap: 0.7rem;
				background: #fff; border: 1px solid rgba(0,0,0,0.08); border-radius: 12px; padding: 0.7rem 0.9rem;
			}
			.sf-search {
				flex: 1; min-width: 220px; border: 1.5px solid rgba(0,0,0,0.15); border-radius: 9px;
				padding: 0.6em 0.9em; font-size: 0.9rem; outline: none;
			}
			.sf-search:focus { border-color: #11141a; }
			.sf-field { display: flex; align-items: center; gap: 0.5rem; font-size: 0.78rem; color: #888; font-weight: 600; }
			.sf-range { display: inline-flex; gap: 0.3rem; }
			.sf-range input {
				width: 78px; border: 1.5px solid rgba(0,0,0,0.15); border-radius: 8px; padding: 0.5em 0.6em; font-size: 0.85rem; outline: none;
			}
			.sf-field select {
				border: 1.5px solid rgba(0,0,0,0.15); border-radius: 8px; padding: 0.5em 0.6em; font-size: 0.85rem;
				font-weight: 600; color: #11141a; background: #fff; cursor: pointer;
			}
			.sf-reset {
				border: none; background: none; cursor: pointer; color: var(--pink, #ff4d8f);
				font-size: 0.82rem; font-weight: 700; text-decoration: underline; text-underline-offset: 3px;
			}
			.sf-brands { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.7rem; }
			.bchip {
				font-size: 0.76rem; font-weight: 600; color: #555; background: #fff;
				border: 1.5px solid rgba(0,0,0,0.15); border-radius: 999px; padding: 0.35em 0.8em; cursor: pointer;
				transition: all 0.12s ease;
			}
			.bchip:hover { border-color: #11141a; }
			.bchip.is-active { background: #11141a; color: #fff; border-color: #11141a; }
			.sf-empty { text-align: center; color: #888; padding: 2rem 0; }

			.shop-body { max-width: 1180px; margin: 0 auto; padding: 1.5rem 1rem 1rem; }
			.sec { margin-bottom: 2.6rem; scroll-margin-top: 1rem; }
			.sec[hidden] { display: none; }
			.card[hidden] { display: none; }
			.sec-hd { margin-bottom: 1rem; }
			.sec-eye { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; }
			.sec-hd h2 {
				font-family: 'Bebas Neue', sans-serif; font-size: 1.9rem; letter-spacing: 0.02em;
				text-transform: uppercase; margin: 0.2rem 0 0; color: #11141a;
			}
			.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(232px, 1fr)); gap: 1rem; }

			.card {
				display: flex; flex-direction: column; background: #fff; border-radius: 14px;
