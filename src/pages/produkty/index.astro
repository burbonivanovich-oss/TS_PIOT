---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { u } from '../../utils/url';
import { SHOP_SECTIONS } from '../../data/shop-catalog';

const title = 'Магазин Контура — кассы, ФН, ОФД, ЭДО и сервисы';
const description =
	'Кассы и POS-терминалы, фискальные накопители, ОФД, ЭДО и сервисы Контура для бизнеса. Готовые кассовые комплекты со скидкой. Подберём и оформим заявку.';

// Короткие подписи табов (eyebrow «ФН и ОФД» повторяется у двух секций).
const TAB_LABELS: Record<string, string> = {
	'kasses': 'Кассы',
	'kits': 'Комплекты',
	'fn-ofd': 'Накопители',
	'ofd': 'ОФД',
	'edo': 'ЭДО',
	'periphery': 'Периферия',
	'servisy': 'Сервисы',
};

const advantages = [
	{ ic: '🚚', t: 'Доставка по РФ', s: 'в Москву за 48 часов' },
	{ ic: '🛡️', t: 'Гарантия', s: 'от производителя' },
	{ ic: '⚡', t: 'Регистрация в ФНС', s: 'онлайн за 1 день' },
	{ ic: '💬', t: 'Поддержка 24/7', s: 'на всех тарифах' },
	{ ic: '💳', t: 'Рассрочка 0%', s: 'до 12 месяцев' },
];
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		<main class="shop">
			<section class="shop-hero">
				<div class="shop-hero-in">
					<p class="shop-eyebrow">Магазин для бизнеса</p>
					<h1>Кассы, ФН, ОФД, ЭДО и сервисы Контура</h1>
					<p class="shop-lead">
						Онлайн-кассы и POS-терминалы, фискальные накопители, ОФД, ЭДО и
						цифровые сервисы. Соберите готовый комплект под свою точку — Контур
						подберёт тариф и оформит регистрацию в ФНС.
					</p>
					<div class="shop-hero-actions">
						<a class="sbtn sbtn-primary" href={u('/podbor/')}>Подобрать за 3 вопроса →</a>
						<a class="sbtn sbtn-ghost" href={u('/sravneniya/')}>Сравнить варианты</a>
					</div>
					<nav class="shop-tabs" aria-label="Категории">
						{SHOP_SECTIONS.map(s => (
							<a href={`#sec-${s.id}`}>{TAB_LABELS[s.id] ?? s.eye ?? s.title}</a>
						))}
					</nav>
				</div>
			</section>

			<div class="shop-adv">
				<div class="shop-adv-in">
					{advantages.map(a => (
						<div class="adv">
							<span class="adv-ic">{a.ic}</span>
							<div>
								<div class="adv-t">{a.t}</div>
								<div class="adv-s">{a.s}</div>
							</div>
						</div>
					))}
				</div>
			</div>

			<div class="shop-body">
				{SHOP_SECTIONS.map(s => (
					<section class="sec" id={`sec-${s.id}`}>
						<div class="sec-hd">
							<div class="sec-eye" style={`color:${s.color}`}>{s.eye}</div>
							<h2>{s.title}</h2>
						</div>
						<div class="grid">
							{s.items.map(it => {
								const detail = it.href ?? (it.slug ? `/produkty/tovar/${it.slug}/` : null);
								return (
								<article class="card">
									<div class="card-img">
										{it.badge && <span class="card-sale">{it.badge}</span>}
										{it.img ? (
											<img src={it.img} alt={it.name} loading="lazy" />
										) : (
											<span class="card-tile" style={`background:${it.visual?.bg ?? '#111'}`}>{it.visual?.abbrev}</span>
										)}
									</div>
									<div class="card-body">
										{it.cat && <div class="card-cat">{it.cat}</div>}
										{detail ? (
											<a class="card-name" href={u(detail)}>{it.name}</a>
										) : (
											<div class="card-name">{it.name}</div>
										)}
										<p class="card-desc">{it.desc}</p>
										<div class="card-foot">
											<div class="card-price">
												{it.oldLabel && <span class="old">{it.oldLabel}</span>}
												<span class="now">{it.priceLabel}</span>
											</div>
											<div class="card-btns">
												{detail && <a class="b-detail" href={u(detail)}>Подробнее</a>}
												{it.price != null ? (
													<button
														class={it.kit ? 'b-kit' : 'b-cart'}
														data-add
														data-id={it.id}
														data-name={it.name}
														data-price={it.price}
													>{it.kit ? 'Купить комплект' : 'В корзину'}</button>
												) : (
													!detail && <a class="b-detail" href={u('/podbor/')}>Оставить заявку</a>
												)}
											</div>
										</div>
									</div>
								</article>
								);
							})}
						</div>
					</section>
				))}
			</div>

			<section class="shop-cta">
				<div class="shop-cta-in">
					<div>
						<h2>Готовы начать? Поможем выбрать.</h2>
						<p>Бесплатная консультация — подберём кассу и тариф за 10 минут.</p>
						<a class="sbtn sbtn-primary" href={u('/podbor/')}>Подобрать кассу →</a>
					</div>
					<div class="shop-cta-shapes" aria-hidden="true">
						<span style="background:#FF6B35"></span>
						<span style="background:#00C896"></span>
						<span style="background:#3D7FFF"></span>
						<span style="background:#7B61FF"></span>
					</div>
				</div>
			</section>
		</main>

		<!-- Корзина -->
		<button class="cart-fab" data-cart-open hidden>
			Корзина <span class="cart-count" data-cart-count>0</span>
		</button>
		<div class="cart-overlay" data-cart-overlay hidden>
			<aside class="cart" role="dialog" aria-label="Корзина">
				<header class="cart-hd">
					<strong>Корзина</strong>
					<button class="cart-close" data-cart-close aria-label="Закрыть">✕</button>
				</header>
				<div class="cart-done" data-cart-done hidden>
					<div class="cart-done-ic">✓</div>
					<strong>Заявка оформлена</strong>
					<p>Менеджер Контура свяжется с вами, подтвердит состав и оформит регистрацию в ФНС. Оплата и договор — на стороне Контура.</p>
					<button class="b-cart" data-cart-close>Понятно</button>
				</div>
				<div class="cart-items" data-cart-items></div>
				<div class="cart-empty" data-cart-empty>Пока пусто. Добавьте товар из каталога.</div>
				<footer class="cart-ft" data-cart-ft hidden>
					<div class="cart-total">Итого <strong data-cart-total>0 ₽</strong></div>
					<button class="b-kit cart-checkout" data-cart-checkout>Оформить заявку</button>
					<p class="cart-note">Оплата и договор — на стороне Контура. Менеджер свяжется и подтвердит состав.</p>
				</footer>
			</aside>
		</div>

		<Footer />

		<script>
			type CartLine = { name: string; price: number; qty: number };
			const KEY = 'kontur-shop-cart';
			const $ = (s: string) => document.querySelector(s);
			const counter = 109130279;
			const ym = (t: string, p?: Record<string, unknown>) =>
				(window as any).ym && (window as any).ym(counter, 'reachGoal', t, p);

			const read = (): Record<string, CartLine> => {
				try { return JSON.parse(localStorage.getItem(KEY) || '{}'); } catch { return {}; }
			};
			const write = (c: Record<string, CartLine>) => localStorage.setItem(KEY, JSON.stringify(c));
			const fmt = (n: number) => n.toLocaleString('ru-RU') + ' ₽';

			function render() {
				const cart = read();
				const ids = Object.keys(cart);
				const count = ids.reduce((s, id) => s + cart[id].qty, 0);
				const total = ids.reduce((s, id) => s + cart[id].qty * cart[id].price, 0);
				const doneShown = !($('[data-cart-done]') as HTMLElement).hidden;

				($('[data-cart-open]') as HTMLElement).hidden = count === 0;
				($('[data-cart-count]') as HTMLElement).textContent = String(count);

				const box = $('[data-cart-items]') as HTMLElement;
				($('[data-cart-empty]') as HTMLElement).hidden = ids.length > 0 || doneShown;
				($('[data-cart-ft]') as HTMLElement).hidden = ids.length === 0 || doneShown;
				box.hidden = doneShown;
				box.innerHTML = ids.map(id => `
					<div class="cline">
						<div class="cline-n"><span class="cline-name">${cart[id].name}</span><span class="cline-pr">${fmt(cart[id].price)}</span></div>
						<div class="cline-q">
							<button data-dec="${id}">−</button>
							<span>${cart[id].qty}</span>
							<button data-inc="${id}">+</button>
							<button class="cline-x" data-del="${id}">✕</button>
						</div>
					</div>`).join('');
				($('[data-cart-total]') as HTMLElement).textContent = fmt(total);
			}

			function add(id: string, name: string, price: number) {
				($('[data-cart-done]') as HTMLElement).hidden = true;
				const cart = read();
				cart[id] = cart[id] ? { ...cart[id], qty: cart[id].qty + 1 } : { name, price, qty: 1 };
				write(cart);
				render();
				openCart();
				ym('cart-add', { product: id });
			}
			const openCart = () => {
				($('[data-cart-overlay]') as HTMLElement).hidden = false;
				document.body.style.overflow = 'hidden';
			};
			const closeCart = () => {
				($('[data-cart-overlay]') as HTMLElement).hidden = true;
				document.body.style.overflow = '';
				($('[data-cart-done]') as HTMLElement).hidden = true;
				render();
			};

			document.addEventListener('click', e => {
				const t = e.target as HTMLElement;
				const addBtn = t.closest('[data-add]') as HTMLElement | null;
				if (addBtn) {
					add(addBtn.dataset.id!, addBtn.dataset.name!, Number(addBtn.dataset.price));
					return;
				}
				if (t.closest('[data-cart-open]')) return openCart();
				if (t.closest('[data-cart-close]') || t.matches('[data-cart-overlay]')) return closeCart();
				const inc = t.closest('[data-inc]') as HTMLElement | null;
				const dec = t.closest('[data-dec]') as HTMLElement | null;
				const del = t.closest('[data-del]') as HTMLElement | null;
				if (inc || dec || del) {
					const cart = read();
					const id = (inc || dec || del)!.dataset.inc || (dec?.dataset.dec) || (del?.dataset.del)!;
					if (inc && cart[id]) cart[id].qty++;
					if (dec && cart[id]) cart[id].qty = Math.max(1, cart[id].qty - 1);
					if (del) delete cart[id];
					write(cart); render();
					return;
				}
				if (t.closest('[data-cart-checkout]')) {
					const cart = read();
					const total = Object.keys(cart).reduce((s, id) => s + cart[id].qty * cart[id].price, 0);
					ym('cart-checkout', { total });
					localStorage.removeItem(KEY);
					($('[data-cart-done]') as HTMLElement).hidden = false;
					render();
				}
			});

			document.addEventListener('keydown', e => {
				if (e.key === 'Escape' && !($('[data-cart-overlay]') as HTMLElement).hidden) closeCart();
			});

			render();

			// Открыть корзину при переходе со страницы товара (/produkty/#cart).
			if (location.hash === '#cart') openCart();

			// Фолбэк для фото товаров (если изображение с kontur.ru не загрузилось).
			document.querySelectorAll<HTMLImageElement>('.card-img img').forEach(img => {
				const fail = () => {
					const wrap = img.closest('.card-img');
					if (wrap && !wrap.querySelector('.imgfb')) {
						const fb = document.createElement('span');
						fb.className = 'imgfb';
						fb.textContent = (img.alt || 'Контур').slice(0, 2).toUpperCase();
						wrap.appendChild(fb);
					}
					img.style.display = 'none';
				};
				if (img.complete && img.naturalWidth === 0) fail();
				else img.addEventListener('error', fail);
			});
		</script>

		<style>
			.shop { background: #f4f5f7; }

			/* Hero */
			.shop-hero { background: #11141a; color: #fff; }
			.shop-hero-in { max-width: 1180px; margin: 0 auto; padding: 2.6rem 1rem 2rem; }
			.shop-eyebrow {
				font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em;
				color: var(--lime, #afcc00); font-weight: 700; margin: 0 0 0.5rem;
			}
			.shop-hero h1 {
				font-family: 'Bebas Neue', sans-serif;
				font-size: clamp(2.2rem, 5vw, 3.6rem); line-height: 0.95; margin: 0 0 0.9rem;
				text-transform: uppercase; letter-spacing: 0.02em;
			}
			.shop-lead { max-width: 720px; margin: 0 0 1.3rem; color: #c4c9d4; font-size: 1.02rem; line-height: 1.55; }
			.shop-hero-actions { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-bottom: 1.6rem; }
			.sbtn {
				display: inline-block; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.03em;
				text-decoration: none; padding: 0.75em 1.25em; border-radius: 9px; transition: all 0.15s ease;
			}
			.sbtn-primary { background: var(--lime, #afcc00); color: #11141a; }
			.sbtn-primary:hover { background: #fff; }
			.sbtn-ghost { color: #fff; border: 1.5px solid rgba(255,255,255,0.35); }
			.sbtn-ghost:hover { border-color: #fff; background: rgba(255,255,255,0.08); }
			.shop-tabs { display: flex; flex-wrap: wrap; gap: 0.5rem; }
			.shop-tabs a {
				font-size: 0.8rem; font-weight: 600; color: #d4d8e0; text-decoration: none;
				padding: 0.45em 0.9em; border-radius: 999px; background: rgba(255,255,255,0.08);
				transition: all 0.15s ease;
			}
			.shop-tabs a:hover { background: var(--lime, #afcc00); color: #11141a; }

			/* Advantages */
			.shop-adv { background: #1b1f29; border-top: 1px solid rgba(255,255,255,0.06); }
			.shop-adv-in {
				max-width: 1180px; margin: 0 auto; padding: 0.9rem 1rem;
				display: flex; flex-wrap: wrap; gap: 1.5rem 2rem;
			}
			.adv { display: flex; align-items: center; gap: 0.6rem; }
			.adv-ic { font-size: 1.3rem; }
			.adv-t { color: #fff; font-size: 0.85rem; font-weight: 700; }
			.adv-s { color: #9aa1b1; font-size: 0.75rem; }

			/* Body */
			.shop-body { max-width: 1180px; margin: 0 auto; padding: 2rem 1rem 1rem; }
			.sec { margin-bottom: 2.6rem; scroll-margin-top: 1rem; }
			.sec-hd { margin-bottom: 1rem; }
			.sec-eye { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; }
			.sec-hd h2 {
				font-family: 'Bebas Neue', sans-serif; font-size: 1.9rem; letter-spacing: 0.02em;
				text-transform: uppercase; margin: 0.2rem 0 0; color: #11141a;
			}
			.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(232px, 1fr)); gap: 1rem; }

			.card {
				display: flex; flex-direction: column; background: #fff; border-radius: 14px;
				overflow: hidden; border: 1px solid rgba(0,0,0,0.07);
				transition: box-shadow 0.15s ease, transform 0.15s ease;
			}
			.card:hover { box-shadow: 0 12px 30px rgba(0,0,0,0.1); transform: translateY(-2px); }
			.card-img {
				position: relative; height: 168px; background: #f4f5f7;
				display: flex; align-items: center; justify-content: center; padding: 0.8rem;
			}
			.card-img img { max-width: 100%; max-height: 100%; object-fit: contain; }
			.imgfb {
				font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 0.06em;
				color: #b6bcc8; font-weight: 700;
			}
			.card-tile {
				width: 84px; height: 84px; border-radius: 14px; display: flex; align-items: center;
				justify-content: center; color: #fff; font-family: 'Bebas Neue', sans-serif;
				font-size: 1.7rem; letter-spacing: 0.04em;
			}
			.card-sale {
				position: absolute; top: 10px; left: 10px; z-index: 1; font-size: 0.68rem; font-weight: 800;
				text-transform: uppercase; color: #fff; background: #E5392F; padding: 0.3em 0.6em; border-radius: 6px;
			}
			.card-body { display: flex; flex-direction: column; flex: 1; padding: 0.85rem 0.95rem 1rem; }
			.card-cat { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #aaa; }
			.card-name {
				font-size: 0.95rem; line-height: 1.3; font-weight: 600; color: #11141a;
				text-decoration: none; margin: 0.25rem 0 0.4rem; display: block;
			}
			a.card-name:hover { color: var(--pink, #ff4d8f); }
			.card-desc {
				margin: 0 0 0.9rem; font-size: 0.8rem; line-height: 1.45; color: #777;
				display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
			}
			.card-foot { margin-top: auto; }
			.card-price { display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.6rem; }
			.card-price .old { font-size: 0.8rem; color: #aaa; text-decoration: line-through; }
			.card-price .now { font-size: 1.15rem; font-weight: 800; color: #11141a; }
			.card-btns { display: flex; align-items: center; gap: 0.5rem; }
			.b-cart, .b-kit {
				flex: 1; border: none; cursor: pointer; text-align: center; text-decoration: none;
				font-size: 0.78rem; font-weight: 700; letter-spacing: 0.02em; padding: 0.72em 0.8em;
				border-radius: 8px; transition: background 0.15s ease, color 0.15s ease;
			}
			.b-cart { background: #11141a; color: #fff; }
			.b-cart:hover { background: #000; }
			.b-kit { background: #00C896; color: #fff; }
			.b-kit:hover { background: #00b085; }
			.b-detail {
				font-size: 0.78rem; font-weight: 600; color: #11141a; text-decoration: none;
				white-space: nowrap; border-bottom: 1.5px solid var(--pink, #ff4d8f); padding-bottom: 1px;
			}
			.b-detail:hover { color: var(--pink, #ff4d8f); }

			/* CTA band */
			.shop-cta { background: #11141a; color: #fff; }
			.shop-cta-in {
				max-width: 1180px; margin: 0 auto; padding: 2.4rem 1rem; display: flex;
				align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap;
			}
			.shop-cta h2 {
				font-family: 'Bebas Neue', sans-serif; font-size: 2.2rem; text-transform: uppercase;
				letter-spacing: 0.02em; margin: 0 0 0.4rem;
			}
			.shop-cta p { margin: 0 0 1.1rem; color: #c4c9d4; }
			.shop-cta-shapes { display: flex; gap: 0.6rem; }
			.shop-cta-shapes span { width: 56px; height: 84px; border-radius: 12px; }

			/* Cart */
			.cart-fab {
				position: fixed; right: 18px; bottom: 18px; z-index: 60; border: none; cursor: pointer;
				background: #11141a; color: #fff; font-size: 0.85rem; font-weight: 700;
				padding: 0.9em 1.3em; border-radius: 999px; box-shadow: 0 10px 30px rgba(0,0,0,0.25);
				display: flex; align-items: center; gap: 0.5rem;
			}
			.cart-count {
				background: var(--lime, #afcc00); color: #11141a; border-radius: 999px;
				min-width: 1.4em; height: 1.4em; display: inline-flex; align-items: center;
				justify-content: center; font-size: 0.78rem; padding: 0 0.4em;
			}
			.cart-fab[hidden] { display: none; }
			.cart-overlay { position: fixed; inset: 0; z-index: 70; background: rgba(0,0,0,0.45); display: flex; justify-content: flex-end; }
			.cart-overlay[hidden] { display: none; }
			.cart {
				width: min(400px, 100%); background: #fff; height: 100%; display: flex; flex-direction: column;
				padding: 1.2rem; overflow-y: auto;
			}
			.cart-hd { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
			.cart-hd strong { font-size: 1.2rem; }
			.cart-close { border: none; background: none; font-size: 1.1rem; cursor: pointer; color: #999; }
			.cart-empty { color: #888; font-size: 0.9rem; padding: 1.5rem 0; }
			.cline { border-bottom: 1px solid rgba(0,0,0,0.08); padding: 0.7rem 0; }
			.cline-n { display: flex; flex-direction: column; gap: 0.2rem; }
			.cline-name { font-size: 0.85rem; line-height: 1.3; color: #11141a; font-weight: 600; }
			.cline-pr { color: #888; font-size: 0.8rem; }
			.cline-q { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem; }
			.cline-q button {
				width: 26px; height: 26px; border: 1px solid rgba(0,0,0,0.15); background: #fff; border-radius: 6px;
				cursor: pointer; font-size: 0.9rem;
			}
			.cline-x { margin-left: auto; border: none !important; color: #c00; }
			.cart-ft { margin-top: auto; padding-top: 1rem; }
