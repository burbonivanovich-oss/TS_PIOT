---
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import { u } from '../../../utils/url';
import { SHOP_SECTIONS, PRICE_DATE, type ShopItem, type ShopSection } from '../../../data/shop-catalog';
import { longDescription, characteristics } from '../../../data/shop-specs';

export function getStaticPaths() {
	const seen = new Set<string>();
	const paths: { params: { slug: string }; props: { item: ShopItem; section: ShopSection } }[] = [];
	for (const section of SHOP_SECTIONS) {
		for (const item of section.items) {
			if (!item.slug || seen.has(item.slug)) continue;
			seen.add(item.slug);
			paths.push({ params: { slug: item.slug }, props: { item, section } });
		}
	}
	return paths;
}

interface Props { item: ShopItem; section: ShopSection }
const { item, section } = Astro.props;

const isKassa = section.id === 'kasses';
const months = (name: string) => Number(name.match(/(\d+)\s*мес/)?.[1] ?? 0);

// Реальные опции комплектации из каталога (цены из фида).
const fnOptions = (SHOP_SECTIONS.find(s => s.id === 'fn-ofd')?.items ?? [])
	.filter(i => i.price != null)
	.map(i => ({ id: i.id, name: i.name, price: i.price as number, label: `${months(i.name)} мес` }))
	.sort((a, b) => a.price - b.price);
const ofdOptions = (SHOP_SECTIONS.find(s => s.id === 'ofd')?.items ?? [])
	.filter(i => /^Оператор фискальных данных/.test(i.name) && i.price != null)
	.map(i => ({ id: i.id, name: i.name, price: i.price as number, label: `${months(i.name)} мес` }))
	.sort((a, b) => a.price - b.price);

const fnDefault = fnOptions.length ? fnOptions[fnOptions.length - 1].id : '';
const ofdDefault = (ofdOptions.find(o => months(o.name) === 15) ?? ofdOptions[0])?.id ?? '';

// «С этим покупают»: для кассы — кросс-селл (ФН, ОФД, периферия), иначе свой раздел.
const crossSell = (isKassa
	? ['fn-ofd', 'ofd', 'periphery'].flatMap(id =>
			(SHOP_SECTIONS.find(s => s.id === id)?.items.filter(i => i.slug) ?? []).slice(0, 2))
	: section.items.filter(i => i.slug && i.slug !== item.slug)
).slice(0, 4);

const descParas = longDescription(item, section);
const specs = characteristics(item, section);

// JSON-LD Product/Offer для SEO.
const jsonLd = item.price != null ? {
	'@context': 'https://schema.org',
	'@type': 'Product',
	name: item.name,
	description: item.desc || item.name,
	sku: item.id,
	category: section.title,
	...(item.img ? { image: [item.img] } : {}),
	brand: { '@type': 'Brand', name: 'Контур' },
	offers: {
		'@type': 'Offer',
		price: item.price,
		priceCurrency: 'RUB',
		availability: 'https://schema.org/InStock',
		url: new URL(`/produkty/tovar/${item.slug}/`, Astro.site ?? 'https://etiketka-media.ru').href,
	},
} : null;

const advantages = [
	['🚚', 'Доставка по Москве — 48 часов, по России от 3 рабочих дней'],
	['🛡️', 'Гарантия производителя'],
	['⚡', 'Регистрируем кассу в ФНС за 1 день'],
	['💳', 'Рассрочка 0% до 12 месяцев'],
];

const SITE = Astro.site ?? new URL('https://etiketka-media.ru');
const breadcrumbLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Магазин', item: new URL('/produkty/', SITE).href },
		{ '@type': 'ListItem', position: 2, name: section.title, item: new URL(`/produkty/#sec-${section.id}`, SITE).href },
		{ '@type': 'ListItem', position: 3, name: item.name },
	],
};

const title = `${item.name} — купить в Контуре`;
const description = item.desc?.slice(0, 160) || item.name;
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

		<main class="pdp">
			<nav class="crumbs" aria-label="Хлебные крошки">
				<a href={u('/produkty/')}>Магазин</a><span>/</span>
				<a href={`${u('/produkty/')}#sec-${section.id}`}>{section.title}</a><span>/</span>
				<span>{item.name}</span>
			</nav>

			<div class="pdp-top">
				<div class="pdp-gallery">
					<div class="pdp-img">
						{item.badge && <span class="pdp-sale">{item.badge}</span>}
						{item.img ? <img src={item.img} alt={item.name} />
							: <span class="pdp-tile" style={`background:${item.visual?.bg ?? '#111'}`}>{item.visual?.abbrev}</span>}
					</div>
				</div>

				<div class="pdp-info">
					<div class="pdp-cat" style={`color:${section.color}`}>{item.cat || section.eye}</div>
					<h1>{item.name}</h1>
					<p class="pdp-short">{item.desc}</p>

					<div class="pdp-pricebox">
						<div class="pdp-price">
							{item.oldLabel && <span class="pdp-old">{item.oldLabel}</span>}
							<span class="pdp-now">{item.priceLabel}</span>
						</div>
						{isKassa && <div class="pdp-price-note">Цена кассы без комплектации</div>}
						<div class="pdp-stock"><span class="dot"></span> В наличии, доставка 48 часов</div>
						<div class="pdp-updated">Цена обновлена: {PRICE_DATE}</div>
					</div>

					{isKassa && item.price != null && (
						<div class="config" data-config data-base={item.price} data-base-id={item.id} data-base-name={item.name}>
							<div class="config-h">Скомплектуйте кассу</div>

							<div class="config-step">
								<div class="config-step-h">1. Ваша отрасль</div>
								<div class="chips" data-info-group>
									<button class="chip is-active">Розница</button>
									<button class="chip">Общепит</button>
									<button class="chip">Услуги</button>
								</div>
							</div>

							<div class="config-step">
								<div class="config-step-h">2. Контур.Маркет — тариф</div>
								<div class="chips" data-info-group>
									<button class="chip">Базовый</button>
									<button class="chip is-active">Оптимальный</button>
									<button class="chip">Премиум</button>
								</div>
							</div>

							{fnOptions.length > 0 && (
								<div class="config-step">
									<div class="config-step-h">3. Фискальный накопитель</div>
									<div class="opts">
										{fnOptions.map(o => (
											<label class={`opt ${o.id === fnDefault ? 'is-sel' : ''}`}>
												<input type="radio" name="fn" value={o.id} data-price={o.price} data-name={o.name} checked={o.id === fnDefault} />
												<span class="opt-l">{o.label}</span>
												<span class="opt-p">{o.price.toLocaleString('ru-RU')} ₽</span>
											</label>
										))}
									</div>
								</div>
							)}

							{ofdOptions.length > 0 && (
								<div class="config-step">
									<div class="config-step-h">4. Контур.ОФД</div>
									<div class="opts">
										{ofdOptions.map(o => (
											<label class={`opt ${o.id === ofdDefault ? 'is-sel' : ''}`}>
												<input type="radio" name="ofd" value={o.id} data-price={o.price} data-name={o.name} checked={o.id === ofdDefault} />
												<span class="opt-l">{o.label}</span>
												<span class="opt-p">{o.price.toLocaleString('ru-RU')} ₽</span>
											</label>
										))}
									</div>
								</div>
							)}

							<details class="config-total">
								<summary>
									<span>Итого касса под ключ</span>
									<strong data-total>—</strong>
								</summary>
								<div class="config-breakdown" data-breakdown></div>
							</details>
							<p class="config-note">Цена ПО зависит от региона. Точную стоимость менеджер подтвердит после заявки.</p>
						</div>
					)}

					<div class="pdp-actions">
						{item.price != null ? (
							<button class={item.kit ? 'pdp-buy kit' : 'pdp-buy'} data-buy
								data-id={item.id} data-name={item.name} data-price={item.price} data-shop={u('/produkty/')}>
								{item.kit ? 'Купить комплект' : 'В корзину'}
							</button>
						) : (
							<a class="pdp-buy" href={u('/podbor/')}>Оставить заявку</a>
						)}
						<a class="pdp-consult" href={u('/podbor/')}>Получить консультацию</a>
					</div>

					<ul class="pdp-adv">
						{advantages.map(([ic, t]) => <li><span>{ic}</span> {t}</li>)}
					</ul>
				</div>
			</div>

			<div class="pdp-tabs">
				<div class="tabbar" role="tablist">
					<button class="tab is-active" data-tab="desc">Описание</button>
					<button class="tab" data-tab="specs">Характеристики</button>
					<button class="tab" data-tab="delivery">Доставка и оплата</button>
				</div>
				<div class="tabpane is-active" data-pane="desc">
					{descParas.map(t => <p>{t}</p>)}
				</div>
				<div class="tabpane" data-pane="specs" hidden>
					<table class="spectable">
						<tbody>
							{specs.map(([k, v]) => (
								<tr><th>{k}</th><td>{v}</td></tr>
							))}
						</tbody>
					</table>
					<p class="spec-note">Полные технические характеристики менеджер уточнит при оформлении заявки.</p>
				</div>
				<div class="tabpane" data-pane="delivery" hidden>
					<p>Доставка по Москве — 48 часов, по России от 3 рабочих дней транспортной компанией.
					Самовывоз со склада — бесплатно.</p>
					<p>Оплата и договор — на стороне Контура: после заявки менеджер свяжется,
					подтвердит состав, выставит счёт и оформит регистрацию кассы в ФНС.
					Доступна рассрочка 0% до 12 месяцев.</p>
				</div>
			</div>

			{crossSell.length > 0 && (
				<section class="pdp-rel">
					<h2>С этим покупают</h2>
					<div class="rel-grid">
						{crossSell.map(r => (
							<a class="rel-card" href={u(`/produkty/tovar/${r.slug}/`)}>
								<div class="rel-img">
									{r.img ? <img src={r.img} alt={r.name} loading="lazy" />
										: <span class="rel-tile" style={`background:${r.visual?.bg ?? '#111'}`}>{r.visual?.abbrev}</span>}
								</div>
								<div class="rel-cat">{r.cat}</div>
								<div class="rel-name">{r.name}</div>
								<div class="rel-price">{r.priceLabel}</div>
							</a>
						))}
					</div>
				</section>
			)}

			<p class="pdp-back"><a href={u('/produkty/')}>← Вернуться в магазин</a></p>
		</main>

		<Footer />

		<script>
			const KEY = 'kontur-shop-cart';
			const fmt = (n: number) => n.toLocaleString('ru-RU') + ' ₽';
			const ymGoal = (t: string, p?: Record<string, unknown>) =>
				(window as any).ym && (window as any).ym(109130279, 'reachGoal', t, p);
			type Line = { name: string; price: number; qty: number };
			const readCart = (): Record<string, Line> => {
				try { return JSON.parse(localStorage.getItem(KEY) || '{}'); } catch { return {}; }
			};
			const addLine = (cart: Record<string, Line>, id: string, name: string, price: number) => {
				cart[id] = cart[id] ? { ...cart[id], qty: cart[id].qty + 1 } : { name, price, qty: 1 };
			};

			// Информационные чипы (отрасль, тариф) — просто переключатель.
			document.querySelectorAll('[data-info-group]').forEach(g => {
				g.querySelectorAll('.chip').forEach(c => c.addEventListener('click', () => {
					g.querySelectorAll('.chip').forEach(x => x.classList.remove('is-active'));
					c.classList.add('is-active');
				}));
			});

			// Конфигуратор: живой итог.
			const cfg = document.querySelector<HTMLElement>('[data-config]');
			function sel(name: string) {
				const el = cfg?.querySelector<HTMLInputElement>(`input[name="${name}"]:checked`);
				return el ? { id: el.value, name: el.dataset.name!, price: Number(el.dataset.price) } : null;
			}
			function recalc() {
				if (!cfg) return;
				const base = Number(cfg.dataset.base);
				const fn = sel('fn'), ofd = sel('ofd');
				const total = base + (fn?.price ?? 0) + (ofd?.price ?? 0);
				const totalEl = cfg.querySelector('[data-total]');
				if (totalEl) totalEl.textContent = fmt(total);
				const bd = cfg.querySelector('[data-breakdown]');
				if (bd) {
					const rows = [[cfg.dataset.baseName!, base]] as [string, number][];
					if (fn) rows.push(['Фискальный накопитель · ' + fn.name.match(/\d+ мес/)?.[0], fn.price]);
					if (ofd) rows.push(['Контур.ОФД · ' + ofd.name.match(/\d+ мес/)?.[0], ofd.price]);
					bd.innerHTML = rows.map(r => `<div><span>${r[0]}</span><span>${fmt(r[1])}</span></div>`).join('');
				}
				cfg.querySelectorAll('.opt').forEach(o => {
					const i = o.querySelector('input') as HTMLInputElement;
					o.classList.toggle('is-sel', i.checked);
				});
			}
			cfg?.querySelectorAll('input[type="radio"]').forEach(r => r.addEventListener('change', recalc));
			recalc();

			// Купить.
			const buy = document.querySelector<HTMLElement>('[data-buy]');
			buy?.addEventListener('click', () => {
				const cart = readCart();
				addLine(cart, buy.dataset.id!, buy.dataset.name!, Number(buy.dataset.price));
				if (cfg) {
					const fn = sel('fn'), ofd = sel('ofd');
					if (fn) addLine(cart, fn.id, fn.name, fn.price);
					if (ofd) addLine(cart, ofd.id, ofd.name, ofd.price);
				}
				localStorage.setItem(KEY, JSON.stringify(cart));
				ymGoal('cart-add', { product: buy.dataset.id });
				window.dispatchEvent(new Event('kontur-cart-changed'));
				window.dispatchEvent(new Event('kontur-cart-open'));
			});

			// Табы.
			document.querySelectorAll('.tab').forEach(t => t.addEventListener('click', () => {
				document.querySelectorAll('.tab').forEach(x => x.classList.remove('is-active'));
				t.classList.add('is-active');
				const name = (t as HTMLElement).dataset.tab;
				document.querySelectorAll<HTMLElement>('.tabpane').forEach(p => {
					p.hidden = p.dataset.pane !== name;
					p.classList.toggle('is-active', p.dataset.pane === name);
				});
			}));

			// Фолбэк фото.
			document.querySelectorAll<HTMLImageElement>('.pdp-img img, .rel-img img').forEach(img => {
				const fail = () => {
					const w = img.parentElement;
					if (w && !w.querySelector('.imgfb')) {
						const fb = document.createElement('span');
						fb.className = 'imgfb';
						fb.textContent = (img.alt || 'Контур').slice(0, 2).toUpperCase();
						w.appendChild(fb);
					}
					img.style.display = 'none';
				};
				if (img.complete && img.naturalWidth === 0) fail();
				else img.addEventListener('error', fail);
			});
		</script>

		<style>
			.pdp { max-width: 1120px; margin: 0 auto; padding: 1.5rem 1rem 4rem; }
			.crumbs { font-size: 0.8rem; color: #888; margin-bottom: 1.4rem; display: flex; flex-wrap: wrap; gap: 0.4rem; }
			.crumbs a { color: #888; text-decoration: none; }
			.crumbs a:hover { color: #111; }

			.pdp-top { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr); gap: 2.5rem; align-items: start; }
			.pdp-gallery { position: sticky; top: 1rem; }
			.pdp-img {
				position: relative; background: #f4f5f7; border-radius: 16px; aspect-ratio: 4/3;
				display: flex; align-items: center; justify-content: center; padding: 2rem;
			}
			.pdp-img img { max-width: 100%; max-height: 100%; object-fit: contain; }
			.pdp-tile { width: 150px; height: 150px; border-radius: 22px; display: flex; align-items: center; justify-content: center; color: #fff; font-family: 'Bebas Neue', sans-serif; font-size: 2.8rem; }
			.imgfb { font-family: 'Bebas Neue', sans-serif; font-size: 3rem; color: #b6bcc8; }
			.pdp-sale { position: absolute; top: 14px; left: 14px; font-size: 0.72rem; font-weight: 800; text-transform: uppercase; color: #fff; background: #E5392F; padding: 0.35em 0.7em; border-radius: 7px; }

			.pdp-cat { font-size: 0.74rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; }
			.pdp-info h1 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(1.7rem, 3.5vw, 2.5rem); line-height: 1.04; text-transform: uppercase; margin: 0.3rem 0 0.6rem; color: #11141a; }
			.pdp-short { margin: 0 0 1.2rem; color: #555; font-size: 0.95rem; line-height: 1.55; }

			.pdp-pricebox { margin-bottom: 1.3rem; }
			.pdp-price { display: flex; align-items: baseline; gap: 0.7rem; }
			.pdp-old { font-size: 1.1rem; color: #aaa; text-decoration: line-through; }
			.pdp-now { font-size: 2rem; font-weight: 800; color: #11141a; }
			.pdp-price-note { font-size: 0.8rem; color: #999; margin-top: 0.15rem; }
			.pdp-stock { font-size: 0.85rem; color: #1a8a4a; margin-top: 0.5rem; display: flex; align-items: center; gap: 0.4rem; }
			.pdp-stock .dot { width: 8px; height: 8px; border-radius: 999px; background: #1a8a4a; display: inline-block; }
			.pdp-updated { font-size: 0.76rem; color: #aaa; margin-top: 0.3rem; }

			.config { border: 1.5px solid rgba(0,0,0,0.1); border-radius: 14px; padding: 1.1rem 1.2rem; margin-bottom: 1.3rem; }
			.config-h { font-size: 0.74rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; color: #FF6B35; margin-bottom: 0.9rem; }
			.config-step { margin-bottom: 0.9rem; }
			.config-step-h { font-size: 0.85rem; font-weight: 700; color: #11141a; margin-bottom: 0.45rem; }
			.chips { display: flex; flex-wrap: wrap; gap: 0.45rem; }
			.chip { font-size: 0.8rem; font-weight: 600; color: #333; background: #fff; border: 1.5px solid rgba(0,0,0,0.15); border-radius: 999px; padding: 0.4em 0.9em; cursor: pointer; transition: all 0.12s ease; }
			.chip:hover { border-color: #FF6B35; }
			.chip.is-active { background: #FF6B35; color: #fff; border-color: #FF6B35; }
			.opts { display: flex; flex-wrap: wrap; gap: 0.45rem; }
			.opt { display: inline-flex; align-items: center; gap: 0.5rem; border: 1.5px solid rgba(0,0,0,0.15); border-radius: 10px; padding: 0.5em 0.8em; cursor: pointer; transition: all 0.12s ease; }
			.opt input { display: none; }
			.opt:hover { border-color: #FF6B35; }
			.opt.is-sel { border-color: #FF6B35; background: rgba(255,107,53,0.06); }
			.opt-l { font-size: 0.85rem; font-weight: 700; color: #11141a; }
			.opt-p { font-size: 0.82rem; color: #666; }
			.config-total { border-top: 1px solid rgba(0,0,0,0.1); margin-top: 0.4rem; padding-top: 0.7rem; }
			.config-total summary { display: flex; align-items: center; justify-content: space-between; cursor: pointer; list-style: none; font-size: 0.95rem; }
			.config-total summary::-webkit-details-marker { display: none; }
			.config-total summary strong { font-size: 1.3rem; color: #11141a; }
			.config-breakdown { margin-top: 0.7rem; display: grid; gap: 0.35rem; }
			.config-breakdown div { display: flex; justify-content: space-between; font-size: 0.82rem; color: #555; }
			.config-note { font-size: 0.74rem; color: #999; margin: 0.7rem 0 0; }

			.pdp-actions { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-bottom: 1.3rem; }
			.pdp-buy { flex: 1; min-width: 200px; border: none; cursor: pointer; text-decoration: none; text-align: center; background: #11141a; color: #fff; font-size: 0.92rem; font-weight: 700; padding: 1em 1.6em; border-radius: 10px; transition: background 0.15s ease; }
			.pdp-buy:hover { background: #000; }
			.pdp-buy.kit { background: #00C896; }
			.pdp-buy.kit:hover { background: #00b085; }
			.pdp-consult { flex: 1; min-width: 200px; text-align: center; text-decoration: none; border: 1.5px solid rgba(0,0,0,0.2); color: #11141a; font-size: 0.9rem; font-weight: 700; padding: 1em 1.6em; border-radius: 10px; transition: all 0.15s ease; }
			.pdp-consult:hover { border-color: #11141a; }

			.pdp-adv { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.5rem; }
			.pdp-adv li { font-size: 0.85rem; color: #333; display: flex; gap: 0.55rem; align-items: baseline; }
			.pdp-adv li span { font-size: 1rem; }

			.pdp-tabs { margin-top: 3rem; }
			.tabbar { display: flex; gap: 0.3rem; border-bottom: 2px solid rgba(0,0,0,0.08); margin-bottom: 1.3rem; flex-wrap: wrap; }
