---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MarkingCalendar from '../components/MarkingCalendar';
import { SITE_TITLE } from '../consts';

const title = 'Календарь маркировки 2026';
const description =
	'Таблица сроков обязательной маркировки «Честный знак» по товарным группам. Фильтр по дате и категории. Актуально на 2026 год.';

const breadcrumbsJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Главная',
			item: new URL('/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: title,
			item: new URL('/kalendar-markirovki/', Astro.site).toString(),
		},
	],
};
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} jsonLd={[breadcrumbsJsonLd]} />
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumbs" aria-label="Хлебные крошки">
				<a href="/">Главная</a>
				<span>›</span>
				<a href="/category/markirovka/">Маркировка</a>
				<span>›</span>
				<span aria-current="page">{title}</span>
			</nav>

			<header class="page-head">
				<h1>{title}</h1>
				<p class="lead">
					Все товарные группы с обязательной маркировкой «Честный знак» — в одной таблице.
					Фильтруйте по статусу или категории, чтобы найти нужное быстро.
				</p>
				<p class="intro">
					С 28 декабря 2025 года обязательным стал <a href="/blog/2026-01-15-chto-takoe-ts-piot/">ТС ПИоТ</a> —
					программный модуль кассы, который проверяет коды при продаже. Каждая строка таблицы
					ниже — это момент, когда ваша касса должна уметь отклонять немаркированный товар.
					Сверьтесь со своей товарной группой и убедитесь, что касса и договор с ОФД готовы.
				</p>
			</header>

			<MarkingCalendar client:load />

			<section class="note">
				<h2>Как пользоваться таблицей</h2>
				<ul>
					<li>
						<strong>«Действует»</strong> — маркировка уже обязательна. Продажа без кода Data Matrix
						влечёт штраф по <a href="/kalkulyator-shtrafov/">ст. 15.12 КоАП РФ</a>.
					</li>
					<li>
						<strong>«С 2026 года»</strong> — срок наступит в 2026 году. Уже сейчас нужно зарегистрироваться
						в «Честном знаке» и подготовить кассу.
					</li>
					<li>
						Точные даты вступления в силу устанавливаются постановлениями Правительства РФ.
						Перед принятием решений сверяйтесь с актуальной редакцией на
						<a href="https://pravo.gov.ru" rel="nofollow noopener" target="_blank">pravo.gov.ru</a>.
					</li>
				</ul>
			</section>

			<section class="related">
				<h2>Полезно почитать</h2>
				<ul>
					<li>
						<a href="/category/markirovka/">Маркировка «Честный знак»</a> — все материалы раздела.
					</li>
					<li>
						<a href="/blog/2026-02-10-kategorii-markirovki-2026/">Категории маркировки в 2026 году</a> —
						подробный разбор по товарным группам.
					</li>
					<li>
						<a href="/kalkulyator-shtrafov/">Калькулятор штрафов</a> — сколько стоит нарушение по ст. 15.12 КоАП.
					</li>
					<li>
						<a href="/blog/2026-01-15-chto-takoe-ts-piot/">Что такое ТС ПИоТ</a> — как касса проверяет маркировку.
					</li>
				</ul>
			</section>
		</main>
		<Footer />

		<style>
			.breadcrumbs {
				font-size: 0.88rem;
				color: rgb(var(--gray));
				margin-top: 1rem;
			}
			.breadcrumbs a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumbs a:hover { color: var(--accent); }
			.breadcrumbs span { margin: 0 0.4em; }
			.page-head {
				padding: 1.5rem 0 1rem;
				max-width: 860px;
			}
			.lead {
				font-size: 1.1rem;
				color: rgb(var(--gray-dark));
				margin-top: 0.5rem;
			}
			.intro {
				font-size: 0.97rem;
				color: rgb(var(--gray-dark));
				margin-top: 0.5rem;
				line-height: 1.65;
			}
			.note, .related {
				max-width: 820px;
				margin-top: 2.5rem;
			}
			.note ul, .related ul {
				margin: 1rem 0 0;
				padding-left: 1.2rem;
			}
			.note li, .related li {
				margin-bottom: 0.6rem;
				color: rgb(var(--gray-dark));
				line-height: 1.6;
			}
		</style>
	</body>
</html>
