---
import BaseHead from '../../components/BaseHead.astro';
import KonturOrderWidget from '../../components/KonturOrderWidget.astro';
import { u } from '../../utils/url';
import { SITE_TITLE } from '../../consts';
import { LANDINGS } from '../../data/landings';

export function getStaticPaths() {
	return Object.values(LANDINGS).map((lp) => ({
		params: { slug: lp.slug },
		props: { lp },
	}));
}

const { lp } = Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={lp.seoTitle} description={lp.seoDescription} noindex />
	</head>
	<body>
		<!-- Стрипнутая шапка: логотип + один CTA, без навигации -->
		<header class="lp-header">
			<a href={u('/')} class="lp-logo">этикетка<span>.</span></a>
			<a href="#lead" class="lp-header-cta">{lp.hero.cta} →</a>
		</header>

		<main class="lp">
			<!-- HERO: оффер слева, форма справа (первый экран) -->
			<section class="lp-hero">
				<div class="lp-hero-text">
					<span class="lp-eyebrow">{lp.hero.eyebrow}</span>
					<h1>{lp.hero.h1}</h1>
					<p class="lp-sub">{lp.hero.sub}</p>
					<ul class="lp-hero-trust">
						{lp.trust.map((t) => <li>{t}</li>)}
					</ul>
					<a href="#lead" class="lp-btn lp-btn-tomobile">{lp.hero.cta} ↓</a>
				</div>
				<div class="lp-hero-form" id="lead">
					<KonturOrderWidget id={lp.bannerId} heading="Оставьте заявку — Контур перезвонит" />
				</div>
			</section>

			<!-- СРОЧНОСТЬ -->
			{lp.urgency && (
				<section class="lp-urgency">
					<h2>{lp.urgency.title}</h2>
					<p>{lp.urgency.text}</p>
				</section>
			)}

			<!-- ВЫГОДЫ -->
			<section class="lp-section">
				<h2 class="lp-h2">Что вы получаете</h2>
				<div class="lp-benefits">
					{lp.benefits.map((b) => (
						<div class="lp-benefit">
							<span class="lp-benefit-mark" aria-hidden="true">✓</span>
							<div>
								<div class="lp-benefit-title">{b.title}</div>
								<p>{b.text}</p>
							</div>
						</div>
					))}
				</div>
			</section>

			<!-- ШАГИ -->
			<section class="lp-section">
				<h2 class="lp-h2">Как подключить</h2>
				<ol class="lp-steps">
					{lp.steps.map((s, i) => (
						<li class="lp-step">
							<span class="lp-step-num">{i + 1}</span>
							<div>
								<div class="lp-step-title">{s.title}</div>
								<p>{s.text}</p>
							</div>
						</li>
					))}
				</ol>
			</section>

			<!-- ДОВЕРИЕ -->
			<section class="lp-trust">
				{lp.trust.map((t) => <span class="lp-trust-item">{t}</span>)}
			</section>

			<!-- FAQ -->
			<section class="lp-section">
				<h2 class="lp-h2">Частые вопросы</h2>
				<div class="lp-faq">
					{lp.faq.map((f) => (
						<details class="lp-faq-item">
							<summary>{f.q}</summary>
							<p>{f.a}</p>
						</details>
					))}
				</div>
				<div class="lp-final-cta">
					<a href="#lead" class="lp-btn">{lp.hero.cta} →</a>
				</div>
			</section>
		</main>

		<footer class="lp-footer">
			<span>© {year} {SITE_TITLE} — информационный партнёр. Заявку обрабатывает Контур.</span>
			<a href={u('/privacy/')}>Политика конфиденциальности</a>
		</footer>

		<!-- Липкий CTA на мобиле -->
		<a href="#lead" class="lp-sticky-cta">{lp.hero.cta} →</a>

		<style>
			:root { --lp-max: 980px; }
			body { margin: 0; background: var(--surface, #F6F4EE); }
			.lp { max-width: var(--lp-max); margin: 0 auto; padding: 0 20px 60px; }

			.lp-header {
				position: sticky; top: 0; z-index: 50;
				display: flex; align-items: center; justify-content: space-between;
				gap: 1rem; padding: 12px 20px;
				background: var(--surface, #F6F4EE); border-bottom: 1px solid var(--line, #E5E1D8);
			}
			.lp-logo {
				font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; letter-spacing: .04em;
				color: #111; text-decoration: none; text-transform: lowercase;
			}
			.lp-logo span { color: var(--pink, #9E2B4F); }
			.lp-header-cta {
				font-size: .74rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase;
				color: #111; text-decoration: none; border: 2px solid #111; padding: 8px 14px;
			}
			.lp-header-cta:hover { background: #111; color: var(--lime, #AFCC00); }

			.lp-btn {
				display: inline-block; padding: 15px 28px;
				background: #111; color: var(--lime, #AFCC00);
				font-size: .8rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
				text-decoration: none; transition: background .15s, color .15s;
			}
			.lp-btn:hover { background: var(--pink, #9E2B4F); color: #fff; }

			/* HERO: оффер слева, форма справа */
			.lp-hero {
				display: grid; grid-template-columns: 1fr 460px; gap: 2.5rem; align-items: start;
				padding: 2.5rem 0;
			}
			.lp-eyebrow {
				font-size: .72rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
				color: var(--pink, #9E2B4F); display: block; margin-bottom: .8rem;
			}
			.lp-hero h1 {
				font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.2rem, 4.6vw, 3.4rem);
				line-height: .98; letter-spacing: .02em; text-transform: uppercase; color: #111; margin: 0 0 1rem;
			}
			.lp-sub { font-size: 1.05rem; line-height: 1.55; color: var(--ink-2, #3a3a3a); margin: 0 0 1.25rem; }
			.lp-hero-trust { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .5rem; }
			.lp-hero-trust li { font-size: .92rem; color: var(--ink-2, #3a3a3a); padding-left: 1.4rem; position: relative; }
			.lp-hero-trust li::before { content: '✓'; position: absolute; left: 0; color: var(--lime-dark, #8aaa00); font-weight: 700; }
			.lp-hero-form { align-self: start; scroll-margin-top: 70px; }
			.lp-hero-form :global(.kow) { margin: 0; }
			.lp-btn-tomobile { display: none; }

			/* СРОЧНОСТЬ */
			.lp-urgency {
				background: #111; color: #fff; padding: 1.5rem 1.75rem; margin: 1rem 0 2.5rem;
				border-left: 4px solid var(--lime, #AFCC00);
			}
			.lp-urgency h2 {
				font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; letter-spacing: .02em;
				text-transform: uppercase; margin: 0 0 .5rem; color: var(--lime, #AFCC00);
			}
			.lp-urgency p { margin: 0; font-size: .98rem; line-height: 1.6; color: #e8e8e8; }

			.lp-section { margin: 2.5rem 0; }
			.lp-h2 {
				font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; letter-spacing: .02em;
				text-transform: uppercase; color: #111; margin: 0 0 1.25rem;
			}

			/* ВЫГОДЫ */
			.lp-benefits { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
			.lp-benefit {
				display: grid; grid-template-columns: auto 1fr; gap: 12px;
				background: #fff; border: 1px solid var(--line, #E5E1D8); padding: 18px;
			}
			.lp-benefit-mark { color: var(--lime-dark, #8aaa00); font-weight: 700; font-size: 1.1rem; }
			.lp-benefit-title { font-weight: 700; color: #111; margin-bottom: .25rem; }
			.lp-benefit p { margin: 0; font-size: .92rem; line-height: 1.5; color: var(--ink-3, #666); }

			/* ШАГИ */
			.lp-steps { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
			.lp-step { display: flex; flex-direction: column; gap: 10px; background: var(--sand-l, #fff); border: 1px solid var(--line, #E5E1D8); padding: 18px; }
			.lp-step-num {
				width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;
				background: #111; color: var(--lime, #AFCC00); font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem;
			}
			.lp-step-title { font-weight: 700; color: #111; }
			.lp-step p { margin: 0; font-size: .92rem; line-height: 1.5; color: var(--ink-3, #666); }

			/* ЛИД */
			.lp-lead { scroll-margin-top: 70px; }

			/* ДОВЕРИЕ */
			.lp-trust {
				display: flex; flex-wrap: wrap; gap: .75rem 1.5rem; justify-content: center;
				padding: 1.25rem; background: var(--sand, #EDE8DF); margin: 2.5rem 0;
			}
			.lp-trust-item { font-size: .85rem; color: var(--ink-2, #3a3a3a); padding-left: 1.2rem; position: relative; }
			.lp-trust-item::before { content: '✓'; position: absolute; left: 0; color: var(--lime-dark, #8aaa00); font-weight: 700; }

			/* FAQ */
			.lp-faq { display: flex; flex-direction: column; gap: 8px; }
			.lp-faq-item { background: #fff; border: 1px solid var(--line, #E5E1D8); padding: 14px 18px; }
			.lp-faq-item summary { font-weight: 600; color: #111; cursor: pointer; font-size: .98rem; }
			.lp-faq-item p { margin: .75rem 0 0; font-size: .92rem; line-height: 1.55; color: var(--ink-2, #3a3a3a); }
			.lp-final-cta { text-align: center; margin-top: 2rem; }

			.lp-footer {
				max-width: var(--lp-max); margin: 0 auto; padding: 1.5rem 20px 2.5rem;
				display: flex; flex-wrap: wrap; gap: .5rem 1.5rem; justify-content: space-between;
				font-size: .8rem; color: var(--ink-3, #666); border-top: 1px solid var(--line, #E5E1D8);
			}
			.lp-footer a { color: var(--pink, #9E2B4F); }

			.lp-sticky-cta { display: none; }

			@media (max-width: 820px) {
				.lp-hero { grid-template-columns: 1fr; gap: 1.5rem; padding: 1.75rem 0; }
				.lp-btn-tomobile { display: inline-block; margin-bottom: .25rem; }
				.lp-benefits { grid-template-columns: 1fr; }
				.lp-steps { grid-template-columns: 1fr; }
				.lp-header-cta { display: none; }
				/* липкий CTA снизу на мобиле */
				.lp-sticky-cta {
					display: block; position: fixed; left: 12px; right: 12px; bottom: 12px; z-index: 60;
					text-align: center; padding: 15px; background: #111; color: var(--lime, #AFCC00);
					font-size: .82rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
					text-decoration: none; box-shadow: 0 4px 16px rgba(0,0,0,.25);
				}
				.lp { padding-bottom: 90px; }
			}
		</style>
	</body>
</html>
