---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES, SITE_TITLE } from '../../consts';
import { alphabetOrder, firstLetter, termSlug } from '../../utils/glossary';
import { u } from '../../utils/url';

const RU_ALPHA = [
	'А','Б','В','Г','Д','Е','Ё','Ж','З','И','Й','К','Л','М','Н','О',
	'П','Р','С','Т','У','Ф','Х','Ц','Ч','Ш','Щ','Ъ','Ы','Ь','Э','Ю','Я',
];

const entries = await getCollection('glossary');
const sorted = [...entries].sort((a, b) =>
	alphabetOrder(firstLetter(a.data.term), firstLetter(b.data.term)) ||
	a.data.term.localeCompare(b.data.term, 'ru'),
);

const grouped = new Map<string, typeof entries>();
for (const entry of sorted) {
	const letter = firstLetter(entry.data.term);
	if (!grouped.has(letter)) grouped.set(letter, []);
	grouped.get(letter)!.push(entry);
}

const initialLetter = grouped.keys().next().value as string | undefined;
const groupedObj: Record<string, Array<{
	id: string;
	slug: string;
	term: string;
	summary: string;
	categoryTitle: string | null;
	categorySlug: string | null;
}>> = {};
for (const [letter, items] of grouped.entries()) {
	groupedObj[letter] = items.map((entry) => ({
		id: entry.id,
		slug: termSlug(entry.data.term),
		term: entry.data.term,
		summary: entry.data.summary,
		categoryTitle: entry.data.category ? CATEGORIES[entry.data.category]?.title ?? null : null,
		categorySlug: entry.data.category ?? null,
	}));
}

const title = 'Словарь';
const description = `Расшифровки ключевых терминов портала «${SITE_TITLE}»: ТС ПИоТ, маркировка, налоги, ЭДО — простыми словами с указанием категории и связанных материалов.`;

const breadcrumbsJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Главная',
			item: new URL('/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: title,
			item: new URL('/slovar/', Astro.site).toString(),
		},
	],
};

const definedTermSetJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'DefinedTermSet',
	name: `${title} — ${SITE_TITLE}`,
	url: new URL('/slovar/', Astro.site).toString(),
	inLanguage: 'ru-RU',
	hasDefinedTerm: sorted.map((entry) => ({
		'@type': 'DefinedTerm',
		'@id': new URL(
			`/slovar/#${termSlug(entry.data.term)}`,
			Astro.site,
		).toString(),
		name: entry.data.term,
		alternateName: entry.data.aliases,
		description: entry.data.summary,
		inDefinedTermSet: new URL('/slovar/', Astro.site).toString(),
	})),
};
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead
			title={title}
			description={description}
			jsonLd={[breadcrumbsJsonLd, definedTermSetJsonLd]}
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="slov-head">
				<div class="wrap">
					<nav class="breadcrumbs" aria-label="Хлебные крошки">
						<a href={u('/')}>Главная</a><span>›</span><span aria-current="page">{title}</span>
					</nav>
					<div class="slov-head-row">
						<div>
							<span class="eyebrow">Справочник</span>
							<h1>{title}</h1>
							<p class="sub">{description}</p>
						</div>
						<div class="slov-search">
							<input id="term-search" type="search" placeholder="Найти термин…" />
						</div>
					</div>
				</div>
			</section>

			<section class="slov-body">
				<div class="wrap">
					<nav class="alpha-tiles" id="alpha-tiles" aria-label="Алфавитный навигатор" data-pagefind-ignore>
						{RU_ALPHA.map((letter) => {
							const has = grouped.has(letter);
							const isCur = letter === initialLetter;
							const cls = ['alpha-tile', has ? '' : 'empty', isCur ? 'cur' : ''].filter(Boolean).join(' ');
							return (
								<a class={cls} data-l={letter} href={has ? `#letter-${letter}` : undefined}>{letter}</a>
							);
						})}
					</nav>

					<div
						class="terms-pane"
						data-pagefind-body
						data-pagefind-meta="type:glossary"
						data-pagefind-filter="type:Словарь"
					>
						{Array.from(grouped.keys()).map((letter, i) => {
							const items = groupedObj[letter];
							return (
								<section
									class={`letter-block ${i === 0 ? 'cur' : ''}`}
									id={`letter-${letter}`}
									data-letter={letter}
								>
									<header class="letter-context">
										<h2><span class="lc-big">{letter}</span>Термины на букву «{letter}»</h2>
									</header>
									<div class="term-3col">
										{items.map((entry) => (
											<div class="term-item" id={entry.slug}>
												<a class="t-name" href={`#${entry.slug}`}>{entry.term}</a>
												<span class="t-desc"> — {entry.summary}</span>
												{entry.categoryTitle && entry.categorySlug && (
													<a class="t-tag" href={u(`/category/${entry.categorySlug}/`)}>{entry.categoryTitle}</a>
												)}
											</div>
										))}
									</div>
								</section>
							);
						})}
					</div>
				</div>
			</section>
		</main>
		<Footer />

		<style>
			main { padding: 0 0 80px; }
			.wrap { max-width: var(--maxw, 1440px); margin: 0 auto; padding: 0 32px; }

			.breadcrumbs {
				font-size: .7rem;
				font-weight: 600;
				letter-spacing: .1em;
				text-transform: uppercase;
				color: var(--mute, #9a9a9a);
				margin-bottom: 18px;
			}
			.breadcrumbs a { color: inherit; text-decoration: none; }
			.breadcrumbs a:hover { color: #111; }
			.breadcrumbs span { margin: 0 .4em; }

			.slov-head {
				background: #fff;
				border-bottom: 1px solid var(--line, #E5E1D8);
				padding: 36px 0 32px;
				margin-bottom: 36px;
			}
			.slov-head-row {
				display: grid;
				grid-template-columns: 1fr auto;
				gap: 40px;
				align-items: end;
			}
			.eyebrow {
				display: block;
				font-size: .68rem;
				font-weight: 700;
				letter-spacing: .18em;
				text-transform: uppercase;
				color: var(--pink, #9E2B4F);
				margin-bottom: 10px;
			}
			.slov-head h1 {
				font-family: var(--f-display, 'Bebas Neue', sans-serif);
				font-size: clamp(2.6rem, 5vw, 4.4rem);
				line-height: .95;
				letter-spacing: .02em;
				color: #111;
				margin: 0 0 14px;
				text-transform: uppercase;
			}
			.slov-head .sub {
				font-size: 1rem;
				color: var(--ink-3, #666);
				max-width: 540px;
				line-height: 1.55;
				margin: 0;
			}
			.slov-search { min-width: 320px; }
			.slov-search input {
				width: 100%;
				padding: 12px 14px 12px 38px;
				border: 2px solid #111;
				font-size: .92rem;
				font-family: inherit;
				background: #fff
					url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%23111' stroke-width='2'><circle cx='11' cy='11' r='7'/><line x1='21' y1='21' x2='16.65' y2='16.65'/></svg>")
					12px center no-repeat;
				border-radius: 0;
				outline: none;
			}
			.slov-search input:focus { border-color: var(--pink, #9E2B4F); }

			.alpha-tiles {
				display: grid;
				grid-template-columns: repeat(16, 1fr);
				gap: 6px;
				margin-bottom: 32px;
			}
			.alpha-tile {
				aspect-ratio: 1/1;
				display: flex;
				align-items: center;
				justify-content: center;
				background: var(--sand, #EDE8DF);
				border: 1px solid var(--line, #E5E1D8);
				font-family: var(--f-display, 'Bebas Neue', sans-serif);
				font-size: 1.5rem;
				color: #111;
				text-decoration: none;
				cursor: pointer;
				transition: all .12s;
				border-radius: 2px;
				letter-spacing: .02em;
				line-height: 1;
			}
			.alpha-tile:hover { background: #111; color: var(--lime, #AFCC00); border-color: #111; }
			.alpha-tile.cur { background: #111; color: var(--lime, #AFCC00); border-color: #111; }
			.alpha-tile.empty {
				color: var(--mute, #9a9a9a);
				background: var(--sand-l, #F6F4EE);
				pointer-events: none;
				opacity: .5;
			}

			.letter-block { display: none; scroll-margin-top: 80px; }
			.letter-block.cur { display: block; }
			.letter-context {
				display: flex;
				justify-content: space-between;
				align-items: end;
				margin-bottom: 22px;
				padding-bottom: 14px;
				border-bottom: 2px solid #111;
			}
			.letter-context h2 {
				font-family: var(--f-display, 'Bebas Neue', sans-serif);
				font-size: 1.7rem;
				margin: 0;
				text-transform: uppercase;
				letter-spacing: .02em;
				display: flex;
				align-items: baseline;
				gap: 12px;
			}
			.letter-context h2 .lc-big {
				color: var(--pink, #9E2B4F);
				font-size: 2.4rem;
			}

			.term-3col {
				column-count: 3;
				column-gap: 40px;
				margin-bottom: 36px;
			}
			.term-item {
				break-inside: avoid;
				margin-bottom: 14px;
				padding-bottom: 14px;
				border-bottom: 1px dashed var(--line-2, #D9D4C6);
				scroll-margin-top: 80px;
			}
			.term-item:last-child { border-bottom: 0; }
			.term-item .t-name {
				font-weight: 700;
				text-decoration: none;
				color: var(--pink, #9E2B4F);
				font-size: .95rem;
			}
			.term-item .t-name:hover { color: #111; }
			.term-item .t-desc {
				font-size: .92rem;
				color: var(--ink-2, #3a3a3a);
				line-height: 1.5;
			}
			.term-item .t-tag {
				display: inline-block;
				font-family: var(--f-mono, ui-monospace, monospace);
				font-size: .6rem;
				color: var(--mute, #9a9a9a);
				text-decoration: none;
				font-weight: 500;
				text-transform: uppercase;
				letter-spacing: .06em;
				margin-top: 6px;
			}
			.term-item .t-tag:hover { color: var(--pink, #9E2B4F); }

			.terms-pane.search-active .letter-block { display: block; }
			.terms-pane.search-active .term-item.hide { display: none; }

			@media (max-width: 1024px) {
				.alpha-tiles { grid-template-columns: repeat(12, 1fr); }
				.term-3col { column-count: 2; }
			}
			@media (max-width: 820px) {
				.slov-head-row { grid-template-columns: 1fr; gap: 18px; }
				.slov-search { min-width: 0; }
				.wrap { padding: 0 20px; }
			}
			@media (max-width: 560px) {
				.alpha-tiles { grid-template-columns: repeat(8, 1fr); gap: 4px; }
				.alpha-tile { font-size: 1.2rem; }
				.term-3col { column-count: 1; }
				.letter-context { flex-direction: column; align-items: start; gap: 6px; }
				.wrap { padding: 0 16px; }
			}
		</style>

		<script>
			const tiles = document.querySelectorAll<HTMLAnchorElement>('#alpha-tiles .alpha-tile');
			const blocks = document.querySelectorAll<HTMLElement>('.letter-block');
			const pane = document.querySelector<HTMLElement>('.terms-pane');
			const search = document.getElementById('term-search') as HTMLInputElement | null;

			function showLetter(letter: string) {
				tiles.forEach((t) => t.classList.toggle('cur', t.dataset.l === letter));
				blocks.forEach((b) => b.classList.toggle('cur', b.dataset.letter === letter));
			}

			tiles.forEach((tile) => {
				tile.addEventListener('click', (e) => {
					if (tile.classList.contains('empty')) return;
					if (pane?.classList.contains('search-active')) return;
					e.preventDefault();
					const letter = tile.dataset.l;
					if (letter) {
						showLetter(letter);
						history.replaceState(null, '', `#letter-${letter}`);
					}
				});
			});

			// Open the letter referenced in hash on load
			const hash = window.location.hash;
			if (hash.startsWith('#letter-')) {
				showLetter(hash.replace('#letter-', ''));
			} else if (hash.startsWith('#')) {
				// Opened a specific term — find its letter
				const slug = hash.slice(1);
				const targetItem = document.getElementById(slug);
				const targetBlock = targetItem?.closest<HTMLElement>('.letter-block');
				if (targetBlock?.dataset.letter) {
					showLetter(targetBlock.dataset.letter);
					setTimeout(() => targetItem?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
				}
			}

			// Search: показываем все буквы, фильтруем термины
			search?.addEventListener('input', () => {
				const q = (search.value || '').trim().toLowerCase();
				if (!q) {
					pane?.classList.remove('search-active');
					document.querySelectorAll<HTMLElement>('.term-item').forEach((i) => i.classList.remove('hide'));
					return;
				}
				pane?.classList.add('search-active');
				document.querySelectorAll<HTMLElement>('.term-item').forEach((item) => {
					const text = (item.textContent || '').toLowerCase();
					item.classList.toggle('hide', !text.includes(q));
				});
			});
		</script>
	</body>
</html>
