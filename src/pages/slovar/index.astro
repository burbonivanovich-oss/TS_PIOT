---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES, SITE_TITLE } from '../../consts';
import { alphabetOrder, firstLetter, termSlug } from '../../utils/glossary';

const entries = await getCollection('glossary');
const sorted = [...entries].sort((a, b) =>
	alphabetOrder(firstLetter(a.data.term), firstLetter(b.data.term)) ||
	a.data.term.localeCompare(b.data.term, 'ru'),
);

const grouped = new Map<string, typeof entries>();
for (const entry of sorted) {
	const letter = firstLetter(entry.data.term);
	if (!grouped.has(letter)) grouped.set(letter, []);
	grouped.get(letter)!.push(entry);
}
const letters = Array.from(grouped.keys());

const renderedBodies = await Promise.all(
	sorted.map(async (entry) => {
		const { Content } = await render(entry);
		return { id: entry.id, Content };
	}),
);
const bodyById = new Map(renderedBodies.map((r) => [r.id, r.Content]));

const title = 'Глоссарий';
const description = `Расшифровки ключевых терминов портала «${SITE_TITLE}»: ТС ПИоТ, маркировка, налоги, ЭДО — простыми словами с указанием категории и связанных материалов.`;

const breadcrumbsJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Главная',
			item: new URL('/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: title,
			item: new URL('/slovar/', Astro.site).toString(),
		},
	],
};

const definedTermSetJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'DefinedTermSet',
	name: `${title} — ${SITE_TITLE}`,
	url: new URL('/slovar/', Astro.site).toString(),
	inLanguage: 'ru-RU',
	hasDefinedTerm: sorted.map((entry) => ({
		'@type': 'DefinedTerm',
		'@id': new URL(
			`/slovar/#${termSlug(entry.data.term)}`,
			Astro.site,
		).toString(),
		name: entry.data.term,
		alternateName: entry.data.aliases,
		description: entry.data.summary,
		inDefinedTermSet: new URL('/slovar/', Astro.site).toString(),
	})),
};
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead
			title={title}
			description={description}
			jsonLd={[breadcrumbsJsonLd, definedTermSetJsonLd]}
		/>
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumbs" aria-label="Хлебные крошки">
				<a href="/">Главная</a>
				<span>›</span>
				<span aria-current="page">{title}</span>
			</nav>

			<header class="page-head">
				<h1>{title}</h1>
				<p>{description}</p>
			</header>

			{letters.length > 1 && (
				<nav class="alphabet" aria-label="Алфавитный навигатор">
					{letters.map((letter) => (
						<a class="alpha-link" href={`#letter-${letter}`}>{letter}</a>
					))}
				</nav>
			)}

			<div class="terms">
				{Array.from(grouped.entries()).map(([letter, items]) => (
					<section class="letter-section" aria-labelledby={`letter-${letter}`}>
						<h2 class="letter-head" id={`letter-${letter}`}>{letter}</h2>
						{items.map((entry) => {
							const slug = termSlug(entry.data.term);
							const cat = entry.data.category;
							const catMeta = cat ? CATEGORIES[cat] : null;
							const Body = bodyById.get(entry.id);
							return (
								<article class="term" id={slug}>
									<header class="term-head">
										<h3>
											<a href={`#${slug}`}>{entry.data.term}</a>
										</h3>
										{catMeta && (
											<a class="term-cat" href={`/category/${cat}/`}>
												{catMeta.title}
											</a>
										)}
									</header>
									{entry.data.aliases.length > 0 && (
										<p class="term-aliases">
											Также: {entry.data.aliases.join(', ')}
										</p>
									)}
									<div class="term-body prose">
										{Body && <Body />}
									</div>
									{entry.data.relatedLinks.length > 0 && (
										<ul class="term-links">
											{entry.data.relatedLinks.map((link) => (
												<li>
													<a href={link.url}>{link.label} →</a>
												</li>
											))}
										</ul>
									)}
								</article>
							);
						})}
					</section>
				))}
			</div>
		</main>
		<Footer />

		<style>
			.breadcrumbs {
				font-size: 0.88rem;
				color: rgb(var(--gray));
				margin-top: 1rem;
			}
			.breadcrumbs a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumbs a:hover {
				color: var(--accent);
			}
			.breadcrumbs span {
				margin: 0 0.4em;
			}
			.page-head {
				padding: 1.5rem 0 1rem;
				max-width: 820px;
			}
			.page-head p {
				color: rgb(var(--gray-dark));
				font-size: 1.05rem;
			}
			.alphabet {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				margin: 1rem 0 2rem;
			}
			.alpha-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-width: 2.2rem;
				height: 2.2rem;
				padding: 0 0.5rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 6px;
				color: rgb(var(--gray-dark));
				text-decoration: none;
				font-weight: 600;
				font-size: 0.95rem;
			}
			.alpha-link:hover {
				border-color: var(--accent);
				color: var(--accent);
				background: var(--accent-soft);
			}
			.terms {
				max-width: 820px;
			}
			.letter-section {
				margin-top: 2rem;
			}
			.letter-head {
				font-size: 2rem;
				color: var(--accent);
				border-bottom: 2px solid var(--accent-soft);
				padding-bottom: 0.3rem;
				margin-bottom: 1rem;
				scroll-margin-top: 80px;
			}
			.term {
				padding: 1.2rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
				scroll-margin-top: 80px;
			}
			.term:last-child {
				border-bottom: none;
			}
			.term-head {
				display: flex;
				flex-wrap: wrap;
				align-items: baseline;
				justify-content: space-between;
				gap: 0.6rem;
				margin-bottom: 0.4rem;
			}
			.term-head h3 {
				margin: 0;
				font-size: 1.3rem;
				color: rgb(var(--black));
			}
			.term-head h3 a {
				color: inherit;
				text-decoration: none;
			}
			.term-head h3 a:hover {
				color: var(--accent);
			}
			.term-cat {
				font-size: 0.82rem;
				font-weight: 600;
				color: var(--accent);
				background: var(--accent-soft);
				padding: 0.2em 0.7em;
				border-radius: 999px;
				text-decoration: none;
			}
			.term-cat:hover {
				background: var(--accent);
				color: #fff;
			}
			.term-aliases {
				font-size: 0.9rem;
				color: rgb(var(--gray));
				font-style: italic;
				margin: 0 0 0.6rem;
			}
			.term-body {
				margin: 0;
			}
			.term-body :global(p:last-child) {
				margin-bottom: 0;
			}
			.term-links {
				list-style: none;
				padding: 0;
				margin: 0.8rem 0 0;
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem 1.2rem;
			}
			.term-links a {
				font-size: 0.92rem;
				color: var(--accent);
				text-decoration: none;
				font-weight: 600;
			}
			.term-links a:hover {
				text-decoration: underline;
			}
		</style>
	</body>
</html>
