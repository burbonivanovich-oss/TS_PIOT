---
import { getCollection, getEntry } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES, SITE_TITLE } from '../../consts';
import { u } from '../../utils/url';

export async function getStaticPaths() {
	return Object.entries(CATEGORIES).map(([slug, meta]) => ({
		params: { category: slug },
		props: { slug, meta },
	}));
}

type Props = {
	slug: string;
	meta: (typeof CATEGORIES)[keyof typeof CATEGORIES];
};

const { slug, meta } = Astro.props as Props;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
	.filter((p) => p.data.categories.includes(slug))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pillar = await getEntry('pillars', slug);
const pillarTitle = pillar?.data?.title ?? meta.fullTitle;
const pillarSummary = pillar?.data?.summary ?? meta.description;
const faq = pillar?.data?.faq ?? [];

const CAT_COLOR: Record<string, string> = {
	'ts-piot':         '#111',
	'markirovka':      '#9E2B4F',
	'zakonodatelstvo': '#1E4A7A',
	'kkt':             '#5A3E7A',
	'egais':           '#1A5C3A',
};
const accentColor = CAT_COLOR[slug] ?? '#111';

function fmtDate(d: Date): string {
	return d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' });
}

const collectionJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: `${meta.title} — ${SITE_TITLE}`,
	description: pillarSummary,
	url: new URL(`/category/${slug}/`, Astro.site).toString(),
	inLanguage: 'ru-RU',
};

const breadcrumbsJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Главная',
			item: new URL('/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Статьи',
			item: new URL('/blog/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: meta.title,
			item: new URL(`/category/${slug}/`, Astro.site).toString(),
		},
	],
};

const faqJsonLd =
	faq.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'FAQPage',
				mainEntity: faq.map((item) => ({
					'@type': 'Question',
					name: item.question,
					acceptedAnswer: {
						'@type': 'Answer',
						text: item.answer,
					},
				})),
			}
		: null;

const jsonLd: Record<string, unknown>[] = [collectionJsonLd, breadcrumbsJsonLd];
if (faqJsonLd) jsonLd.push(faqJsonLd);
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={pillarTitle} description={pillarSummary} jsonLd={jsonLd} />
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumbs" aria-label="Хлебные крошки">
				<a href={u("/")}>Главная</a>
				<span>›</span>
				<a href={u("/blog/")}>Статьи</a>
				<span>›</span>
				<span aria-current="page">{meta.title}</span>
			</nav>

			<header class="page-head">
				<div class="page-eyebrow" style={`background:${accentColor}`}>{meta.title}</div>
				<h1 class="page-title">{pillarTitle}</h1>
				<p class="page-lead">{pillarSummary}</p>
			</header>

			{posts.length === 0 ? (
				<p class="empty">
					Материалы в этом разделе скоро появятся.
					<a href={u("/blog/")}>Посмотрите все статьи</a>.
				</p>
			) : (
				<section class="posts-section" aria-label="Материалы раздела">
					{/* Featured card — first post */}
					{posts[0] && (() => {
						const post = posts[0];
						const img = post.data.previewImage ?? post.data.heroImage ?? null;
						return (
							<a href={u(`/blog/${post.id}/`)} class="post-card post-card--featured">
								<div class="post-card-img" style={`--accent:${accentColor}`}>
									{img
										? <img src={u(img)} alt={post.data.title} loading="eager" />
										: <span class="post-card-placeholder" style={`background:${accentColor}`}></span>
									}
								</div>
								<div class="post-card-body">
									<span class="post-card-cat" style={`background:${accentColor};color:#fff`}>{meta.title}</span>
									<div class="post-card-title">{post.data.title}</div>
									{post.data.description && (
										<div class="post-card-desc">{post.data.description}</div>
									)}
									<div class="post-card-meta">{fmtDate(post.data.pubDate)}</div>
								</div>
							</a>
						);
					})()}

					{/* Grid — remaining posts */}
					{posts.length > 1 && (
						<div class="posts-grid">
							{posts.slice(1).map((post) => {
								const img = post.data.previewImage ?? post.data.heroImage ?? null;
								return (
									<a href={u(`/blog/${post.id}/`)} class="post-card">
										<div class="post-card-img" style={`--accent:${accentColor}`}>
											{img
												? <img src={u(img)} alt={post.data.title} loading="lazy" />
												: <span class="post-card-placeholder" style={`background:${accentColor}`}></span>
											}
										</div>
										<div class="post-card-body">
											<span class="post-card-cat" style={`background:${accentColor};color:#fff`}>{meta.title}</span>
											<div class="post-card-title">{post.data.title}</div>
											<div class="post-card-meta">{fmtDate(post.data.pubDate)}</div>
										</div>
									</a>
								);
							})}
						</div>
					)}
				</section>
			)}
		</main>
		<Footer />

		<style>
			main {
				padding: 48px 32px 80px;
				max-width: 1280px;
				margin: 0 auto;
			}

			.breadcrumbs {
				font-size: .7rem;
				font-weight: 600;
				letter-spacing: .08em;
				text-transform: uppercase;
				color: #999;
				margin-bottom: 32px;
			}
			.breadcrumbs a {
				color: #999;
				text-decoration: none;
			}
			.breadcrumbs a:hover { color: #111; }
			.breadcrumbs span { margin: 0 0.4em; }

			.page-head {
				padding-bottom: 40px;
				border-bottom: 1px solid rgba(0,0,0,.12);
				margin-bottom: 40px;
				max-width: 820px;
			}
			.page-eyebrow {
				display: inline-block;
				font-size: .65rem;
				font-weight: 700;
				letter-spacing: .12em;
				text-transform: uppercase;
				padding: 4px 8px;
				color: #fff;
				margin-bottom: 16px;
			}
			.page-title {
				font-family: 'Bebas Neue', sans-serif;
				font-size: clamp(2.2rem, 4vw, 3.8rem);
				line-height: .95;
				letter-spacing: .02em;
				color: #111;
				text-transform: uppercase;
				margin: 0 0 16px;
			}
			.page-lead {
				font-size: 1rem;
				color: #555;
				line-height: 1.65;
				margin: 0;
			}

			.empty {
				color: #666;
				padding: 2rem 0;
			}
			.empty a { color: #111; }

			/* Featured card */
			.post-card--featured {
				display: flex;
				flex-direction: row;
				background: #fff;
				border: 1px solid rgba(0,0,0,.08);
				text-decoration: none;
				color: #111;
				margin-bottom: 8px;
				transition: box-shadow .15s, transform .15s;
			}
			.post-card--featured:hover {
				box-shadow: 0 4px 20px rgba(0,0,0,.1);
				transform: translateY(-2px);
			}
			.post-card--featured { align-items: stretch; }
			.post-card--featured .post-card-img {
				width: 58%;
				flex-shrink: 0;
				min-height: 320px;
				overflow: hidden;
			}
			.post-card--featured .post-card-body {
				padding: 32px 36px;
				display: flex;
				flex-direction: column;
				justify-content: flex-start;
			}
			.post-card--featured .post-card-title {
				font-size: clamp(1.6rem, 2.5vw, 2.4rem);
				margin-bottom: 14px;
			}
			.post-card--featured .post-card-desc {
				font-size: .95rem;
				line-height: 1.6;
				color: #444;
			}

			/* Grid cards */
			.posts-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 8px;
			}
			.post-card {
				background: #fff;
				display: flex;
				flex-direction: column;
				text-decoration: none;
				color: #111;
				border: 1px solid rgba(0,0,0,.08);
				transition: box-shadow .15s, transform .15s;
			}
			.post-card:hover {
				box-shadow: 0 4px 20px rgba(0,0,0,.1);
				transform: translateY(-2px);
			}
			.post-card-img {
				width: 100%;
				aspect-ratio: 16/9;
				overflow: hidden;
				position: relative;
				background: var(--accent, #111);
			}
			.post-card-img img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.post-card-placeholder {
				display: block;
				width: 100%;
				height: 100%;
			}
			.post-card-body {
				padding: 20px;
				flex: 1;
				display: flex;
				flex-direction: column;
			}
			.post-card-cat {
				display: inline-block;
				font-size: .6rem;
				font-weight: 700;
				letter-spacing: .12em;
				text-transform: uppercase;
				padding: 3px 8px;
				margin-bottom: 10px;
				align-self: flex-start;
			}
			.post-card-title {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.45rem;
				line-height: 1.05;
				letter-spacing: .02em;
				text-transform: uppercase;
				color: #111;
				flex: 1;
				margin-bottom: 8px;
			}
			.post-card-desc {
				font-size: .88rem;
				color: #555;
				line-height: 1.55;
				margin-bottom: 12px;
			}
			.post-card-meta {
				font-size: .65rem;
				letter-spacing: .08em;
				text-transform: uppercase;
				color: #aaa;
				margin-top: auto;
			}

			@media (max-width: 960px) {
				.post-card--featured { flex-direction: column; }
				.post-card--featured .post-card-img { width: 100%; }
			}
			@media (max-width: 820px) {
				main { padding: 32px 20px 60px; }
				.posts-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
			}
			@media (max-width: 560px) {
				main { padding: 24px 16px 48px; }
				.posts-grid { grid-template-columns: 1fr; }
			}
		</style>
	</body>
</html>
