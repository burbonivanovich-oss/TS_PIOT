---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import ScenarioChecklist, { type ScenarioPhase } from '../../components/interactive/ScenarioChecklist.tsx';
import RoiIpVsOoo from '../../components/interactive/RoiIpVsOoo.tsx';
import { u } from '../../utils/url';

const title = 'Переход с ИП на ООО за 60 дней: пошаговый план';
const description =
	'Когда ИП становится тесным и нужно ООО: от просчёта выгоды до закрытия ИП. 25 задач в 6 фазах + калькулятор разницы налоговой нагрузки.';

const phases: ScenarioPhase[] = [
	{
		id: 'decision',
		name: '1. Решение и стратегия',
		color: 'pink',
		tasks: [
			{
				id: 'roi',
				day: 'День 1–3',
				title: 'Просчитать разницу налоговой нагрузки ИП vs ООО',
				detail: 'Калькулятор ниже показывает порядок цифр. С бухгалтером считайте под свою структуру доходов, льгот и зарплат.',
			},
			{
				id: 'why',
				day: 'День 3',
				title: 'Зафиксировать причину перехода',
				detail: 'Партнёрство, выход на тендеры, ограничение ответственности, получение лицензии. Без чёткого «зачем» переход обычно не оправдан — у ИП проще учёт и меньше взносов.',
			},
			{
				id: 'structure',
				day: 'День 4',
				title: 'Определить структуру: один учредитель или несколько',
				detail: 'Один учредитель — единственный возможный директор. Несколько — нужен корпоративный договор и распределение долей.',
			},
			{
				id: 'name',
				day: 'День 5',
				title: 'Выбрать название и проверить уникальность',
				detail: 'Через сервис «Прозрачный бизнес» ФНС. Полное и сокращённое наименование. Запрещены слова «Россия», «федеральный» и т. п. без разрешения.',
			},
			{
				id: 'docs',
				day: 'День 6–7',
				title: 'Подготовить пакет документов для регистрации',
				detail: 'Устав, решение единственного учредителя или протокол, заявление Р11001, госпошлина (бесплатно через Госуслуги с УКЭП).',
			},
		],
	},
	{
		id: 'register',
		name: '2. Регистрация ООО',
		color: 'lime',
		tasks: [
			{
				id: 'submit',
				day: 'День 8',
				title: 'Подать документы на регистрацию ООО',
				detail: 'Через Госуслуги с электронной подписью — бесплатно. Через нотариуса — пошлина 4000 ₽.',
			},
			{
				id: 'usn',
				day: 'День 8',
				title: 'Подать заявление о применении УСН вместе с регистрацией',
				detail: 'Форма 26.2-1. Если не подать в течение 30 дней после регистрации — окажетесь на ОСН с НДС 20%.',
				link: { href: '/blog/2026-03-05-nalogi-msb-2026/', label: 'Что выбрать: УСН-Д или УСН-Д-Р' },
			},
			{
				id: 'wait',
				day: 'День 9–11',
				title: 'Получить лист записи ЕГРЮЛ',
				detail: 'Срок регистрации — 3 рабочих дня. Лист записи, устав с отметкой, свидетельство о постановке на учёт. Всё в электронном виде на Госуслугах.',
			},
			{
				id: 'bank-ooo',
				day: 'День 12–14',
				title: 'Открыть расчётный счёт ООО в банке',
				detail: 'Сравните комиссии за РКО и интернет-эквайринг. Многие банки открывают счёт за день при наличии листа записи ЕГРЮЛ.',
			},
			{
				id: 'pechat',
				day: 'День 13–15',
				title: 'Решить вопрос с печатью',
				detail: 'ООО не обязано иметь печать с 2015 года, но многие контрагенты её просят. Если печать есть — упомяните это в уставе.',
			},
		],
	},
	{
		id: 'parallel',
		name: '3. Параллельная работа ИП и ООО',
		color: 'sand',
		tasks: [
			{
				id: 'inform',
				day: 'День 16–18',
				title: 'Уведомить ключевых клиентов о смене юрлица',
				detail: 'Письма с реквизитами ООО. Договорённость, что с такого-то числа платежи идут на счёт ООО.',
			},
			{
				id: 'contracts',
				day: 'День 19–25',
				title: 'Перезаключить договоры с поставщиками и арендодателем',
				detail: 'Самый трудозатратный этап. Часть договоров — допсоглашение о переуступке. Часть — новые с ООО. Аренда обычно требует нового договора.',
			},
			{
				id: 'kkt-ooo',
				day: 'День 20–23',
				title: 'Зарегистрировать ККТ от имени ООО',
				detail: 'В личном кабинете на nalog.gov.ru. Касса от ИП должна быть перерегистрирована — на физическом устройстве сменится регистрационный номер.',
			},
			{
				id: 'ofd-ooo',
				day: 'День 22–24',
				title: 'Подключить ОФД и ЭДО для ООО',
				detail: 'Договор с ОФД от имени ООО. ЭДО для приёмки УПД — обязательно, если работаете с маркированным товаром.',
				link: { href: '/kak-rabotaet-ts-piot/', label: 'Как работает ТС ПИоТ' },
			},
			{
				id: 'tspot-ooo',
				day: 'День 23–25',
				title: 'Проверить, что ТС ПИоТ работает на кассе после перерегистрации',
				detail: 'Прогнать тестовую продажу маркированного товара под учётной записью ООО. Касса должна формировать чек с тегами 1163 + 2106.',
			},
		],
	},
	{
		id: 'transfer',
		name: '4. Перевод операционной деятельности',
		color: 'pink',
		tasks: [
			{
				id: 'staff',
				day: 'День 26–32',
				title: 'Решить вопрос с сотрудниками',
				detail: 'Если у ИП были работники: увольнение из ИП по соглашению сторон + приём в ООО. Со страхом потери стажа сотрудники соглашаются неохотно — лучше готовить заранее.',
			},
			{
				id: 'inventory',
				day: 'День 28–32',
				title: 'Решить судьбу остатков товара ИП',
				detail: 'Вариант A: распродать через ИП. Вариант B: продать ООО по договору, оформить как ввод в оборот через ЧЗ. Маркированные коды требуют корректной передачи в ЭДО.',
			},
			{
				id: 'subs',
				day: 'День 30–35',
				title: 'Перевести подписки и сервисы на ООО',
				detail: 'Домен, хостинг, бухгалтерия, эквайринг, рассылки, реклама. Часть сервисов требует перерегистрации, часть — просто смены реквизитов.',
			},
			{
				id: 'rent',
				day: 'День 32–38',
				title: 'Перевести аренду помещения на ООО',
				detail: 'Расторгнуть договор ИП и подписать новый с ООО. Депозит переоформить — или вернуть и внести заново.',
			},
			{
				id: 'fully-ooo',
				day: 'День 35–45',
				title: 'Перевести 100% продаж через ООО',
				detail: 'Все новые чеки только через кассу ООО. ИП оставляем для закрытия — никаких новых операций.',
			},
		],
	},
	{
		id: 'close',
		name: '5. Закрытие ИП',
		color: 'lime',
		tasks: [
			{
				id: 'declar',
				day: 'День 46–48',
				title: 'Сдать декларацию УСН за период работы ИП',
				detail: 'За период с 1 января по дату подачи заявления о закрытии. Можно через ЛК налогоплательщика на nalog.gov.ru.',
			},
			{
				id: 'pay',
				day: 'День 48–50',
				title: 'Уплатить все налоги и взносы ИП',
				detail: 'УСН по декларации, фиксированные взносы пропорционально месяцам, дополнительные взносы 1% если оборот > 300 тыс ₽.',
			},
			{
				id: 'r26001',
				day: 'День 50–52',
				title: 'Подать заявление на закрытие ИП (Р26001)',
				detail: 'Через Госуслуги с УКЭП — бесплатно. Через нотариуса — пошлина 160 ₽. Срок закрытия — 5 рабочих дней.',
			},
			{
				id: 'list',
				day: 'День 53–55',
				title: 'Получить лист записи о прекращении деятельности ИП',
				detail: 'Электронно на Госуслугах. Снятие с учёта в ПФР и ФОМС происходит автоматически — отдельных заявлений не нужно.',
			},
		],
	},
	{
		id: 'finalize',
		name: '6. Финализация и контроль',
		color: 'dark',
		tasks: [
			{
				id: 'close-account',
				day: 'День 56–57',
				title: 'Закрыть расчётный счёт ИП после получения листа записи',
				detail: 'Заявление в банке. До закрытия — убедиться, что не висят непогашенные платежи и все возвраты прошли.',
			},
			{
				id: 'reconcile',
				day: 'День 57–58',
				title: 'Запросить акт сверки с ФНС',
				detail: 'Чтобы убедиться, что налоги и взносы зачлись и переплат/недоплат нет. Через ЛК налогоплательщика.',
			},
			{
				id: 'archive',
				day: 'День 58',
				title: 'Архивировать документы ИП минимум на 4 года',
				detail: 'Налоговая декларация, книга учёта доходов, договоры, банковские выписки. По НК РФ срок хранения — 4 года, по архивному праву — до 5 лет.',
			},
			{
				id: 'mark-week',
				day: 'День 59–60',
				title: 'Провести «контрольную неделю» работы ООО',
				detail: 'Все процессы под новым юрлицом — продажи, приёмка, учёт, выплата зарплат. Если что-то ломается — фиксируйте и исправляйте сразу, пока ИП ещё в памяти.',
			},
		],
	},
];
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		<main class="scenario-page">
			<article>
				<header class="scenario-hero">
					<p class="scenario-eyebrow">Сценарный гайд · 60 дней</p>
					<h1>{title}</h1>
					<p class="scenario-lead">
						Переход с ИП на ООО — не «закрыл одно, открыл другое», а длинная
						операция с пересадкой клиентов, поставщиков, кассы, ЭДО и сотрудников.
						Тут 25 задач в 6 фазах. Идём параллельно: пока ООО подключается,
						ИП продолжает работать, а в конце ИП аккуратно закрываем.
					</p>
					<p class="scenario-lead">
						Перед стартом — прикиньте, оправдан ли переход вообще.
					</p>
				</header>

				<section class="scenario-roi">
					<h2>Сначала посчитайте: выгодно ли вам переходить</h2>
					<p>
						Для большинства МСБ ИП остаётся выгоднее, чем ООО, — главные причины
						перехода обычно не финансовые: партнёрство, лицензии, тендеры,
						ограничение личной ответственности. Калькулятор показывает, во
						сколько обойдётся ООО относительно ИП на ваших цифрах.
					</p>
					<RoiIpVsOoo client:visible />
				</section>

				<section class="scenario-checklist">
					<h2>План на 60 дней</h2>
					<ScenarioChecklist
						storageKey="scenario-ip-ooo-60"
						trackPrefix="scenario-ip-ooo"
						phases={phases}
						client:load
					/>
				</section>

				<section class="scenario-foot">
					<h2>Связанное</h2>
					<ul>
						<li><a href={u('/scenario/kofeynya-za-30-dney/')}>Открываю кофейню за 30 дней — для тех, кто стартует с нуля</a></li>
						<li><a href={u('/blog/2026-03-05-nalogi-msb-2026/')}>Налоги для МСБ в 2026: УСН, НДС, патент</a></li>
						<li><a href={u('/test-ts-piot/')}>Тест: готов ли ваш бизнес к ТС ПИоТ</a></li>
						<li><a href={u('/kak-rabotaet-ts-piot/')}>Как работает ТС ПИоТ — пошаговый разбор</a></li>
					</ul>
				</section>
			</article>
		</main>

		<Footer />

		<style>
			.scenario-page {
				max-width: 860px;
				margin: 0 auto;
				padding: 2rem 1rem 4rem;
			}
			.scenario-hero { margin-bottom: 2.5rem; }
			.scenario-eyebrow {
				font-size: 0.85rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--pink, #ff4d8f);
				margin: 0 0 0.5rem;
			}
			.scenario-hero h1 {
				font-size: clamp(1.5rem, 4vw, 2.2rem);
				line-height: 1.15;
				margin: 0 0 1rem;
			}
			.scenario-lead {
				font-size: 1.05rem;
				line-height: 1.55;
				color: #333;
				margin: 0 0 0.85rem;
			}
			.scenario-roi,
			.scenario-checklist { margin-bottom: 3rem; }
			.scenario-roi h2,
			.scenario-checklist h2 {
				font-size: 1.4rem;
				margin: 0 0 0.75rem;
			}
			.scenario-roi p {
				color: #444;
				line-height: 1.55;
				margin: 0 0 1.25rem;
			}
			.scenario-foot {
				padding: 1.5rem;
				background: var(--sand, #f4ebd9);
				border-radius: 12px;
			}
			.scenario-foot h2 {
				margin: 0 0 0.75rem;
				font-size: 1.2rem;
			}
			.scenario-foot ul {
				margin: 0;
				padding-left: 1.25rem;
				line-height: 1.85;
			}
			.scenario-foot a {
				color: var(--pink, #ff4d8f);
				font-weight: 500;
			}
		</style>
	</body>
</html>
