---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import ScenarioChecklist, { type ScenarioPhase } from '../../components/interactive/ScenarioChecklist.tsx';
import { u } from '../../utils/url';

const title = 'Открываю кофейню за 30 дней: пошаговый план';
const description =
	'Что и когда делать, чтобы открыть кофейню за месяц. 30 задач разбиты на 6 фаз — от концепции до первого чека. Отмечайте сделанное — прогресс сохраняется в браузере.';

const phases: ScenarioPhase[] = [
	{
		id: 'concept',
		name: '1. Концепция и расчёты',
		color: 'pink',
		tasks: [
			{
				id: 'idea',
				day: 'День 1–2',
				title: 'Зафиксировать концепцию: формат, средний чек, целевая аудитория',
				detail: 'Кофейня с собой, кофейня-кондитерская, с/без посадки. От этого зависят площадь, оборудование и СанПиН.',
			},
			{
				id: 'unit-econ',
				day: 'День 2–3',
				title: 'Посчитать юнит-экономику',
				detail: 'Себестоимость напитка, аренда, ФОТ, налоги. Цель — понять точку безубыточности по чекам в день.',
			},
			{
				id: 'budget',
				day: 'День 3',
				title: 'Свести общий бюджет на старт',
				detail: 'Оборудование, ремонт, депозит за аренду, первая закупка, маркетинг, резерв на 2 месяца. Без резерва открываться рискованно.',
			},
		],
	},
	{
		id: 'register',
		name: '2. Регистрация и налоги',
		color: 'lime',
		tasks: [
			{
				id: 'form',
				day: 'День 4',
				title: 'Выбрать форму: ИП или ООО',
				detail: 'Для одиночной точки чаще ИП — проще, дешевле взносы. ООО — если будут партнёры или планируется сеть.',
			},
			{
				id: 'tax-regime',
				day: 'День 4',
				title: 'Выбрать систему налогообложения',
				detail: 'УСН «Доходы» 6% — для кофейни без больших расходов на материалы. УСН «Доходы–Расходы» 15% — если расходы > 60% от выручки.',
				link: { href: '/blog/2026-03-05-nalogi-msb-2026/', label: 'Подробно об УСН и НДС в 2026' },
			},
			{
				id: 'register-fns',
				day: 'День 5–7',
				title: 'Зарегистрировать ИП или ООО через Госуслуги',
				detail: 'Срок регистрации — 3 рабочих дня. Уведомление о начале деятельности в Роспотребнадзор подаётся отдельно.',
			},
			{
				id: 'okved',
				day: 'День 5',
				title: 'Подобрать ОКВЭДы: 56.10, 56.30, 47.11',
				detail: 'Минимум один основной + дополнительные. Лучше указать с запасом — добавление позже потребует визита в налоговую.',
			},
			{
				id: 'bank',
				day: 'День 6–7',
				title: 'Открыть расчётный счёт в банке',
				detail: 'Сравните комиссии за эквайринг — для кофейни это главная статья банковских расходов.',
			},
		],
	},
	{
		id: 'location',
		name: '3. Помещение и разрешения',
		color: 'sand',
		tasks: [
			{
				id: 'search',
				day: 'День 8–10',
				title: 'Найти помещение и согласовать условия аренды',
				detail: 'Проверьте: мощность электричества (от 15 кВт), наличие вентиляции и подвода воды, разрешённый трафик в районе.',
			},
			{
				id: 'lease',
				day: 'День 10–12',
				title: 'Подписать договор аренды',
				detail: 'На срок от 11 месяцев — иначе нужна госрегистрация. Зафиксируйте право подключения вывески и условия выхода.',
			},
			{
				id: 'sanpin',
				day: 'День 11',
				title: 'Изучить требования СанПиН 2.3/2.4.3590-20',
				detail: 'Зона выдачи, мойка посуды, журнал учёта температуры, программа производственного контроля.',
			},
			{
				id: 'fire',
				day: 'День 12',
				title: 'Подать уведомление о начале деятельности',
				detail: 'Через Госуслуги в Роспотребнадзор и в МЧС (пожарный надзор). Без уведомлений работать нельзя.',
			},
		],
	},
	{
		id: 'equipment',
		name: '4. Оборудование и поставщики',
		color: 'pink',
		tasks: [
			{
				id: 'coffee-machine',
				day: 'День 13–16',
				title: 'Заказать кофемашину, кофемолку, холодильное оборудование',
				detail: 'Профессиональная двухгруппная кофемашина — основная статья расходов. Выбирайте под планируемый поток чеков.',
			},
			{
				id: 'pos',
				day: 'День 15–17',
				title: 'Выбрать кассу с модулем ТС ПИоТ',
				detail: 'С 28.12.2025 ТС ПИоТ обязателен для всех касс, через которые идёт маркированный товар (молочка, бутилированные напитки).',
				link: { href: '/kak-rabotaet-ts-piot/', label: 'Как работает ТС ПИоТ — наглядно' },
			},
			{
				id: 'supplies',
				day: 'День 18–20',
				title: 'Договориться с поставщиками: зерно, молоко, сиропы, посуда',
				detail: 'Несколько поставщиков по каждой категории — на случай срыва поставки. Молоко и сливки — маркированный товар, поставщик должен передавать УПД с кодами.',
			},
			{
				id: 'edo',
				day: 'День 20–22',
				title: 'Подключить ЭДО для приёмки УПД от поставщиков молочки',
				detail: 'Электронный документооборот с кодами маркировки — обязателен для приёмки молочной продукции. Без ЭДО товар легально не оприходовать.',
			},
		],
	},
	{
		id: 'people',
		name: '5. Персонал и оформление',
		color: 'lime',
		tasks: [
			{
				id: 'hire',
				day: 'День 21–24',
				title: 'Найти и оформить бариста (1–2 человека)',
				detail: 'Если планируете полную смену — нужно 2 человека на ставку. Сначала ГПД или испытательный срок — это нормально.',
			},
			{
				id: 'med',
				day: 'День 23–25',
				title: 'Оформить медкнижки и пройти медосмотр',
				detail: 'Обязательное требование для работников общепита. Без действующей медкнижки сотрудник работать не может.',
			},
			{
				id: 'kedo',
				day: 'День 24–26',
				title: 'Решить вопрос с КЭДО или бумажным документооборотом',
				detail: 'КЭДО позволяет подписывать кадровые документы электронно — удобно, если бариста меняются часто.',
				link: { href: '/blog/2026-03-05-nalogi-msb-2026/', label: 'Где КЭДО обязательно, а где нет' },
			},
			{
				id: 'buh',
				day: 'День 25–26',
				title: 'Подключить бухгалтерское сопровождение',
				detail: 'Аутсорс для ИП на УСН-Д — от 2000 ₽/мес. Самостоятельная сдача — теоретически возможна, на практике быстро становится неудобно.',
			},
		],
	},
	{
		id: 'launch',
		name: '6. Запуск и маркетинг',
		color: 'dark',
		tasks: [
			{
				id: 'kkt-fns',
				day: 'День 27',
				title: 'Зарегистрировать ККТ в ФНС и подключить ОФД',
				detail: 'Через личный кабинет на nalog.gov.ru. ОФД выбирается из списка аккредитованных — Платформа ОФД, Такском, Контур.ОФД.',
			},
			{
				id: 'marking-test',
				day: 'День 27–28',
				title: 'Прогнать тестовую продажу маркированного товара',
				detail: 'Просканируйте код на пачке молока. Касса должна отправить запрос в «Честный знак» и сформировать чек с тегом 1163.',
			},
			{
				id: 'menu',
				day: 'День 28',
				title: 'Сформировать меню с фотографиями и ценами',
				detail: 'Печатное меню, ламинированные таблички у кассы. Двуязычное — если район туристический.',
			},
			{
				id: 'social',
				day: 'День 28–29',
				title: 'Завести соцсети и Яндекс-карты',
				detail: 'Telegram-канал, VK или Дзен. Без Яндекс-карт и 2GIS вас не найдут в новом районе.',
			},
			{
				id: 'soft-launch',
				day: 'День 29',
				title: 'Сделать «мягкий запуск» для друзей и соседей',
				detail: 'Бесплатный кофе для первых 50 человек — обратная связь и стартовая лояльность. Соберите контакты.',
			},
			{
				id: 'launch',
				day: 'День 30',
				title: 'Открыть кофейню официально',
				detail: 'Первый рабочий день: проверьте все процессы — приёмку, чеки, выдачу. Не делайте сложные напитки в первую неделю.',
			},
		],
	},
];
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		<main class="scenario-page">
			<article>
				<header class="scenario-hero">
					<p class="scenario-eyebrow">Сценарный гайд · 30 дней</p>
					<h1>{title}</h1>
					<p class="scenario-lead">
						Реалистичный план для одного человека или пары без опыта общепита.
						30 задач, разбитых на 6 фаз: от концепции до первого чека. Это не
						юридическая консультация — это roadmap, по которому вы поймёте,
						что когда делать и где не ошибиться.
					</p>
					<p class="scenario-lead">
						Отмечайте задачи галочками — прогресс сохраняется в вашем браузере.
						Вернувшись завтра, увидите, на каком шаге остановились.
					</p>
				</header>

				<ScenarioChecklist
					storageKey="scenario-kofeynya-30"
					trackPrefix="scenario-kofeynya"
					phases={phases}
					client:load
				/>

				<section class="scenario-foot">
					<h2>Что почитать параллельно</h2>
					<ul>
						<li><a href={u('/kak-rabotaet-ts-piot/')}>Как работает ТС ПИоТ — пошаговый разбор пути чека</a></li>
						<li><a href={u('/blog/2026-03-05-nalogi-msb-2026/')}>Налоги для МСБ в 2026: УСН, НДС, патент</a></li>
						<li><a href={u('/zakon-2026/')}>Журнал изменений законодательства 2026</a></li>
						<li><a href={u('/kalkulyator-shtrafov/')}>Калькулятор штрафов — что грозит за нарушения</a></li>
					</ul>
				</section>
			</article>
		</main>

		<Footer />

		<style>
			.scenario-page {
				max-width: 860px;
				margin: 0 auto;
				padding: 2rem 1rem 4rem;
			}
			.scenario-hero {
				margin-bottom: 2rem;
			}
			.scenario-eyebrow {
				font-size: 0.85rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--pink, #ff4d8f);
				margin: 0 0 0.5rem;
			}
			.scenario-hero h1 {
				font-size: clamp(1.5rem, 4vw, 2.2rem);
				line-height: 1.15;
				margin: 0 0 1rem;
			}
			.scenario-lead {
				font-size: 1.05rem;
				line-height: 1.55;
				color: #333;
				margin: 0 0 0.85rem;
			}
			.scenario-foot {
				margin-top: 3rem;
				padding: 1.5rem;
				background: var(--sand, #f4ebd9);
				border-radius: 12px;
			}
			.scenario-foot h2 {
				margin: 0 0 0.75rem;
				font-size: 1.2rem;
			}
			.scenario-foot ul {
				margin: 0;
				padding-left: 1.25rem;
				line-height: 1.85;
			}
			.scenario-foot a {
				color: var(--pink, #ff4d8f);
				font-weight: 500;
			}
		</style>
	</body>
</html>
