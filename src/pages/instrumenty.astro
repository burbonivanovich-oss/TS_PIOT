---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { u } from '../utils/url';

const title = 'Инструменты и интерактивы — Этикетка';
const description =
	'Симуляторы, калькуляторы, тесты и сценарии для МСБ: путь чека через ТС ПИоТ, проверка готовности к маркировке, штрафы, налоги, открытие бизнеса.';

interface Tool {
	href: string;
	eyebrow: string;
	title: string;
	description: string;
	cta: string;
	color: string;
	icon: string;
	featured?: boolean;
}

const tools: Tool[] = [
	{
		href: '/kak-rabotaet-ts-piot/',
		eyebrow: 'Интерактивный лонгрид · 7 шагов',
		title: 'Как живёт чек в ТС ПИоТ',
		description:
			'Пошаговый разбор: от сканирования DataMatrix до отметки «выведен из оборота» в Честном знаке. 7 секций с интерактивами и иллюстрациями.',
		cta: 'Пройти симулятор',
		color: '#FF4D8F',
		icon: 'ТС',
		featured: true,
	},
	{
		href: '/test-ts-piot/',
		eyebrow: 'Тест · 6 вопросов · 2 минуты',
		title: 'Готов ли ваш бизнес к ТС ПИоТ',
		description:
			'Ветвящийся квиз: ответы определяют, какие пробелы у вас в готовности к разрешительному режиму. На выходе — план действий со ссылками.',
		cta: 'Пройти тест',
		color: '#1E4A7A',
		icon: 'ТЕСТ',
	},
	{
		href: '/test-tsepochka-edo/',
		eyebrow: 'Тренажёр · 7 карточек',
		title: 'Соберите цепочку ЭДО при маркировке',
		description:
			'Перетащите карточки от эмиссии кодов в ЦРПТ до отметки «выведен из оборота» в правильном порядке. Тренажёр для тех, кто работает с маркированным товаром.',
		cta: 'Открыть пазл',
		color: '#9E2B4F',
		icon: 'ЭДО',
	},
	{
		href: '/scenario/kofeynya-za-30-dney/',
		eyebrow: 'Сценарий · 30 задач',
		title: 'Открываю кофейню за 30 дней',
		description:
			'Пошаговый план открытия кофейни в 6 фазах: концепция, регистрация, помещение, оборудование, персонал, запуск. Прогресс сохраняется в браузере.',
		cta: 'Открыть план',
		color: '#5A3E7A',
		icon: 'КОФЕ',
	},
	{
		href: '/scenario/perekhod-ip-na-ooo-za-60-dney/',
		eyebrow: 'Сценарий · 25 задач + ROI',
		title: 'Переход с ИП на ООО за 60 дней',
		description:
			'Когда ИП становится тесным: пересадка клиентов, поставщиков, кассы, ЭДО, сотрудников. С калькулятором разницы налоговой нагрузки.',
		cta: 'Открыть план',
		color: '#1A5C3A',
		icon: 'ИП→ОО',
	},
	{
		href: '/zakon-2026/',
		eyebrow: 'Трекер · 10 норм',
		title: 'Законы 2026 для МСБ',
		description:
			'Хронологический журнал изменений: налоги, маркировка, ТС ПИоТ, ККТ, трудовое право. Фильтр по месяцам и темам — увидите, что ждёт именно вас.',
		cta: 'Открыть трекер',
		color: '#111',
		icon: '2026',
	},
	{
		href: '/kalkulyator-shtrafov/',
		eyebrow: 'Калькулятор · КоАП',
		title: 'Калькулятор штрафов',
		description:
			'Введите тип нарушения и сумму операции — увидите вилку штрафа по актуальной редакции КоАП РФ. Сценарии по 14.5, 15.12 и другим статьям.',
		cta: 'Рассчитать',
		color: '#AFCC00',
		icon: '15.12',
	},
	{
		href: '/kalendar-markirovki/',
		eyebrow: 'Календарь',
		title: 'Календарь маркировки',
		description:
			'Когда какая категория попадает под обязательную маркировку «Честный знак»: молочка, напитки, парфюмерия, БАДы, корма, бытовая химия и др.',
		cta: 'Открыть календарь',
		color: '#C8FF6B',
		icon: 'КАЛ',
	},
];
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		<main class="tools-page">
			<header class="tools-hero">
				<p class="tools-eyebrow">Инструменты</p>
				<h1>Интерактивные материалы для МСБ</h1>
				<p class="tools-lead">
					Симуляторы, тесты, калькуляторы и сценарии. Помогают разобраться
					в требованиях 2026 года быстрее, чем читать длинные статьи.
				</p>
			</header>

			<div class="tools-grid">
				{tools.map(tool => (
					<a
						href={u(tool.href)}
						class={`tool-card ${tool.featured ? 'tool-card--featured' : ''}`}
					>
						<div class="tool-icon" style={`background:${tool.color}`}>
							<span>{tool.icon}</span>
						</div>
						<div class="tool-body">
							<p class="tool-eyebrow">{tool.eyebrow}</p>
							<h3 class="tool-title">{tool.title}</h3>
							<p class="tool-desc">{tool.description}</p>
							<span class="tool-cta">{tool.cta} →</span>
						</div>
					</a>
				))}
			</div>

			<aside class="tools-note">
				<p>
					Внутри отдельных статей есть встроенные калькуляторы — например,
					<a href={u('/blog/2026-03-05-nalogi-msb-2026/')}>УСН/НДС</a> в
					разборе налогов 2026 и <a href={u('/blog/2026-05-01-shtraf-za-markirovku/')}>слайдер штрафа</a>
					в разборе наказаний за маркировку. Полный список — в навигации
					по категориям.
				</p>
			</aside>
		</main>

		<Footer />

		<style>
			.tools-page {
				max-width: 1080px;
				margin: 0 auto;
				padding: 2.5rem 1rem 4rem;
			}
			.tools-hero { margin-bottom: 2.5rem; max-width: 760px; }
			.tools-eyebrow {
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--pink, #9E2B4F);
				margin: 0 0 0.5rem;
				font-weight: 700;
			}
			.tools-hero h1 {
				font-family: 'Bebas Neue', sans-serif;
				font-size: clamp(2rem, 5vw, 3.2rem);
				line-height: 0.95;
				margin: 0 0 1rem;
				text-transform: uppercase;
				letter-spacing: 0.02em;
				color: #111;
			}
			.tools-lead {
				margin: 0;
				font-size: 1.05rem;
				color: #555;
				line-height: 1.55;
			}

			.tools-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1rem;
				margin-bottom: 2rem;
			}
			.tool-card {
				display: grid;
				grid-template-columns: 96px 1fr;
				gap: 1.25rem;
				padding: 1.25rem;
				background: #fff;
				border: 2px solid rgba(0, 0, 0, 0.08);
				border-radius: 12px;
				text-decoration: none;
				color: #111;
				transition: border-color 0.15s ease, transform 0.15s ease;
			}
			.tool-card:hover {
				border-color: #111;
				transform: translateY(-2px);
			}
			.tool-card--featured {
				grid-column: 1 / -1;
				grid-template-columns: 140px 1fr;
				border-color: var(--pink, #9E2B4F);
			}
			.tool-icon {
				display: flex;
				align-items: center;
				justify-content: center;
				border-radius: 8px;
				color: #fff;
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.4rem;
				letter-spacing: 0.04em;
			}
			.tool-card--featured .tool-icon { font-size: 1.8rem; }
			.tool-icon span { padding: 0 0.4em; }
			.tool-body { min-width: 0; }
			.tool-eyebrow {
				margin: 0 0 0.35rem;
				font-size: 0.72rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: #888;
			}
			.tool-title {
				margin: 0 0 0.5rem;
				font-size: 1.2rem;
				line-height: 1.25;
				color: #111;
			}
			.tool-card--featured .tool-title { font-size: 1.6rem; }
			.tool-desc {
				margin: 0 0 0.75rem;
				font-size: 0.92rem;
				line-height: 1.5;
				color: #444;
			}
			.tool-cta {
				font-weight: 600;
				color: var(--pink, #9E2B4F);
				font-size: 0.9rem;
			}

			.tools-note {
				margin-top: 2rem;
				padding: 1.25rem 1.5rem;
				background: var(--sand, #f4ebd9);
				border-radius: 12px;
				font-size: 0.95rem;
				line-height: 1.55;
				color: #444;
			}
			.tools-note a { color: var(--pink, #9E2B4F); font-weight: 600; }

			@media (max-width: 720px) {
				.tools-grid { grid-template-columns: 1fr; }
				.tool-card,
				.tool-card--featured {
					grid-template-columns: 72px 1fr;
				}
				.tool-icon { font-size: 1rem; }
				.tool-card--featured .tool-icon { font-size: 1.2rem; }
				.tool-card--featured .tool-title { font-size: 1.25rem; }
			}
		</style>
	</body>
</html>
