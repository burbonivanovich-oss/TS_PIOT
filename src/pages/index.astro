---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Picture from '../components/Picture.astro';
import PopupBanner from '../components/PopupBanner';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { u } from '../utils/url';
import { publishedPosts } from '../utils/posts';

const posts = (await publishedPosts()).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = posts[0];
const feed = posts.slice(1, 7);

function fmtDate(d: Date): string {
	return d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' });
}

function pluralMaterials(n: number): string {
	const mod10 = n % 10;
	const mod100 = n % 100;
	if (mod100 >= 11 && mod100 <= 14) return `${n} материалов`;
	if (mod10 === 1) return `${n} материал`;
	if (mod10 >= 2 && mod10 <= 4) return `${n} материала`;
	return `${n} материалов`;
}

const categoryNav = [
	{ slug: 'ts-piot',         cls: 'k-ts', num: '01', name: 'ТС ПИоТ' },
	{ slug: 'markirovka',      cls: 'k-mk', num: '02', name: 'Маркировка' },
	{ slug: 'zakonodatelstvo', cls: 'k-zk', num: '03', name: 'Законы' },
	{ slug: 'kkt',             cls: 'k-kk', num: '04', name: 'Кассы' },
	{ slug: 'egais',           cls: 'k-eg', num: '05', name: 'ЕГАИС' },
].map(c => ({
	...c,
	count: posts.filter(p => p.data.categories?.includes(c.slug as keyof typeof CATEGORIES)).length,
}));

const tagCls: Record<string, string> = {
	'ts-piot': 'ts',
	'markirovka': 'mk',
	'zakonodatelstvo': 'zk',
	'kkt': 'kk',
	'egais': 'eg',
};

const featuredCat = featured?.data.categories?.[0] as string | undefined;
const featuredCatCls = featuredCat ? tagCls[featuredCat] : 'zk';
const featuredCatTitle = featuredCat ? CATEGORIES[featuredCat as keyof typeof CATEGORIES]?.title : '';
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<PopupBanner client:load />
		<main>
			<!-- HERO -->
			<section class="hero">
				<div class="wrap">
					<div class="hero-eyebrow">Медиа для малого и среднего бизнеса · с 2025</div>
					<h1 class="hero-title">Разбираем требования,<br />которые догоняют бизнес</h1>
					<p class="hero-lead">
						ТС ПИоТ для онлайн-касс, маркировка «Честного знака», налоги, ЭДО
						и трудовое законодательство — понятно, без паники и со ссылками
						на первоисточники.
					</p>
					<div class="hero-cta">
						<a href={u('/blog/')} class="btn btn-primary">Все материалы →</a>
						<a href={u('/instrumenty/')} class="btn btn-lime">Подобрать сервис →</a>
					</div>
				</div>
			</section>

			<!-- СВЕЖЕЕ -->
			{featured && (
				<section class="sec wrap">
					<div class="sec-head">
						<h2>Свежее</h2>
						<a class="see-all" href={u('/blog/')}>Все материалы →</a>
					</div>
					<div class="fresh-inner">
						<a class="fresh-feat" href={u(`/blog/${featured.id}/`)}>
							<div class={`fph ph p-${featuredCatCls}`}>
								{(featured.data.previewImage || featured.data.heroImage) ? (
									<Picture src={u(featured.data.previewImage || featured.data.heroImage || '')} alt={featured.data.title} loading="eager" />
								) : (
									<span class="ph-label">{featuredCatTitle}</span>
								)}
							</div>
							<div class="ff-tag">
								<span class={`tag t-${featuredCatCls}`}>{featuredCatTitle}</span>
								<span class="ft-meta">{fmtDate(featured.data.pubDate)}</span>
							</div>
							<h3>{featured.data.title}</h3>
							<p class="ff-desc">{featured.data.description}</p>
							<span class="ff-meta">Читать →</span>
						</a>
						<nav class="cat-cards" aria-label="Категории">
							{categoryNav.map(cat => (
								<a class={`cat-card ${cat.cls}`} href={u(`/category/${cat.slug}/`)}>
									<span class="cc-num">{cat.num}</span>
									<div class="cc-body">
										<div class="cc-eyebrow">{pluralMaterials(cat.count)}</div>
										<div class="cc-name">{cat.name}</div>
									</div>
									<span class="cc-arr">→</span>
								</a>
							))}
						</nav>
					</div>
				</section>
			)}

			<!-- МАТЕРИАЛЫ НЕДЕЛИ -->
			{feed.length > 0 && (
				<section class="sec wrap tight">
					<div class="sec-head">
						<h2>Материалы недели</h2>
						<a class="see-all" href={u('/blog/')}>Все материалы →</a>
					</div>
					<div class="feed-grid">
						{feed.map(post => {
							const cat = post.data.categories?.[0] as string | undefined;
							const cls = cat ? tagCls[cat] : 'ts';
							const catTitle = cat ? CATEGORIES[cat as keyof typeof CATEGORIES]?.title ?? cat : 'Статья';
							const img = post.data.previewImage || post.data.heroImage;
							return (
								<a class="fcard" href={u(`/blog/${post.id}/`)}>
									<div class={`ph p-${cls}`}>
										{img ? <Picture src={u(img)} alt={post.data.title} loading="lazy" /> : <span class="ph-label">{catTitle}</span>}
									</div>
									<div class="fc-body">
										<span class={`tag t-${cls}`}>{catTitle}</span>
										<span class="fc-title">{post.data.title}</span>
										<span class="fc-meta">{fmtDate(post.data.pubDate)}</span>
									</div>
								</a>
							);
						})}
					</div>
				</section>
			)}

			<!-- ИНСТРУМЕНТЫ -->
			<section class="sec wrap">
				<div class="sec-head">
					<h2>Инструменты</h2>
					<a class="see-all" href={u('/instrumenty/')}>Все интерактивы →</a>
				</div>
				<div class="tools-grid">
					<a href={u('/kak-rabotaet-ts-piot/')} class="tool-card t-flag">
						<span class="tc-eyebrow">Симулятор · 7 шагов</span>
						<span class="tc-title">Как живёт чек в ТС ПИоТ</span>
						<span class="tc-cta">Пройти пошагово →</span>
					</a>
					<a href={u('/test-ts-piot/')} class="tool-card t-test">
						<span class="tc-eyebrow">Тест · 2 минуты</span>
						<span class="tc-title">Готов ли бизнес к ТС ПИоТ</span>
						<span class="tc-cta">Пройти тест →</span>
					</a>
					<a href={u('/scenario/kofeynya-za-30-dney/')} class="tool-card t-sc1">
						<span class="tc-eyebrow">Сценарий · 30 дней</span>
						<span class="tc-title">Открываю кофейню</span>
						<span class="tc-cta">Открыть план →</span>
					</a>
					<a href={u('/scenario/perekhod-ip-na-ooo-za-60-dney/')} class="tool-card t-sc2">
						<span class="tc-eyebrow">Сценарий + ROI</span>
						<span class="tc-title">ИП → ООО за 60 дней</span>
						<span class="tc-cta">Открыть план →</span>
					</a>
					<a href={u('/zakon-2026/')} class="tool-card t-zak">
						<span class="tc-eyebrow">Трекер · 10 норм</span>
						<span class="tc-title">Законы 2026 для МСБ</span>
						<span class="tc-cta">Открыть трекер →</span>
					</a>
				</div>
			</section>
		</main>
		<Footer />

		<style>
			main { padding: 0 0 80px; }
			.wrap { max-width: var(--maxw, 1400px); margin: 0 auto; padding: 0 32px; }

			h1, h2, h3, h4 {
				font-family: var(--f-display, 'Bebas Neue', sans-serif);
				font-weight: 400;
				letter-spacing: .02em;
				line-height: .95;
				margin: 0;
				text-transform: uppercase;
			}

			/* Hero */
			.hero { padding: 72px 0 56px; background: #fff; border-bottom: 1px solid var(--line, #E5E1D8); }
			.hero-eyebrow {
				font-size: .68rem;
				font-weight: 700;
				letter-spacing: .18em;
				text-transform: uppercase;
				color: var(--ink-3, #666);
				margin-bottom: 18px;
			}
			.hero-title {
				font-family: var(--f-display, 'Bebas Neue', sans-serif);
				font-size: clamp(2.8rem, 5.2vw, 4.6rem);
				line-height: .95;
				letter-spacing: .02em;
				color: #111;
				margin: 0 0 18px;
				text-transform: uppercase;
			}
			.hero-lead {
				font-size: 1.05rem;
				color: var(--ink-3, #666);
				max-width: 560px;
				line-height: 1.6;
				margin: 0 0 26px;
			}
			.hero-cta { display: flex; flex-wrap: wrap; gap: 8px; }
			.btn {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 14px 22px;
				text-decoration: none;
				font-size: .74rem;
				font-weight: 700;
				letter-spacing: .12em;
				text-transform: uppercase;
				border: 0;
				cursor: pointer;
				transition: all .15s;
				border-radius: 2px;
			}
			.btn-primary { background: #111; color: var(--lime, #AFCC00); }
			.btn-primary:hover { background: var(--pink, #9E2B4F); color: #fff; }
			.btn-ghost { background: transparent; color: #111; border: 2px solid #111; padding: 12px 20px; }
			.btn-ghost:hover { background: #111; color: var(--lime, #AFCC00); }
			.btn-lime { background: var(--lime, #AFCC00); color: #111; }
			.btn-lime:hover { background: var(--lime-dark, #9bb500); }

			/* Section heading */
			.sec { padding: 64px 0; position: relative; }
			.sec.tight { padding: 36px 0; }
			.sec-head {
				display: flex;
				align-items: end;
				justify-content: space-between;
				gap: 24px;
				margin-bottom: 28px;
				padding-bottom: 14px;
				border-bottom: 1px solid var(--line, #E5E1D8);
			}
			.sec-head h2 { font-size: clamp(1.7rem, 2.8vw, 2.4rem); }
			.sec-head .see-all {
				font-size: .7rem;
				font-weight: 700;
				letter-spacing: .1em;
				text-transform: uppercase;
				color: var(--ink-3, #666);
				text-decoration: none;
				white-space: nowrap;
			}
			.sec-head .see-all:hover { color: #111; }

			/* Tags */
			.tag {
				display: inline-block;
				font-size: .6rem;
				font-weight: 700;
				letter-spacing: .14em;
				text-transform: uppercase;
				padding: 3px 7px;
				color: #fff;
				border-radius: 2px;
				align-self: flex-start;
			}
			.tag.t-ts { background: #111; }
			.tag.t-mk { background: var(--pink, #9E2B4F); }
			.tag.t-zk { background: var(--blue, #1E4A7A); }
			.tag.t-kk { background: var(--purple, #5A3E7A); }
			.tag.t-eg { background: var(--lime, #AFCC00); color: #111; }

			/* Image placeholders — radial + diagonal stripes по категории */
			.ph { position: relative; overflow: hidden; background: #111; }
			.ph :global(img) { width: 100%; height: 100%; object-fit: cover; display: block; }
			.ph::before {
				content: "";
				position: absolute;
				inset: 0;
				opacity: .85;
				z-index: 0;
			}
			.ph.p-ts::before { background: radial-gradient(circle at 30% 20%, #2a2a2a, #0a0a0a); }
			.ph.p-mk::before { background: radial-gradient(circle at 70% 30%, #b73765, #5b1b30); }
			.ph.p-zk::before { background: radial-gradient(circle at 30% 70%, #2a5d96, #0d2440); }
			.ph.p-kk::before { background: radial-gradient(circle at 60% 40%, #6e4e92, #2e1f44); }
			.ph.p-eg::before { background: radial-gradient(circle at 50% 60%, #c5e324, #7d9300); }
			.ph::after {
				content: "";
				position: absolute;
				inset: 0;
				background:
					repeating-linear-gradient(45deg, rgba(255,255,255,.03) 0 2px, transparent 2px 8px),
					radial-gradient(circle at 80% 80%, rgba(0,0,0,.4), transparent 60%);
				z-index: 1;
				pointer-events: none;
			}
			.ph:has(img)::before, .ph:has(img)::after { display: none; }
			.ph .ph-label {
				position: absolute;
				left: 14px;
				bottom: 12px;
				font-family: var(--f-display, 'Bebas Neue', sans-serif);
				color: rgba(255,255,255,.6);
				font-size: .7rem;
				letter-spacing: .12em;
				z-index: 2;
			}

			/* Свежее: featured pillar + категории мини section-headers */
			.fresh-inner { display: grid; grid-template-columns: 1.55fr 1fr; gap: 24px; align-items: stretch; }
			.fresh-feat { display: flex; flex-direction: column; text-decoration: none; color: #111; }
			.fresh-feat .fph { aspect-ratio: 16/10; background: #111; }
			.fresh-feat .ff-tag { display: flex; gap: 12px; align-items: center; margin: 18px 0 14px; }
			.fresh-feat .ff-tag .ft-meta {
				font-family: var(--f-mono, ui-monospace, monospace);
				font-size: .7rem;
				color: var(--mute, #9a9a9a);
				letter-spacing: .04em;
			}
			.fresh-feat h3 {
				font-family: var(--f-display, 'Bebas Neue', sans-serif);
				font-size: clamp(1.6rem, 2.2vw, 2.1rem);
				line-height: 1.02;
				color: #111;
				margin: 0 0 12px;
				text-transform: uppercase;
				letter-spacing: .02em;
			}
			.fresh-feat .ff-desc {
				color: var(--ink-3, #666);
				font-size: .92rem;
				line-height: 1.55;
				margin: 0 0 10px;
				max-width: 580px;
			}
			.fresh-feat .ff-meta {
				font-family: var(--f-mono, ui-monospace, monospace);
				font-size: .72rem;
				color: var(--pink, #9E2B4F);
				letter-spacing: .04em;
				text-transform: uppercase;
				font-weight: 700;
			}

			/* Category mini cards */
			.cat-cards { display: flex; flex-direction: column; gap: 6px; }
			.cat-card {
				display: grid;
				grid-template-columns: auto 1fr auto;
				gap: 14px;
				padding: 16px 18px;
				text-decoration: none;
				color: #fff;
				align-items: center;
				position: relative;
				overflow: hidden;
				transition: all .15s;
				flex: 1;
				border-radius: 2px;
			}
			.cat-card:hover { transform: translateX(4px); }
			.cat-card .cc-num {
				font-family: var(--f-display, 'Bebas Neue', sans-serif);
				font-size: 2.6rem;
				line-height: .8;
				letter-spacing: 0;
				color: rgba(255,255,255,.32);
			}
			.cat-card .cc-body { display: flex; flex-direction: column; gap: 2px; }
			.cat-card .cc-eyebrow {
				font-family: var(--f-mono, ui-monospace, monospace);
				font-size: .62rem;
				color: rgba(255,255,255,.65);
				letter-spacing: .06em;
				text-transform: uppercase;
			}
			.cat-card .cc-name {
				font-family: var(--f-display, 'Bebas Neue', sans-serif);
				font-size: 1.4rem;
				letter-spacing: .04em;
				text-transform: uppercase;
				line-height: 1;
			}
			.cat-card .cc-arr {
				font-family: var(--f-display, 'Bebas Neue', sans-serif);
				font-size: 1.4rem;
				line-height: 1;
				color: rgba(255,255,255,.5);
				transition: all .15s;
			}
			.cat-card:hover .cc-arr { color: #fff; transform: translateX(4px); }
			.cat-card.k-ts { background: #111; }
			.cat-card.k-mk { background: var(--pink, #9E2B4F); }
			.cat-card.k-zk { background: var(--blue, #1E4A7A); }
			.cat-card.k-kk { background: #5A3E7A; }
			.cat-card.k-eg { background: var(--lime, #AFCC00); color: #111; }
			.cat-card.k-eg .cc-num { color: rgba(0,0,0,.2); }
			.cat-card.k-eg .cc-eyebrow { color: rgba(0,0,0,.6); }
			.cat-card.k-eg .cc-arr { color: rgba(0,0,0,.45); }
			.cat-card.k-eg:hover .cc-arr { color: #111; }

			/* Лента материалов */
			.feed-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
			.fcard {
				background: #fff;
				border: 1px solid var(--line, #E5E1D8);
				text-decoration: none;
				color: #111;
				display: flex;
				flex-direction: column;
				overflow: hidden;
				transition: all .15s;
			}
			.fcard:hover { border-color: #111; transform: translateY(-2px); }
			.fcard .ph { aspect-ratio: 16/9; }
			.fcard .fc-body { padding: 18px; display: flex; flex-direction: column; gap: 10px; flex: 1; }
			.fcard .fc-title {
				font-family: var(--f-display, 'Bebas Neue', sans-serif);
				font-size: 1.18rem;
				letter-spacing: .02em;
				line-height: 1.08;
				text-transform: uppercase;
			}
			.fcard .fc-meta {
				font-family: var(--f-mono, ui-monospace, monospace);
				font-size: .7rem;
				color: var(--mute, #9a9a9a);
				letter-spacing: .04em;
				margin-top: auto;
			}

			/* Инструменты */
			.tools-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; }
			.tool-card {
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				gap: 12px;
				padding: 22px;
				min-height: 170px;
				text-decoration: none;
				color: #111;
				transition: all .15s;
				border-radius: 2px;
			}
			.tool-card:hover { transform: translateY(-2px); }
			.tool-card .tc-eyebrow {
				font-size: .6rem;
				font-weight: 700;
				letter-spacing: .16em;
				text-transform: uppercase;
				opacity: .75;
			}
			.tool-card .tc-title {
				font-family: var(--f-display, 'Bebas Neue', sans-serif);
				font-size: 1.25rem;
				letter-spacing: .03em;
				line-height: 1.05;
				text-transform: uppercase;
			}
			.tool-card .tc-cta {
				font-size: .66rem;
				font-weight: 700;
				letter-spacing: .12em;
				text-transform: uppercase;
			}
			.tool-card.t-flag { background: var(--pink, #9E2B4F); color: #fff; grid-column: span 3; min-height: 200px; }
			.tool-card.t-flag .tc-title { font-size: 1.7rem; }
			.tool-card.t-test { background: var(--lime, #AFCC00); color: #111; grid-column: span 3; }
			.tool-card.t-test .tc-title { font-size: 1.5rem; }
			.tool-card.t-sc1 { background: var(--blue, #1E4A7A); color: #fff; grid-column: span 2; }
			.tool-card.t-sc2 { background: #fff; color: #111; border: 1px solid var(--line, #E5E1D8); grid-column: span 2; }
			.tool-card.t-zak { background: #111; color: #fff; grid-column: span 2; }

			/* Responsive */
			@media (max-width: 1024px) {
				.tools-grid { grid-template-columns: repeat(2, 1fr); }
				.tool-card.t-flag, .tool-card.t-test, .tool-card.t-sc1, .tool-card.t-sc2, .tool-card.t-zak { grid-column: auto; }
				.fresh-inner { grid-template-columns: 1fr; gap: 24px; }
				.cat-cards { flex-direction: row; flex-wrap: wrap; }
				.cat-card { flex: 1 1 30%; }
				.feed-grid { grid-template-columns: repeat(2, 1fr); }
			}
			@media (max-width: 680px) {
				.hero { padding: 48px 0 32px; }
				.tools-grid { grid-template-columns: 1fr; }
				.cat-card { flex: 1 1 100%; }
				.feed-grid { grid-template-columns: 1fr; }
				.wrap { padding: 0 16px; }
			}
		</style>
	</body>
</html>
