---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const latest = posts.slice(0, 6);
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Этикетка — медиа для предпринимателей</h1>
				<p class="hero-lead">
					Разбираем требования, которые догоняют малый и средний бизнес: ТС ПИоТ для
					онлайн-касс, маркировка «Честный знак», разрешительный режим, изменения в
					налогах, ЭДО и трудовом законодательстве. Понятно и без паники.
				</p>
				<div class="hero-cta">
					<a href="/blog/" class="btn btn-primary">Все статьи</a>
					<a href="/category/ts-piot/" class="btn btn-ghost">Что такое ТС ПИоТ</a>
				</div>
			</section>

			<section class="categories" aria-labelledby="cat-heading">
				<h2 id="cat-heading" class="section-heading">Основные направления</h2>
				<div class="cat-grid">
					{Object.entries(CATEGORIES).map(([slug, cat]) => (
						<a class="cat-card" href={`/category/${slug}/`}>
							<div class="cat-card-icon" aria-hidden="true">
								{slug === 'ts-piot' ? 'ТС' : slug === 'markirovka' ? 'МЗ' : 'НА'}
							</div>
							<h3>{cat.title}</h3>
							<p>{cat.description}</p>
							<span class="cat-link">Подробнее →</span>
						</a>
					))}
				</div>
			</section>

			<section class="latest" aria-labelledby="latest-heading">
				<h2 id="latest-heading">Последние материалы</h2>
				{latest.length === 0 ? (
					<p>Скоро здесь появятся первые статьи.</p>
				) : (
					<ul class="post-list">
						{latest.map((post) => (
							<li class="post-card">
								<a href={`/blog/${post.id}/`}>
									{post.data.previewImage && (
										<div class="post-card-img">
											<img src={post.data.previewImage} alt="" loading="lazy" width="800" height="420" />
										</div>
									)}
									<div class="post-card-body">
										<h3>{post.data.title}</h3>
										<p class="post-desc">{post.data.description}</p>
										<p class="post-date">
											{post.data.updatedDate ? (
												<>обновлено <FormattedDate date={post.data.updatedDate} /></>
											) : (
												<FormattedDate date={post.data.pubDate} />
											)}
										</p>
									</div>
								</a>
							</li>
						))}
					</ul>
				)}
			</section>
		</main>
		<Footer />

		<style>
			/* Hero */
			.hero {
				padding: var(--sp-7) 0 var(--sp-5);
				border-bottom: 1px solid var(--border);
				margin-bottom: var(--sp-7);
			}
			.hero h1 { max-width: 800px; }
			.hero-lead {
				font-size: 1.125rem;
				max-width: 680px;
				color: var(--text-2);
				margin-top: var(--sp-3);
				line-height: 1.65;
			}
			.hero-cta {
				display: flex;
				flex-wrap: wrap;
				gap: var(--sp-3);
				margin-top: var(--sp-5);
			}

			/* Категории */
			.categories,
			.latest { margin-top: var(--sp-7); }

			.section-heading {
				font-size: 1.375rem;
				margin-bottom: var(--sp-5);
			}

			.cat-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: var(--sp-4);
			}

			.cat-card {
				display: block;
				padding: var(--sp-5);
				border: 1px solid var(--border);
				border-radius: var(--r-md);
				text-decoration: none;
				color: var(--text-2);
				background: var(--bg);
				transition: border-color var(--ease), box-shadow var(--ease), transform var(--ease);
			}
			.cat-card:hover {
				border-color: var(--accent);
				box-shadow: var(--shadow-hover);
				transform: translateY(-2px);
				text-decoration: none;
			}
			.cat-card-icon {
				width: 36px; height: 36px;
				border-radius: var(--r-sm);
				margin-bottom: var(--sp-3);
				display: flex; align-items: center; justify-content: center;
				font-size: 1rem;
				font-weight: 700;
				font-family: 'Commissioner', sans-serif;
			}
			.cat-card[href*="ts-piot"] .cat-card-icon   { background: var(--cat-ts-piot-bg); color: var(--cat-ts-piot-fg); }
			.cat-card[href*="markirovka"] .cat-card-icon { background: var(--cat-mark-bg);    color: var(--cat-mark-fg); }
			.cat-card[href*="zakon"] .cat-card-icon      { background: var(--cat-zakon-bg);   color: var(--cat-zakon-fg); }

			.cat-card h3 {
				margin: 0 0 var(--sp-2);
				font-size: 1.0625rem;
				color: var(--text);
			}
			.cat-card p {
				font-size: 0.875rem;
				color: var(--text-3);
				margin-bottom: var(--sp-3);
				line-height: 1.55;
			}
			.cat-link {
				font-size: 0.875rem;
				font-weight: 600;
				color: var(--accent);
			}

			/* Карточки статей */
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: var(--sp-4);
			}
			.post-card a {
				display: flex;
				flex-direction: column;
				border: 1px solid var(--border);
				border-radius: var(--r-md);
				background: var(--bg);
				color: var(--text-2);
				text-decoration: none;
				height: 100%;
				overflow: hidden;
				transition: border-color var(--ease), box-shadow var(--ease);
			}
			.post-card a:hover {
				border-color: var(--accent);
				box-shadow: var(--shadow-hover);
				text-decoration: none;
			}
			.post-card-img {
				width: 100%;
				aspect-ratio: 16 / 9;
				overflow: hidden;
				flex-shrink: 0;
			}
			.post-card-img img {
				width: 100%; height: 100%;
				object-fit: cover;
				display: block;
				transition: transform 0.25s ease;
			}
			.post-card a:hover .post-card-img img { transform: scale(1.04); }
			.post-card-body {
				padding: var(--sp-4);
				display: flex;
				flex-direction: column;
				flex: 1;
			}
			.post-card h3 {
				margin: 0 0 var(--sp-2);
				color: var(--text);
				font-size: 1rem;
				line-height: 1.35;
			}
			.post-desc {
				font-size: 0.875rem;
				color: var(--text-3);
				margin-bottom: var(--sp-2);
				flex: 1;
				line-height: 1.55;
			}
			.post-date {
				font-size: 0.8125rem;
				color: var(--text-4);
				margin: 0;
				margin-top: auto;
			}

			@media (max-width: 900px) {
				.cat-grid, .post-list { grid-template-columns: 1fr 1fr; }
			}
			@media (max-width: 560px) {
				.cat-grid, .post-list { grid-template-columns: 1fr; }
			}
		</style>
	</body>
</html>
