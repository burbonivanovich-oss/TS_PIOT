---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const latest = posts.slice(0, 6);

const CAT_COLORS: Record<string, string> = {
	'ts-piot': 'lime',
	'markirovka': 'pink',
	'zakonodatelstvo': 'dark',
};
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero">
				<div class="hero-eyebrow">
					<span class="tag-pill tag-pill--lime">Медиа для бизнеса</span>
				</div>
				<h1 class="hero-title">Разбираем требования,<br />которые догоняют бизнес</h1>
				<p class="hero-lead">
					ТС ПИоТ для онлайн-касс, маркировка «Честный знак», налоги, ЭДО
					и трудовое законодательство — понятно и без паники.
				</p>
				<div class="hero-cta">
					<a href="/blog/" class="btn btn-primary">Все статьи</a>
					<a href="/category/ts-piot/" class="btn btn-ghost">Что такое ТС ПИоТ →</a>
				</div>
			</section>

			<!-- Направления -->
			<section class="categories" aria-labelledby="cat-heading">
				<h2 class="section-label" id="cat-heading">Направления</h2>
				<div class="cat-grid">
					{Object.entries(CATEGORIES).map(([slug, cat]) => {
						const color = CAT_COLORS[slug] ?? 'dark';
						return (
							<a class={`cat-card cat-card--${color}`} href={`/category/${slug}/`}>
								<span class={`cat-tag tag-pill tag-pill--${color === 'lime' ? 'dark' : color === 'pink' ? 'dark' : 'lime'}`}>{cat.title}</span>
								<p class="cat-desc">{cat.description}</p>
								<span class="cat-arrow">→</span>
							</a>
						);
					})}
				</div>
			</section>

			<!-- Последние материалы -->
			<section class="latest" aria-labelledby="latest-heading">
				<div class="section-header">
					<h2 class="section-label" id="latest-heading">Последние материалы</h2>
					<a href="/blog/" class="see-all">Все статьи →</a>
				</div>
				{latest.length === 0 ? (
					<p>Скоро здесь появятся первые статьи.</p>
				) : (
					<ul class="post-grid">
						{latest.map((post, idx) => {
							const cat = post.data.categories?.[0];
							const color = cat ? (CAT_COLORS[cat] ?? 'dark') : 'dark';
							const isFeatured = idx === 0;
							return (
								<li class={`post-card${isFeatured ? ' post-card--featured' : ''}`}>
									<a href={`/blog/${post.id}/`}>
										{post.data.previewImage && (
											<div class="post-img">
												<img src={post.data.previewImage} alt="" loading={idx < 2 ? 'eager' : 'lazy'} width="800" height="420" />
											</div>
										)}
										<div class="post-body">
											{cat && (
												<span class={`tag-pill tag-pill--${color}`}>
													{CATEGORIES[cat as keyof typeof CATEGORIES]?.title ?? cat}
												</span>
											)}
											<h3 class="post-title">{post.data.title}</h3>
											{isFeatured && <p class="post-desc">{post.data.description}</p>}
											<p class="post-date">
												{post.data.updatedDate ? (
													<>обновлено <FormattedDate date={post.data.updatedDate} /></>
												) : (
													<FormattedDate date={post.data.pubDate} />
												)}
											</p>
										</div>
									</a>
								</li>
							);
						})}
					</ul>
				)}
			</section>
		</main>
		<Footer />

		<style>
			/* Hero */
			.hero {
				padding: 3.5rem 0 2.5rem;
				border-bottom: 1px solid var(--border);
				margin-bottom: 3rem;
			}
			.hero-eyebrow {
				margin-bottom: 1.25rem;
			}
			.hero-title {
				font-size: clamp(2.2rem, 5vw, 3.6rem);
				letter-spacing: -0.03em;
				max-width: 760px;
				line-height: 1.1;
				margin-bottom: 1rem;
			}
			.hero-lead {
				font-size: 1.1rem;
				max-width: 640px;
				color: var(--muted);
				margin: 0 0 1.75rem;
				line-height: 1.6;
			}
			.hero-cta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
			}
			.btn {
				display: inline-block;
				padding: 0.65em 1.4em;
				border-radius: 4px;
				text-decoration: none;
				font-weight: 700;
				font-size: 0.9rem;
				letter-spacing: 0.01em;
				transition: all 0.12s ease;
				font-family: 'Commissioner', sans-serif;
				text-transform: uppercase;
			}
			.btn-primary {
				background: var(--dark);
				color: var(--lime);
				border: 2px solid var(--dark);
			}
			.btn-primary:hover {
				background: var(--pink);
				border-color: var(--pink);
				color: #fff;
			}
			.btn-ghost {
				background: transparent;
				color: var(--dark);
				border: 2px solid var(--dark);
			}
			.btn-ghost:hover {
				background: var(--dark);
				color: var(--lime);
			}

			/* Section labels */
			.section-label {
				font-size: 0.75rem;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--muted);
				margin: 0;
			}

			/* Categories */
			.categories {
				margin-bottom: 3.5rem;
			}
			.cat-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1px;
				background: var(--border);
				border: 1px solid var(--border);
				border-radius: 8px;
				overflow: hidden;
				margin-top: 1.25rem;
			}
			.cat-card {
				display: flex;
				flex-direction: column;
				padding: 1.75rem;
				text-decoration: none;
				transition: all 0.12s ease;
				background: #fff;
				gap: 0.75rem;
			}
			.cat-card--lime { border-top: 3px solid var(--lime); }
			.cat-card--pink { border-top: 3px solid var(--pink); }
			.cat-card--dark { border-top: 3px solid var(--dark); }
			.cat-card:hover {
				background: var(--dark);
			}
			.cat-card:hover .cat-desc { color: rgba(255,255,255,0.6); }
			.cat-card:hover .cat-arrow { color: var(--lime); }
			.cat-tag { align-self: flex-start; }
			.cat-desc {
				font-size: 0.88rem;
				color: var(--muted);
				margin: 0;
				line-height: 1.5;
				flex: 1;
				transition: color 0.12s ease;
			}
			.cat-arrow {
				font-size: 1.1rem;
				color: var(--muted);
				transition: color 0.12s ease;
				align-self: flex-end;
			}

			/* Tag pills (переопределяем для локального использования) */
			.tag-pill {
				display: inline-block;
				padding: 0.22em 0.65em;
				border-radius: 3px;
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				line-height: 1.4;
				text-decoration: none;
			}
			.tag-pill--lime { background: var(--lime); color: var(--dark); }
			.tag-pill--pink { background: var(--pink); color: #fff; }
			.tag-pill--dark { background: var(--dark); color: var(--lime); }

			/* Latest posts */
			.latest { }
			.section-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 1.25rem;
			}
			.see-all {
				font-size: 0.82rem;
				font-weight: 700;
				letter-spacing: 0.02em;
				color: var(--muted);
				text-decoration: none;
				text-transform: uppercase;
			}
			.see-all:hover { color: var(--dark); }

			.post-grid {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1px;
				background: var(--border);
				border: 1px solid var(--border);
				border-radius: 8px;
				overflow: hidden;
			}
			.post-card--featured {
				grid-column: 1 / 3;
			}
			.post-card a {
				display: flex;
				flex-direction: column;
				background: #fff;
				color: var(--mid);
				text-decoration: none;
				height: 100%;
				overflow: hidden;
				transition: background 0.12s ease;
			}
			.post-card--featured a {
				flex-direction: row;
			}
			.post-card a:hover { background: var(--surface); }
			.post-card--featured a:hover { background: var(--dark); }
			.post-card--featured a:hover .post-title { color: var(--lime); }
			.post-card--featured a:hover .post-desc { color: rgba(255,255,255,0.6); }
			.post-card--featured a:hover .post-date { color: rgba(255,255,255,0.35); }

			.post-img {
				width: 100%;
				aspect-ratio: 16 / 9;
				overflow: hidden;
				flex-shrink: 0;
			}
			.post-card--featured .post-img {
				width: 45%;
				aspect-ratio: unset;
			}
			.post-img img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
				transition: transform 0.4s ease;
			}
			.post-card a:hover .post-img img { transform: scale(1.04); }

			.post-body {
				padding: 1.4rem 1.6rem 1.6rem;
				display: flex;
				flex-direction: column;
				flex: 1;
				gap: 0.5rem;
			}
			.post-card--featured .post-body {
				padding: 2rem 2rem;
				justify-content: flex-end;
			}
			.post-title {
				margin: 0;
				font-size: 1rem;
				font-weight: 700;
				color: var(--dark);
				line-height: 1.25;
				letter-spacing: -0.01em;
				transition: color 0.12s ease;
			}
			.post-card--featured .post-title {
				font-size: 1.5rem;
				letter-spacing: -0.02em;
				line-height: 1.18;
			}
			.post-desc {
				font-size: 0.88rem;
				color: var(--muted);
				margin: 0;
				line-height: 1.5;
				transition: color 0.12s ease;
			}
			.post-date {
				font-size: 0.75rem;
				color: #9CA3AF;
				margin: 0;
				margin-top: auto;
				padding-top: 0.5rem;
				transition: color 0.12s ease;
			}

			@media (max-width: 900px) {
				.cat-grid { grid-template-columns: 1fr 1fr; }
				.post-grid { grid-template-columns: 1fr 1fr; }
				.post-card--featured { grid-column: 1 / -1; }
			}
			@media (max-width: 600px) {
				.cat-grid { grid-template-columns: 1fr; }
				.post-grid { grid-template-columns: 1fr; }
				.post-card--featured a { flex-direction: column; }
				.post-card--featured .post-img { width: 100%; aspect-ratio: 16/9; }
				.hero { padding: 2rem 0 1.5rem; }
			}
		</style>
	</body>
</html>
