---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { u } from '../utils/url';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const latest = posts.slice(0, 7);

function fmtDate(d: Date): string {
	return d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' });
}

const catList = [
	{ slug: 'ts-piot',          num: '01', name: 'ТС ПИоТ',         cls: 't1', count: posts.filter(p => p.data.categories?.includes('ts-piot')).length },
	{ slug: 'markirovka',       num: '02', name: 'Маркировка',       cls: 't2', count: posts.filter(p => p.data.categories?.includes('markirovka')).length },
	{ slug: 'zakonodatelstvo',  num: '03', name: 'Законодательство', cls: 't3', count: posts.filter(p => p.data.categories?.includes('zakonodatelstvo')).length },
	{ slug: 'tools',            num: '04', name: 'Инструменты',      cls: 't4', count: null },
];

const CAT_COLOR: Record<string, string> = {
	'ts-piot':         '#111',
	'markirovka':      '#9E2B4F',
	'zakonodatelstvo': '#1E4A7A',
	'kkt':             '#5A3E7A',
	'egais':           '#1A5C3A',
};
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero">
				<div class="hero-eyebrow">
					<span class="eyebrow-tag">Медиа для бизнеса</span>
				</div>
				<h1 class="hero-title">РАЗБИРАЕМ ТРЕБОВАНИЯ,<br />КОТОРЫЕ ДОГОНЯЮТ БИЗНЕС</h1>
				<p class="hero-lead">
					ТС ПИоТ для онлайн-касс, маркировка «Честный знак», налоги, ЭДО
					и трудовое законодательство — понятно и без паники.
				</p>
				<div class="hero-cta">
					<a href={u("/blog/")} class="btn btn-primary">Все статьи</a>
				</div>
			</section>

			<!-- Category tiles -->
			<section class="categories">
				<div class="section-label">
					Разделы
					<a href={u("/blog/")} class="see-all">СМ. ВСЕ →</a>
				</div>
				<div class="cat-tiles">
					{catList.filter(c => c.slug !== 'tools').map((cat) => (
						<a class={`cat-tile ${cat.cls}`} href={u(`/category/${cat.slug}/`)}>
							<div>
								<div class="t-num">{cat.num}</div>
								<div class="t-name">{cat.name}</div>
							</div>
							<div>
								<div class="t-count">{cat.count} материалов</div>
								<div class="t-dot"></div>
							</div>
						</a>
					))}
					<div class="cat-tile t4">
						<div>
							<div class="t-num">04</div>
							<div class="t-name">Инструменты</div>
						</div>
						<div class="t4-links">
							<a href={u('/kalkulyator-shtrafov/')} class="t4-link">Калькулятор штрафов →</a>
							<a href={u('/kalendar-markirovki/')} class="t4-link">Календарь маркировки →</a>
						</div>
					</div>
				</div>
			</section>

			<!-- Latest posts -->
			{latest.length > 0 && (
				<section class="latest">
					<div class="section-label">
						Последние материалы
						<a href={u("/blog/")} class="see-all">СМ. ВСЕ →</a>
					</div>

					<div class="posts-grid">
						{latest.map((post, i) => {
							const cat = post.data.categories?.[0];
							const catTitle = cat ? (CATEGORIES[cat as keyof typeof CATEGORIES]?.title ?? cat) : 'Статья';
							const accentColor = cat ? (CAT_COLOR[cat] ?? '#111') : '#111';
							const img = post.data.previewImage ?? post.data.heroImage ?? null;
							return (
								<a href={u(`/blog/${post.id}/`)} class={`post-card${i === 0 ? ' post-card--featured' : ''}`}>
									<div class="post-card-img" style={`--accent:${accentColor}`}>
										{img
											? <img src={u(img)} alt={post.data.title} loading={i === 0 ? 'eager' : 'lazy'} />
											: <span class="post-card-placeholder" style={`background:${accentColor}`}></span>
										}
									</div>
									<div class="post-card-body">
										<span class="post-card-cat" style={`background:${accentColor};color:#fff`}>{catTitle}</span>
										<div class="post-card-title">{post.data.title}</div>
										{i === 0 && post.data.description && (
											<div class="post-card-desc">{post.data.description}</div>
										)}
										<div class="post-card-meta">{fmtDate(post.data.pubDate)}</div>
									</div>
								</a>
							);
						})}
					</div>
				</section>
			)}
		</main>
		<Footer />

		<style>
			main {
				padding: 48px 32px 80px;
				max-width: 1280px;
				margin: 0 auto;
			}

			/* ── Hero ── */
			.hero {
				padding: 56px 0 56px;
				border-bottom: 1px solid rgba(0,0,0,.12);
				margin-bottom: 56px;
			}
			.eyebrow-tag {
				display: inline-block;
				font-size: .65rem;
				font-weight: 700;
				letter-spacing: .12em;
				text-transform: uppercase;
				padding: 4px 8px;
				background: #AFCC00;
				color: #111;
				margin-bottom: 20px;
			}
			.hero-title {
				font-family: 'Bebas Neue', sans-serif;
				font-size: clamp(3rem, 5.5vw, 5rem);
				line-height: .95;
				letter-spacing: .02em;
				color: #111;
				margin-bottom: 20px;
				text-transform: uppercase;
			}
			.hero-lead {
				font-size: 1rem;
				color: #666;
				max-width: 560px;
				line-height: 1.65;
				margin-bottom: 24px;
			}
			.hero-cta {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
			}
			.btn {
				display: inline-block;
				padding: .65em 1.5em;
				text-decoration: none;
				font-size: .78rem;
				font-weight: 700;
				letter-spacing: .1em;
				text-transform: uppercase;
				transition: all .12s ease;
			}
			.btn-primary { background: #111; color: #AFCC00; }
			.btn-primary:hover { background: #9E2B4F; color: #fff; }
			.btn-ghost { background: transparent; color: #111; border: 2px solid #111; }
			.btn-ghost:hover { background: #111; color: #AFCC00; }

			/* ── Section label ── */
			.section-label {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.5rem;
				letter-spacing: .06em;
				color: #111;
				margin-bottom: 20px;
				display: flex;
				align-items: center;
				gap: 12px;
				margin-top: 0;
			}
			.section-num { color: #ccc; }
			.see-all {
				font-family: 'Inter', sans-serif;
				font-size: .7rem;
				font-weight: 700;
				letter-spacing: .1em;
				text-transform: uppercase;
				color: #999;
				margin-left: auto;
				text-decoration: none;
				transition: color .15s;
			}
			.see-all:hover { color: #111; }

			/* ── Category tiles ── */
			.categories { margin-bottom: 56px; }
			.cat-tiles {
				display: grid;
				grid-template-columns: repeat(4, minmax(0, 1fr));
				gap: 8px;
			}
			.cat-tile {
				padding: 24px;
				min-height: 140px;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				text-decoration: none;
				transition: opacity .15s;
			}
			.cat-tile:hover { opacity: .88; }
			.cat-tile.t1 { background: #EDE8DF; border: 1px solid rgba(0,0,0,.12); }
			.cat-tile.t2 { background: #AFCC00; }
			.cat-tile.t3 { background: #1E4A7A; }
			.t-num {
				font-size: .65rem;
				font-weight: 700;
				letter-spacing: .1em;
				text-transform: uppercase;
				color: #aaa;
				margin-bottom: 6px;
			}
			.t2 .t-num { color: #8aaa00; }
			.t3 .t-num { color: rgba(255,255,255,.4); }
			.t-name {
				font-family: 'Bebas Neue', sans-serif;
				font-size: clamp(1.1rem, 1.35vw, 1.65rem);
				letter-spacing: .04em;
				text-transform: uppercase;
				color: #111;
				line-height: 1.1;
				word-break: normal;
				hyphens: none;
			}
			.t3 .t-name { color: #fff; }
			.t-count {
				font-size: .65rem;
				font-weight: 600;
				letter-spacing: .06em;
				color: #888;
				margin-bottom: 4px;
			}
			.t2 .t-count { color: #666; }
			.t3 .t-count { color: rgba(255,255,255,.4); }
			.t-dot { width: 8px; height: 8px; border-radius: 50%; }
			.t1 .t-dot { background: #9E2B4F; }
			.t2 .t-dot { background: #111; }
			.t3 .t-dot { background: #AFCC00; }
			.cat-tile.t4 { background: #F6F4F0; border: 1px solid rgba(0,0,0,.12); cursor: default; }
			.t4-links { display: flex; flex-direction: column; gap: 6px; }
			.t4-link { font-size: .75rem; font-weight: 700; letter-spacing: .06em; color: #9E2B4F; text-decoration: none; transition: color .15s; }
			.t4-link:hover { color: #7d2240; }

			/* ── Posts grid ── */
			.latest { margin-bottom: 0; }
			.posts-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 8px;
			}

			/* Featured card spans full width */
			.post-card--featured {
				grid-column: 1 / -1;
				flex-direction: row;
			}
			.post-card--featured .post-card-img {
				width: 45%;
				flex-shrink: 0;
				min-height: 220px;
				overflow: hidden;
			}
			.post-card--featured .post-card-body {
				padding: 28px 32px;
				display: flex;
				flex-direction: column;
				justify-content: center;
			}
			.post-card--featured .post-card-title {
				font-size: clamp(1.6rem, 2.5vw, 2.4rem);
			}

			/* All cards */
			.post-card {
				background: #fff;
				display: flex;
				flex-direction: column;
				text-decoration: none;
				color: #111;
				border: 1px solid rgba(0,0,0,.08);
				transition: box-shadow .15s, transform .15s;
			}
			.post-card:hover {
				box-shadow: 0 4px 20px rgba(0,0,0,.1);
				transform: translateY(-2px);
			}
			.post-card-img {
				width: 100%;
				aspect-ratio: 16/9;
				overflow: hidden;
				position: relative;
				background: var(--accent, #111);
			}
			.post-card-img img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.post-card-placeholder {
				display: block;
				width: 100%;
				height: 100%;
			}
			.post-card-body {
				padding: 20px;
				flex: 1;
				display: flex;
				flex-direction: column;
			}
			.post-card-cat {
				display: inline-block;
				font-size: .6rem;
				font-weight: 700;
				letter-spacing: .12em;
				text-transform: uppercase;
				padding: 3px 8px;
				margin-bottom: 10px;
				align-self: flex-start;
			}
			.post-card-title {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.45rem;
				line-height: 1.05;
				letter-spacing: .02em;
				text-transform: uppercase;
				color: #111;
				flex: 1;
				margin-bottom: 8px;
			}
			.post-card-desc {
				font-size: .88rem;
				color: #555;
				line-height: 1.55;
				margin-bottom: 12px;
			}
			.post-card-meta {
				font-size: .65rem;
				letter-spacing: .08em;
				text-transform: uppercase;
				color: #aaa;
				margin-top: auto;
			}

			/* ── Responsive ── */
			@media (max-width: 960px) {
				.post-card--featured { flex-direction: column; }
				.post-card--featured .post-card-img { width: 100%; aspect-ratio: 16/9; }
			}
			@media (max-width: 820px) {
				main { padding: 32px 20px 60px; }
				.cat-tiles { grid-template-columns: repeat(2, minmax(0, 1fr)); }
				.posts-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
			}
			@media (max-width: 560px) {
				main { padding: 24px 16px 48px; }
				.hero-title { font-size: 2.2rem; }
				.cat-tiles { grid-template-columns: 1fr; }
				.posts-grid { grid-template-columns: 1fr; }
				.post-card--featured { grid-column: auto; }
			}
		</style>
	</body>
</html>
