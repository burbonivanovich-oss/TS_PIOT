---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const title = 'О проекте';
const description =
	'Регламент.Бизнес — независимый информационный портал для МСБ. Простым языком разбираем требования ТС ПИоТ, маркировки «Честный знак» и изменения в законодательстве.';
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<article class="static-page">
				<h1>О проекте «{SITE_TITLE}»</h1>
				<p class="lead">
					Мы помогаем малому и среднему бизнесу разобраться с потоком регуляторных
					требований и не пропустить сроки введения новых правил.
				</p>

				<h2>Что мы публикуем</h2>
				<ul>
					<li>
						<strong>Разборы новых требований.</strong> Что такое ТС ПИоТ, кто обязан его подключать,
						как настроить и какие штрафы за отсутствие.
					</li>
					<li>
						<strong>Гайды по маркировке.</strong> Категории товаров, сроки введения,
						разрешительный режим, поэкземплярный учёт, типичные ошибки кассы.
					</li>
					<li>
						<strong>Изменения в законодательстве.</strong> Налоги, ЕНС/ЕНП, ЭДО, КЭДО,
						проверки, трудовое право, лимиты УСН и патент.
					</li>
					<li>
						<strong>Чек-листы и шаблоны.</strong> Готовые документы и пошаговые инструкции,
						которые можно скачать и использовать в работе.
					</li>
				</ul>

				<h2>Принципы редакции</h2>
				<ol>
					<li>
						<strong>Источники.</strong> Ссылаемся на официальные нормативные акты, разъяснения
						ведомств и публикации профильных регуляторов.
					</li>
					<li>
						<strong>Актуальность.</strong> Мы помечаем дату публикации и обновляем материалы при
						изменении требований.
					</li>
					<li>
						<strong>Без воды.</strong> Конкретные действия, сроки, формы документов и сценарии,
						что делать, если что-то пошло не так.
					</li>
				</ol>

				<h2>Важная оговорка</h2>
				<p>
					Материалы портала носят информационный характер и не являются
					индивидуальной юридической, налоговой или бухгалтерской консультацией.
					Перед принятием решений сверяйтесь с действующей редакцией нормативных
					актов и при необходимости обращайтесь к профильным специалистам.
				</p>

				<h2>Связаться с нами</h2>
				<p>
					Нашли ошибку или хотите предложить тему? Напишите на
					<a href="mailto:hello@reglament-biznes.ru">hello@reglament-biznes.ru</a>.
				</p>
			</article>
		</main>
		<Footer />

		<style>
			.static-page {
				max-width: 760px;
				margin: 0 auto;
				padding: 2rem 0;
			}
			.lead {
				font-size: 1.15rem;
				color: rgb(var(--gray-dark));
			}
		</style>
	</body>
</html>
