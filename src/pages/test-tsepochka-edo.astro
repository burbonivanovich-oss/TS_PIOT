---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import EdoChainPuzzle from '../components/interactive/EdoChainPuzzle.tsx';
import CpaCallout from '../components/CpaCallout.astro';
import { u } from '../utils/url';

const title = 'Цепочка ЭДО при маркировке: соберите по шагам';
const description =
	'7 карточек документооборота — от эмиссии кодов до отметки «выведен из оборота». Перетащите в правильном порядке. Тренажёр для тех, кто работает с маркированным товаром.';
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		<main class="puzzle-page">
			<article>
				<header class="puzzle-hero">
					<p class="puzzle-eyebrow">Тренажёр · 7 карточек · 2 минуты</p>
					<h1>{title}</h1>
					<p class="puzzle-lead">
						Путь маркированного товара от ЦРПТ до кассы в магазине — это не
						одна операция, а цепочка ЭДО и фискальных документов. Соберите её
						в правильном порядке. После проверки появится разбор каждого шага.
					</p>
				</header>

				<EdoChainPuzzle client:load />

				<CpaCallout id="kontur-diadoc" />

				<section class="puzzle-foot">
					<h2>Если хотите глубже</h2>
					<ul>
						<li><a href={u('/kak-rabotaet-ts-piot/')}>Как работает ТС ПИоТ — пошаговый разбор пути одного чека</a></li>
						<li><a href={u('/test-ts-piot/')}>Готов ли ваш бизнес к ТС ПИоТ — тест за 2 минуты</a></li>
						<li><a href={u('/category/markirovka/')}>Раздел «Маркировка» — статьи по категориям и срокам</a></li>
						<li><a href={u('/blog/2026-05-01-shtraf-za-markirovku/')}>Штрафы за нарушения маркировки</a></li>
					</ul>
				</section>
			</article>
		</main>

		<Footer />

		<style>
			.puzzle-page {
				max-width: 760px;
				margin: 0 auto;
				padding: 2rem 1rem 4rem;
			}
			.puzzle-hero { margin-bottom: 2rem; }
			.puzzle-eyebrow {
				font-size: 0.85rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--pink, #ff4d8f);
				margin: 0 0 0.5rem;
			}
			.puzzle-hero h1 {
				font-size: clamp(1.5rem, 4vw, 2.2rem);
				line-height: 1.15;
				margin: 0 0 1rem;
			}
			.puzzle-lead {
				font-size: 1.05rem;
				line-height: 1.55;
				color: #333;
				margin: 0;
			}
			.puzzle-foot {
				margin-top: 3rem;
				padding: 1.5rem;
				background: var(--sand, #f4ebd9);
				border-radius: 12px;
			}
			.puzzle-foot h2 {
				margin: 0 0 0.75rem;
				font-size: 1.2rem;
			}
			.puzzle-foot ul {
				margin: 0;
				padding-left: 1.25rem;
				line-height: 1.85;
			}
			.puzzle-foot a {
				color: var(--pink, #ff4d8f);
				font-weight: 500;
			}
		</style>
	</body>
</html>
