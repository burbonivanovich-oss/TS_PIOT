---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import ServicePicker from '../../components/interactive/ServicePicker.tsx';
import { u } from '../../utils/url';

const title = 'Подбор сервиса Контура под бизнес';
const description =
	'Ответьте на 3 вопроса о вашей задаче — касса, бухгалтерия, ЭДО, кадры, проверка контрагентов или счёт — и получите подходящий сервис Контура за минуту.';
const SITE = Astro.site ?? new URL('https://etiketka-media.ru');
const breadcrumbLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Главная', item: new URL('/', SITE).href },
		{ '@type': 'ListItem', position: 2, name: 'Магазин', item: new URL('/produkty/', SITE).href },
		{ '@type': 'ListItem', position: 3, name: 'Подбор сервиса' },
	],
};
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

		<main class="podbor">
			<header class="podbor-hero">
				<nav class="crumbs" aria-label="Хлебные крошки">
					<a href={u('/produkty/')}>Магазин</a><span>/</span><span>Подбор сервиса</span>
				</nav>
				<p class="podbor-eyebrow">Подбор · 3 вопроса · 1 минута</p>
				<h1>Подберите сервис Контура под свою задачу</h1>
				<p class="podbor-lead">
					Ответьте на пару вопросов о приоритетной задаче — кассе и
					маркировке, бухгалтерии, документах с контрагентами, кадрах,
					проверке контрагентов или расчётном счёте. Покажем сервис, который
					закроет задачу, и откроем страницу с условиями.
				</p>
			</header>

			<ServicePicker client:load />

			<section class="podbor-foot">
				<h2>Если хотите осмотреться сами</h2>
				<p>
					Откройте всю <a href={u('/produkty/')}>витрину сервисов</a> —
					карточки сгруппированы по задачам бизнеса. Чтобы взвесить близкие
					варианты бок о бок, загляните в <a href={u('/sravneniya/')}>сравнения</a>.
				</p>
			</section>
		</main>

		<Footer />

		<style>
			.podbor {
				max-width: 760px;
				margin: 0 auto;
				padding: 2.5rem 1rem 4rem;
			}
			.podbor-hero { margin-bottom: 2.5rem; }
			.crumbs { font-size: 0.8rem; color: #888; margin-bottom: 1rem; display: flex; gap: 0.4rem; }
			.crumbs a { color: #888; text-decoration: none; }
			.crumbs a:hover { color: #111; }
			.podbor-eyebrow {
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--pink, #ff4d8f);
				margin: 0 0 0.5rem;
				font-weight: 700;
			}
			.podbor-hero h1 {
				font-family: 'Bebas Neue', sans-serif;
				font-size: clamp(2rem, 5vw, 3.2rem);
				line-height: 0.95;
				margin: 0 0 1rem;
				text-transform: uppercase;
				letter-spacing: 0.02em;
				color: #111;
			}
			.podbor-lead {
				font-size: 1.05rem;
				line-height: 1.55;
				color: #555;
				margin: 0;
			}
			.podbor-foot {
				margin-top: 3rem;
				padding: 1.5rem;
				background: var(--sand, #f4ebd9);
				border-radius: 12px;
			}
			.podbor-foot h2 {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.4rem;
				letter-spacing: 0.02em;
				text-transform: uppercase;
				margin: 0 0 0.75rem;
				color: #111;
			}
			.podbor-foot p {
				margin: 0;
				line-height: 1.55;
				color: #444;
			}
			.podbor-foot a {
				color: var(--pink, #ff4d8f);
				font-weight: 600;
			}
		</style>
	</body>
</html>
