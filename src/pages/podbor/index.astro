---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { u } from '../../utils/url';
import { PRODUCT_CATALOG, CPA_BANNERS } from '../../data/cpa-banners';

const title = 'Подбор сервиса Контура под задачу бизнеса';
const description =
	'Ответьте на 2 вопроса — подберём сервис Контура под вашу задачу: касса с ТС ПИоТ, маркировка, бухгалтерия, ЭДО, кадры или проверка контрагентов.';

// Пул карточек продуктов (рендерим все, JS показывает подходящие).
const pool = PRODUCT_CATALOG.map(p => ({
	id: p.bannerId,
	slug: p.slug,
	audience: p.audience,
	banner: CPA_BANNERS[p.bannerId],
})).filter(p => p.banner);

const tasks = [
	{ id: 'kassa', label: 'Продавать маркированный товар или алкоголь через кассу' },
	{ id: 'ofd', label: 'Передавать чеки в ФНС (ОФД), зарегистрировать кассу' },
	{ id: 'markirovka', label: 'Маркировать товар как производитель или импортёр' },
	{ id: 'buh', label: 'Вести бухгалтерию, налоги и отчётность' },
	{ id: 'edo', label: 'Обмениваться документами с контрагентами (ЭДО, УПД)' },
	{ id: 'kadry', label: 'Перевести кадровые документы в электронный вид' },
	{ id: 'kontragenty', label: 'Проверять контрагентов перед сделкой' },
];
const forms = [
	{ id: 'ip-solo', label: 'ИП без сотрудников' },
	{ id: 'ip-staff', label: 'ИП с сотрудниками' },
	{ id: 'ooo', label: 'ООО' },
];
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		<main class="podbor">
			<header class="pb-hero">
				<p class="pb-eyebrow">Подбор сервиса</p>
				<h1>Какой сервис Контура вам нужен</h1>
				<p class="pb-lead">
					Два коротких вопроса — и мы предложим подходящее решение под вашу
					задачу. Заявку обрабатывает Контур, договор вы заключаете с ним напрямую.
				</p>
			</header>

			<!-- Шаг 1 -->
			<section class="pb-step" data-step="1">
				<div class="pb-q">Вопрос 1 из 2</div>
				<h2>Что для вас важнее всего прямо сейчас?</h2>
				<div class="pb-options">
					{tasks.map(t => (
						<button type="button" class="pb-opt" data-task={t.id}>{t.label}</button>
					))}
				</div>
			</section>

			<!-- Шаг 2 -->
			<section class="pb-step is-hidden" data-step="2">
				<div class="pb-q">Вопрос 2 из 2</div>
				<h2>Какая у вас форма бизнеса?</h2>
				<div class="pb-options">
					{forms.map(f => (
						<button type="button" class="pb-opt" data-form={f.id}>{f.label}</button>
					))}
				</div>
				<button type="button" class="pb-back" data-back>← Назад</button>
			</section>

			<!-- Результат -->
			<section class="pb-step is-hidden" data-step="result">
				<div class="pb-q">Рекомендуем</div>
				<h2 id="pb-result-title">Подходящие сервисы</h2>
				<div class="pb-result-grid" id="pb-result-grid">
					{pool.map(p => (
						<a class="pb-card is-hidden" data-product={p.id} href={u(`/produkty/${p.slug}/`)}>
							<span class="pb-visual" style={`background:${p.banner.visual.bg}`}>{p.banner.visual.abbrev}</span>
							<span class="pb-body">
								<span class="pb-title">{p.banner.title}</span>
								<span class="pb-audience">{p.audience}</span>
								<span class="pb-cta">Подробнее и заявка →</span>
							</span>
						</a>
					))}
				</div>
				<div class="pb-actions">
					<button type="button" class="pb-restart" data-restart>Пройти заново</button>
					<a class="pb-alllink" href={u('/produkty/')}>Все сервисы →</a>
					<a class="pb-alllink" href={u('/sravneniya/')}>Сравнения и выбор →</a>
				</div>
			</section>
		</main>

		<Footer />

		<script>
			// Логика подбора: задача (Q1) задаёт основной продукт, форма (Q2) добавляет
			// сопутствующие. Все карточки уже в DOM — показываем подходящие.
			const steps: Record<string, HTMLElement | null> = {
				'1': document.querySelector('[data-step="1"]'),
				'2': document.querySelector('[data-step="2"]'),
				'result': document.querySelector('[data-step="result"]'),
			};
			let task = '';

			function show(step: string) {
				Object.entries(steps).forEach(([k, el]) => el?.classList.toggle('is-hidden', k !== step));
				window.scrollTo({ top: 0, behavior: 'smooth' });
			}

			// task → основной продукт (для buh уточняется формой)
			const taskMap: Record<string, string[]> = {
				kassa: ['kontur-market', 'kontur-ofd'],
				ofd: ['kontur-ofd'],
				markirovka: ['kontur-markirovka', 'kontur-diadoc'],
				buh: [],
				edo: ['kontur-diadoc'],
				kadry: ['diadoc-kedo'],
				kontragenty: ['kontur-focus'],
			};

			function recommend(form: string): string[] {
				const ids = [...(taskMap[task] || [])];
				// Бухгалтерия зависит от формы.
				if (task === 'buh') {
					ids.push(form === 'ooo' ? 'kontur-extern' : 'kontur-elba');
				}
				// Сопутствующее по форме бизнеса.
				if (form === 'ip-staff' && !ids.includes('diadoc-kedo')) ids.push('diadoc-kedo');
				if (form === 'ooo' && !ids.includes('kontur-mchd')) ids.push('kontur-mchd');
				return [...new Set(ids)];
			}

			document.querySelectorAll<HTMLButtonElement>('[data-task]').forEach(btn => {
				btn.addEventListener('click', () => { task = btn.dataset.task || ''; show('2'); });
			});
			document.querySelector('[data-back]')?.addEventListener('click', () => show('1'));
			document.querySelector('[data-restart]')?.addEventListener('click', () => { task = ''; show('1'); });

			document.querySelectorAll<HTMLButtonElement>('[data-form]').forEach(btn => {
				btn.addEventListener('click', () => {
					const ids = recommend(btn.dataset.form || '');
					document.querySelectorAll<HTMLElement>('[data-product]').forEach(card => {
						card.classList.toggle('is-hidden', !ids.includes(card.dataset.product || ''));
					});
					show('result');
				});
			});
		</script>

		<style>
			.podbor { max-width: 820px; margin: 0 auto; padding: 2.5rem 1rem 4rem; }
			.pb-hero { margin-bottom: 2rem; }
			.pb-eyebrow {
				font-size: .8rem; text-transform: uppercase; letter-spacing: .1em;
				color: var(--pink, #9E2B4F); font-weight: 700; margin: 0 0 .5rem;
			}
			.pb-hero h1 {
				font-family: 'Bebas Neue', sans-serif; font-size: clamp(2rem, 5vw, 3rem);
				line-height: .95; text-transform: uppercase; letter-spacing: .02em; margin: 0 0 1rem; color: #111;
			}
			.pb-lead { margin: 0; font-size: 1.05rem; color: #555; line-height: 1.55; }

			.pb-step { margin-top: 1.5rem; }
			.pb-step.is-hidden { display: none; }
			.pb-q {
				font-family: var(--f-mono, monospace); font-size: .72rem; letter-spacing: .06em;
				text-transform: uppercase; color: var(--pink, #9E2B4F); margin-bottom: .5rem;
			}
			.pb-step h2 {
				font-family: 'Bebas Neue', sans-serif; font-size: 1.7rem; letter-spacing: .02em;
				text-transform: uppercase; margin: 0 0 1.25rem; color: #111;
			}
			.pb-options { display: flex; flex-direction: column; gap: 8px; }
			.pb-opt {
				text-align: left; padding: 16px 18px; background: #fff;
				border: 1.5px solid var(--line, #E5E1D8); cursor: pointer;
				font-size: .98rem; color: #111; line-height: 1.4; transition: all .15s;
			}
			.pb-opt:hover { border-color: #111; transform: translateX(4px); }
			.pb-back, .pb-restart {
				margin-top: 1.25rem; background: none; border: 0; cursor: pointer;
				font-size: .8rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
				color: var(--ink-3, #666);
			}
			.pb-back:hover, .pb-restart:hover { color: #111; }

			.pb-result-grid { display: grid; gap: 8px; }
			.pb-card {
				display: grid; grid-template-columns: 56px 1fr; gap: 14px; padding: 18px;
				background: #fff; border: 1.5px solid var(--line, #E5E1D8);
				text-decoration: none; color: #111; transition: all .15s;
			}
			.pb-card.is-hidden { display: none; }
			.pb-card:hover { border-color: #111; transform: translateY(-2px); }
			.pb-visual {
				display: flex; align-items: center; justify-content: center; aspect-ratio: 1;
				border-radius: 2px; color: #fff; font-family: 'Bebas Neue', sans-serif;
				font-size: 1.1rem; letter-spacing: .04em;
			}
			.pb-body { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
			.pb-title {
				font-family: 'Bebas Neue', sans-serif; font-size: 1.05rem; line-height: 1.1;
				letter-spacing: .02em; text-transform: uppercase;
			}
			.pb-audience { font-size: .85rem; line-height: 1.4; color: var(--ink-3, #666); }
			.pb-cta {
				font-size: .68rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
				color: var(--pink, #9E2B4F); margin-top: auto;
			}
			.pb-actions { display: flex; flex-wrap: wrap; gap: 1.25rem; align-items: center; margin-top: 1.5rem; }
			.pb-alllink {
				font-size: .8rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
				color: var(--pink, #9E2B4F); text-decoration: none;
			}
		</style>
	</body>
</html>
