---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = 'Поиск по сайту';
const description =
	'Поиск по материалам портала «Регламент.Бизнес»: статьи о ТС ПИоТ, маркировке «Честный знак» и изменениях в законодательстве для МСБ.';
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
		<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<h1>{title}</h1>
				<p>{description}</p>
			</header>

			<div id="search" class="search-widget"></div>

			<noscript>
				<p class="noscript">
					Для поиска требуется JavaScript. Если он у вас отключён —
					<a href="/blog/">посмотрите все статьи</a> или перейдите в нужный раздел:
					<a href="/category/ts-piot/">ТС ПИоТ</a>,
					<a href="/category/markirovka/">Маркировка</a>,
					<a href="/category/zakonodatelstvo/">Законодательство</a>.
				</p>
			</noscript>
		</main>
		<Footer />

		<script src="/pagefind/pagefind-ui.js" is:inline></script>
		<script is:inline>
			window.addEventListener('DOMContentLoaded', () => {
				if (typeof PagefindUI === 'undefined') return;
				const ui = new PagefindUI({
					element: '#search',
					showSubResults: true,
					showImages: false,
					resetStyles: false,
					translations: {
						placeholder: 'Найти: ТС ПИоТ, маркировка, УСН…',
						clear_search: 'Очистить',
						load_more: 'Показать ещё',
						search_label: 'Поиск по сайту',
						filters_label: 'Фильтры',
						zero_results: 'По запросу «[SEARCH_TERM]» ничего не найдено',
						many_results: 'Найдено [COUNT] материалов по запросу «[SEARCH_TERM]»',
						one_result: 'Найден 1 материал по запросу «[SEARCH_TERM]»',
						alt_search: 'По запросу «[SEARCH_TERM]» ничего нет. Возможно, имелось в виду:',
						search_suggestion: 'По запросу «[SEARCH_TERM]» подходят:',
						searching: 'Ищем «[SEARCH_TERM]»…',
					},
				});
				const params = new URLSearchParams(window.location.search);
				const q = params.get('q');
				if (q) ui.triggerSearch(q);
			});
		</script>

		<style>
			.page-head {
				padding: 2rem 0 1rem;
			}
			.page-head p {
				color: rgb(var(--gray-dark));
				font-size: 1.05rem;
				max-width: 720px;
			}
			.search-widget {
				margin: 1rem 0 3rem;
				--pagefind-ui-primary: var(--accent);
				--pagefind-ui-text: rgb(var(--gray-dark));
				--pagefind-ui-background: #fff;
				--pagefind-ui-border: rgb(var(--gray-light));
				--pagefind-ui-tag: var(--accent-soft);
				--pagefind-ui-border-radius: 10px;
				--pagefind-ui-border-width: 1px;
				--pagefind-ui-font: inherit;
			}
			.noscript {
				margin-top: 1.5rem;
				padding: 1rem;
				background: var(--accent-soft);
				border-radius: 8px;
			}
		</style>
	</body>
</html>
