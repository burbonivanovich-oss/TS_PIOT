---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ZakonTimeline, { type Norm } from '../components/interactive/ZakonTimeline.tsx';
import CpaCallout from '../components/CpaCallout.astro';
import { u } from '../utils/url';

const title = 'Журнал изменений законодательства 2026 для МСБ';
const description =
	'Хронологический трекер: какие нормы для малого и среднего бизнеса вступают в силу в 2026 году. Фильтр по месяцам и темам — налоги, маркировка, ТС ПИоТ, ККТ, трудовое право.';

const norms: Norm[] = [
	{
		date: '2025-12-28',
		monthIdx: 11,
		title: 'ТС ПИоТ обязателен на каждой кассе с маркированным товаром',
		category: 'ts-piot',
		source: 'ПП № 1944 от 21.11.2023',
		sourceUrl: 'http://publication.pravo.gov.ru/document/0001202311270058',
		summary:
			'Кассы, через которые проходят маркированные товары, должны быть оснащены программным модулем ТС ПИоТ. До 01.07.2026 ещё можно работать через X-API-KEY ЦРПТ, но после этой даты токены отключают.',
		articleUrl: '/blog/2026-01-15-chto-takoe-ts-piot/',
	},
	{
		date: '2026-01-01',
		monthIdx: 0,
		title: 'НДС для УСН с оборотом свыше 60 млн ₽',
		category: 'nalogi',
		source: '176-ФЗ от 12.07.2024',
		summary:
			'Упрощенцы с годовым доходом выше 60 млн ₽ становятся плательщиками НДС. Можно выбрать пониженные ставки 5% (до 250 млн) и 7% (250–450 млн) без вычетов или общую 20% с правом на вычет.',
		articleUrl: '/blog/2026-03-05-nalogi-msb-2026/',
	},
	{
		date: '2026-01-01',
		monthIdx: 0,
		title: 'Изменение лимитов УСН',
		category: 'nalogi',
		source: '176-ФЗ от 12.07.2024',
		summary:
			'Базовый лимит для УСН с 2026 года повышается. Сохраняется единая шкала: до достижения порога — пониженные ставки, выше — повышенные с переходом к ОСН при превышении максимального лимита.',
	},
	{
		date: '2026-01-01',
		monthIdx: 0,
		title: 'Повышение МРОТ',
		category: 'trud',
		source: '82-ФЗ',
		summary:
			'МРОТ индексируется. Под пересчёт попадают минимальная зарплата, пособия по временной нетрудоспособности, расчёт отпускных и компенсаций при увольнении.',
	},
	{
		date: '2026-03-01',
		monthIdx: 2,
		title: 'Маркировка сахаристых кондитерских изделий — производители',
		category: 'markirovka',
		source: 'ПП № 818 от 31.05.2025',
		summary:
			'Печенье, мармелад, зефир, шоколадная паста, конфеты — производители обязаны наносить DataMatrix-коды и вводить продукцию в оборот через «Честный знак».',
	},
	{
		date: '2026-03-01',
		monthIdx: 2,
		title: 'Маркировка безалкогольных напитков — поэкземплярный учёт',
		category: 'markirovka',
		source: 'ПП № 887 от 31.05.2023',
		summary:
			'С 01.03.2025 уже идёт объёмно-сортовой учёт через ККТ. С марта 2026 — поэкземплярный учёт: каждая бутылка лимонада или сока со своим уникальным кодом.',
	},
	{
		date: '2026-03-01',
		monthIdx: 2,
		title: 'Маркировка пива — поэкземпляр и разрешительный режим',
		category: 'markirovka',
		source: 'ПП о маркировке пива',
		summary:
			'Розничные продажи пива и пивных напитков переходят на поэкземплярный учёт. На кассах включается разрешительный режим: запрос в «Честный знак» перед каждой продажей.',
	},
	{
		date: '2026-07-01',
		monthIdx: 6,
		title: 'Отключение X-API-KEY ЦРПТ — ТС ПИоТ становится обязательным фактически',
		category: 'ts-piot',
		source: 'Разъяснения ФНС и ЦРПТ',
		summary:
			'Старая схема работы с кассой через токен X-API-KEY перестаёт поддерживаться. Без установленного ТС ПИоТ продать маркированный товар технически невозможно — касса заблокирует операцию.',
		articleUrl: '/blog/2026-01-15-chto-takoe-ts-piot/',
	},
	{
		date: '2026-09-01',
		monthIdx: 8,
		title: 'Маркировка сахаристых кондитерских изделий — розница',
		category: 'markirovka',
		source: 'ПП № 818 от 31.05.2025',
		summary:
			'Розничные продажи сладостей через ККТ. На первом этапе — объёмно-сортовой учёт: при продаже передаётся информация о товарной группе и количестве, ещё без идентификации каждой пачки.',
	},
	{
		date: '2026-12-01',
		monthIdx: 11,
		title: 'Корма для животных — поэкземплярный учёт',
		category: 'markirovka',
		source: 'ПП № 674 от 27.05.2024',
		summary:
			'Сухие и влажные корма для домашних животных переходят на поэкземплярный учёт. Зоомагазины должны включить разрешительный режим на кассах.',
	},
];
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		<main class="zakon-page">
			<article>
				<header class="zakon-hero">
					<p class="zakon-eyebrow">Журнал · 2026 год</p>
					<h1>{title}</h1>
					<p class="zakon-lead">
						Десять ключевых норм для МСБ — налоги, маркировка, ТС ПИоТ, кассовый
						учёт. Передвигайте ползунки, чтобы увидеть, что вступает в окне
						выбранных месяцев. Цифры на шкале — количество изменений в этом месяце.
					</p>
				</header>

				<ZakonTimeline norms={norms} client:visible />

				<CpaCallout id="kontur-extern" />

				<aside class="zakon-foot">
					<p>
						Если хочется не списком, а пройти всю цепочку «как живёт чек в ТС ПИоТ»
						руками — у нас есть{' '}
						<a href={u('/kak-rabotaet-ts-piot/')}>интерактивный симулятор</a>.
					</p>
				</aside>
			</article>
		</main>

		<Footer />

		<style>
			.zakon-page {
				max-width: 860px;
				margin: 0 auto;
				padding: 2rem 1rem 4rem;
			}
			.zakon-hero {
				margin-bottom: 2rem;
			}
			.zakon-eyebrow {
				font-size: 0.85rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--pink, #9E2B4F);
				margin: 0 0 0.5rem;
			}
			.zakon-hero h1 {
				font-size: clamp(1.5rem, 4vw, 2.2rem);
				line-height: 1.15;
				margin: 0 0 1rem;
			}
			.zakon-lead {
				font-size: 1.05rem;
				line-height: 1.55;
				color: #333;
				margin: 0;
			}
			.zakon-foot {
				margin-top: 3rem;
				padding: 1.25rem 1.5rem;
				background: var(--sand, #f4ebd9);
				border-radius: 12px;
				font-size: 0.95rem;
				line-height: 1.55;
				color: #333;
			}
			.zakon-foot a {
				color: var(--pink, #9E2B4F);
				font-weight: 600;
			}
		</style>
	</body>
</html>
