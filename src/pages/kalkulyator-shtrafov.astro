---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PenaltyCalculator from '../components/PenaltyCalculator';
import { SITE_TITLE } from '../consts';
import { SCENARIOS } from '../data/penalties';

const title = 'Калькулятор штрафов для бизнеса';
const description =
	'Бесплатный калькулятор штрафов по КоАП РФ для МСБ: ККТ, маркировка «Честный знак», ст. 14.5 и 15.12. Введите параметры — получите диапазон штрафа и ссылку на статью.';

const FAQ_ITEMS: { question: string; answer: string }[] = [
	{
		question:
			'Чем отличается штраф для ИП и должностного лица от штрафа для юридического лица?',
		answer:
			'КоАП устанавливает разные шкалы. Индивидуальный предприниматель по большинству норм приравнен к должностному лицу — это нижняя шкала. Юридические лица платят на порядок больше: например, по ст. 15.12 ч. 2 КоАП РФ за продажу немаркированного товара ИП заплатит до 15 000 ₽, юрлицо — до 300 000 ₽. В калькуляторе вы видите оба варианта при выборе соответствующего пункта в форме.',
	},
	{
		question: 'Учитывает ли калькулятор повторное нарушение?',
		answer:
			'Нет. При повторном неприменении ККТ (ст. 14.5 ч. 3 КоАП) и сумме расчётов от 1 млн ₽ предусмотрена дисквалификация должностного лица на срок до двух лет или приостановка деятельности юрлица до 90 суток. Это отдельная мера, выходящая за рамки штрафа.',
	},
	{
		question: 'Когда применяется уголовная ответственность по ст. 171.1 УК РФ?',
		answer:
			'Если оборот немаркированных товаров составил крупный размер (свыше 2,25 млн ₽ для большинства категорий) или особо крупный (свыше 9 млн ₽). В таких случаях дело идёт по уголовной статье, а не по ст. 15.12 КоАП РФ. Калькулятор такие суммы не учитывает — это предмет отдельной правовой оценки.',
	},
	{
		question:
			'Почему по ст. 14.5 ч. 2 КоАП РФ штраф зависит от суммы расчёта?',
		answer:
			'Это процентная норма: для ИП и должностных лиц штраф составляет 25–50% от суммы расчёта без ККТ, но не менее 10 000 ₽; для юрлиц — 75–100%, но не менее 30 000 ₽. Поэтому при выборе сценария «не применил ККТ» в калькуляторе появляется поле для ввода суммы.',
	},
	{
		question: 'Можно ли заменить штраф предупреждением?',
		answer:
			'По ряду статей КоАП первое нарушение можно заменить предупреждением — это касается, например, ч. 4–6 ст. 14.5 (нарушение требований к ККТ, ненаправление электронного чека). Решение принимает инспектор или суд. По ст. 15.12 (маркировка) предупреждение, как правило, не предусмотрено.',
	},
	{
		question: 'На какую дату актуальны цифры в калькуляторе?',
		answer:
			'Калькулятор использует редакции КоАП РФ, действующие на момент публикации страницы. Перед использованием результата сверьтесь с действующей редакцией на pravo.gov.ru или в справочно-правовой системе. Мы обновляем сценарии при изменении норм.',
	},
];

const breadcrumbsJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Главная',
			item: new URL('/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: title,
			item: new URL('/kalkulyator-shtrafov/', Astro.site).toString(),
		},
	],
};

const appJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: title,
	url: new URL('/kalkulyator-shtrafov/', Astro.site).toString(),
	applicationCategory: 'BusinessApplication',
	operatingSystem: 'Web',
	browserRequirements: 'Requires JavaScript',
	inLanguage: 'ru-RU',
	publisher: { '@type': 'Organization', name: SITE_TITLE },
	offers: { '@type': 'Offer', price: 0, priceCurrency: 'RUB' },
};

const faqJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: FAQ_ITEMS.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: { '@type': 'Answer', text: item.answer },
	})),
};
import { u } from '../utils/url';
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead
			title={title}
			description={description}
			jsonLd={[breadcrumbsJsonLd, appJsonLd, faqJsonLd]}
		/>
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumbs" aria-label="Хлебные крошки">
				<a href={u("/")}>Главная</a>
				<span>›</span>
				<span aria-current="page">{title}</span>
			</nav>

			<header class="page-head">
				<h1>{title}</h1>
				<p class="lead">
					Введите тип нарушения и форму бизнеса — увидите минимальный и максимальный
					размер штрафа со ссылкой на статью КоАП РФ. Расчёт мгновенный, ничего
					заполнять и отправлять не нужно.
				</p>

				<div class="intro">
					<p>
						Калькулятор охватывает основные нарушения, с которыми сталкивается малый и
						средний бизнес: применение ККТ (<a href={u("/category/ts-piot/")}>ст. 14.5 КоАП</a>),
						маркировка «Честный знак» (<a href={u("/category/markirovka/")}>ст. 15.12 и 15.12.1 КоАП</a>),
						несоответствие данных в системе мониторинга. Не учитываются: уголовная
						ответственность по ст. 171.1 УК РФ за крупный сбыт, специфические шкалы по
						алкоголю и табаку, а также штрафы по другим статьям (например, нарушение
						кассовой дисциплины наличными).
					</p>
					<p>
						Тема стала особенно актуальной с 28 декабря 2025 года, когда обязательным стал
						<a href={u("/slovar/#тс-пиот")}>ТС ПИоТ</a> — программный модуль, через который
						касса проверяет коды маркировки в «Честном знаке». Каждая попытка пробить
						немаркированный товар фиксируется в логах ОФД и становится поводом для штрафа
						даже без визита инспектора.
					</p>
					<p>
						КоАП обычно даёт диапазон «от — до». Конкретный размер выбирает инспектор или
						суд, исходя из обстоятельств: наличия повторности, тяжести последствий,
						смягчающих и отягчающих факторов. Поэтому ниже вы видите вилку, а не одно
						число.
					</p>
				</div>
			</header>

			<PenaltyCalculator client:load />

			<section class="how-to">
				<h2>Как пользоваться калькулятором</h2>
				<ol>
					<li>
						<strong>Выберите сценарий.</strong> В списке — типичные нарушения МСБ: не
						пробил чек, нарушение в работе ККТ, не направил электронный чек, продажа
						или производство немаркированного товара, расхождение данных в «Честном знаке».
					</li>
					<li>
						<strong>Укажите субъекта.</strong> Для ИП и должностных лиц действует одна
						шкала, для юридических лиц — другая. Если нарушение совершил наёмный
						кассир, по ст. 14.5 КоАП штраф несёт работодатель: ИП или юрлицо.
					</li>
					<li>
						<strong>Если выбран сценарий «не применил ККТ»</strong> — введите сумму
						расчёта без ККТ. Штраф рассчитывается как процент от неё, но не ниже
						минимума, заданного нормой.
					</li>
					<li>
						<strong>Сохраните результат и сверьте статью КоАП.</strong> Перед оплатой
						штрафа или подачей возражений проверьте действующую редакцию нормы на
						<a
							href="https://pravo.gov.ru"
							rel="nofollow noopener"
							target="_blank"
							>pravo.gov.ru</a
						>
						или в справочно-правовой системе.
					</li>
				</ol>
			</section>

			<section class="disclaimer">
				<p>
					<strong>Дисклеймер.</strong> Калькулятор показывает диапазоны штрафов
					по действующим редакциям КоАП РФ. Окончательный размер штрафа определяет
					инспектор или суд исходя из обстоятельств. Калькулятор не учитывает
					повторность, тяжесть последствий, смягчающие/отягчающие обстоятельства и
					уголовную ответственность по ст. 171.1 УК РФ. Перед принятием решений
					сверьтесь с актуальной редакцией нормативных актов.
				</p>
			</section>

			<section class="all-scenarios">
				<h2>Все учтённые сценарии</h2>
				<ul>
					{SCENARIOS.map((s) => (
						<li>
							<strong>{s.label}.</strong> {s.short} — <em>{s.article}</em>.
							{s.confiscation && <span class="badge">+ конфискация</span>}
						</li>
					))}
				</ul>
			</section>

			<section class="faq" aria-labelledby="faq-heading">
				<h2 id="faq-heading">Частые вопросы</h2>
				{FAQ_ITEMS.map((item) => (
					<details class="faq-item">
						<summary>{item.question}</summary>
						<p>{item.answer}</p>
					</details>
				))}
			</section>

			<section class="related">
				<h2>Полезно почитать</h2>
				<ul>
					<li>
						<a href={u("/category/ts-piot/")}>ТС ПИоТ — раздел</a>: что это, кто обязан, сроки и штрафы.
					</li>
					<li>
						<a href={u("/category/markirovka/")}>Маркировка «Честный знак» — раздел</a>: категории
						товаров, разрешительный режим, поэкземплярный учёт.
					</li>
					<li>
						<a href={u("/blog/2026-01-15-chto-takoe-ts-piot/")}>Что такое ТС ПИоТ</a> — пошаговый
						разбор технического средства получения информации о товаре.
					</li>
					<li>
						<a href={u("/blog/2026-02-10-kategorii-markirovki-2026/")}>Категории маркировки 2026</a>
						 — таблица сроков по товарным группам.
					</li>
					<li>
						<a href={u("/slovar/")}>Глоссарий</a>: расшифровка терминов из калькулятора —
						<a href={u("/slovar/#тс-пиот")}>ТС ПИоТ</a>,
						<a href={u("/slovar/#честный-знак")}>«Честный знак»</a>,
						<a href={u("/slovar/#офд")}>ОФД</a>,
						<a href={u("/slovar/#укэп")}>УКЭП</a>.
					</li>
				</ul>
			</section>
		</main>
		<Footer />


		<style>
			.breadcrumbs {
				font-size: 0.88rem;
				color: rgb(var(--gray));
				margin-top: 1rem;
			}
			.breadcrumbs a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumbs a:hover {
				color: var(--accent);
			}
			.breadcrumbs span {
				margin: 0 0.4em;
			}
			.page-head {
				padding: 1.5rem 0 1rem;
				max-width: 820px;
			}
			.page-head .lead {
				color: rgb(var(--gray-dark));
				font-size: 1.1rem;
			}
			.intro {
				margin-top: 1rem;
			}
			.intro p {
				color: rgb(var(--gray-dark));
				font-size: 1rem;
				line-height: 1.65;
				margin: 0 0 0.9rem;
			}
			.how-to {
				max-width: 820px;
				margin-top: 2.5rem;
			}
			.how-to ol {
				margin: 1rem 0 0;
				padding-left: 1.2rem;
			}
			.how-to li {
				margin-bottom: 0.8rem;
				color: rgb(var(--gray-dark));
				line-height: 1.6;
			}
			.disclaimer {
				max-width: 820px;
				margin-top: 1.5rem;
				padding: 1rem 1.2rem;
				background: rgba(var(--gray-light), 0.6);
				border-radius: 8px;
				font-size: 0.92rem;
				color: rgb(var(--gray-dark));
			}
			.disclaimer p {
				margin: 0;
			}
			.all-scenarios {
				max-width: 820px;
				margin-top: 2.5rem;
			}
			.all-scenarios ul {
				list-style: none;
				padding: 0;
				margin: 1rem 0 0;
			}
			.all-scenarios li {
				padding: 0.8rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
				font-size: 0.95rem;
			}
			.all-scenarios li:last-child {
				border-bottom: none;
			}
			.all-scenarios em {
				color: var(--accent);
				font-style: normal;
				font-weight: 600;
			}
			.badge {
				display: inline-block;
				font-size: 0.78rem;
				font-weight: 600;
				color: #b45309;
				background: #fef3c7;
				padding: 0.15em 0.6em;
				border-radius: 999px;
				margin-left: 0.4rem;
			}
			.faq {
				max-width: 820px;
				margin-top: 2.5rem;
			}
			.faq-item {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 0.9rem 1.1rem;
				margin-top: 0.6rem;
				background: #fff;
			}
			.faq-item[open] {
				border-color: var(--accent);
			}
			.faq-item summary {
				cursor: pointer;
				font-weight: 600;
				color: rgb(var(--black));
				list-style: none;
				display: flex;
				justify-content: space-between;
				gap: 1rem;
			}
			.faq-item summary::-webkit-details-marker {
				display: none;
			}
			.faq-item summary::after {
				content: '+';
				font-size: 1.4rem;
				color: var(--accent);
				line-height: 1;
				flex-shrink: 0;
			}
			.faq-item[open] summary::after {
				content: '−';
			}
			.faq-item p {
				margin: 0.7rem 0 0;
				color: rgb(var(--gray-dark));
			}
			.related {
				max-width: 820px;
				margin-top: 2.5rem;
			}
			.related ul {
				margin: 1rem 0 0;
				padding-left: 1.2rem;
			}
			.related li {
				margin-bottom: 0.6rem;
				color: rgb(var(--gray-dark));
				line-height: 1.6;
			}
		</style>
	</body>
</html>
