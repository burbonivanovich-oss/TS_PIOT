---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { SCENARIOS } from '../data/penalties';

const title = 'Калькулятор штрафов для бизнеса';
const description =
	'Бесплатный калькулятор штрафов по КоАП РФ для МСБ: ККТ, маркировка «Честный знак», ст. 14.5 и 15.12. Введите параметры — получите диапазон штрафа и ссылку на статью.';

const breadcrumbsJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Главная',
			item: new URL('/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: title,
			item: new URL('/kalkulyator-shtrafov/', Astro.site).toString(),
		},
	],
};

const appJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: title,
	url: new URL('/kalkulyator-shtrafov/', Astro.site).toString(),
	applicationCategory: 'BusinessApplication',
	operatingSystem: 'Web',
	browserRequirements: 'Requires JavaScript',
	inLanguage: 'ru-RU',
	publisher: { '@type': 'Organization', name: SITE_TITLE },
	offers: { '@type': 'Offer', price: 0, priceCurrency: 'RUB' },
};
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead
			title={title}
			description={description}
			jsonLd={[breadcrumbsJsonLd, appJsonLd]}
		/>
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumbs" aria-label="Хлебные крошки">
				<a href="/">Главная</a>
				<span>›</span>
				<span aria-current="page">{title}</span>
			</nav>

			<header class="page-head">
				<h1>{title}</h1>
				<p>
					Введите тип нарушения и форму бизнеса — увидите минимальный и максимальный
					размер штрафа со ссылкой на статью КоАП и пояснением. Цифры основаны на
					действующих редакциях КоАП РФ; они не заменяют юридическую консультацию.
				</p>
			</header>

			<form class="calc" id="calc" novalidate>
				<div class="field">
					<label for="scenario">Что произошло?</label>
					<select id="scenario" name="scenario">
						{SCENARIOS.map((s) => (
							<option value={s.id}>{s.label}</option>
						))}
					</select>
				</div>

				<div class="field">
					<label for="subject">Кто нарушил?</label>
					<select id="subject" name="subject">
						<option value="ip">ИП или должностное лицо</option>
						<option value="legal">Юридическое лицо</option>
					</select>
				</div>

				<div class="field" id="amount-field" hidden>
					<label for="amount">Сумма расчёта без ККТ, ₽</label>
					<input
						id="amount"
						name="amount"
						type="number"
						min="0"
						step="100"
						inputmode="numeric"
						placeholder="например, 50000"
					/>
					<small class="hint">Сумма всех продаж, не пробитых через кассу.</small>
				</div>
			</form>

			<section class="result" id="result" aria-live="polite" aria-atomic="true">
				<!-- Заполняется JS -->
			</section>

			<section class="disclaimer">
				<p>
					<strong>Дисклеймер.</strong> Калькулятор показывает диапазоны штрафов
					по действующим редакциям КоАП РФ. Окончательный размер штрафа определяет
					инспектор или суд исходя из обстоятельств. Калькулятор не учитывает
					повторность, тяжесть последствий, смягчающие/отягчающие обстоятельства и
					уголовную ответственность по ст. 171.1 УК РФ. Перед принятием решений
					сверьтесь с актуальной редакцией нормативных актов.
				</p>
			</section>

			<section class="all-scenarios">
				<h2>Все учтённые сценарии</h2>
				<ul>
					{SCENARIOS.map((s) => (
						<li>
							<strong>{s.label}.</strong> {s.short} — <em>{s.article}</em>.
							{s.confiscation && <span class="badge">+ конфискация</span>}
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />

		<script define:vars={{ scenarios: SCENARIOS }}>
			const formatRub = (value) =>
				new Intl.NumberFormat('ru-RU').format(Math.round(value)) + ' ₽';

			const calc = (scenario, subject, amount) => {
				const c = scenario.calc;
				if (c.type === 'fixed') {
					const r = c[subject];
					return { min: r.min, max: r.max, kind: 'fixed' };
				}
				const r = c[subject];
				const baseMin = ((amount || 0) * r.minPct) / 100;
				const baseMax = ((amount || 0) * r.maxPct) / 100;
				return {
					min: Math.max(baseMin, r.floor),
					max: Math.max(baseMax, r.floor),
					kind: 'percent',
					floor: r.floor,
					minPct: r.minPct,
					maxPct: r.maxPct,
					hadAmount: !!amount,
				};
			};

			const escapeHtml = (s) =>
				String(s)
					.replace(/&/g, '&amp;')
					.replace(/</g, '&lt;')
					.replace(/>/g, '&gt;')
					.replace(/"/g, '&quot;');

			const render = (scenario, subject, amount) => {
				const r = calc(scenario, subject, amount);
				const range =
					r.min === r.max ? formatRub(r.min) : `${formatRub(r.min)} — ${formatRub(r.max)}`;
				const subjectLabel =
					subject === 'ip' ? 'ИП / должностное лицо' : 'юридическое лицо';

				let extra = '';
				if (r.kind === 'percent') {
					if (!r.hadAmount) {
						extra = `<p class="result-hint">Введите сумму расчёта без ККТ, чтобы увидеть точный диапазон. Минимум — ${formatRub(r.floor)}.</p>`;
					} else {
						extra = `<p class="result-hint">Расчёт: ${r.minPct}–${r.maxPct}% от суммы, но не менее ${formatRub(r.floor)}.</p>`;
					}
				}

				const conf = scenario.confiscation
					? '<p class="result-conf">Дополнительно — конфискация продукции.</p>'
					: '';
				const note = scenario.note
					? `<p class="result-note">${escapeHtml(scenario.note)}</p>`
					: '';

				return `
					<div class="result-card">
						<p class="result-label">Размер штрафа для категории «${escapeHtml(subjectLabel)}»</p>
						<p class="result-amount">${range}</p>
						<p class="result-article">${escapeHtml(scenario.article)}</p>
						${extra}
						${conf}
						${note}
					</div>
				`;
			};

			const form = document.getElementById('calc');
			const result = document.getElementById('result');
			const amountField = document.getElementById('amount-field');
			const scenarioSelect = document.getElementById('scenario');
			const subjectSelect = document.getElementById('subject');
			const amountInput = document.getElementById('amount');

			const update = () => {
				const scenario = scenarios.find((s) => s.id === scenarioSelect.value);
				if (!scenario) return;
				const isPercent = scenario.calc.type === 'percent';
				amountField.hidden = !isPercent;
				const amount = isPercent ? Number(amountInput.value) : 0;
				result.innerHTML = render(scenario, subjectSelect.value, amount);
			};

			form.addEventListener('input', update);
			form.addEventListener('change', update);
			update();
		</script>

		<style>
			.breadcrumbs {
				font-size: 0.88rem;
				color: rgb(var(--gray));
				margin-top: 1rem;
			}
			.breadcrumbs a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumbs a:hover {
				color: var(--accent);
			}
			.breadcrumbs span {
				margin: 0 0.4em;
			}
			.page-head {
				padding: 1.5rem 0 1rem;
				max-width: 820px;
			}
			.page-head p {
				color: rgb(var(--gray-dark));
				font-size: 1.05rem;
			}
			.calc {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
				gap: 1rem;
				max-width: 820px;
				padding: 1.4rem;
				background: var(--accent-soft);
				border-radius: 12px;
				margin-top: 1.5rem;
			}
			.field {
				display: flex;
				flex-direction: column;
			}
			.field label {
				font-weight: 600;
				font-size: 0.92rem;
				margin-bottom: 0.4rem;
				color: rgb(var(--gray-dark));
			}
			.field select,
			.field input {
				padding: 0.7em 0.9em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				font-size: 1rem;
				font-family: inherit;
				background: #fff;
				color: rgb(var(--gray-dark));
				width: 100%;
			}
			.field select:focus,
			.field input:focus {
				outline: 2px solid var(--accent);
				outline-offset: 1px;
			}
			.hint {
				font-size: 0.82rem;
				color: rgb(var(--gray));
				margin-top: 0.4rem;
			}
			.result {
				max-width: 820px;
				margin-top: 1.5rem;
			}
			.result-card {
				padding: 1.6rem;
				border: 1px solid rgb(var(--gray-light));
				border-left: 4px solid var(--accent);
				border-radius: 10px;
				background: #fff;
			}
			.result-label {
				font-size: 0.92rem;
				color: rgb(var(--gray));
				margin: 0;
			}
			.result-amount {
				font-size: 2rem;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0.3rem 0 0.6rem;
			}
			.result-article {
				font-size: 1rem;
				color: var(--accent);
				font-weight: 600;
				margin: 0 0 0.6rem;
			}
			.result-hint {
				font-size: 0.92rem;
				color: rgb(var(--gray-dark));
				margin: 0 0 0.5rem;
			}
			.result-conf {
				font-size: 0.95rem;
				color: #b45309;
				background: #fef3c7;
				padding: 0.5em 0.8em;
				border-radius: 6px;
				margin: 0.6rem 0 0;
			}
			.result-note {
				font-size: 0.9rem;
				color: rgb(var(--gray-dark));
				border-top: 1px solid rgb(var(--gray-light));
				padding-top: 0.8rem;
				margin: 0.8rem 0 0;
			}
			.disclaimer {
				max-width: 820px;
				margin-top: 1.5rem;
				padding: 1rem 1.2rem;
				background: rgba(var(--gray-light), 0.6);
				border-radius: 8px;
				font-size: 0.92rem;
				color: rgb(var(--gray-dark));
			}
			.disclaimer p {
				margin: 0;
			}
			.all-scenarios {
				max-width: 820px;
				margin-top: 2.5rem;
			}
			.all-scenarios ul {
				list-style: none;
				padding: 0;
				margin: 1rem 0 0;
			}
			.all-scenarios li {
				padding: 0.8rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
				font-size: 0.95rem;
			}
			.all-scenarios li:last-child {
				border-bottom: none;
			}
			.all-scenarios em {
				color: var(--accent);
				font-style: normal;
				font-weight: 600;
			}
			.badge {
				display: inline-block;
				font-size: 0.78rem;
				font-weight: 600;
				color: #b45309;
				background: #fef3c7;
				padding: 0.15em 0.6em;
				border-radius: 999px;
				margin-left: 0.4rem;
			}
		</style>
	</body>
</html>
