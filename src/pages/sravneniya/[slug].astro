---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { u } from '../../utils/url';
import { COMPARISONS } from '../../data/comparisons';
import { CPA_BANNERS } from '../../data/cpa-banners';

export function getStaticPaths() {
	return COMPARISONS.map(table => ({
		params: { slug: table.slug },
		props: { table },
	}));
}

const { table } = Astro.props;

// Колонки-продукты с визуалом и заголовком из CPA_BANNERS.
const columns = table.products.map(id => ({
	id,
	banner: CPA_BANNERS[id],
}));

const title = `${table.title} — сравнение сервисов Контура`;
const description = table.lead;
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		<main class="cmp">
			<nav class="crumbs" aria-label="Хлебные крошки">
				<a href={u('/sravneniya/')}>Сравнения</a>
				<span>›</span>
				<span class="crumbs-current">{table.title}</span>
			</nav>

			<header class="cmp-hero">
				<p class="cmp-eyebrow">{table.eyebrow}</p>
				<h1>{table.title}</h1>
				<p class="cmp-lead">{table.lead}</p>
			</header>

			<div class="cmp-table-wrap">
				<table class="cmp-table">
					<thead>
						<tr>
							<th class="th-label" scope="col">Параметр</th>
							{columns.map(col => (
								<th scope="col" class="th-product">
									<a href={u(`/produkty/${col.id}/`)} class="th-product-link">
										<span
											class="th-visual"
											style={`background:${col.banner.visual.bg}`}
										>{col.banner.visual.abbrev}</span>
										<span class="th-name">{col.banner.title}</span>
									</a>
								</th>
							))}
						</tr>
					</thead>
					<tbody>
						{table.rows.map(row => (
							<tr>
								<th scope="row" class="cell-label">{row.label}</th>
								{row.values.map(value => (
									<td class="cell-value">{value}</td>
								))}
							</tr>
						))}
						<tr class="cta-row">
							<th scope="row" class="cell-label">Заявка</th>
							{columns.map(col => (
								<td class="cell-value">
									<a
										href={u(`/produkty/${col.id}/`)}
										class="cmp-cta"
										data-product={col.id}
									>Оставить заявку →</a>
								</td>
							))}
						</tr>
					</tbody>
				</table>
			</div>

			<section class="cmp-summary">
				<p>
					Сервисы решают разные задачи: выбирайте по тому, что закрываете
					сейчас. На странице каждого продукта есть подробности и форма заявки —
					её обрабатывает Контур, договор вы заключаете с ним напрямую.
				</p>
				<p class="cmp-back">
					<a href={u('/sravneniya/')}>← Все сравнения</a>
					<span class="cmp-back-sep">·</span>
					<a href={u('/produkty/')}>Каталог сервисов</a>
				</p>
			</section>
		</main>

		<Footer />

		<style>
			.cmp {
				max-width: 1080px;
				margin: 0 auto;
				padding: 2rem 1rem 4rem;
			}
			.crumbs {
				display: flex;
				gap: 0.5rem;
				align-items: center;
				font-size: 0.82rem;
				color: #888;
				margin-bottom: 1.5rem;
				flex-wrap: wrap;
			}
			.crumbs a { color: var(--pink, #ff4d8f); text-decoration: none; font-weight: 600; }
			.crumbs-current { color: #888; }

			.cmp-hero { margin-bottom: 2rem; max-width: 760px; }
			.cmp-eyebrow {
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--pink, #ff4d8f);
				margin: 0 0 0.5rem;
				font-weight: 700;
			}
			.cmp-hero h1 {
				font-family: 'Bebas Neue', sans-serif;
				font-size: clamp(1.8rem, 4.5vw, 2.8rem);
				line-height: 0.98;
				margin: 0 0 1rem;
				text-transform: uppercase;
				letter-spacing: 0.02em;
				color: #111;
			}
			.cmp-lead {
				margin: 0;
				font-size: 1.02rem;
				color: #555;
				line-height: 1.55;
			}

			/* Горизонтальный скролл на мобильном */
			.cmp-table-wrap {
				overflow-x: auto;
				border: 2px solid rgba(0, 0, 0, 0.08);
				border-radius: 12px;
				background: #fff;
			}
			.cmp-table {
				width: 100%;
				border-collapse: collapse;
				min-width: 520px;
			}

			/* Sticky-шапка */
			.cmp-table thead th {
				position: sticky;
				top: 0;
				z-index: 3;
				background: var(--sand, #f4ebd9);
				vertical-align: bottom;
				padding: 0.9rem 1rem;
				text-align: left;
				border-bottom: 2px solid rgba(0, 0, 0, 0.12);
			}
			.th-label {
				min-width: 150px;
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1rem;
				letter-spacing: 0.03em;
				text-transform: uppercase;
				color: #111;
			}
			.th-product { min-width: 180px; }
			.th-product-link {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
				text-decoration: none;
				color: #111;
			}
			.th-visual {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 40px;
				height: 40px;
				border-radius: 8px;
				color: #fff;
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1rem;
				letter-spacing: 0.04em;
			}
			.th-name {
				font-size: 0.9rem;
				line-height: 1.3;
				font-weight: 700;
				color: #111;
			}
			.th-product-link:hover .th-name { color: var(--pink, #ff4d8f); }

			.cmp-table tbody tr { border-bottom: 1px solid rgba(0, 0, 0, 0.07); }
			.cmp-table tbody tr:last-child { border-bottom: none; }

			.cell-label {
				position: sticky;
				left: 0;
				z-index: 2;
				background: #fafafa;
				text-align: left;
				font-weight: 700;
				font-size: 0.88rem;
				color: #222;
				padding: 0.85rem 1rem;
				border-right: 1px solid rgba(0, 0, 0, 0.07);
				min-width: 150px;
			}
			.cell-value {
				padding: 0.85rem 1rem;
				font-size: 0.92rem;
				line-height: 1.45;
				color: #333;
				vertical-align: top;
			}

			.cta-row .cell-label { background: var(--lime, #afcc00); color: #111; }
			.cta-row .cell-value { background: rgba(175, 204, 0, 0.12); }
			.cmp-cta {
				display: inline-block;
				padding: 0.55em 1em;
				background: var(--pink, #ff4d8f);
				color: #fff;
				font-weight: 700;
				font-size: 0.85rem;
				text-decoration: none;
				border-radius: 999px;
				transition: transform 0.15s ease, filter 0.15s ease;
			}
			.cmp-cta:hover { transform: translateY(-1px); filter: brightness(1.05); }

			.cmp-summary { margin-top: 2rem; max-width: 760px; }
			.cmp-summary p { margin: 0 0 1rem; font-size: 1rem; line-height: 1.6; color: #444; }
			.cmp-back a { color: var(--pink, #ff4d8f); font-weight: 600; text-decoration: none; }
			.cmp-back-sep { color: #bbb; margin: 0 0.5rem; }

			@media (max-width: 640px) {
				.th-product { min-width: 150px; }
				.cell-label { min-width: 120px; }
				.cmp-cta { font-size: 0.8rem; padding: 0.5em 0.8em; }
			}
		</style>

		<script define:vars={{ tableSlug: table.slug }}>
			document.querySelectorAll('.cmp-cta').forEach(el => {
				el.addEventListener('click', () => {
					window.ym &&
						window.ym(109130279, 'reachGoal', 'sravnenie-cta-click', {
							product: el.dataset.product,
							table: tableSlug,
						});
				});
			});
		</script>
	</body>
</html>
