---
// Бандл продуктов под сценарий: «что понадобится» одним блоком (роадмап 10.3).
// Ведёт на внутренние страницы продуктов /produkty/<slug>/ (середина воронки),
// а не на внешний лендинг — заявку читатель оставит на странице продукта.
import { CPA_BANNERS, PRODUCT_CATALOG } from '../data/cpa-banners';
import { u } from '../utils/url';

interface Props {
	/** Заголовок блока */
	heading?: string;
	/** bannerId офферов в нужном порядке */
	ids: string[];
}

const { heading = 'Что понадобится', ids } = Astro.props;

const slugByBanner = new Map(PRODUCT_CATALOG.map(p => [p.bannerId, p.slug]));
const items = ids
	.map(id => {
		const banner = CPA_BANNERS[id];
		const slug = slugByBanner.get(id);
		// Показываем только то, что есть в витрине и с erid (38-ФЗ).
		return banner && slug && banner.erid ? { id, banner, slug } : null;
	})
	.filter((x): x is NonNullable<typeof x> => x !== null);
---

{items.length > 0 && (
	<section class="bundle" data-pagefind-ignore>
		<h2 class="bundle-head">{heading}</h2>
		<ol class="bundle-list">
			{items.map((it, i) => (
				<li class="bundle-item">
					<span class="bundle-num">{i + 1}</span>
					<span class="bundle-visual" style={`background:${it.banner.visual.bg}`}>{it.banner.visual.abbrev}</span>
					<span class="bundle-body">
						<span class="bundle-title">{it.banner.title}</span>
						<span class="bundle-eyebrow">{it.banner.eyebrow}</span>
					</span>
					<a class="bundle-cta" href={u(`/produkty/${it.slug}/`)}>Подробнее и заявка →</a>
				</li>
			))}
		</ol>
		<p class="bundle-note">Один набор под задачу — заявку обрабатывает Контур, договор вы заключаете с ним напрямую.</p>
	</section>
)}

<style>
	.bundle {
		margin: 2.5rem 0;
		border: 2px solid var(--dark, #111);
		background: var(--sand-l, #f6f4ee);
		padding: 1.5rem;
	}
	.bundle-head {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 1.6rem; letter-spacing: .02em; text-transform: uppercase;
		margin: 0 0 1.1rem; color: #111;
	}
	.bundle-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
	.bundle-item {
		display: grid;
		grid-template-columns: auto 44px 1fr auto;
		gap: 14px; align-items: center;
		background: #fff; border: 1px solid var(--line, #E5E1D8); padding: 12px 14px;
	}
	.bundle-num {
		font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; line-height: 1;
		color: var(--pink, #9E2B4F); min-width: 1ch; text-align: center;
	}
	.bundle-visual {
		width: 44px; height: 44px; display: flex; align-items: center; justify-content: center;
		border-radius: 2px; color: #fff; font-family: 'Bebas Neue', sans-serif; font-size: .95rem;
	}
	.bundle-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
	.bundle-title { font-size: .95rem; font-weight: 600; line-height: 1.25; color: #111; }
	.bundle-eyebrow {
		font-size: .66rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase;
		color: var(--ink-3, #666);
	}
	.bundle-cta {
		font-size: .68rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
		color: var(--pink, #9E2B4F); text-decoration: none; white-space: nowrap;
	}
	.bundle-cta:hover { text-decoration: underline; }
	.bundle-note { margin: 1rem 0 0; font-size: .8rem; color: var(--ink-3, #666); }
	@media (max-width: 600px) {
		.bundle-item { grid-template-columns: auto 1fr; gap: 8px 10px; }
		.bundle-visual { display: none; }
		.bundle-cta { grid-column: 1 / -1; }
	}
</style>
