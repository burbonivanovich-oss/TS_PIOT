---
// Бандл «набор продуктов под задачу» (roadmap 10.3).
// Собирает несколько сервисов Контура в один блок: каждая строка —
// задача бизнеса (role) → продукт из CPA_BANNERS → ссылка на страницу
// продукта с лид-формой (/produkty/<bannerId>/). Данные берутся из
// CPA_BANNERS по bannerId: title, visual.abbrev, visual.bg.
import { CPA_BANNERS } from '../data/cpa-banners';
import { u } from '../utils/url';

interface BundleItem {
	/** задача бизнеса, под которую нужен продукт */
	role: string;
	/** id продукта из CPA_BANNERS */
	bannerId: string;
}

interface Props {
	/** заголовок-плашка бандла */
	heading: string;
	/** метка сценария для трекинга */
	scenario?: string;
	/** строки бандла */
	items: BundleItem[];
}

const { heading, scenario, items } = Astro.props;

const rows = items
	.map((item) => ({ ...item, banner: CPA_BANNERS[item.bannerId] }))
	.filter((row) => {
		if (!row.banner) {
			console.warn(`[ProductBundle] баннер с id="${row.bannerId}" не найден в CPA_BANNERS`);
			return false;
		}
		return true;
	});

const count = rows.length;
---

<section class="bundle" data-pagefind-ignore data-bundle data-scenario={scenario}>
	<div class="bundle-heading">{heading}</div>

	<ol class="bundle-list">
		{rows.map((row, i) => (
			<li class="bundle-row">
				<span class="bundle-num">{i + 1}</span>
				<span class="bundle-role">{row.role}</span>
				<span class="bundle-product">
					<span class="bundle-visual" style={`background:${row.banner.visual.bg}`}>
						{row.banner.visual.abbrev}
					</span>
					<span class="bundle-product-title">{row.banner.title}</span>
				</span>
				<a
					href={u(`/produkty/${row.bannerId}/`)}
					class="bundle-cta"
					data-product={row.bannerId}
				>
					Оставить заявку →
				</a>
			</li>
		))}
	</ol>

	<p class="bundle-note">Один блок — {count} сервисов под задачу</p>
</section>

<style>
	.bundle {
		margin: 2.5rem 0;
		border: 2px solid #111;
		overflow: hidden;
	}
	.bundle-heading {
		font-family: 'Bebas Neue', sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		font-size: 1.6rem;
		line-height: 1.1;
		color: #fff;
		background: #111;
		padding: 0.75rem 1.5rem;
	}
	.bundle-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.bundle-row {
		display: grid;
		grid-template-columns: 2.25rem 1fr 1.4fr auto;
		align-items: center;
		gap: 1rem;
		padding: 1rem 1.5rem;
		border-bottom: 1px solid rgba(0, 0, 0, 0.1);
	}
	.bundle-row:last-child {
		border-bottom: none;
	}
	.bundle-num {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 1.6rem;
		line-height: 1;
		color: var(--pink, #ff4d8f);
		text-align: center;
	}
	.bundle-role {
		font-size: 0.95rem;
		font-weight: 700;
		color: #111;
		line-height: 1.3;
	}
	.bundle-product {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		min-width: 0;
	}
	.bundle-visual {
		flex: 0 0 auto;
		width: 2.4rem;
		height: 2.4rem;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #fff;
		font-family: 'Bebas Neue', sans-serif;
		font-size: 0.95rem;
		letter-spacing: 0.03em;
	}
	.bundle-product-title {
		font-size: 0.88rem;
		line-height: 1.4;
		color: #444;
		min-width: 0;
	}
	.bundle-cta {
		display: inline-block;
		padding: 0.6em 1.1em;
		background: #111;
		color: #afcc00;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		text-decoration: none;
		white-space: nowrap;
		transition: background 0.15s ease;
	}
	.bundle-cta:hover {
		background: #9e2b4f;
		color: #fff;
	}
	.bundle-note {
		margin: 0;
		padding: 0.5rem 1.5rem;
		background: var(--sand, #f4ebd9);
		color: #666;
		font-size: 0.75rem;
		border-top: 1px solid rgba(0, 0, 0, 0.08);
	}
	@media (max-width: 640px) {
		.bundle-row {
			grid-template-columns: 1fr;
			gap: 0.6rem;
		}
		.bundle-num {
			text-align: left;
		}
		.bundle-cta {
			justify-self: start;
		}
	}
</style>

<script>
	document.querySelectorAll('.bundle-cta').forEach((el) => {
		el.addEventListener('click', () => {
			const product = (el as HTMLElement).dataset.product;
			const scenario = (el.closest('[data-bundle]') as HTMLElement | null)?.dataset.scenario;
			window.ym && window.ym(109130279, 'reachGoal', 'bundle-cta-click', { product, scenario });
		});
	});
</script>
