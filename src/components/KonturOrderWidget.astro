---
// Инлайн-виджет заявки Контура с ленивой загрузкой и перекраской под токены сайта.
//
// Что делает:
// - рисует чистую карточку в стиле Этикетки с кнопкой «Заполнить заявку»;
// - по клику лениво подгружает jQuery + официальный loader Контура и монтирует
//   их форму прямо в карточку (button → форма);
// - значения _skbOrder (ProductId/ProductName/SupplierUid/Source) берутся из
//   widget-конфига оффера и уходят ДОСЛОВНО — форма не переписывается, поэтому
//   партнёрская атрибуция и валидация Контура сохраняются.
//
// Почему лениво и по клику: _skbOrder — глобальный массив, loader инициализирует
// один продукт на загрузку страницы. Монтирование по требованию решает конфликт
// (инициализируется только открытый виджет) и не тащит legacy-jQuery на страницы,
// где форму не открыли.
//
// Маркировка 38-ФЗ: без erid форма не рендерится (как и CpaCallout). Плашка
// «Реклама · erid: …» обязательна.
import { CPA_BANNERS } from '../data/cpa-banners';

interface Props {
	/** id оффера из CPA_BANNERS (источник erid, заголовков и widget-конфига) */
	id: string;
	/** подводка над формой */
	heading?: string;
	/** текст кнопки-триггера */
	cta?: string;
	/** внешний класс для отступов */
	class?: string;
}

const { id, heading, cta, class: className } = Astro.props;
const banner = CPA_BANNERS[id];
const w = banner?.widget;
const erid = banner?.erid;

if (banner && !w) {
	console.warn(`[KonturOrderWidget] у оффера "${id}" нет widget-конфига — форма не рендерится`);
}
if (banner && !erid) {
	console.warn(`[KonturOrderWidget] оффер "${id}" без erid — форма не рендерится (38-ФЗ)`);
}

const render = !!(banner && w && erid);
const headingText = heading ?? banner?.title ?? 'Оставьте заявку — Контур перезвонит';
const ctaText = cta ?? 'Заполнить заявку';
const source = w?.source ?? 'etiketka-media.ru';
---

{render && (
	<section class={`kow ${className ?? ''}`} data-pagefind-ignore>
		<div class="kow-head">
			<span class="kow-eyebrow">{banner.eyebrow}</span>
			<h3 class="kow-title">{headingText}</h3>
			<p class="kow-desc">{banner.description}</p>
		</div>

		<div class="kow-mount kontur-widget-scope" data-kontur-widget data-goal={`lead-${id}`}>
			{/* Штатный сниппет заявки Контура: исполняется на месте, форма
			    монтируется лоадером в этот контейнер. Значения _skbOrder уходят
			    дословно — атрибуция сохранена. is:inline, чтобы Astro не трогал. */}
			<noscript>
				<p class="kow-nojs">
					Для отправки заявки включите JavaScript или {' '}
					<a href={banner.ctaHref} target="_blank" rel="noopener noreferrer sponsored">перейдите на сайт Контура</a>.
				</p>
			</noscript>

			<script
				is:inline
				define:vars={{ cfg: { productId: w.productId, productName: w.productName, supplierUid: w.supplierUid, source } }}
			>
				window._skbOrder = window._skbOrder || [];
				window._skbOrder.push(['ProductId', cfg.productId]);
				window._skbOrder.push(['ProductName', cfg.productName]);
				window._skbOrder.push(['SupplierUid', cfg.supplierUid]);
				window._skbOrder.push(['Source', cfg.source]);
			</script>
			<script is:inline src="https://code.jquery.com/jquery-1.11.2.min.js"></script>
			<script is:inline src="https://kontur.ru/widget/order/loader" defer></script>
		</div>

		<p class="kow-fallback">
			Форма не загрузилась? {' '}
			<a href={banner.ctaHref} target="_blank" rel="noopener noreferrer sponsored">Оставьте заявку на сайте Контура →</a>
		</p>

		<ul class="kow-trust">
			<li>Оформление и договор — на стороне Контура</li>
			<li>Сервисами пользуются более 2 млн компаний</li>
		</ul>

		<div class="kow-erid">Реклама · АО «ПФ „СКБ Контур"» · erid: {erid}</div>
	</section>
)}

<script>
	import { track } from '../utils/track';

	// Цель Метрики на отправку заявки — ловим submit делегированно на контейнере
	// (форму впрыскивает сторонний лоадер уже после загрузки страницы).
	document.querySelectorAll<HTMLElement>('[data-kontur-widget]').forEach((mount) => {
		const goal = mount.dataset.goal;
		if (goal) mount.addEventListener('submit', () => track(goal), true);
	});
</script>

<!-- Наша «обёртка» (карточка, кнопка, доверие, erid) -->
<style>
	.kow {
		margin: 2.5rem 0;
		border: 2px solid var(--dark, #111);
		background: var(--sand-l, #f6f4ee);
		padding: 1.5rem;
	}
	.kow-head {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		margin-bottom: 1.1rem;
	}
	.kow-eyebrow {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--pink, #9e2b4f);
	}
	.kow-title {
		font-size: 1.2rem;
		font-weight: 700;
		line-height: 1.3;
		color: var(--dark, #111);
		margin: 0;
	}
	.kow-desc {
		margin: 0;
		font-size: 0.92rem;
		line-height: 1.5;
		color: var(--ink-2, #3a3a3a);
	}
	.kow-mount {
		min-height: 2.6rem;
	}
	.kow-trust {
		list-style: none;
		margin: 1rem 0 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1.25rem;
	}
	.kow-trust li {
		font-size: 0.8rem;
		color: var(--ink-3, #666);
		padding-left: 1.1rem;
		position: relative;
	}
	.kow-trust li::before {
		content: '✓';
		position: absolute;
		left: 0;
		color: var(--lime-dark, #8aaa00);
		font-weight: 700;
	}
	.kow-erid {
		margin-top: 1rem;
		padding-top: 0.6rem;
		border-top: 1px solid rgba(0, 0, 0, 0.08);
		font-size: 0.7rem;
		color: var(--ink-3, #888);
	}
	.kow-nojs {
		font-size: 0.9rem;
		color: var(--ink-2, #3a3a3a);
	}
	.kow-fallback {
		margin: 0.9rem 0 0;
		font-size: 0.82rem;
		color: var(--ink-3, #666);
	}
	.kow-fallback a {
		color: var(--pink, #9e2b4f);
		font-weight: 600;
	}
</style>

<!-- Перекраска формы Контура. Форма впрыскивается лоадером в рантайме, поэтому
     scoped-стили Astro её не достанут — нужен is:global, ограниченный
     .kontur-widget-scope, чтобы не течь на остальной сайт. Селекторы общие
     (input/button/label), т.к. внутренняя разметка виджета не документирована —
     перекрашиваем то, что доступно: шрифт, цвета, рамки, кнопку. -->
<style is:global>
	.kow-trigger {
		display: inline-block;
		padding: 0.75em 1.4em;
		background: var(--dark, #111);
		color: var(--lime, #afcc00);
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		text-decoration: none;
		border: none;
		cursor: pointer;
		transition: background 0.15s ease, color 0.15s ease;
	}
	.kow-trigger:hover { background: var(--pink, #9e2b4f); color: #fff; }
	.kow-trigger.is-loading { opacity: 0.7; cursor: default; }

	/* Перекраска инжектируемой формы Контура под токены сайта */
	.kontur-widget-scope,
	.kontur-widget-scope * {
		font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif !important;
		box-sizing: border-box;
	}
	.kontur-widget-scope label {
		font-size: 0.85rem !important;
		color: var(--ink-2, #3a3a3a) !important;
		font-weight: 500 !important;
	}
	.kontur-widget-scope input[type='text'],
	.kontur-widget-scope input[type='tel'],
	.kontur-widget-scope input[type='email'],
	.kontur-widget-scope input:not([type='checkbox']):not([type='radio']):not([type='submit']),
	.kontur-widget-scope select,
	.kontur-widget-scope textarea {
		width: 100%;
		padding: 0.6em 0.75em !important;
		font-size: 0.95rem !important;
		color: var(--dark, #111) !important;
		background: #fff !important;
		border: 1.5px solid #d8d2c6 !important;
		border-radius: 0 !important;
		box-shadow: none !important;
		transition: border-color 0.15s ease;
	}
	.kontur-widget-scope input:focus,
	.kontur-widget-scope select:focus,
	.kontur-widget-scope textarea:focus {
		outline: none;
		border-color: var(--pink, #9e2b4f) !important;
	}
	.kontur-widget-scope button,
	.kontur-widget-scope input[type='submit'] {
		padding: 0.75em 1.4em !important;
		background: var(--dark, #111) !important;
		color: var(--lime, #afcc00) !important;
		font-size: 0.82rem !important;
		font-weight: 700 !important;
		letter-spacing: 0.06em !important;
		text-transform: uppercase !important;
		border: none !important;
		border-radius: 0 !important;
		cursor: pointer;
		box-shadow: none !important;
		transition: background 0.15s ease, color 0.15s ease;
	}
	.kontur-widget-scope button:hover,
	.kontur-widget-scope input[type='submit']:hover {
		background: var(--pink, #9e2b4f) !important;
		color: #fff !important;
	}
	.kontur-widget-scope a { color: var(--pink, #9e2b4f); }
	/* Гасим возможные фоновые карточки/тени виджета, чтобы он не «отрывался»
	   от нашей карточки */
	.kontur-widget-scope > div,
	.kontur-widget-scope form {
		background: transparent !important;
		box-shadow: none !important;
		border: none !important;
		padding: 0 !important;
		margin: 0 !important;
	}
	.skb_form_script_disabled { color: var(--pink, #9e2b4f) !important; }
</style>
