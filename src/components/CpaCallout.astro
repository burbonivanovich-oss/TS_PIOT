---
// Переиспользуемый CPA-блок для встраивания на спецстраницы
// (флагман, квизы, сценарии, трекеры). Берёт данные из
// CPA_BANNERS по id. Маркировка по 38-ФЗ автоматическая: если у
// баннера есть erid (партнёрский) — добавляется плашка
// «Реклама · erid: …». Без erid — рендерится как
// информационный блок без маркировки рекламы.
import { CPA_BANNERS } from '../data/cpa-banners';

interface Props {
	/** id баннера из src/data/cpa-banners.ts */
	id: string;
	/** Опциональная замена заголовка (для контекста страницы) */
	titleOverride?: string;
	/** Опциональный класс-обёртка для внешних отступов */
	class?: string;
}

const { id, titleOverride, class: className } = Astro.props;
const banner = CPA_BANNERS[id];

if (!banner) {
	console.warn(`[CpaCallout] баннер с id="${id}" не найден в CPA_BANNERS`);
}

const isAd = !!banner?.erid;
---

{banner && (
	<div class={`cpa-block ${className ?? ''}`} data-pagefind-ignore>
		<div class="cpa-visual" style={`background:${banner.visual.bg}`}>
			<span class="cpa-visual-letter">{banner.visual.abbrev}</span>
		</div>
		<div class="cpa-body">
			<div class="cpa-eyebrow">{banner.eyebrow}</div>
			<div class="cpa-title">{titleOverride ?? banner.title}</div>
			<p class="cpa-desc">{banner.description}</p>
		</div>
		<div class="cpa-action">
			<a
				href={banner.ctaHref}
				class="cpa-btn"
				target={banner.ctaHref.startsWith('http') ? '_blank' : undefined}
				rel={isAd ? 'noopener noreferrer sponsored' : (banner.ctaHref.startsWith('http') ? 'noopener noreferrer' : undefined)}
			>
				{banner.cta}
			</a>
		</div>
		{banner.erid && (
			<div class="cpa-erid">Реклама · erid: {banner.erid}</div>
		)}
	</div>
)}

<style>
	.cpa-block {
		display: grid;
		grid-template-columns: 120px 1fr auto;
		grid-template-rows: auto auto;
		align-items: stretch;
		margin: 2.5rem 0;
		border: 2px solid #111;
		overflow: hidden;
	}
	.cpa-visual {
		grid-row: 1 / span 1;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #fff;
	}
	.cpa-visual-letter {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 2.5rem;
		letter-spacing: 0.04em;
	}
	.cpa-body {
		padding: 1.25rem 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
		min-width: 0;
	}
	.cpa-eyebrow {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #666;
	}
	.cpa-title {
		font-size: 1.1rem;
		font-weight: 700;
		color: #111;
		line-height: 1.3;
	}
	.cpa-desc {
		margin: 0;
		font-size: 0.92rem;
		line-height: 1.5;
		color: #444;
	}
	.cpa-action {
		display: flex;
		align-items: center;
		padding: 0 1.5rem;
	}
	.cpa-btn {
		display: inline-block;
		padding: 0.7em 1.25em;
		background: #111;
		color: #AFCC00;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		text-decoration: none;
		white-space: nowrap;
		transition: background 0.15s ease;
	}
	.cpa-btn:hover { background: #9E2B4F; color: #fff; }
	.cpa-erid {
		grid-column: 1 / -1;
		padding: 0.4rem 1.5rem;
		background: #f3f3f3;
		color: #888;
		font-size: 0.7rem;
		border-top: 1px solid rgba(0, 0, 0, 0.06);
	}
	@media (max-width: 640px) {
		.cpa-block { grid-template-columns: 1fr; }
		.cpa-visual { min-height: 80px; }
		.cpa-action { padding: 0 1.5rem 1.25rem; }
	}
</style>
