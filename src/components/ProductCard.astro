---
import type { AffiliateProduct } from '../data/affiliates';

interface Props {
	product: AffiliateProduct;
}

const { product } = Astro.props;
---

<div class="pc">
	<div class="pc-head">
		<div class="pc-names">
			<span class="pc-name">{product.name}</span>
			<span class="pc-tagline">{product.tagline}</span>
		</div>
		<span class="pc-vendor">{product.vendor}</span>
	</div>
	<p class="pc-desc">{product.description}</p>
	{product.note && <p class="pc-note">{product.note}</p>}
	<a
		class="pc-cta"
		href={product.cpaUrl}
		target="_blank"
		rel="sponsored noopener noreferrer"
	>
		{product.ctaLabel} →
	</a>
</div>

<style>
	.pc {
		border: 1px solid rgb(var(--gray-light));
		border-radius: 10px;
		padding: 1.2rem 1.4rem;
		background: #fff;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		transition: box-shadow 0.15s ease, border-color 0.15s ease;
	}
	.pc:hover {
		border-color: var(--accent);
		box-shadow: var(--box-shadow);
	}
	.pc-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.5rem;
	}
	.pc-names {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}
	.pc-name {
		font-weight: 700;
		font-size: 1.05rem;
		color: rgb(var(--black));
	}
	.pc-tagline {
		font-size: 0.82rem;
		color: rgb(var(--gray));
	}
	.pc-vendor {
		font-size: 0.75rem;
		color: var(--accent);
		background: var(--accent-soft);
		padding: 0.2em 0.6em;
		border-radius: 999px;
		white-space: nowrap;
		flex-shrink: 0;
	}
	.pc-desc {
		font-size: 0.93rem;
		color: rgb(var(--gray-dark));
		margin: 0;
		line-height: 1.55;
	}
	.pc-note {
		font-size: 0.82rem;
		color: #16a34a;
		background: #f0fdf4;
		border: 1px solid #bbf7d0;
		border-radius: 6px;
		padding: 0.3em 0.7em;
		margin: 0;
	}
	.pc-cta {
		display: inline-block;
		align-self: flex-start;
		margin-top: 0.2rem;
		padding: 0.55em 1.1em;
		background: var(--accent);
		color: #fff;
		border-radius: 8px;
		font-size: 0.9rem;
		font-weight: 600;
		text-decoration: none;
		transition: background 0.15s ease;
	}
	.pc-cta:hover {
		background: var(--accent-dark);
		color: #fff;
	}
</style>
