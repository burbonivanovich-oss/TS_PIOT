---
import { AFFILIATE_PRODUCTS, CATEGORY_DEFAULT_AFFILIATES } from '../data/affiliates';
import ProductCard from './ProductCard.astro';

interface Props {
	affiliates?: string[];
	categories?: string[];
}

const { affiliates, categories = [] } = Astro.props;

// Явные ID из frontmatter имеют приоритет.
// Если не указаны — берём дефолты по первой категории статьи.
const ids: string[] =
	affiliates && affiliates.length > 0
		? affiliates
		: CATEGORY_DEFAULT_AFFILIATES[categories[0]] ?? [];

const products = ids
	.map((id) => AFFILIATE_PRODUCTS[id])
	.filter(Boolean);
---

{products.length > 0 && (
	<aside class="af" aria-labelledby="af-heading">
		<h2 id="af-heading" class="af-heading">Рекомендуемые инструменты</h2>
		<p class="af-disclaimer">
			Партнёрские ссылки — рекомендуем сервисы, которые сами проверили.
			При переходе и покупке портал получает комиссию без изменения цены для вас.
		</p>
		<div class="af-grid">
			{products.map((product) => (
				<ProductCard product={product} />
			))}
		</div>
	</aside>
)}

<style>
	.af {
		margin-top: 2.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.af-heading {
		font-size: 1.25rem;
		margin: 0 0 0.4rem;
	}
	.af-disclaimer {
		font-size: 0.82rem;
		color: rgb(var(--gray));
		margin: 0 0 1.1rem;
		font-style: italic;
	}
	.af-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 0.9rem;
	}
</style>
