---
// Лид-блок продукта Контура для страниц витрины /produkty/ и спецстраниц.
//
// Сейчас использует одобренный CTA-механизм (CpaCallout → переход на
// лендинг Контура с тегом f74746 и маркировкой 38-ФЗ по erid). Когда из
// кабинета партнёра будет получен HTML официального виджета заявки,
// его HTML подставляется через слот <Fragment slot="widget"> — тогда
// заявка оформляется inline, без ухода с сайта.
//
// Маркировка рекламы (erid) наследуется из CpaCallout: оффер без erid
// не должен показываться (38-ФЗ).
import CpaCallout from './CpaCallout.astro';

interface Props {
	/** id оффера из CPA_BANNERS */
	id: string;
	/** заголовок-подводка над блоком */
	heading?: string;
}

const { id, heading = 'Оставьте заявку — Контур перезвонит и подберёт тариф' } = Astro.props;

const trust = [
	'Оформление на стороне Контура',
	'Договор заключаете с Контуром',
	'Сервисами пользуются более 2 млн компаний',
];

const hasWidget = Astro.slots.has('widget');
---

<section class="lead" data-pagefind-ignore>
	<h2 class="lead-heading">{heading}</h2>

	{hasWidget ? (
		<div class="lead-widget">
			<slot name="widget" />
		</div>
	) : (
		<CpaCallout id={id} />
	)}

	<ul class="lead-trust">
		{trust.map(item => (
			<li>{item}</li>
		))}
	</ul>
</section>

<style>
	.lead {
		margin: 2.5rem 0;
	}
	.lead-heading {
		font-size: 1.25rem;
		line-height: 1.3;
		color: #111;
		margin: 0 0 1rem;
	}
	.lead-widget {
		border: 2px solid #111;
		padding: 1.25rem 1.5rem;
	}
	.lead-trust {
		list-style: none;
		margin: 1rem 0 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1.25rem;
	}
	.lead-trust li {
		font-size: 0.82rem;
		color: #555;
		padding-left: 1.1rem;
		position: relative;
	}
	.lead-trust li::before {
		content: '✓';
		position: absolute;
		left: 0;
		color: var(--lime, #afcc00);
		font-weight: 700;
	}
</style>
