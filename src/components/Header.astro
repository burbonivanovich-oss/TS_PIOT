---
import { SITE_TITLE } from '../consts';

const navLinks = [
	{ href: '/', label: 'Главная' },
	{ href: '/category/ts-piot/', label: 'ТС ПИоТ' },
	{ href: '/category/markirovka/', label: 'Маркировка' },
	{ href: '/category/zakonodatelstvo/', label: 'Законодательство' },
	{ href: '/slovar/', label: 'Словарь' },
];

const pathname = Astro.url.pathname.replace(/\/+$/, '/') || '/';
const isActive = (href: string) => {
	if (href === '/') return pathname === '/';
	return pathname.startsWith(href);
};
---

<header class="site-header">
	<nav class="nav-inner">
		<a href="/" class="brand" aria-label={SITE_TITLE}>
			<span class="brand-name">{SITE_TITLE}</span>
			<span class="brand-sub">·медиа</span>
		</a>

		<button class="nav-toggle" aria-label="Открыть меню" aria-controls="primary-nav" aria-expanded="false">
			<span></span><span></span><span></span>
		</button>

		<div class="nav-center" id="primary-nav">
			{navLinks.map((link) => (
				<a href={link.href} class:list={['nav-link', { 'is-active': isActive(link.href) }]}>{link.label}</a>
			))}
		</div>

		<div class="nav-right">
			<a class="nav-search" href="/search/" aria-label="Поиск">⌕</a>
			<a class="btn btn-primary nav-cta" href="/#newsletter">Подписаться</a>
		</div>
	</nav>
</header>

<script>
	const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
	const nav = document.querySelector<HTMLElement>('#primary-nav');
	toggle?.addEventListener('click', () => {
		const open = nav?.classList.toggle('is-open');
		toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
	});
</script>

<style>
	.site-header {
		background: var(--bg);
		border-bottom: 1px solid var(--border);
		position: sticky;
		top: 0;
		z-index: 50;
	}

	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		padding: 12px 40px;
		min-height: 56px;
		max-width: 1440px;
		margin: 0 auto;
	}

	.brand {
		display: inline-flex;
		align-items: baseline;
		gap: 6px;
		text-decoration: none;
		flex-shrink: 0;
	}
	.brand:hover { text-decoration: none; }
	.brand-name {
		font-family: 'Bebas Neue', 'Oswald', sans-serif;
		font-size: 26px;
		line-height: 1;
		letter-spacing: -0.01em;
		color: var(--text);
	}
	.brand-sub {
		font-family: 'JetBrains Mono', monospace;
		font-size: 10px;
		letter-spacing: 0.08em;
		color: var(--text-3);
	}

	.nav-center {
		display: flex;
		align-items: center;
		gap: 24px;
		flex: 1;
		justify-content: center;
	}

	.nav-link {
		font-family: 'Inter Tight', 'Inter', sans-serif;
		font-size: 13px;
		color: var(--text-2);
		text-decoration: none;
		padding: 4px 0 2px;
		border-bottom: 2px solid transparent;
		transition: color var(--ease), border-color var(--ease);
		white-space: nowrap;
	}
	.nav-link:hover {
		color: var(--text);
		text-decoration: none;
		border-bottom-color: var(--border-strong);
	}
	.nav-link.is-active {
		color: var(--text);
		font-weight: 600;
		border-bottom-color: var(--accent);
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 14px;
		flex-shrink: 0;
	}

	.nav-search {
		font-family: 'JetBrains Mono', monospace;
		font-size: 18px;
		color: var(--text-2);
		text-decoration: none;
		line-height: 1;
		padding: 4px;
	}
	.nav-search:hover { color: var(--accent); text-decoration: none; }

	.nav-cta {
		font-size: 12px;
		padding: 8px 14px;
	}

	.nav-toggle {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		background: none;
		border: none;
		padding: 8px;
		cursor: pointer;
	}
	.nav-toggle span {
		display: block;
		width: 22px;
		height: 2px;
		background: var(--text);
	}

	@media (max-width: 900px) {
		.nav-inner {
			padding: 12px 20px;
			flex-wrap: wrap;
		}
		.nav-toggle { display: flex; order: 2; }
		.nav-right { order: 1; }
		.nav-center {
			order: 3;
			flex-basis: 100%;
			display: none;
			flex-direction: column;
			align-items: flex-start;
			justify-content: flex-start;
			gap: 0;
			padding: 12px 0;
		}
		.nav-center.is-open { display: flex; }
		.nav-link {
			width: 100%;
			padding: 8px 0;
			border-bottom: 1px solid var(--border);
		}
		.nav-link.is-active { border-bottom-color: var(--accent); }
	}
</style>
