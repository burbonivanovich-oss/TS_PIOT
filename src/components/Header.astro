---
import { SITE_TITLE, NAV } from '../consts';
import { u } from '../utils/url';

// Текущий путь для подсветки активного раздела (с учётом base).
const path = Astro.url.pathname;
const isActive = (href: string) => {
	const full = u(href);
	if (href === '/blog/') return path.startsWith(full);
	return path === full || path.startsWith(full);
};
// Группа «Темы» активна, если открыт любой её ребёнок.
const groupActive = (children: readonly { href: string }[]) =>
	children.some(c => isActive(c.href));
---

<header class="site-header">
	<div class="header-inner">
		<div class="header-left">
			<a href={u('/')} class="logo" aria-label={SITE_TITLE}>
				этикетка<span class="logo-dot">.</span>
			</a>
			<nav class="site-nav" id="primary-nav" aria-label="Основная навигация">
				{NAV.map((item) => (
					'children' in item ? (
						<div class={`nav-group ${groupActive(item.children) ? 'is-active' : ''}`}>
							<button type="button" class="nav-group-btn" aria-expanded="false" aria-haspopup="true">
								{item.label}<span class="caret" aria-hidden="true">▾</span>
							</button>
							<div class="nav-dropdown">
								{item.children.map((c) => (
									<a href={u(c.href)} class={isActive(c.href) ? 'is-active' : ''}>{c.label}</a>
								))}
							</div>
						</div>
					) : (
						<a href={u(item.href)} class={`nav-link ${isActive(item.href) ? 'is-active' : ''}`}>{item.label}</a>
					)
				))}
				<a href={u('/search/')} class="nav-link nav-search-mobile">Поиск</a>
			</nav>
		</div>
		<div class="header-right">
			<a href={u('/search/')} class="search-link">+ Поиск</a>
		</div>
		<button class="nav-toggle" aria-label="Открыть меню" aria-controls="primary-nav" aria-expanded="false">
			<span></span><span></span><span></span>
		</button>
	</div>
</header>

<script>
	// Бургер
	const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
	const nav = document.querySelector<HTMLElement>('#primary-nav');
	toggle?.addEventListener('click', () => {
		const open = nav?.classList.toggle('is-open');
		toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
	});

	// Дропдаун «Темы»: на десктопе работает по hover (CSS), на тач/мобиле — по клику.
	document.querySelectorAll<HTMLButtonElement>('.nav-group-btn').forEach((btn) => {
		btn.addEventListener('click', (e) => {
			e.preventDefault();
			const group = btn.closest('.nav-group');
			const open = group?.classList.toggle('is-open');
			btn.setAttribute('aria-expanded', open ? 'true' : 'false');
		});
	});
	// Клик вне меню — закрыть открытые группы.
	document.addEventListener('click', (e) => {
		document.querySelectorAll('.nav-group.is-open').forEach((g) => {
			if (!g.contains(e.target as Node)) {
				g.classList.remove('is-open');
				g.querySelector('.nav-group-btn')?.setAttribute('aria-expanded', 'false');
			}
		});
	});
</script>

<style>
	.site-header {
		background: var(--surface, #F6F4EE);
		border-bottom: 1px solid var(--line, #E5E1D8);
		position: sticky;
		top: 0;
		z-index: 50;
		padding: 0 32px;
		height: 56px;
	}
	.header-inner {
		max-width: var(--maxw, 1400px);
		margin: 0 auto;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: nowrap;
		gap: 1rem;
	}
	.header-left {
		display: flex;
		align-items: center;
		gap: 28px;
	}
	.logo {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 1.75rem;
		letter-spacing: 0.04em;
		color: #111;
		text-decoration: none;
		line-height: 1;
		flex-shrink: 0;
		text-transform: lowercase;
	}
	.logo .logo-dot { color: var(--pink, #9E2B4F); }

	.site-nav {
		display: flex;
		align-items: center;
		gap: 2px;
		white-space: nowrap;
	}
	/* Базовый пункт и кнопка группы — единый вид, выше контраст (#333). */
	.site-nav a,
	.nav-group-btn {
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #333;
		text-decoration: none;
		padding: 0 14px;
		line-height: 56px;
		display: inline-flex;
		align-items: center;
		gap: 4px;
		background: none;
		border: 0;
		cursor: pointer;
		transition: color 0.15s;
		position: relative;
	}
	.site-nav a:hover,
	.nav-group-btn:hover { color: #111; }

	/* Подсветка активного раздела — линия снизу брендовым цветом. */
	.site-nav .nav-link.is-active,
	.nav-group.is-active > .nav-group-btn {
		color: #111;
	}
	.site-nav .nav-link.is-active::after,
	.nav-group.is-active > .nav-group-btn::after {
		content: '';
		position: absolute;
		left: 14px;
		right: 14px;
		bottom: 0;
		height: 2px;
		background: var(--pink, #9E2B4F);
	}
	.caret { font-size: 0.6rem; transition: transform 0.15s; }

	/* Дропдаун «Темы» */
	.nav-group { position: relative; }
	.nav-dropdown {
		position: absolute;
		top: 100%;
		left: 0;
		min-width: 220px;
		background: #fff;
		border: 1px solid var(--line, #E5E1D8);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
		padding: 6px;
		display: none;
		flex-direction: column;
		z-index: 60;
	}
	.nav-group:hover .nav-dropdown,
	.nav-group.is-open .nav-dropdown { display: flex; }
	.nav-group:hover .caret,
	.nav-group.is-open .caret { transform: rotate(180deg); }
	.nav-dropdown a {
		line-height: 1;
		padding: 11px 12px;
		font-size: 0.74rem;
		color: #333;
		border-radius: 2px;
	}
	.nav-dropdown a:hover { background: var(--surface, #F6F4EE); color: #111; }
	.nav-dropdown a.is-active { color: var(--pink, #9E2B4F); }
	.nav-dropdown a.is-active::after { display: none; }

	.header-right {
		display: flex;
		align-items: center;
		gap: 12px;
		flex-shrink: 0;
	}
	.search-link {
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #555;
		text-decoration: none;
		transition: color 0.15s;
	}
	.search-link:hover { color: #111; }

	.nav-search-mobile { display: none; }
	.site-nav .nav-search-mobile { display: none; }

	.nav-toggle {
		display: none;
		background: none;
		border: 0;
		width: 2.4rem;
		height: 2.4rem;
		cursor: pointer;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		padding: 0;
		flex-shrink: 0;
	}
	.nav-toggle span {
		display: block;
		height: 2px;
		background: #111;
		border-radius: 2px;
	}

	@media (max-width: 820px) {
		.site-header { height: auto; padding: 0 16px; }
		.header-inner { flex-wrap: wrap; height: auto; padding: 12px 0; }
		.header-left { flex: 1; }
		.nav-toggle { display: flex; }
		.header-right { display: none; }
		.site-nav {
			display: none;
			width: 100%;
			flex-direction: column;
			align-items: stretch;
			padding: 8px 0 12px;
			order: 3;
			gap: 0;
		}
		.site-nav.is-open { display: flex; }
		.site-nav a,
		.nav-group-btn {
			line-height: 2.4;
			padding: 0;
			width: 100%;
			justify-content: space-between;
		}
		.site-nav .nav-link.is-active::after,
		.nav-group.is-active > .nav-group-btn::after { display: none; }
		.site-nav .nav-link.is-active,
		.nav-dropdown a.is-active { color: var(--pink, #9E2B4F); }
		/* На мобиле дропдаун раскрыт всегда, с отступом-вложением. */
		.nav-group { width: 100%; }
		.nav-dropdown {
			position: static;
			display: flex;
			border: 0;
			box-shadow: none;
			padding: 0 0 6px 14px;
			min-width: 0;
		}
		.nav-dropdown a { padding: 6px 0; line-height: 1.6; }
		.caret { display: none; }
		.site-nav .nav-search-mobile { display: block; }
	}
</style>
