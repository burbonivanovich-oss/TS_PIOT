---
import { SITE_TITLE, NAV_LINKS } from '../consts';
import { u } from '../utils/url';
---

<header class="site-header">
	<div class="header-inner">
		<div class="header-left">
			<a href={u('/')} class="logo" aria-label={SITE_TITLE}>
				этикетка<span class="logo-dot">.</span>
			</a>
			<nav class="site-nav" id="primary-nav">
				{NAV_LINKS.filter(l => !['/', '/slovar/', '/about/', '/search/'].includes(l.href)).map((link) => (
					<a href={u(link.href)}>{link.label}</a>
				))}
				<a href={u('/search/')} class="nav-search-mobile">Поиск</a>
			</nav>
		</div>
		<div class="header-right">
			<a href={u('/search/')} class="search-link">+ Поиск</a>
		</div>
		<button class="nav-toggle" aria-label="Открыть меню" aria-controls="primary-nav" aria-expanded="false">
			<span></span><span></span><span></span>
		</button>
	</div>
</header>

<script>
	const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
	const nav = document.querySelector<HTMLElement>('#primary-nav');
	toggle?.addEventListener('click', () => {
		const open = nav?.classList.toggle('is-open');
		toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
	});
</script>

<style>
	.site-header {
		background: var(--surface, #F6F4EE);
		border-bottom: 1px solid var(--line, #E5E1D8);
		position: sticky;
		top: 0;
		z-index: 50;
		padding: 0 32px;
		height: 56px;
	}
	.header-inner {
		max-width: var(--maxw, 1440px);
		margin: 0 auto;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: nowrap;
		gap: 1rem;
	}
	.header-left {
		display: flex;
		align-items: center;
		gap: 24px;
	}
	.logo {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 1.75rem;
		letter-spacing: 0.04em;
		color: #111;
		text-decoration: none;
		line-height: 1;
		flex-shrink: 0;
		text-transform: lowercase;
	}
	.logo .logo-dot { color: #E8175D; }
	.site-nav {
		display: flex;
		align-items: center;
		gap: 0;
		white-space: nowrap;
	}
	.site-nav a {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #555;
		text-decoration: none;
		padding: 0 14px;
		transition: color 0.15s;
		line-height: 56px;
		display: inline-block;
	}
	.site-nav a:hover {
		color: #111;
	}
	.header-right {
		display: flex;
		align-items: center;
		gap: 12px;
		flex-shrink: 0;
	}
	.search-link {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #888;
		text-decoration: none;
		transition: color 0.15s;
	}
	.search-link:hover {
		color: #111;
	}
	.nav-search-mobile {
		display: none;
	}
	.site-nav .nav-search-mobile {
		display: none;
	}
	.nav-toggle {
		display: none;
		background: none;
		border: 0;
		width: 2.4rem;
		height: 2.4rem;
		cursor: pointer;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		padding: 0;
		flex-shrink: 0;
	}
	.nav-toggle span {
		display: block;
		height: 2px;
		background: #111;
		border-radius: 2px;
	}
	@media (max-width: 820px) {
		.site-header {
			height: auto;
			padding: 0 16px;
		}
		.header-inner {
			flex-wrap: wrap;
			height: auto;
			padding: 12px 0;
		}
		.header-left {
			flex: 1;
		}
		.nav-toggle {
			display: flex;
		}
		.header-right {
			display: none;
		}
		.site-nav {
			display: none;
			width: 100%;
			flex-direction: column;
			align-items: flex-start;
			padding: 8px 0 12px;
			order: 3;
		}
		.site-nav.is-open {
			display: flex;
		}
		.site-nav a {
			line-height: 2.2;
			padding: 0 0;
		}
		.site-nav .nav-search-mobile {
			display: block;
		}
	}
</style>
