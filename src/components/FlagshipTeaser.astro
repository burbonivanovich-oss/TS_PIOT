---
// Тизер для входа на флагман-симулятор /kak-rabotaet-ts-piot/.
// Минималистичная CSS-анимация цепочки касса → ОФД → ФНС/ЧЗ —
// чек проходит по стрелкам зацикленно, привлекая внимание.
// Lottie не используем — для трёх движущихся элементов это
// overkill, CSS-аnimation весит ноль и работает на любом устройстве.
import { u } from '../utils/url';
---

<a href={u('/kak-rabotaet-ts-piot/')} class="ft-card" data-track="flagship-teaser-clicked">
	<div class="ft-anim" aria-hidden="true">
		<div class="ft-node node-kkt">Касса</div>
		<div class="ft-flow">
			<div class="ft-arrow"><span class="ft-dot"></span></div>
		</div>
		<div class="ft-node node-ofd">ОФД</div>
		<div class="ft-fork">
			<div class="ft-arrow fork-up"><span class="ft-dot delay-1"></span></div>
			<div class="ft-arrow fork-down"><span class="ft-dot delay-2"></span></div>
		</div>
		<div class="ft-targets">
			<div class="ft-node node-fns">ФНС</div>
			<div class="ft-node node-cz">Честный знак</div>
		</div>
	</div>

	<div class="ft-text">
		<p class="ft-eyebrow">Интерактивный разбор · 7 шагов</p>
		<h3 class="ft-title">Пройдите путь чека через ТС ПИоТ сами</h3>
		<p class="ft-desc">
			Сканирование DataMatrix → запрос в «Честный знак» → формирование
			фискального чека → передача в ФНС и ЧЗ. Каждый шаг — мини-интерактив.
		</p>
		<span class="ft-cta">Открыть симулятор →</span>
	</div>
</a>

<script>
	document.querySelector('a[data-track="flagship-teaser-clicked"]')?.addEventListener('click', async () => {
		const { track } = await import('../utils/track');
		track('flagship-teaser-clicked');
	});
</script>

<style>
	.ft-card {
		display: grid;
		grid-template-columns: minmax(260px, 1fr) 1.4fr;
		gap: 1.5rem;
		padding: 1.5rem;
		background: linear-gradient(135deg, var(--sand, #f4ebd9) 0%, #fff 100%);
		border-radius: 14px;
		border: 2px solid transparent;
		text-decoration: none;
		color: var(--dark, #1f1f1f);
		transition: border-color 0.2s ease, transform 0.2s ease;
	}
	.ft-card:hover {
		border-color: var(--pink, #ff4d8f);
		transform: translateY(-2px);
	}

	.ft-anim {
		position: relative;
		display: grid;
		grid-template-columns: auto auto auto auto auto;
		align-items: center;
		gap: 0.5rem;
		padding: 1.5rem 1rem;
		background: rgba(255, 255, 255, 0.6);
		border-radius: 10px;
		min-height: 120px;
	}
	.ft-node {
		padding: 0.4rem 0.7rem;
		background: #fff;
		border-radius: 6px;
		font-size: 0.8rem;
		font-weight: 600;
		white-space: nowrap;
		box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
	}
	.ft-node.node-kkt { background: #fff; }
	.ft-node.node-ofd { background: var(--lime, #c8ff6b); }
	.ft-node.node-fns,
	.ft-node.node-cz  { background: #fff; }

	.ft-flow,
	.ft-fork {
		position: relative;
	}
	.ft-arrow {
		position: relative;
		width: 30px;
		height: 2px;
		background: rgba(31, 31, 31, 0.2);
	}
	.ft-arrow::after {
		content: '';
		position: absolute;
		right: -1px;
		top: -3px;
		border-left: 6px solid rgba(31, 31, 31, 0.35);
		border-top: 4px solid transparent;
		border-bottom: 4px solid transparent;
	}
	.ft-fork {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.ft-arrow.fork-up,
	.ft-arrow.fork-down {
		width: 30px;
	}
	.ft-targets {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.ft-dot {
		position: absolute;
		top: -3px;
		left: -4px;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--pink, #ff4d8f);
		animation: ft-travel 2.4s linear infinite;
	}
	.ft-dot.delay-1 { animation-delay: 0.3s; background: #888; }
	.ft-dot.delay-2 {
		animation-delay: 0.3s;
		background: var(--pink, #ff4d8f);
		animation-duration: 2.7s;
	}
	@keyframes ft-travel {
		from { left: -4px; opacity: 0; }
		15%  { opacity: 1; }
		85%  { opacity: 1; }
		to   { left: calc(100% - 4px); opacity: 0; }
	}

	.ft-text {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.5rem;
	}
	.ft-eyebrow {
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--pink, #ff4d8f);
		margin: 0;
		font-weight: 600;
	}
	.ft-title {
		margin: 0;
		font-size: 1.25rem;
		line-height: 1.25;
		color: var(--dark, #1f1f1f);
	}
	.ft-desc {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.55;
		color: #444;
	}
	.ft-cta {
		margin-top: 0.5rem;
		font-weight: 600;
		color: var(--pink, #ff4d8f);
	}

	@media (max-width: 720px) {
		.ft-card { grid-template-columns: 1fr; }
		.ft-anim {
			grid-template-columns: 1fr;
			justify-items: center;
			gap: 0.6rem;
		}
		.ft-flow .ft-arrow,
		.ft-fork .ft-arrow {
			width: 2px;
			height: 24px;
		}
		.ft-flow .ft-arrow::after,
		.ft-fork .ft-arrow::after {
			right: auto;
			top: auto;
			bottom: -1px;
			left: -3px;
			border-left: 4px solid transparent;
			border-right: 4px solid transparent;
			border-top: 6px solid rgba(31, 31, 31, 0.35);
			border-bottom: none;
		}
		.ft-dot { animation: ft-travel-v 2.4s linear infinite; }
		@keyframes ft-travel-v {
			from { top: -4px; left: -3px; opacity: 0; }
			15%  { opacity: 1; }
			85%  { opacity: 1; }
			to   { top: calc(100% - 4px); left: -3px; opacity: 0; }
		}
		.ft-fork { flex-direction: row; gap: 1rem; }
		.ft-targets { flex-direction: row; gap: 0.4rem; }
	}

	@media (prefers-reduced-motion: reduce) {
		.ft-dot { animation: none; opacity: 1; }
	}
</style>
