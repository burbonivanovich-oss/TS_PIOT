---
// Глобальные мета-теги, OG, Twitter Cards, JSON-LD.
// Импортируется на каждой странице.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { SITE_TITLE, SITE_LOCALE } from '../consts';
import { u } from '../utils/url';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata | string;
	type?: 'website' | 'article';
	publishedTime?: string;
	modifiedTime?: string;
	keywords?: string[];
	noindex?: boolean;
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
	title,
	description,
	image,
	type = 'website',
	publishedTime,
	modifiedTime,
	keywords,
	noindex = false,
	jsonLd,
} = Astro.props;

const fullTitle = title === SITE_TITLE ? title : `${title} — ${SITE_TITLE}`;
// PNG default обязателен: Telegram игнорирует SVG для og:image.
const imageSrc =
	typeof image === 'string' ? image : image?.src ?? '/og-default.png';
const ogImage = new URL(imageSrc, Astro.url);
const ogImageIsSvg = imageSrc.endsWith('.svg');
const ogImageType = imageSrc.endsWith('.jpg') || imageSrc.endsWith('.jpeg')
	? 'image/jpeg'
	: imageSrc.endsWith('.png')
	? 'image/png'
	: imageSrc.endsWith('.webp')
	? 'image/webp'
	: undefined;

const orgJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: SITE_TITLE,
	url: Astro.site?.toString(),
	logo: new URL('/favicon.svg', Astro.site).toString(),
};

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: SITE_TITLE,
	url: Astro.site?.toString(),
	inLanguage: SITE_LOCALE,
	potentialAction: {
		'@type': 'SearchAction',
		target: `${Astro.site?.toString()}search/?q={search_term_string}`,
		'query-input': 'required name=search_term_string',
	},
};

const extraJsonLd = jsonLd
	? Array.isArray(jsonLd)
		? jsonLd
		: [jsonLd]
	: [];
---

<!-- Базовые мета-теги -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<link rel="icon" type="image/svg+xml" href={u('/favicon.svg')} />
<link rel="sitemap" href={u('/sitemap.xml')} />
<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={new URL('rss.xml', Astro.site)} />
<link rel="canonical" href={canonicalURL} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700;900&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />
<link rel="preload" href={u('/fonts/inter-regular.woff')} as="font" type="font/woff" crossorigin />
<link rel="preload" href={u('/fonts/inter-bold.woff')} as="font" type="font/woff" crossorigin />
<link rel="preload" href={u('/fonts/geologica-regular.woff')} as="font" type="font/woff" crossorigin />
<link rel="preload" href={u('/fonts/commissioner-bold.woff')} as="font" type="font/woff" crossorigin />

{noindex ? (
	<meta name="robots" content="noindex,nofollow" />
) : (
	<meta name="robots" content="index,follow" />
)}


<!-- Основные мета -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
{keywords && keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
<meta http-equiv="content-language" content={SITE_LOCALE} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:locale" content={SITE_LOCALE} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:secure_url" content={ogImage} />
{ogImageType && <meta property="og:image:type" content={ogImageType} />}
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImage} />

<!-- JSON-LD: Organization + WebSite -->
<script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
{extraJsonLd.map((data) => (
	<script type="application/ld+json" set:html={JSON.stringify(data)} />
))}

<!-- Yandex / Google verification -->
<meta name="yandex-verification" content="8b85e2f93ab1d090" />
<meta name="google-site-verification" content="EHL_AX5GcVNNuQARka6H4Hs9vT5aPgbH9qydRC1iA0o" />

<!-- Yandex.Metrika -->
<script type="text/javascript" is:inline>
	(function(m,e,t,r,i,k,a){
		m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
		m[i].l=1*new Date();
		for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
		k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
	})(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=109130279', 'ym');
	ym(109130279, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});
</script>
