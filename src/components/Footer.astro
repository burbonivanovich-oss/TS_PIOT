---
import { SITE_TITLE, NAV_LINKS } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-col footer-col--brand">
			<a href="/" class="footer-brand">{SITE_TITLE}</a>
			<p class="footer-desc">
				Информационный портал для малого и среднего бизнеса. Разбираем требования
				ТС ПИоТ, маркировки «Честный знак» и изменения в законодательстве простым
				языком.
			</p>
		</div>
		<div class="footer-col">
			<p class="footer-heading">Разделы</p>
			<ul>
				{NAV_LINKS.filter((l) => l.href !== '/').map((link) => (
					<li><a href={link.href}>{link.label}</a></li>
				))}
				<li><a href="/rss.xml">RSS-лента</a></li>
			</ul>
		</div>
		<div class="footer-col">
			<p class="footer-heading">Инструменты</p>
			<ul>
				<li><a href="/kalkulyator-shtrafov/">Калькулятор штрафов</a></li>
				<li><a href="/kalendar-markirovki/">Календарь маркировки</a></li>
				<li><a href="/slovar/">Словарь терминов</a></li>
				<li><a href="/tags/">Все теги</a></li>
			</ul>
		</div>
		<div class="footer-col">
			<p class="footer-heading">Документы</p>
			<ul>
				<li><a href="/about/">О проекте</a></li>
				<li><a href="/privacy/">Конфиденциальность</a></li>
			</ul>
		</div>
	</div>
	<div class="footer-bottom">
		<small>
			© {today.getFullYear()} {SITE_TITLE}. Материалы носят информационный характер
			и не являются юридической или налоговой консультацией.
		</small>
	</div>
</footer>

<style>
	footer {
		background: var(--text);
		color: rgba(255, 255, 255, 0.6);
		padding: var(--sp-8) var(--sp-4) var(--sp-6);
		margin-top: var(--sp-8);
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 2fr repeat(3, 1fr);
		gap: var(--sp-7);
	}

	.footer-brand {
		display: block;
		font-family: 'Commissioner', sans-serif;
		font-weight: 700;
		font-size: 1.125rem;
		letter-spacing: -0.02em;
		color: #fff;
		text-decoration: none;
		margin-bottom: var(--sp-3);
	}

	.footer-desc {
		font-size: 0.875rem;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.45);
		margin: 0;
	}

	.footer-heading {
		font-family: 'Commissioner', sans-serif;
		font-weight: 700;
		font-size: 0.875rem;
		color: #fff;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		margin: 0 0 var(--sp-3);
	}

	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.footer-col li {
		margin-bottom: var(--sp-2);
	}

	.footer-col a {
		color: rgba(255, 255, 255, 0.6);
		text-decoration: none;
		font-size: 0.9375rem;
		transition: color var(--ease);
	}

	.footer-col a:hover {
		color: #fff;
		text-decoration: none;
	}

	.footer-bottom {
		max-width: 1100px;
		margin: var(--sp-7) auto 0;
		padding-top: var(--sp-5);
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		text-align: center;
		font-size: 0.875rem;
		color: rgba(255, 255, 255, 0.35);
	}

	@media (max-width: 900px) {
		.footer-inner {
			grid-template-columns: 1fr 1fr;
			gap: var(--sp-6);
		}
	}

	@media (max-width: 520px) {
		.footer-inner {
			grid-template-columns: 1fr;
			gap: var(--sp-5);
		}
	}
</style>
