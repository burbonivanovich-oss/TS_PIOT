---
import { SITE_TITLE, NAV_LINKS } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-col footer-col--brand">
			<a href="/" class="footer-brand">{SITE_TITLE}<span style="color:var(--accent)">.</span></a>
			<p class="footer-desc">
				Информационный портал для малого и среднего бизнеса. Разбираем требования
				ТС ПИоТ, маркировки «Честный знак» и изменения в законодательстве простым
				языком.
			</p>
		</div>
		<div class="footer-col">
			<p class="footer-heading">Разделы</p>
			<ul>
				{NAV_LINKS.filter((l) => l.href !== '/').map((link) => (
					<li><a href={link.href}>{link.label}</a></li>
				))}
				<li><a href="/rss.xml">RSS-лента</a></li>
			</ul>
		</div>
		<div class="footer-col">
			<p class="footer-heading">Инструменты</p>
			<ul>
				<li><a href="/kalkulyator-shtrafov/">Калькулятор штрафов</a></li>
				<li><a href="/kalendar-markirovki/">Календарь маркировки</a></li>
				<li><a href="/slovar/">Словарь терминов</a></li>
				<li><a href="/tags/">Все теги</a></li>
			</ul>
		</div>
		<div class="footer-col">
			<p class="footer-heading">Документы</p>
			<ul>
				<li><a href="/about/">О проекте</a></li>
				<li><a href="/privacy/">Конфиденциальность</a></li>
			</ul>
		</div>
	</div>
	<div class="footer-bottom">
		<small>
			© {today.getFullYear()} {SITE_TITLE}. Материалы носят информационный характер
			и не являются юридической или налоговой консультацией.
		</small>
	</div>
</footer>

<style>
	footer {
		background: var(--bg-muted);
		color: var(--text-3);
		border-top: 1px solid var(--border);
		padding: 32px 28px 24px;
		margin-top: var(--sp-8);
	}

	.footer-inner {
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 2fr repeat(3, 1fr);
		gap: var(--sp-7);
	}

	.footer-brand {
		display: block;
		font-family: 'Inter', sans-serif;
		font-weight: 800;
		font-size: 1.05rem;
		letter-spacing: -0.02em;
		color: var(--text);
		text-decoration: none;
		margin-bottom: var(--sp-3);
	}

	.footer-desc {
		font-size: 0.85rem;
		line-height: 1.6;
		color: var(--text-3);
		margin: 0;
	}

	.footer-heading,
	.ft-h {
		font-family: 'Inter', sans-serif;
		font-weight: 800;
		font-size: 0.55rem;
		color: var(--accent);
		letter-spacing: 0.16em;
		text-transform: uppercase;
		margin: 0 0 var(--sp-3);
	}

	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.footer-col li {
		margin-bottom: var(--sp-2);
	}

	.footer-col a {
		color: var(--text-3);
		text-decoration: none;
		font-size: 0.8rem;
		transition: color var(--ease);
	}

	.footer-col a:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.footer-bottom {
		max-width: 1200px;
		margin: var(--sp-6) auto 0;
		padding-top: var(--sp-4);
		border-top: 1px solid var(--border);
		text-align: center;
		font-size: 0.8rem;
		color: var(--text-4);
	}

	@media (max-width: 900px) {
		.footer-inner {
			grid-template-columns: 1fr 1fr;
			gap: var(--sp-6);
		}
	}

	@media (max-width: 520px) {
		.footer-inner {
			grid-template-columns: 1fr;
			gap: var(--sp-5);
		}
	}
</style>
