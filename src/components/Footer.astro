---
import { SITE_TITLE, NAV_LINKS } from '../consts';
import { u } from '../utils/url';
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-col footer-col--brand">
			<div class="footer-logo">
				этикетка<span class="logo-dot">.</span>
			</div>
			<p class="footer-about">
				Информационный портал для малого и среднего бизнеса. Разбираем требования
				ТС ПИоТ, маркировки «Честный знак» и изменения в законодательстве.
			</p>
		</div>
		<div class="footer-col">
			<strong>Разделы</strong>
			<ul>
				{NAV_LINKS.filter((l) => l.href !== '/').map((link) => (
					<li><a href={u(link.href)}>{link.label}</a></li>
				))}
				<li><a href={u('/rss.xml')}>RSS-лента</a></li>
			</ul>
		</div>
		<div class="footer-col">
			<strong>Инструменты</strong>
			<ul>
				<li><a href={u('/kalkulyator-shtrafov/')}>Калькулятор штрафов</a></li>
				<li><a href={u('/kalendar-markirovki/')}>Календарь маркировки</a></li>
				<li><a href={u('/slovar/')}>Словарь терминов</a></li>
				<li><a href={u('/tags/')}>Все теги</a></li>
				<li><a href={u('/search/')}>Поиск</a></li>
			</ul>
		</div>
		<div class="footer-col">
			<strong>Документы</strong>
			<ul>
				<li><a href={u('/about/')}>О проекте</a></li>
				<li><a href={u('/privacy/')}>Политика конфиденциальности</a></li>
			</ul>
		</div>
	</div>
	<div class="footer-bottom">
		<small>
			© {today.getFullYear()} {SITE_TITLE}. Материалы носят информационный характер
			и не являются юридической или налоговой консультацией.
		</small>
	</div>
</footer>

<style>
	.site-footer {
		padding: 3em 32px 2em;
		background: #111;
		color: #8A8A8A;
		margin-top: 5rem;
	}
	.footer-inner {
		max-width: var(--maxw, 1680px);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 2fr 1fr 1fr 1fr;
		gap: 2.5rem;
	}
	.footer-logo {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 1.9rem;
		letter-spacing: 0.04em;
		color: #fff;
		line-height: 1;
		margin-bottom: 0.85rem;
		text-transform: lowercase;
	}
	.footer-logo .logo-dot { color: #E8175D; }
	.footer-about {
		font-size: 0.84rem;
		line-height: 1.6;
		margin: 0;
		color: #8A8A8A;
	}
	.footer-col strong {
		display: block;
		color: #fff;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		margin-bottom: 0.85rem;
	}
	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.footer-col li {
		margin-bottom: 0.45rem;
	}
	.footer-col a {
		color: #8A8A8A;
		text-decoration: none;
		font-size: 0.875rem;
		transition: color 0.15s;
	}
	.footer-col a:hover {
		color: #AFCC00;
	}
	.footer-bottom {
		max-width: var(--maxw, 1680px);
		margin: 2.5rem auto 0;
		padding-top: 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.07);
		color: #555;
		font-size: 0.8rem;
		text-align: center;
	}
	@media (max-width: 900px) {
		.footer-inner {
			grid-template-columns: 1fr 1fr;
		}
	}
	@media (max-width: 560px) {
		.site-footer {
			padding: 2em 16px 1.5em;
		}
		.footer-inner {
			grid-template-columns: 1fr;
		}
	}
</style>
