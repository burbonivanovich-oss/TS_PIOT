---
import { Image } from 'astro:assets';
import { type CollectionEntry, getCollection } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_TITLE, SITE_AUTHOR, SITE_LOCALE } from '../consts';
import { tagSlug } from '../utils/tags';

type Props = CollectionEntry<'blog'>['data'] & {
	slug?: string;
	headings?: MarkdownHeading[];
	readingTime?: number;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	categories = [],
	tags = [],
	author = SITE_AUTHOR,
	seo,
	slug: currentSlug,
	headings = [],
	readingTime,
} = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const candidates = allPosts.filter((p) => p.id !== currentSlug);
const scored = candidates
	.map((p) => ({
		post: p,
		score:
			(p.data.tags ?? []).filter((t) => tags.includes(t)).length * 2 +
			(p.data.categories ?? []).filter((c) => categories.includes(c)).length,
	}))
	.filter((x) => x.score > 0)
	.sort(
		(a, b) =>
			b.score - a.score ||
			b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf(),
	);
const related = scored.slice(0, 3).map((x) => x.post);

const canonical = seo?.canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const keywords = [...new Set([...tags, ...(seo?.keywords ?? [])])];

const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

const articleImageUrl = currentSlug
	? new URL(`/og/${currentSlug}.png`, Astro.site).toString()
	: undefined;

const articleJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	inLanguage: SITE_LOCALE,
	...(articleImageUrl && {
		image: {
			'@type': 'ImageObject',
			url: articleImageUrl,
			width: 1200,
			height: 630,
		},
	}),
	author: {
		'@type': 'Person',
		name: author,
		url: new URL('/about/avtor/', Astro.site).toString(),
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		logo: {
			'@type': 'ImageObject',
			url: new URL('/favicon.svg', Astro.site).toString(),
		},
	},
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	mainEntityOfPage: canonical,
	keywords: keywords.join(', '),
	articleSection: categories.map((c) => CATEGORIES[c as keyof typeof CATEGORIES]?.title ?? c),
};

const breadcrumbsJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Главная',
			item: new URL('/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Статьи',
			item: new URL('/blog/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: title,
			item: canonical,
		},
	],
};

const primaryCategory = categories[0] as keyof typeof CATEGORIES | undefined;
const categoryMeta = primaryCategory ? CATEGORIES[primaryCategory] : null;

const catAccent =
	primaryCategory === 'ts-piot' ? '#111' :
	primaryCategory === 'markirovka' ? '#E8175D' :
	primaryCategory === 'zakonodatelstvo' ? '#C8F500' : '#111';

const catAccentText =
	primaryCategory === 'zakonodatelstvo' ? '#111' : '#fff';

const ogImage = heroImage ?? (currentSlug ? `/og/${currentSlug}.png` : undefined);

const shareUrl = encodeURIComponent(canonical);
const shareTitle = encodeURIComponent(title);
---

<html lang="ru">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={ogImage}
			type="article"
			publishedTime={pubDate.toISOString()}
			modifiedTime={updatedDate?.toISOString()}
			keywords={keywords}
			noindex={seo?.noindex}
			jsonLd={[articleJsonLd, breadcrumbsJsonLd]}
		/>
	</head>

	<body>
		<div id="rp-bar" aria-hidden="true"></div>

		<Header />
		<main class="post-main">
			<article class="article" data-pagefind-body>

				<!-- Breadcrumbs -->
				<nav class="breadcrumbs" aria-label="Хлебные крошки" data-pagefind-ignore>
					<a href="/">Главная</a>
					<span>/</span>
					<a href="/blog/">Статьи</a>
					{categoryMeta && (
						<>
							<span>/</span>
							<a href={`/category/${primaryCategory}/`}>{categoryMeta.title}</a>
						</>
					)}
				</nav>

				<!-- Article header -->
				<header class="article-head">
					{categoryMeta && (
						<div class="cat-chip" style={`background:${catAccent};color:${catAccentText}`}>
							{categoryMeta.title}
						</div>
					)}
					<h1>{title}</h1>
					<p class="lead">{description}</p>
					<div class="meta">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span> · обновлено <FormattedDate date={updatedDate} /></span>
						)}
						{readingTime && (
							<span> · {readingTime} мин</span>
						)}
					</div>
					{tags.length > 0 && (
						<div class="tags" data-pagefind-ignore>
							{tags.map((tag) => (
								<a class="tag-pill" href={`/tag/${tagSlug(tag)}/`}>#{tag}</a>
							))}
						</div>
					)}
				</header>

				{heroImage && (
					<div class="hero-image">
						<Image width={1100} height={550} src={heroImage} alt={title} loading="eager" />
					</div>
				)}

				<!-- TOC -->
				{tocHeadings.length > 2 && (
					<details class="toc" data-pagefind-ignore>
						<summary>Содержание</summary>
						<nav>
							<ol class="toc-list">
								{tocHeadings.map((h) => (
									<li class={`toc-item toc-depth-${h.depth}`}>
										<a href={`#${h.slug}`}>{h.text}</a>
									</li>
								))}
							</ol>
						</nav>
					</details>
				)}

				<div class="prose">
					<slot />
				</div>

				<!-- Share -->
				<div class="share" data-pagefind-ignore>
					<span class="share-label">Поделиться</span>
					<a
						class="share-btn share-tg"
						href={`https://t.me/share/url?url=${shareUrl}&text=${shareTitle}`}
						target="_blank"
						rel="noopener noreferrer"
					>Telegram</a>
					<a
						class="share-btn share-vk"
						href={`https://vk.com/share.php?url=${shareUrl}`}
						target="_blank"
						rel="noopener noreferrer"
					>ВКонтакте</a>
				</div>

				<!-- Related -->
				{related.length > 0 && (
					<aside class="related" aria-labelledby="related-heading" data-pagefind-ignore>
						<div class="related-header">
							<span class="related-eyebrow">Читайте также</span>
						</div>
						<ul class="related-list">
							{related.map((post) => {
								const cat = post.data.categories?.[0] as keyof typeof CATEGORIES | undefined;
								const catM = cat ? CATEGORIES[cat] : null;
								const accent =
									cat === 'ts-piot' ? '#111' :
									cat === 'markirovka' ? '#E8175D' :
									cat === 'zakonodatelstvo' ? '#C8F500' : '#111';
								return (
									<li class="related-card" style={`border-left-color:${accent}`}>
										<a href={`/blog/${post.id}/`}>
											{catM && <span class="related-cat">{catM.title}</span>}
											<h3>{post.data.title}</h3>
											<p>{post.data.description}</p>
										</a>
									</li>
								);
							})}
						</ul>
					</aside>
				)}

				<footer class="article-foot">
					<p class="disclaimer">
						Материал носит информационный характер и не является юридической
						или налоговой консультацией. Перед принятием решений сверяйтесь
						с действующей редакцией нормативных актов.
					</p>
				</footer>
			</article>
		</main>
		<Footer />

		<script>
			const bar = document.getElementById('rp-bar');
			if (bar) {
				const update = () => {
					const scrolled = document.documentElement.scrollTop;
					const total = document.documentElement.scrollHeight - window.innerHeight;
					bar.style.width = total > 0 ? `${(scrolled / total) * 100}%` : '0%';
				};
				window.addEventListener('scroll', update, { passive: true });
				update();
			}
		</script>

		<style>
			/* Reading progress bar */
			#rp-bar {
				position: fixed;
				top: 0;
				left: 0;
				height: 3px;
				width: 0%;
				background: #E8175D;
				z-index: 100;
				transition: width 0.1s linear;
			}

			.post-main {
				padding: 48px 32px 80px;
			}

			.article {
				max-width: 720px;
				margin: 0 auto;
			}

			/* Breadcrumbs */
			.breadcrumbs {
				font-size: 0.7rem;
				font-weight: 600;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: #999;
				margin-bottom: 28px;
				display: flex;
				align-items: center;
				gap: 6px;
				flex-wrap: wrap;
			}
			.breadcrumbs a {
				color: #999;
				text-decoration: none;
			}
			.breadcrumbs a:hover { color: #111; }
			.breadcrumbs span { color: #ccc; }

			/* Article header */
			.article-head {
				margin-bottom: 2rem;
			}
			.cat-chip {
				display: inline-block;
				font-size: 0.65rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				padding: 0.25em 0.8em;
				margin-bottom: 16px;
			}
			.article-head h1 {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 3.6rem;
				line-height: 1;
				letter-spacing: 0.02em;
				color: #111;
				text-transform: uppercase;
				margin: 0 0 18px;
			}
			.lead {
				font-size: 1.1rem;
				color: #555;
				line-height: 1.6;
				margin: 0 0 14px;
				font-style: italic;
			}
			.meta {
				font-size: 0.82rem;
				color: #888;
				margin-bottom: 16px;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 6px;
				margin-top: 4px;
			}
			/* tag-pill is defined in global.css */

			/* Hero image */
			.hero-image {
				margin: 0 0 2rem;
			}
			.hero-image img {
				width: 100%;
				height: auto;
				display: block;
			}

			/* TOC */
			.toc {
				border-left: 3px solid #E8175D;
				background: #F6F4F0;
				padding: 1rem 1.2rem;
				margin: 0 0 2rem;
			}
			.toc summary {
				cursor: pointer;
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.1rem;
				letter-spacing: 0.06em;
				color: #111;
				list-style: none;
				display: flex;
				justify-content: space-between;
				align-items: center;
				user-select: none;
			}
			.toc summary::-webkit-details-marker { display: none; }
			.toc summary::after {
				content: '▸';
				font-size: 0.8rem;
				color: #E8175D;
				transition: transform 0.15s;
				font-family: inherit;
			}
			.toc[open] summary::after { transform: rotate(90deg); }
			.toc-list {
				margin: 0.8rem 0 0;
				padding-left: 1rem;
				list-style: none;
			}
			.toc-item {
				margin-bottom: 0.3rem;
				line-height: 1.4;
			}
			.toc-depth-3 { padding-left: 1rem; }
			.toc-item a {
				color: #444;
				text-decoration: none;
				font-size: 0.88rem;
			}
			.toc-item a:hover {
				color: #E8175D;
			}

			/* Prose */
			.prose {
				font-size: 1rem;
				line-height: 1.75;
				color: #1a1a1a;
				border-top: 2px solid #111;
				padding-top: 2rem;
			}

			/* Share */
			.share {
				display: flex;
				align-items: center;
				gap: 8px;
				margin: 2.5rem 0 0;
				padding: 1.2rem 0;
				border-top: 1px solid rgba(0,0,0,.1);
				border-bottom: 1px solid rgba(0,0,0,.1);
			}
			.share-label {
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: #888;
				margin-right: 4px;
			}
			.share-btn {
				display: inline-block;
				padding: 6px 14px;
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				text-decoration: none;
				background: #111;
				color: #EDE8DF;
				transition: background 0.15s;
			}
			.share-btn:hover { background: #E8175D; color: #fff; }

			/* Related */
			.related {
				margin-top: 3rem;
			}
			.related-header {
				margin-bottom: 1.2rem;
			}
			.related-eyebrow {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.8rem;
				letter-spacing: 0.03em;
				color: #111;
			}
			.related-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1px;
				background: rgba(0,0,0,.1);
				border: 1px solid rgba(0,0,0,.1);
			}
			.related-card {
				border-left: 4px solid #111;
				background: #fff;
			}
			.related-card a {
				display: block;
				padding: 1rem 1rem 1rem 0.9rem;
				text-decoration: none;
				height: 100%;
				transition: background 0.15s;
			}
			.related-card a:hover { background: #F6F4F0; }
			.related-cat {
				display: block;
				font-size: 0.65rem;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: #888;
				margin-bottom: 6px;
			}
			.related-card h3 {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.05rem;
				letter-spacing: 0.02em;
				color: #111;
				margin: 0 0 6px;
				line-height: 1.2;
				text-transform: uppercase;
			}
			.related-card p {
				font-size: 0.8rem;
				color: #666;
				margin: 0;
				line-height: 1.4;
			}

			/* Article footer */
			.article-foot {
				margin-top: 2.5rem;
				padding-top: 1.5rem;
				border-top: 1px solid rgba(0,0,0,.1);
			}
			.disclaimer {
				font-size: 0.82rem;
				color: #999;
				font-style: italic;
				margin: 0;
			}

			/* Responsive */
			@media (max-width: 820px) {
				.post-main { padding: 32px 20px 60px; }
				.article-head h1 { font-size: 2.8rem; }
				.related-list { grid-template-columns: 1fr; }
			}
			@media (max-width: 560px) {
				.post-main { padding: 24px 16px 48px; }
				.article-head h1 { font-size: 2.2rem; }
			}
		</style>
	</body>
</html>
