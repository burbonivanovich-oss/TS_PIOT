---
import { Image } from 'astro:assets';
import { type CollectionEntry, getCollection } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import {
	CATEGORIES,
	SITE_TITLE,
	SITE_AUTHOR,
	SITE_LOCALE,
	SIDEBAR_BANNER,
	INLINE_SUBSCRIBE,
} from '../consts';
import { tagSlug } from '../utils/tags';

type Props = CollectionEntry<'blog'>['data'] & {
	slug?: string;
	headings?: MarkdownHeading[];
	readingTime?: number;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	categories = [],
	tags = [],
	author = SITE_AUTHOR,
	seo,
	slug: currentSlug,
	headings = [],
	readingTime,
} = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = allPosts.sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const currentIndex = sorted.findIndex((p) => p.id === currentSlug);
const prevPost = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sorted[currentIndex - 1] : null;

const candidates = sorted.filter((p) => p.id !== currentSlug);
const scored = candidates
	.map((p) => ({
		post: p,
		score:
			(p.data.tags ?? []).filter((t) => tags.includes(t)).length * 2 +
			(p.data.categories ?? []).filter((c) => categories.includes(c)).length,
	}))
	.filter((x) => x.score > 0)
	.sort(
		(a, b) =>
			b.score - a.score ||
			b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf(),
	);
const related = scored.slice(0, 3).map((x) => x.post);

const canonical = seo?.canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const keywords = [...new Set([...tags, ...(seo?.keywords ?? [])])];
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

const articleImageUrl = currentSlug
	? new URL(`/og/${currentSlug}.png`, Astro.site).toString()
	: undefined;

const articleJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	inLanguage: SITE_LOCALE,
	...(articleImageUrl && {
		image: { '@type': 'ImageObject', url: articleImageUrl, width: 1200, height: 630 },
	}),
	author: {
		'@type': 'Person',
		name: author,
		url: new URL('/about/avtor/', Astro.site).toString(),
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', Astro.site).toString() },
	},
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	mainEntityOfPage: canonical,
	keywords: keywords.join(', '),
	articleSection: categories.map(
		(c) => CATEGORIES[c as keyof typeof CATEGORIES]?.title ?? c,
	),
};

const breadcrumbsJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Главная', item: new URL('/', Astro.site).toString() },
		{ '@type': 'ListItem', position: 2, name: 'Статьи', item: new URL('/blog/', Astro.site).toString() },
		{ '@type': 'ListItem', position: 3, name: title, item: canonical },
	],
};

const primaryCategory = categories[0] as keyof typeof CATEGORIES | undefined;
const categoryMeta = primaryCategory ? CATEGORIES[primaryCategory] : null;

const catAccent =
	primaryCategory === 'ts-piot' ? '#111' :
	primaryCategory === 'markirovka' ? '#E8175D' :
	primaryCategory === 'zakonodatelstvo' ? '#C8F500' : '#111';
const catAccentText = primaryCategory === 'zakonodatelstvo' ? '#111' : '#fff';

/* Background letter from title abbreviation */
function abbrev(t: string): string {
	const words = t.replace(/[«»"']/g, '').split(/\s+/).filter((w) => w.length > 2);
	if (words.length >= 2) return (words[0][0] + words[1][0]).toUpperCase();
	return t.slice(0, 2).toUpperCase();
}
const bgLetter = abbrev(title);

const ogImage = heroImage ?? (currentSlug ? `/og/${currentSlug}.png` : undefined);
const shareUrl = encodeURIComponent(canonical);
const shareTitle = encodeURIComponent(title);
---

<html lang="ru">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={ogImage}
			type="article"
			publishedTime={pubDate.toISOString()}
			modifiedTime={updatedDate?.toISOString()}
			keywords={keywords}
			noindex={seo?.noindex}
			jsonLd={[articleJsonLd, breadcrumbsJsonLd]}
		/>
	</head>

	<body>
		<!-- Reading progress bar -->
		<div id="rp-bar" aria-hidden="true"></div>

		<Header />

		<article data-pagefind-body>

			<!-- ═══ HERO: 58% image / 42% text ═══ -->
			<section class="art-hero">
				<div class="art-hero-img" style={`background:${catAccent}`}>
					{categoryMeta && (
						<span class="art-hero-cat" style={`background:${primaryCategory === 'zakonodatelstvo' ? '#111' : '#E8175D'};color:#fff`}>
							{categoryMeta.title}
						</span>
					)}
					{heroImage ? (
						<Image
							width={900}
							height={700}
							src={heroImage}
							alt={title}
							loading="eager"
							class="art-hero-photo"
						/>
					) : (
						<span class="art-hero-bg-letter" aria-hidden="true">{bgLetter}</span>
					)}
				</div>
				<div class="art-hero-info">
					<!-- Breadcrumbs in hero -->
					<nav class="art-hero-breadcrumbs" aria-label="Хлебные крошки">
						<a href="/">Главная</a><span>/</span>
						<a href="/blog/">Статьи</a>
						{categoryMeta && (
							<><span>/</span><a href={`/category/${primaryCategory}/`}>{categoryMeta.title}</a></>
						)}
					</nav>

					<div class="art-hero-top">
						<span class="art-hero-date">
							{updatedDate ? (
								<>
									<span class="art-updated-badge">Актуально на <FormattedDate date={updatedDate} /></span>
									<span class="art-pubdate"> · опубл. <FormattedDate date={pubDate} /></span>
								</>
							) : (
								<FormattedDate date={pubDate} />
							)}
							{readingTime && <span> · {readingTime} мин</span>}
						</span>
						<span class="art-verified-badge" title="Редакция проверила факты и источники">✓ Проверено</span>
						{tags.slice(0, 1).map((tag) => (
							<a class="art-hero-hash" href={`/tag/${tagSlug(tag)}/`}>#{tag}</a>
						))}
					</div>
					<h1 class="art-h1">{title}</h1>
					<div class="art-hero-bottom">
						<p class="art-lead">{description}</p>
					</div>
				</div>
			</section>

			<!-- ═══ BODY: 28% sidebar / 72% content ═══ -->
			<div class="art-body">

				<!-- Sticky sidebar -->
				<aside class="art-sidebar" data-pagefind-ignore>
					<div class="art-banner">
						<div class="art-banner-visual" style={`background:${catAccent}`}>
							<span class="art-banner-big" aria-hidden="true">{bgLetter}</span>
						</div>
						<span class="art-banner-eyebrow">{SIDEBAR_BANNER.eyebrow}</span>
						<div class="art-banner-title">{SIDEBAR_BANNER.title}</div>
						<p class="art-banner-desc">{SIDEBAR_BANNER.description}</p>
						<a href={SIDEBAR_BANNER.ctaHref} class="art-banner-cta" target="_blank" rel="noopener noreferrer">
							{SIDEBAR_BANNER.cta}
						</a>
					</div>
				</aside>

				<!-- Main content -->
				<main class="art-content">
					{tags.length > 0 && (
						<div class="art-tags" data-pagefind-ignore>
							{tags.map((tag) => (
								<a class="tag-pill" href={`/tag/${tagSlug(tag)}/`}>#{tag}</a>
							))}
						</div>
					)}

					{tocHeadings.length > 2 && (
						<details class="toc" data-pagefind-ignore>
							<summary>Содержание</summary>
							<nav>
								<ol class="toc-list">
									{tocHeadings.map((h) => (
										<li class={`toc-item toc-depth-${h.depth}`}>
											<a href={`#${h.slug}`}>{h.text}</a>
										</li>
									))}
								</ol>
							</nav>
						</details>
					)}

					<div class="prose">
						<slot />
					</div>

					<!-- Inline subscribe form -->
					<div class="inline-subscribe" data-pagefind-ignore>
						<div class="inline-subscribe-text">
							<strong>{INLINE_SUBSCRIBE.title}</strong>
							<p>{INLINE_SUBSCRIBE.description}</p>
						</div>
						<form class="inline-subscribe-form" action={INLINE_SUBSCRIBE.formAction} method="post">
							<input
								type="email"
								name="email"
								placeholder={INLINE_SUBSCRIBE.placeholder}
								required
								class="subscribe-input"
							/>
							<button type="submit" class="subscribe-btn">{INLINE_SUBSCRIBE.cta}</button>
						</form>
					</div>

					<!-- Share -->
					<div class="art-share" data-pagefind-ignore>
						<span class="share-label">Поделиться</span>
						<a
							class="share-btn"
							href={`https://t.me/share/url?url=${shareUrl}&text=${shareTitle}`}
							target="_blank"
							rel="noopener noreferrer"
						>Telegram</a>
						<a
							class="share-btn"
							href={`https://vk.com/share.php?url=${shareUrl}`}
							target="_blank"
							rel="noopener noreferrer"
						>ВКонтакте</a>
					</div>

					<!-- Was this helpful? -->
					<div class="helpful" id="helpful-widget" data-pagefind-ignore>
						<span class="helpful-label">Была ли статья полезна?</span>
						<div class="helpful-btns">
							<button class="helpful-btn" id="helpful-yes" aria-label="Да">👍 Да</button>
							<button class="helpful-btn" id="helpful-no" aria-label="Нет">👎 Нет</button>
						</div>
						<span class="helpful-thanks" id="helpful-thanks" hidden>Спасибо за оценку!</span>
					</div>

					<!-- Related posts -->
					{related.length > 0 && (
						<aside class="related" aria-labelledby="related-heading" data-pagefind-ignore>
							<span class="related-eyebrow" id="related-heading">Читайте также</span>
							<ul class="related-list">
								{related.map((post) => {
									const cat = post.data.categories?.[0] as keyof typeof CATEGORIES | undefined;
									const catM = cat ? CATEGORIES[cat] : null;
									const accent =
										cat === 'ts-piot' ? '#111' :
										cat === 'markirovka' ? '#E8175D' :
										cat === 'zakonodatelstvo' ? '#C8F500' : '#111';
									return (
										<li class="related-card" style={`border-left-color:${accent}`}>
											<a href={`/blog/${post.id}/`}>
												{catM && <span class="related-cat">{catM.title}</span>}
												<h3>{post.data.title}</h3>
												<p>{post.data.description}</p>
											</a>
										</li>
									);
								})}
							</ul>
						</aside>
					)}

					<!-- Prev / Next navigation -->
					{(prevPost || nextPost) && (
						<nav class="post-nav" aria-label="Между статьями" data-pagefind-ignore>
							{prevPost ? (
								<a class="post-nav-item post-nav-prev" href={`/blog/${prevPost.id}/`}>
									<span class="post-nav-dir">← Предыдущая</span>
									<span class="post-nav-title">{prevPost.data.title}</span>
								</a>
							) : <div />}
							{nextPost ? (
								<a class="post-nav-item post-nav-next" href={`/blog/${nextPost.id}/`}>
									<span class="post-nav-dir">Следующая →</span>
									<span class="post-nav-title">{nextPost.data.title}</span>
								</a>
							) : <div />}
						</nav>
					)}

					<!-- CTA: question to editors -->
					<div class="art-cta" data-pagefind-ignore>
						<div class="art-cta-text">
							<strong>Остались вопросы?</strong>
							<p>Если что-то неясно или вы нашли неточность — напишите редакции. Мы проверяем каждое сообщение.</p>
						</div>
						<a href="mailto:hello@etiketka.media" class="art-cta-btn">Написать →</a>
					</div>

					<footer class="art-foot" data-pagefind-ignore>
						<p class="disclaimer">
							Материал носит информационный характер и не является юридической
							или налоговой консультацией. Перед принятием решений сверяйтесь
							с действующей редакцией нормативных актов.
						</p>
					</footer>
				</main>
			</div>
		</article>

		<Footer />

		<!-- Back to top button -->
		<button id="back-to-top" aria-label="Наверх" title="Наверх">↑</button>

		<script>
			/* Reading progress */
			const bar = document.getElementById('rp-bar');
			if (bar) {
				const update = () => {
					const s = document.documentElement.scrollTop;
					const t = document.documentElement.scrollHeight - window.innerHeight;
					bar.style.width = t > 0 ? `${(s / t) * 100}%` : '0%';
				};
				window.addEventListener('scroll', update, { passive: true });
				update();
			}

			/* Back to top */
			const btt = document.getElementById('back-to-top');
			if (btt) {
				window.addEventListener('scroll', () => {
					btt.classList.toggle('visible', window.scrollY > 400);
				}, { passive: true });
				btt.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
			}

			/* Was this helpful? */
			const key = 'helpful_' + location.pathname;
			const widget = document.getElementById('helpful-widget');
			const thanks = document.getElementById('helpful-thanks');
			const yesBtn = document.getElementById('helpful-yes');
			const noBtn = document.getElementById('helpful-no');
			if (localStorage.getItem(key)) {
				widget?.querySelector('.helpful-btns')?.setAttribute('hidden', '');
				thanks?.removeAttribute('hidden');
			}
			[yesBtn, noBtn].forEach((btn) => {
				btn?.addEventListener('click', () => {
					localStorage.setItem(key, btn.id);
					widget?.querySelector('.helpful-btns')?.setAttribute('hidden', '');
					thanks?.removeAttribute('hidden');
				});
			});
		</script>

		<style>
			/* Reading progress */
			#rp-bar {
				position: fixed;
				top: 0;
				left: 0;
				height: 3px;
				width: 0%;
				background: #E8175D;
				z-index: 200;
				transition: width 0.1s linear;
			}

			/* ═══ HERO breadcrumbs ═══ */
			.art-hero-breadcrumbs {
				font-size: .65rem;
				font-weight: 600;
				letter-spacing: .1em;
				text-transform: uppercase;
				color: #aaa;
				display: flex;
				align-items: center;
				gap: 6px;
				flex-wrap: wrap;
			}
			.art-hero-breadcrumbs a { color: #aaa; text-decoration: none; }
			.art-hero-breadcrumbs a:hover { color: #111; }
			.art-hero-breadcrumbs span { color: #ccc; }

			/* ═══ HERO ═══ */
			.art-hero {
				display: grid;
				grid-template-columns: 58fr 42fr;
				height: calc(100vh - 56px);
				min-height: 480px;
			}
			.art-hero-img {
				position: relative;
				overflow: hidden;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.art-hero-cat {
				position: absolute;
				top: 20px;
				left: 20px;
				font-size: .65rem;
				font-weight: 700;
				letter-spacing: .12em;
				text-transform: uppercase;
				padding: .3em .85em;
				z-index: 2;
			}
			.art-hero-photo {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.art-hero-bg-letter {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 24rem;
				color: #C8F500;
				opacity: .15;
				line-height: 1;
				letter-spacing: -.03em;
				pointer-events: none;
				user-select: none;
			}
			/* Right column: space-between */
			.art-hero-info {
				padding: 32px 48px;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				background: #EDE8DF;
				overflow: auto;
			}
			.art-hero-top {
				display: flex;
				align-items: center;
				flex-wrap: wrap;
				gap: 12px;
			}
			.art-hero-date {
				font-size: .78rem;
				font-weight: 600;
				letter-spacing: .06em;
				text-transform: uppercase;
				color: #888;
			}
			.art-updated-badge {
				background: #C8F500;
				color: #111;
				font-size: .6rem;
				font-weight: 700;
				letter-spacing: .1em;
				text-transform: uppercase;
				padding: .2em .6em;
				margin-right: 4px;
			}
			.art-pubdate { color: #aaa; font-size: .72rem; }
			.art-verified-badge {
				display: inline-flex;
				align-items: center;
				gap: 4px;
				font-size: .65rem;
				font-weight: 700;
				letter-spacing: .08em;
				text-transform: uppercase;
				color: #fff;
				background: #111;
				padding: .25em .7em;
			}
			.art-hero-hash {
				font-size: .75rem;
				font-weight: 700;
				letter-spacing: .08em;
				color: #E8175D;
				text-decoration: none;
			}
			.art-hero-hash:hover { color: #c50f4b; }
			.art-h1 {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 3.2rem;
				line-height: 1;
				letter-spacing: .02em;
				color: #111;
				text-transform: uppercase;
				margin: 0;
			}
			.art-hero-bottom {
				border-top: 2px solid #111;
				padding-top: 20px;
			}
			.art-lead {
				font-size: 1rem;
				color: #444;
				line-height: 1.65;
				font-style: italic;
				margin: 0;
			}

			/* ═══ BODY ═══ */
			.art-body {
				display: grid;
				grid-template-columns: 28fr 72fr;
			}

			/* Sidebar */
			.art-sidebar { padding: 16px; }
			.art-banner {
				position: sticky;
				top: calc(56px + 16px);
				background: #111;
				color: #fff;
				overflow: hidden;
			}
			.art-banner-visual {
				width: 100%;
				aspect-ratio: 16 / 9;
				display: flex;
				align-items: center;
				justify-content: center;
				overflow: hidden;
			}
			.art-banner-big {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 7rem;
				color: #fff;
				opacity: .18;
				line-height: 1;
			}
			.art-banner-eyebrow {
				font-size: .6rem;
				font-weight: 700;
				letter-spacing: .12em;
				text-transform: uppercase;
				color: #C8F500;
				display: block;
				padding: 14px 14px 6px;
			}
			.art-banner-title {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.5rem;
				line-height: 1.05;
				letter-spacing: .03em;
				text-transform: uppercase;
				color: #fff;
				padding: 0 14px 8px;
			}
			.art-banner-desc {
				font-size: .78rem;
				color: #8A8A8A;
				line-height: 1.5;
				padding: 0 14px 14px;
				margin: 0;
			}
			.art-banner-cta {
				display: block;
				margin: 0 14px 14px;
				background: #E8175D;
				color: #fff;
				font-size: .7rem;
				font-weight: 700;
				letter-spacing: .1em;
				text-transform: uppercase;
				padding: 10px 14px;
				text-decoration: none;
				text-align: center;
				transition: background .15s;
			}
			.art-banner-cta:hover { background: #c50f4b; }

			/* Content */
			.art-content {
				padding: 40px 48px 80px;
				border-left: 1px solid rgba(0, 0, 0, .08);
				min-height: 100vh;
			}

			/* Breadcrumbs */
			.art-breadcrumbs {
				font-size: .7rem;
				font-weight: 600;
				letter-spacing: .1em;
				text-transform: uppercase;
				color: #999;
				margin-bottom: 20px;
				display: flex;
				align-items: center;
				gap: 6px;
				flex-wrap: wrap;
			}
			.art-breadcrumbs a { color: #999; text-decoration: none; }
			.art-breadcrumbs a:hover { color: #111; }
			.art-breadcrumbs span { color: #ccc; }

			/* Tags */
			.art-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 6px;
				margin-bottom: 24px;
			}

			/* TOC */
			.toc {
				border-left: 3px solid #E8175D;
				background: #F6F4F0;
				padding: 1rem 1.2rem;
				margin-bottom: 2rem;
			}
			.toc summary {
				cursor: pointer;
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.1rem;
				letter-spacing: .06em;
				color: #111;
				list-style: none;
				display: flex;
				justify-content: space-between;
				align-items: center;
				user-select: none;
			}
			.toc summary::-webkit-details-marker { display: none; }
			.toc summary::after { content: '▸'; font-size: .8rem; color: #E8175D; transition: transform .15s; }
			.toc[open] summary::after { transform: rotate(90deg); }
			.toc-list { margin: .8rem 0 0; padding-left: 1rem; list-style: none; }
			.toc-item { margin-bottom: .3rem; line-height: 1.4; }
			.toc-depth-3 { padding-left: 1rem; }
			.toc-item a { color: #444; text-decoration: none; font-size: .88rem; }
			.toc-item a:hover { color: #E8175D; }

			/* Prose */
			.prose { font-size: 1rem; line-height: 1.75; color: #1a1a1a; }

			/* Inline subscribe */
			.inline-subscribe {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 24px;
				margin: 2.5rem 0;
				padding: 20px 24px;
				background: #111;
				color: #fff;
				flex-wrap: wrap;
			}
			.inline-subscribe-text { flex: 1; min-width: 200px; }
			.inline-subscribe-text strong {
				display: block;
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.3rem;
				letter-spacing: .03em;
				text-transform: uppercase;
				margin-bottom: 4px;
			}
			.inline-subscribe-text p { font-size: .82rem; color: #8A8A8A; margin: 0; }
			.inline-subscribe-form { display: flex; gap: 0; flex-shrink: 0; }
			.subscribe-input {
				border: none;
				background: rgba(255,255,255,.08);
				color: #fff;
				padding: 9px 14px;
				font-size: .82rem;
				font-family: inherit;
				outline: none;
				width: 200px;
			}
			.subscribe-input::placeholder { color: #555; }
			.subscribe-btn {
				background: #E8175D;
				color: #fff;
				border: none;
				padding: 9px 16px;
				font-size: .72rem;
				font-weight: 700;
				letter-spacing: .08em;
				text-transform: uppercase;
				cursor: pointer;
				font-family: inherit;
				white-space: nowrap;
				transition: background .15s;
			}
			.subscribe-btn:hover { background: #c50f4b; }

			/* Share */
			.art-share {
				display: flex;
				align-items: center;
				gap: 8px;
				padding: 1.2rem 0;
				border-top: 1px solid rgba(0, 0, 0, .1);
				border-bottom: 1px solid rgba(0, 0, 0, .1);
			}
			.share-label {
				font-size: .72rem;
				font-weight: 700;
				letter-spacing: .1em;
				text-transform: uppercase;
				color: #888;
				margin-right: 4px;
			}
			.share-btn {
				display: inline-block;
				padding: 6px 14px;
				font-size: .72rem;
				font-weight: 700;
				letter-spacing: .08em;
				text-transform: uppercase;
				text-decoration: none;
				background: #111;
				color: #EDE8DF;
				transition: background .15s;
			}
			.share-btn:hover { background: #E8175D; color: #fff; }

			/* Was this helpful? */
			.helpful {
				display: flex;
				align-items: center;
				gap: 16px;
				margin: 1.5rem 0;
				padding: 16px 20px;
				background: #F6F4F0;
				flex-wrap: wrap;
			}
			.helpful-label {
				font-size: .82rem;
				font-weight: 600;
				color: #555;
			}
			.helpful-btns { display: flex; gap: 8px; }
			.helpful-btn {
				background: none;
				border: 1px solid rgba(0, 0, 0, .15);
				padding: 6px 16px;
				font-size: .82rem;
				cursor: pointer;
				font-family: inherit;
				transition: all .15s;
			}
			.helpful-btn:hover { background: #111; color: #EDE8DF; border-color: #111; }
			.helpful-thanks { font-size: .82rem; color: #888; font-style: italic; }

			/* Related */
			.related { margin-top: 2.5rem; }
			.related-eyebrow {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.8rem;
				letter-spacing: .03em;
				color: #111;
				display: block;
				margin-bottom: 1rem;
			}
			.related-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1px;
				background: rgba(0, 0, 0, .1);
				border: 1px solid rgba(0, 0, 0, .1);
			}
			.related-card { border-left: 4px solid #111; background: #fff; }
			.related-card a {
				display: block;
				padding: 1rem 1rem 1rem .9rem;
				text-decoration: none;
				height: 100%;
				transition: background .15s;
			}
			.related-card a:hover { background: #F6F4F0; }
			.related-cat {
				display: block;
				font-size: .65rem;
				font-weight: 700;
				letter-spacing: .1em;
				text-transform: uppercase;
				color: #888;
				margin-bottom: 6px;
			}
			.related-card h3 {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.05rem;
				letter-spacing: .02em;
				color: #111;
				margin: 0 0 6px;
				line-height: 1.2;
				text-transform: uppercase;
			}
			.related-card p { font-size: .8rem; color: #666; margin: 0; line-height: 1.4; }

			/* Prev / Next */
			.post-nav {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1px;
				background: rgba(0, 0, 0, .1);
				margin-top: 2rem;
				border: 1px solid rgba(0, 0, 0, .1);
			}
			.post-nav-item {
				background: #fff;
				padding: 16px 20px;
				text-decoration: none;
				display: flex;
				flex-direction: column;
				gap: 6px;
				transition: background .15s;
			}
			.post-nav-item:hover { background: #F6F4F0; }
			.post-nav-next { text-align: right; }
			.post-nav-dir {
				font-size: .65rem;
				font-weight: 700;
				letter-spacing: .1em;
				text-transform: uppercase;
				color: #999;
			}
			.post-nav-title {
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.1rem;
				letter-spacing: .02em;
				text-transform: uppercase;
				color: #111;
				line-height: 1.1;
			}

			/* CTA block */
			.art-cta {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 20px;
				margin: 2rem 0;
				padding: 20px 24px;
				border: 2px solid #111;
				flex-wrap: wrap;
			}
			.art-cta-text { flex: 1; min-width: 180px; }
			.art-cta-text strong {
				display: block;
				font-family: 'Bebas Neue', sans-serif;
				font-size: 1.4rem;
				letter-spacing: .03em;
				text-transform: uppercase;
				margin-bottom: 4px;
			}
			.art-cta-text p { font-size: .82rem; color: #555; margin: 0; }
			.art-cta-btn {
				background: #111;
				color: #EDE8DF;
				font-size: .72rem;
				font-weight: 700;
				letter-spacing: .1em;
				text-transform: uppercase;
				padding: 10px 20px;
				text-decoration: none;
				white-space: nowrap;
				flex-shrink: 0;
				transition: background .15s;
			}
			.art-cta-btn:hover { background: #E8175D; color: #fff; }

			/* Disclaimer */
			.art-foot {
				margin-top: 2.5rem;
				padding-top: 1.5rem;
				border-top: 1px solid rgba(0, 0, 0, .1);
			}
			.disclaimer { font-size: .82rem; color: #999; font-style: italic; margin: 0; }

			/* Back to top */
			#back-to-top {
				position: fixed;
				bottom: 24px;
				right: 24px;
				width: 40px;
				height: 40px;
				background: #111;
				color: #EDE8DF;
				border: none;
				font-size: 1rem;
				cursor: pointer;
				opacity: 0;
				pointer-events: none;
				transition: opacity .2s, background .15s;
				z-index: 90;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			#back-to-top.visible { opacity: 1; pointer-events: auto; }
			#back-to-top:hover { background: #E8175D; }

			/* Responsive */
			@media (max-width: 1024px) {
				.art-body { grid-template-columns: 1fr; }
				.art-sidebar { display: none; }
				.art-content { padding: 32px 32px 60px; border-left: none; }
			}
			@media (max-width: 820px) {
				.art-hero { grid-template-columns: 1fr; height: auto; }
				.art-hero-img { height: 280px; }
				.art-hero-info { padding: 24px; }
				.art-h1 { font-size: 2.4rem; }
				.art-content { padding: 24px 20px 48px; }
				.related-list { grid-template-columns: 1fr; }
				.post-nav { grid-template-columns: 1fr; }
				.inline-subscribe { flex-direction: column; align-items: flex-start; }
				.subscribe-input { width: 100%; }
			}
			@media (max-width: 560px) {
				.art-h1 { font-size: 2rem; }
				.art-content { padding: 20px 16px 40px; }
			}
		</style>
	</body>
</html>
