---
import { Image } from 'astro:assets';
import { type CollectionEntry, getCollection } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_TITLE, SITE_AUTHOR, SITE_LOCALE } from '../consts';
import { tagSlug } from '../utils/tags';
import {
  PRODUCTS,
  SIDEBAR_DEFAULTS,
  CAT_GRADIENTS,
  CATEGORY_BLOCKS,
  type InlineBlock,
} from '../data/affiliates';

type Props = CollectionEntry<'blog'>['data'] & {
  slug?: string;
  headings?: MarkdownHeading[];
  readingTime?: number;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  categories = [],
  tags = [],
  author = SITE_AUTHOR,
  seo,
  slug: currentSlug,
  headings = [],
  readingTime,
} = Astro.props;

// Related posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const candidates = allPosts.filter((p) => p.id !== currentSlug);
const scored = candidates
  .map((p) => ({
    post: p,
    score:
      (p.data.tags ?? []).filter((t) => tags.includes(t)).length * 2 +
      (p.data.categories ?? []).filter((c) => categories.includes(c)).length,
  }))
  .filter((x) => x.score > 0)
  .sort(
    (a, b) =>
      b.score - a.score ||
      b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf(),
  );
const related = scored.slice(0, 3).map((x) => x.post);

// SEO / meta
const canonical = seo?.canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const keywords = [...new Set([...tags, ...(seo?.keywords ?? [])])];
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const articleImageUrl = currentSlug
  ? new URL(`/og/${currentSlug}.png`, Astro.site).toString()
  : undefined;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  inLanguage: SITE_LOCALE,
  ...(articleImageUrl && {
    image: { '@type': 'ImageObject', url: articleImageUrl, width: 1200, height: 630 },
  }),
  author: {
    '@type': 'Person',
    name: author,
    url: new URL('/about/avtor/', Astro.site).toString(),
  },
  publisher: {
    '@type': 'Organization',
    name: SITE_TITLE,
    logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', Astro.site).toString() },
  },
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  mainEntityOfPage: canonical,
  keywords: keywords.join(', '),
  articleSection: categories.map((c) => CATEGORIES[c as keyof typeof CATEGORIES]?.title ?? c),
};

const breadcrumbsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: new URL('/', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: 'Статьи', item: new URL('/blog/', Astro.site).toString() },
    { '@type': 'ListItem', position: 3, name: title, item: canonical },
  ],
};

const primaryCategory = categories[0] as keyof typeof CATEGORIES | undefined;
const categoryMeta = primaryCategory ? CATEGORIES[primaryCategory] : null;
const ogImage = heroImage ?? (currentSlug ? `/og/${currentSlug}.png` : undefined);
const shareUrl = encodeURIComponent(canonical);
const shareTitle = encodeURIComponent(title);

// Hero gradient
const catKey = primaryCategory ?? 'default';
const grad = CAT_GRADIENTS[catKey] ?? CAT_GRADIENTS['default'];

// Sidebar product
const sidebarProductId =
  (primaryCategory && SIDEBAR_DEFAULTS[primaryCategory]) || 'evotor';
const sidebarProduct = PRODUCTS[sidebarProductId] ?? PRODUCTS['evotor'];

// Inline affiliate blocks
const inlineBlocks = primaryCategory ? (CATEGORY_BLOCKS[primaryCategory] ?? []) : [];

// Helper: render one inline block to a data object for the template
function resolveBlock(block: InlineBlock) {
  if (block.type === 'product') return { ...block, product: PRODUCTS[block.productId] };
  if (block.type === 'compare') {
    return {
      ...block,
      products: block.productIds.map((id) => PRODUCTS[id]).filter(Boolean),
    };
  }
  return block;
}
const resolvedBlocks = inlineBlocks.map((b) => ({ afterH2: b.afterH2, ...resolveBlock(b.block) }));
---

<html lang="ru">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={ogImage}
      type="article"
      publishedTime={pubDate.toISOString()}
      modifiedTime={updatedDate?.toISOString()}
      keywords={keywords}
      noindex={seo?.noindex}
      jsonLd={[articleJsonLd, breadcrumbsJsonLd]}
    />
  </head>

  <body>
    <div id="rp-bar" aria-hidden="true"></div>
    <Header />

    <main class="main--article">

      <!-- ═══════════════════════════════════════════════════
           HERO: две колонки, полная высота экрана
           ═══════════════════════════════════════════════════ -->
      <section class="a-hero" data-pagefind-ignore>

        <!-- Левая колонка 58%: изображение или градиент категории -->
        <div
          class="a-hero__left"
          style={`background: linear-gradient(155deg, ${grad.from} 0%, ${grad.to} 100%)`}
        >
          {heroImage ? (
            <Image
              width={1100}
              height={1400}
              src={heroImage}
              alt=""
              loading="eager"
              class="a-hero__img"
            />
          ) : (
            <div class="a-hero__deco" aria-hidden="true">
              <svg viewBox="0 0 480 600" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="240" cy="300" r="220" stroke="rgba(255,255,255,0.08)" stroke-width="80"/>
                <circle cx="240" cy="300" r="140" stroke="rgba(255,255,255,0.06)" stroke-width="60"/>
                <circle cx="240" cy="300" r="70" fill="rgba(255,255,255,0.05)"/>
                <line x1="0" y1="300" x2="480" y2="300" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
                <line x1="240" y1="0" x2="240" y2="600" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
              </svg>
            </div>
          )}
        </div>

        <!-- Правая колонка 42%: дата+тег / H1 / лид — через space-between -->
        <div class="a-hero__right">

          <!-- Верх: дата и хэштег категории -->
          <div class="a-hero__top">
            <time class="a-hero__date" datetime={pubDate.toISOString()}>
              <FormattedDate date={pubDate} />
            </time>
            {categoryMeta && (
              <a class="a-hero__cat" href={`/category/${primaryCategory}/`}>
                {categoryMeta.title}
              </a>
            )}
          </div>

          <!-- Середина: H1 -->
          <h1 class="a-hero__title">{title}</h1>

          <!-- Низ: черта + лид + теги -->
          <div class="a-hero__bottom">
            <div class="a-hero__rule"></div>
            <p class="a-hero__lead">{description}</p>
            {tags.length > 0 && (
              <div class="a-hero__tags">
                {tags.slice(0, 5).map((tag) => (
                  <a class="a-hero__tag" href={`/tag/${tagSlug(tag)}/`}>#{tag}</a>
                ))}
              </div>
            )}
            {readingTime && (
              <p class="a-hero__time">{readingTime} мин чтения</p>
            )}
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════
           ТЕЛО: липкий сайдбар (28%) + контент (72%)
           ═══════════════════════════════════════════════════ -->
      <div class="a-body">

        <!-- Липкий баннер в левой колонке -->
        <aside class="a-sidebar" aria-label="Партнёрский материал" data-pagefind-ignore>
          <div class="a-sidebar__inner">
            <div
              class="a-sidebar__banner"
              style={`--banner-from: ${grad.from}; --banner-to: ${grad.to}`}
            >
              <div class="a-sidebar__content">
                <p class="a-sidebar__disclaimer">Партнёрская ссылка</p>
                <p class="a-sidebar__label">{sidebarProduct.label}</p>
                <p class="a-sidebar__name">{sidebarProduct.name}</p>
                <p class="a-sidebar__pitch">{sidebarProduct.pitch}</p>
                <a
                  href={sidebarProduct.ctaUrl}
                  class="a-sidebar__cta"
                  rel="nofollow noopener sponsored"
                  target="_blank"
                >
                  {sidebarProduct.ctaText}
                </a>
              </div>
            </div>
          </div>
        </aside>

        <!-- Основной контент -->
        <div class="a-content">

          <!-- Хлебные крошки -->
          <nav class="breadcrumbs" aria-label="Хлебные крошки" data-pagefind-ignore>
            <a href="/">Главная</a>
            <span aria-hidden="true">›</span>
            <a href="/blog/">Статьи</a>
            {categoryMeta && (
              <>
                <span aria-hidden="true">›</span>
                <a href={`/category/${primaryCategory}/`}>{categoryMeta.title}</a>
              </>
            )}
          </nav>

          <!-- Метаданные под хлебными крошками -->
          {(updatedDate || readingTime) && (
            <div class="a-meta" data-pagefind-ignore>
              {updatedDate && (
                <span>обновлено <FormattedDate date={updatedDate} /></span>
              )}
              {readingTime && <span>{readingTime} мин чтения</span>}
            </div>
          )}

          <!-- Содержание (показывается при ≥3 заголовках) -->
          {tocHeadings.length > 2 && (
            <details class="toc" data-pagefind-ignore>
              <summary>Содержание</summary>
              <nav>
                <ol class="toc-list">
                  {tocHeadings.map((h) => (
                    <li class={`toc-item toc-depth-${h.depth}`}>
                      <a href={`#${h.slug}`}>{h.text}</a>
                    </li>
                  ))}
                </ol>
              </nav>
            </details>
          )}

          <!-- Основной текст статьи -->
          <div class="a-prose" data-pagefind-body>
            <slot />
          </div>

          <!-- ───────────────────────────────────────────────
               Партнёрские врезки (server-rendered).
               JS перемещает каждый блок после нужного H2.
               Если JS не сработал — блоки остаются здесь
               как отдельная секция между текстом и шарингом.
               ─────────────────────────────────────────────── -->
          {resolvedBlocks.length > 0 && (
            <div class="aff-fallback" data-pagefind-ignore>
              {resolvedBlocks.map((rb) => {
                if (rb.type === 'product' && 'product' in rb && rb.product) {
                  const p = rb.product;
                  return (
                    <div class="aff-block aff-block--product" data-after-h2={rb.afterH2}>
                      <p class="aff-block__disclaimer">Партнёрская ссылка</p>
                      <span class="aff-block__cat">{p.label}</span>
                      <strong class="aff-block__name">{p.name}</strong>
                      <p class="aff-block__pitch">{p.pitch}</p>
                      <a
                        href={p.ctaUrl}
                        class="aff-block__cta"
                        rel="nofollow noopener sponsored"
                        target="_blank"
                      >
                        {p.ctaText} →
                      </a>
                    </div>
                  );
                }
                if (rb.type === 'compare' && 'products' in rb) {
                  const products = rb.products as typeof PRODUCTS[string][];
                  return (
                    <div class="aff-block aff-block--compare" data-after-h2={rb.afterH2}>
                      <p class="aff-block__disclaimer">Партнёрские ссылки</p>
                      <p class="aff-block__compare-title">Выберите решение</p>
                      <div class="aff-compare-grid">
                        {products.map((p) => (
                          <div class="aff-compare-item">
                            <span class="aff-block__cat">{p.label}</span>
                            <strong class="aff-block__name">{p.name}</strong>
                            <p class="aff-block__pitch">{p.pitch}</p>
                            <a
                              href={p.ctaUrl}
                              class="aff-block__cta"
                              rel="nofollow noopener sponsored"
                              target="_blank"
                            >
                              {p.ctaText}
                            </a>
                          </div>
                        ))}
                      </div>
                    </div>
                  );
                }
                if (rb.type === 'tool' && 'label' in rb) {
                  const isInternal = 'internal' in rb && rb.internal;
                  return (
                    <div class="aff-block aff-block--tool" data-after-h2={rb.afterH2}>
                      <strong class="aff-block__name">{rb.label as string}</strong>
                      <p class="aff-block__pitch">{rb.desc as string}</p>
                      <a
                        href={rb.url as string}
                        class="aff-block__cta"
                        {...(!isInternal && { rel: 'nofollow noopener', target: '_blank' })}
                      >
                        Открыть →
                      </a>
                    </div>
                  );
                }
                return null;
              })}
            </div>
          )}

          <!-- Поделиться -->
          <div class="share" data-pagefind-ignore>
            <span class="share-label">Поделиться:</span>
            <a
              class="share-btn share-tg"
              href={`https://t.me/share/url?url=${shareUrl}&text=${shareTitle}`}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Поделиться в Telegram"
            >Telegram</a>
            <a
              class="share-btn share-vk"
              href={`https://vk.com/share.php?url=${shareUrl}`}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Поделиться ВКонтакте"
            >ВКонтакте</a>
          </div>

          <!-- Читайте также -->
          {related.length > 0 && (
            <aside class="related" aria-labelledby="related-heading" data-pagefind-ignore>
              <h2 id="related-heading">Читайте также</h2>
              <ul class="related-list">
                {related.map((post) => {
                  const cat = post.data.categories[0] as keyof typeof CATEGORIES | undefined;
                  const catM = cat ? CATEGORIES[cat] : null;
                  return (
                    <li class="related-card">
                      <a href={`/blog/${post.id}/`}>
                        {catM && <span class="related-cat">{catM.title}</span>}
                        <h3>{post.data.title}</h3>
                        <p>{post.data.description}</p>
                      </a>
                    </li>
                  );
                })}
              </ul>
            </aside>
          )}

          <!-- Оговорка -->
          <footer class="article-foot">
            <p class="disclaimer">
              Материал носит информационный характер. Перед принятием решений
              сверяйтесь с действующей редакцией нормативных актов и при необходимости
              проконсультируйтесь со специалистом.
            </p>
          </footer>
        </div>
      </div>
    </main>

    <!-- Кнопка «Наверх» -->
    <button id="back-top" class="back-top" aria-label="Вернуться наверх">↑</button>

    <Footer />

    <script>
      // Прогресс-бар чтения
      const bar = document.getElementById('rp-bar');
      if (bar) {
        const updateBar = () => {
          const scrolled = document.documentElement.scrollTop;
          const total = document.documentElement.scrollHeight - window.innerHeight;
          bar.style.width = total > 0 ? `${(scrolled / total) * 100}%` : '0%';
        };
        window.addEventListener('scroll', updateBar, { passive: true });
        updateBar();
      }

      // Кнопка «Наверх»
      const backTop = document.getElementById('back-top');
      if (backTop) {
        window.addEventListener('scroll', () => {
          backTop.classList.toggle('back-top--visible', window.scrollY > 400);
        }, { passive: true });
        backTop.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      // Инъекция партнёрских врезок в текст статьи
      // Блоки изначально рендерятся в .aff-fallback после текста.
      // Скрипт перемещает каждый блок после нужного H2 внутри .a-prose.
      (function injectAffBlocks() {
        const prose = document.querySelector<HTMLElement>('.a-prose');
        const fallback = document.querySelector<HTMLElement>('.aff-fallback');
        if (!prose || !fallback) return;

        const blocks = Array.from(
          fallback.querySelectorAll<HTMLElement>('.aff-block[data-after-h2]'),
        );
        if (!blocks.length) return;

        const h2s = Array.from(prose.querySelectorAll('h2'));

        blocks.forEach((block) => {
          const idx = parseInt(block.getAttribute('data-after-h2') ?? '99', 10);
          const targetH2 = h2s[idx];
          if (!targetH2) return; // нет нужного H2 — блок остаётся в fallback

          // Ищем точку вставки: после 2 параграфов, следующих за H2
          let insertPoint: Element = targetH2;
          let pCount = 0;
          let el = targetH2.nextElementSibling;
          while (el && el.tagName !== 'H2' && pCount < 2) {
            if (el.tagName === 'P') pCount++;
            insertPoint = el;
            el = el.nextElementSibling;
          }

          block.remove();
          insertPoint.after(block);
        });

        // Убираем пустой fallback-контейнер
        if (!fallback.children.length) fallback.remove();
      })();
    </script>

    <style>
      /* ── Прогресс-бар ─────────────────────────────────── */
      #rp-bar {
        position: fixed;
        top: 0;
        left: 0;
        height: 3px;
        width: 0%;
        background: var(--accent);
        z-index: 200;
        transition: width 0.1s linear;
      }

      /* ── Сброс глобальных стилей main для статьи ──────── */
      .main--article {
        max-width: none;
        padding: 0;
      }

      /* ══════════════════════════════════════════════════════
         HERO
         ══════════════════════════════════════════════════════ */
      .a-hero {
        display: grid;
        grid-template-columns: 58fr 42fr;
        min-height: 100dvh;
        min-height: 100vh; /* fallback */
      }

      /* Левая колонка: изображение или градиент */
      .a-hero__left {
        position: relative;
        overflow: hidden;
        min-height: 50vh; /* страховка для высоких экранов */
      }
      .a-hero__img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 0;
      }
      .a-hero__deco {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 10%;
      }
      .a-hero__deco svg {
        width: 100%;
        height: 100%;
        max-width: 400px;
      }

      /* Правая колонка: верх / центр / низ */
      .a-hero__right {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 3rem 3.5rem 3rem 3rem;
        overflow: hidden;
        max-height: 100dvh;
        max-height: 100vh;
      }
      .a-hero__top {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        flex-wrap: wrap;
      }
      .a-hero__date {
        font-size: 0.88rem;
        color: rgb(var(--gray));
      }
      .a-hero__cat {
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--accent);
        background: var(--accent-soft);
        padding: 0.2em 0.7em;
        border-radius: 999px;
        text-decoration: none;
      }
      .a-hero__cat:hover {
        background: var(--accent);
        color: #fff;
      }
      .a-hero__title {
        font-size: clamp(1.75rem, 3vw, 2.9rem);
        line-height: 1.18;
        margin: 0;
        letter-spacing: -0.02em;
      }
      .a-hero__bottom {
        /* нижний блок */
      }
      .a-hero__rule {
        height: 1px;
        background: rgb(var(--gray-light));
        margin-bottom: 1.5rem;
      }
      .a-hero__lead {
        font-size: 1.05rem;
        color: rgb(var(--gray-dark));
        line-height: 1.65;
        margin: 0 0 1rem;
      }
      .a-hero__tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-bottom: 0.8rem;
      }
      .a-hero__tag {
        font-size: 0.82rem;
        color: rgb(var(--gray));
        background: rgb(var(--gray-light));
        padding: 0.2em 0.6em;
        border-radius: 999px;
        text-decoration: none;
        transition: all 0.15s ease;
      }
      .a-hero__tag:hover {
        background: var(--accent-soft);
        color: var(--accent);
      }
      .a-hero__time {
        font-size: 0.85rem;
        color: rgb(var(--gray));
        margin: 0;
      }

      /* ══════════════════════════════════════════════════════
         ТЕЛО: сайдбар + контент
         ══════════════════════════════════════════════════════ */
      .a-body {
        display: grid;
        grid-template-columns: 28fr 72fr;
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1rem;
        align-items: start;
      }

      /* ── Липкий сайдбар ───────────────────────────────── */
      .a-sidebar {
        position: sticky;
        top: 64px; /* высота header */
        height: calc(100dvh - 64px);
        height: calc(100vh - 64px);
        padding: 16px;
      }
      .a-sidebar__inner {
        height: 100%;
      }
      .a-sidebar__banner {
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: flex-end; /* контент прибит к низу */
        background: linear-gradient(
          160deg,
          color-mix(in srgb, var(--banner-from) 80%, #000) 0%,
          color-mix(in srgb, var(--banner-to) 60%, #000) 100%
        );
        /* Fallback для браузеров без color-mix */
        background: #0f172a;
        border-radius: 14px;
        overflow: hidden;
        position: relative;
      }
      /* Градиентный оверлей поверх тёмного фона */
      .a-sidebar__banner::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(
          160deg,
          rgba(29, 78, 216, 0.6) 0%,
          rgba(14, 165, 233, 0.3) 100%
        );
        pointer-events: none;
      }
      .a-sidebar__content {
        position: relative;
        z-index: 1;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }
      .a-sidebar__disclaimer {
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.4);
        margin: 0 0 0.6rem;
      }
      .a-sidebar__label {
        font-size: 0.78rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.6);
        margin: 0;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .a-sidebar__name {
        font-size: 1.25rem;
        font-weight: 700;
        color: #fff;
        margin: 0.2rem 0 0.5rem;
        font-family: 'Commissioner', sans-serif;
        line-height: 1.2;
      }
      .a-sidebar__pitch {
        font-size: 0.88rem;
        color: rgba(255, 255, 255, 0.72);
        line-height: 1.55;
        margin: 0 0 1.2rem;
      }
      .a-sidebar__cta {
        display: block;
        background: #fff;
        color: #0f172a;
        padding: 0.75em 1em;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.88rem;
        text-align: center;
        transition: all 0.15s ease;
      }
      .a-sidebar__cta:hover {
        background: var(--accent-soft);
        color: var(--accent);
      }

      /* ── Контент-колонка ──────────────────────────────── */
      .a-content {
        padding: 2.5rem 0 3rem 2.5rem;
        min-width: 0; /* не выходить за пределы grid */
      }

      /* Хлебные крошки */
      .breadcrumbs {
        font-size: 0.88rem;
        color: rgb(var(--gray));
        margin-bottom: 0.8rem;
        display: flex;
        align-items: center;
        gap: 0.3em;
        flex-wrap: wrap;
      }
      .breadcrumbs a {
        color: rgb(var(--gray));
        text-decoration: none;
      }
      .breadcrumbs a:hover { color: var(--accent); }
      .breadcrumbs span { color: rgb(var(--gray-light)); }

      /* Мета-строка */
      .a-meta {
        display: flex;
        gap: 1rem;
        font-size: 0.87rem;
        color: rgb(var(--gray));
        margin-bottom: 1.5rem;
      }

      /* TOC */
      .toc {
        border: 1px solid rgb(var(--gray-light));
        border-radius: 10px;
        padding: 0.9rem 1.1rem;
        margin: 0 0 2rem;
        background: #f8fafc;
      }
      .toc summary {
        cursor: pointer;
        font-weight: 600;
        font-size: 0.95rem;
        color: rgb(var(--black));
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        user-select: none;
      }
      .toc summary::-webkit-details-marker { display: none; }
      .toc summary::after {
        content: '▸';
        font-size: 0.8rem;
        color: var(--accent);
        transition: transform 0.15s ease;
      }
      .toc[open] summary::after { transform: rotate(90deg); }
      .toc-list {
        margin: 0.8rem 0 0;
        padding-left: 1.2rem;
        list-style: none;
      }
      .toc-item { margin-bottom: 0.35rem; line-height: 1.4; }
      .toc-depth-3 { padding-left: 1rem; }
      .toc-item a {
        color: rgb(var(--gray-dark));
        text-decoration: none;
        font-size: 0.9rem;
      }
      .toc-item a:hover { color: var(--accent); text-decoration: underline; }

      /* ── Партнёрские врезки ───────────────────────────── */
      .aff-fallback { margin: 2rem 0; }

      .aff-block {
        border: 1px solid rgb(var(--gray-light));
        border-radius: 12px;
        padding: 1.3rem 1.5rem;
        margin: 2.5rem 0;
        background: #f8fafc;
        position: relative;
      }
      .aff-block__disclaimer {
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: rgb(var(--gray));
        margin: 0 0 0.9rem;
      }
      .aff-block__cat {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--accent);
        background: var(--accent-soft);
        padding: 0.15em 0.65em;
        border-radius: 999px;
        margin-bottom: 0.5rem;
      }
      .aff-block__name {
        display: block;
        font-size: 1.12rem;
        color: rgb(var(--black));
        font-family: 'Commissioner', sans-serif;
        font-weight: 700;
        margin: 0 0 0.4rem;
        line-height: 1.25;
      }
      .aff-block__pitch {
        font-size: 0.92rem;
        color: rgb(var(--gray-dark));
        line-height: 1.55;
        margin: 0 0 1rem;
      }
      .aff-block__cta {
        display: inline-block;
        background: var(--accent);
        color: #fff;
        padding: 0.6em 1.3em;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.15s ease;
      }
      .aff-block__cta:hover { background: var(--accent-dark); color: #fff; }

      /* Врезка: инструмент/калькулятор */
      .aff-block--tool {
        border-left: 4px solid var(--accent);
        background: var(--accent-soft);
        border-top: none;
        border-right: none;
        border-bottom: none;
        border-radius: 0 12px 12px 0;
      }

      /* Врезка: сравнение двух продуктов */
      .aff-block__compare-title {
        font-size: 1rem;
        font-weight: 700;
        color: rgb(var(--black));
        font-family: 'Commissioner', sans-serif;
        margin: 0 0 1rem;
      }
      .aff-compare-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.8rem;
      }
      .aff-compare-item {
        background: #fff;
        border: 1px solid rgb(var(--gray-light));
        border-radius: 10px;
        padding: 1rem 1.1rem;
        display: flex;
        flex-direction: column;
      }
      .aff-compare-item .aff-block__pitch { flex: 1; }
      .aff-compare-item .aff-block__cta {
        display: block;
        text-align: center;
        margin-top: auto;
      }

      /* ── Шаринг ───────────────────────────────────────── */
      .share {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin: 2.5rem 0 1rem;
        padding: 1rem 1.2rem;
        border: 1px solid rgb(var(--gray-light));
        border-radius: 10px;
        background: #f8fafc;
      }
      .share-label {
        font-size: 0.9rem;
        font-weight: 600;
        color: rgb(var(--gray-dark));
      }
      .share-btn {
        display: inline-block;
        padding: 0.4em 1em;
        border-radius: 999px;
        font-size: 0.88rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.15s ease;
      }
      .share-tg { background: #e8f4fd; color: #0088cc; border: 1px solid #b3d9f0; }
      .share-tg:hover { background: #0088cc; color: #fff; }
      .share-vk { background: #e8f0fb; color: #2787f5; border: 1px solid #b3cef7; }
      .share-vk:hover { background: #2787f5; color: #fff; }

      /* ── «Читайте также» ──────────────────────────────── */
      .related {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgb(var(--gray-light));
      }
      .related h2 { font-size: 1.3rem; margin: 0 0 1rem; }
      .related-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0.8rem;
      }
      .related-card a {
        display: block;
        padding: 1rem 1.1rem;
        border: 1px solid rgb(var(--gray-light));
        border-radius: 10px;
        background: #fff;
        color: rgb(var(--gray-dark));
        text-decoration: none;
        height: 100%;
        transition: all 0.15s ease;
      }
      .related-card a:hover { border-color: var(--accent); box-shadow: var(--box-shadow); }
      .related-cat {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--accent);
        background: var(--accent-soft);
        padding: 0.15em 0.6em;
        border-radius: 999px;
        margin-bottom: 0.5rem;
      }
      .related-card h3 { margin: 0 0 0.4rem; font-size: 1.02rem; color: rgb(var(--black)); }
      .related-card p { font-size: 0.9rem; margin: 0; }

      /* ── Оговорка ─────────────────────────────────────── */
      .article-foot {
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgb(var(--gray-light));
      }
      .disclaimer {
        font-size: 0.88rem;
        color: rgb(var(--gray));
        font-style: italic;
      }

      /* ── Кнопка «Наверх» ──────────────────────────────── */
      .back-top {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        width: 2.8rem;
        height: 2.8rem;
        border-radius: 50%;
        background: var(--accent);
        color: #fff;
        border: none;
        font-size: 1.1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 14px rgba(29, 78, 216, 0.4);
        opacity: 0;
        transform: translateY(8px);
        transition: opacity 0.2s ease, transform 0.2s ease;
        pointer-events: none;
        z-index: 90;
      }
      .back-top--visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }
      .back-top:hover { background: var(--accent-dark); }

      /* ══════════════════════════════════════════════════════
         АДАПТИВ
         ══════════════════════════════════════════════════════ */
      @media (max-width: 1000px) {
        .a-hero__right { padding: 2.5rem 2rem; }
        .a-content { padding: 2rem 0 2.5rem 2rem; }
      }

      @media (max-width: 820px) {
        /* Hero: одна колонка */
        .a-hero {
          grid-template-columns: 1fr;
          min-height: auto;
        }
        .a-hero__left {
          min-height: 50vw;
          max-height: 55vw;
        }
        .a-hero__right {
          padding: 1.8rem 1.2rem 2rem;
          max-height: none;
          gap: 1.5rem;
          justify-content: flex-start;
        }
        .a-hero__title { font-size: clamp(1.5rem, 5vw, 2.2rem); }

        /* Body: одна колонка, сайдбар — мобильный баннер вверху */
        .a-body {
          grid-template-columns: 1fr;
          padding: 0 1rem;
        }
        .a-sidebar {
          position: static;
          height: auto;
          padding: 1.2rem 0 0;
        }
        .a-sidebar__inner { height: auto; }
        .a-sidebar__banner {
          justify-content: flex-start;
          border-radius: 12px;
          min-height: auto;
        }
        .a-sidebar__banner::before { display: none; }
        .a-sidebar__content { padding: 1.2rem; }
        .a-content { padding: 1.5rem 0 2rem; }
      }

      @media (max-width: 560px) {
        .aff-compare-grid { grid-template-columns: 1fr; }
        .back-top { bottom: 1.2rem; right: 1.2rem; }
      }
    </style>
  </body>
</html>
