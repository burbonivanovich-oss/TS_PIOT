---
import { Image } from 'astro:assets';
import { type CollectionEntry, getCollection } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_TITLE, SITE_AUTHOR, SITE_LOCALE } from '../consts';
import { tagSlug } from '../utils/tags';

type Props = CollectionEntry<'blog'>['data'] & {
	slug?: string;
	headings?: MarkdownHeading[];
	readingTime?: number;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	categories = [],
	tags = [],
	author = SITE_AUTHOR,
	seo,
	slug: currentSlug,
	headings = [],
	readingTime,
} = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const candidates = allPosts.filter((p) => p.id !== currentSlug);
const scored = candidates
	.map((p) => ({
		post: p,
		score:
			(p.data.tags ?? []).filter((t) => tags.includes(t)).length * 2 +
			(p.data.categories ?? []).filter((c) => categories.includes(c)).length,
	}))
	.filter((x) => x.score > 0)
	.sort(
		(a, b) =>
			b.score - a.score ||
			b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf(),
	);
const related = scored.slice(0, 3).map((x) => x.post);

const canonical = seo?.canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const keywords = [...new Set([...tags, ...(seo?.keywords ?? [])])];

const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

const articleImageUrl = currentSlug
	? new URL(`/og/${currentSlug}.png`, Astro.site).toString()
	: undefined;

const articleJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	inLanguage: SITE_LOCALE,
	...(articleImageUrl && {
		image: {
			'@type': 'ImageObject',
			url: articleImageUrl,
			width: 1200,
			height: 630,
		},
	}),
	author: {
		'@type': 'Person',
		name: author,
		url: new URL('/about/avtor/', Astro.site).toString(),
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		logo: {
			'@type': 'ImageObject',
			url: new URL('/favicon.svg', Astro.site).toString(),
		},
	},
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	mainEntityOfPage: canonical,
	keywords: keywords.join(', '),
	articleSection: categories.map((c) => CATEGORIES[c as keyof typeof CATEGORIES]?.title ?? c),
};

const breadcrumbsJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Главная',
			item: new URL('/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Статьи',
			item: new URL('/blog/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: title,
			item: canonical,
		},
	],
};

const primaryCategory = categories[0] as keyof typeof CATEGORIES | undefined;
const categoryMeta = primaryCategory ? CATEGORIES[primaryCategory] : null;

const ogImage = heroImage ?? (currentSlug ? `/og/${currentSlug}.png` : undefined);

const shareUrl = encodeURIComponent(canonical);
const shareTitle = encodeURIComponent(title);
---

<html lang="ru">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={ogImage}
			type="article"
			publishedTime={pubDate.toISOString()}
			modifiedTime={updatedDate?.toISOString()}
			keywords={keywords}
			noindex={seo?.noindex}
			jsonLd={[articleJsonLd, breadcrumbsJsonLd]}
		/>
	</head>

	<body>
		<div id="rp-bar" aria-hidden="true"></div>

		<Header />
		<main>
			<article class="article" data-pagefind-body>
				<nav class="breadcrumbs" aria-label="Хлебные крошки" data-pagefind-ignore>
					<a href="/">Главная</a>
					<span>›</span>
					<a href="/blog/">Статьи</a>
					{categoryMeta && (
						<>
							<span>›</span>
							<a href={`/category/${primaryCategory}/`}>{categoryMeta.title}</a>
						</>
					)}
				</nav>

				<header class="article-head">
					<h1>{title}</h1>
					<p class="lead">{description}</p>
					<div class="meta">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="updated">
								· обновлено <FormattedDate date={updatedDate} />
							</span>
						)}
						{readingTime && (
							<span class="reading-time">· {readingTime} мин чтения</span>
						)}
					</div>
					{tags.length > 0 && (
						<div class="tags">
							{tags.map((tag) => (
								<a class="tag" href={`/tag/${tagSlug(tag)}/`}>#{tag}</a>
							))}
						</div>
					)}
				</header>

				{heroImage && (
					<div class="hero-image">
						<Image width={1100} height={550} src={heroImage} alt={title} loading="eager" />
					</div>
				)}

				{tocHeadings.length > 2 && (
					<details class="toc" data-pagefind-ignore>
						<summary>Содержание</summary>
						<nav>
							<ol class="toc-list">
								{tocHeadings.map((h) => (
									<li class={`toc-item toc-depth-${h.depth}`}>
										<a href={`#${h.slug}`}>{h.text}</a>
									</li>
								))}
							</ol>
						</nav>
					</details>
				)}

				<div class="prose">
					<slot />
				</div>

				<div class="share" data-pagefind-ignore>
					<span class="share-label">Поделиться:</span>
					<a
						class="share-btn share-tg"
						href={`https://t.me/share/url?url=${shareUrl}&text=${shareTitle}`}
						target="_blank"
						rel="noopener noreferrer"
						aria-label="Поделиться в Telegram"
					>
						Telegram
					</a>
					<a
						class="share-btn share-vk"
						href={`https://vk.com/share.php?url=${shareUrl}`}
						target="_blank"
						rel="noopener noreferrer"
						aria-label="Поделиться ВКонтакте"
					>
						ВКонтакте
					</a>
				</div>

				{related.length > 0 && (
					<aside class="related" aria-labelledby="related-heading" data-pagefind-ignore>
						<h2 id="related-heading">Читайте также</h2>
						<ul class="related-list">
							{related.map((post) => {
								const cat = post.data.categories[0] as keyof typeof CATEGORIES | undefined;
								const catMeta = cat ? CATEGORIES[cat] : null;
								return (
									<li class="related-card">
										<a href={`/blog/${post.id}/`}>
											{catMeta && <span class="related-cat">{catMeta.title}</span>}
											<h3>{post.data.title}</h3>
											<p>{post.data.description}</p>
										</a>
									</li>
								);
							})}
						</ul>
					</aside>
				)}

				<footer class="article-foot">
					<p class="disclaimer">
						Материал носит информационный характер. Перед принятием решений
						сверяйтесь с действующей редакцией нормативных актов и при необходимости
						проконсультируйтесь со специалистом.
					</p>
				</footer>
			</article>
		</main>
		<Footer />

		<script>
			const bar = document.getElementById('rp-bar');
			if (bar) {
				const update = () => {
					const scrolled = document.documentElement.scrollTop;
					const total = document.documentElement.scrollHeight - window.innerHeight;
					bar.style.width = total > 0 ? `${(scrolled / total) * 100}%` : '0%';
				};
				window.addEventListener('scroll', update, { passive: true });
				update();
			}
		</script>

		<style>
			/* Полоса прокрутки */
			#rp-bar {
				position: fixed;
				top: 0; left: 0;
				height: 2px;
				width: 0%;
				background: var(--accent);
				z-index: 100;
				transition: width 0.1s linear;
			}

			.article {
				max-width: 720px;
				margin: 0 auto;
			}

			/* Breadcrumbs */
			.breadcrumbs {
				font-size: var(--text-xs, 0.8125rem);
				color: var(--text-4);
				margin-bottom: var(--sp-5);
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.2em;
			}
			.breadcrumbs a {
				color: var(--text-3);
				text-decoration: none;
			}
			.breadcrumbs a:hover { color: var(--accent); text-decoration: none; }
			.breadcrumbs span { color: var(--text-4); }

			/* Шапка статьи */
			.article-head { margin-bottom: var(--sp-6); }
			.article-head h1 { margin-bottom: var(--sp-3); }

			.lead {
				font-size: 1.125rem;
				line-height: 1.6;
				color: var(--text-2);
				margin-bottom: var(--sp-3);
			}

			.meta {
				font-size: 0.875rem;
				color: var(--text-3);
				margin-bottom: var(--sp-3);
			}

			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: var(--sp-1);
				margin-bottom: var(--sp-5);
			}

			.tag {
				background: var(--bg-subtle);
				color: var(--text-3);
				padding: 3px 10px;
				border-radius: var(--r-pill);
				font-size: 0.8125rem;
				text-decoration: none;
				transition: background var(--ease), color var(--ease);
			}
			.tag:hover {
				background: var(--accent-light);
				color: var(--accent);
				text-decoration: none;
			}

			/* Hero image */
			.hero-image { margin: var(--sp-5) 0 var(--sp-6); }
			.hero-image img {
				border-radius: var(--r-md);
				box-shadow: var(--shadow-card);
			}

			/* TOC */
			.toc {
				border: 1px solid var(--border);
				border-radius: var(--r-md);
				padding: var(--sp-4) var(--sp-5);
				margin: var(--sp-5) 0 var(--sp-6);
				background: var(--bg-muted);
			}
			.toc summary {
				cursor: pointer;
				font-family: 'Commissioner', sans-serif;
				font-weight: 700;
				font-size: 0.9375rem;
				color: var(--text);
				list-style: none;
				display: flex;
				justify-content: space-between;
				align-items: center;
				user-select: none;
			}
			.toc summary::-webkit-details-marker { display: none; }
			.toc summary::after {
				content: '›';
				font-size: 1.1rem;
				color: var(--accent);
				transition: transform var(--ease);
				line-height: 1;
			}
			.toc[open] summary::after { transform: rotate(90deg); }
			.toc-list {
				margin: var(--sp-3) 0 0;
				padding-left: var(--sp-5);
				list-style: none;
			}
			.toc-item {
				margin-bottom: var(--sp-1);
				line-height: 1.45;
			}
			.toc-depth-3 { padding-left: var(--sp-4); }
			.toc-item a {
				color: var(--text-2);
				text-decoration: none;
				font-size: 0.9rem;
			}
			.toc-item a:hover {
				color: var(--accent);
				text-decoration: underline;
				text-underline-offset: 2px;
			}

			/* Share */
			.share {
				display: flex;
				align-items: center;
				flex-wrap: wrap;
				gap: var(--sp-2);
				margin: var(--sp-7) 0 var(--sp-4);
			}
			.share-label {
				font-size: 0.875rem;
				font-weight: 600;
				color: var(--text-2);
			}
			.share-btn {
				display: inline-block;
				padding: 0.4em 1em;
				border-radius: var(--r-pill);
				font-size: 0.875rem;
				font-weight: 600;
				text-decoration: none;
				transition: background var(--ease), color var(--ease);
			}
			.share-tg { background: #E8F4FD; color: #0088CC; }
			.share-tg:hover { background: #0088CC; color: #fff; text-decoration: none; }
			.share-vk { background: #E8F0FB; color: #2787F5; }
			.share-vk:hover { background: #2787F5; color: #fff; text-decoration: none; }

			/* Related */
			.related {
				margin-top: var(--sp-8);
				padding-top: var(--sp-6);
				border-top: 1px solid var(--border);
			}
			.related h2 {
				font-size: 1.25rem;
				margin: 0 0 var(--sp-4);
			}
			.related-list {
				list-style: none;
				padding: 0; margin: 0;
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: var(--sp-3);
			}
			.related-card a {
				display: block;
				padding: var(--sp-4);
				border: 1px solid var(--border);
				border-radius: var(--r-md);
				background: var(--bg);
				color: var(--text-2);
				text-decoration: none;
				height: 100%;
				transition: border-color var(--ease), box-shadow var(--ease);
			}
			.related-card a:hover {
				border-color: var(--accent);
				box-shadow: var(--shadow-hover);
				text-decoration: none;
			}
			.related-cat {
				display: inline-block;
				font-size: 0.8125rem;
				font-weight: 600;
				color: var(--accent);
				background: var(--accent-light);
				padding: 2px 8px;
				border-radius: var(--r-pill);
				margin-bottom: var(--sp-2);
			}
			.related-card h3 {
				margin: 0 0 var(--sp-2);
				font-size: 1rem;
				color: var(--text);
			}
			.related-card p {
				font-size: 0.875rem;
				margin: 0;
				color: var(--text-3);
			}

			/* Footer статьи */
			.article-foot {
				margin-top: var(--sp-7);
				padding-top: var(--sp-5);
				border-top: 1px solid var(--border);
			}
			.disclaimer {
				font-size: 0.875rem;
				color: var(--text-4);
				font-style: italic;
			}
		</style>
	</body>
</html>
