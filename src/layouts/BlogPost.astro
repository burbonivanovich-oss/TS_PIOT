---
import { type CollectionEntry, getCollection } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import {
	CATEGORIES,
	SITE_TITLE,
	SITE_AUTHOR,
	SITE_LOCALE,
	SIDEBAR_BANNER,
} from '../consts';
import { CPA_BANNERS, CATEGORY_DEFAULT_CPA, CATEGORY_DEFAULT_CPA2 } from '../data/cpa-banners';
import { tagSlug } from '../utils/tags';
import { u } from '../utils/url';

type Props = CollectionEntry<'blog'>['data'] & {
	slug?: string;
	headings?: MarkdownHeading[];
	readingTime?: number;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	categories = [],
	tags = [],
	author = SITE_AUTHOR,
	seo,
	cpa,
	slug: currentSlug,
	headings = [],
	readingTime,
} = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = allPosts.sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const candidates = sorted.filter((p) => p.id !== currentSlug);
const scored = candidates
	.map((p) => ({
		post: p,
		score:
			(p.data.tags ?? []).filter((t) => tags.includes(t)).length * 2 +
			(p.data.categories ?? []).filter((c) => categories.includes(c)).length,
	}))
	.filter((x) => x.score > 0)
	.sort(
		(a, b) =>
			b.score - a.score ||
			b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf(),
	);
const related = scored.slice(0, 4).map((x) => x.post);

/* Адаптивный макет «Читайте также»:
   2 поста  → A2 (две равные карточки)
   3 поста  → A3 (1 большая + 2) или B (2 + wide), детерминировано по slug
   4+ поста → C  (1 большая + 3 компактных)
*/
const relatedCount = related.length;
const slugCharSum = (currentSlug ?? '').split('').reduce((a, c) => a + c.charCodeAt(0), 0);
const relatedLayout =
	relatedCount >= 4 ? 'C' :
	relatedCount === 3 ? (slugCharSum % 2 === 0 ? 'A3' : 'B') :
	relatedCount === 2 ? 'A2' : null;


const canonical = seo?.canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const keywords = [...new Set([...tags, ...(seo?.keywords ?? [])])];
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

const articleImageUrl = currentSlug
	? new URL(`/og/${currentSlug}.png`, Astro.site).toString()
	: undefined;

const articleJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	inLanguage: SITE_LOCALE,
	...(articleImageUrl && {
		image: { '@type': 'ImageObject', url: articleImageUrl, width: 1200, height: 630 },
	}),
	author: {
		'@type': 'Person',
		name: author,
		url: new URL('/about/avtor/', Astro.site).toString(),
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', Astro.site).toString() },
	},
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	mainEntityOfPage: canonical,
	keywords: keywords.join(', '),
	articleSection: categories.map(
		(c) => CATEGORIES[c as keyof typeof CATEGORIES]?.title ?? c,
	),
};

const breadcrumbsJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Главная', item: new URL('/', Astro.site).toString() },
		{ '@type': 'ListItem', position: 2, name: 'Статьи', item: new URL('/blog/', Astro.site).toString() },
		{ '@type': 'ListItem', position: 3, name: title, item: canonical },
	],
};

const primaryCategory = categories[0] as keyof typeof CATEGORIES | undefined;
const categoryMeta = primaryCategory ? CATEGORIES[primaryCategory] : null;

/* CPA-баннер: из frontmatter или дефолт по категории */
const cpaBannerId = cpa ?? CATEGORY_DEFAULT_CPA[primaryCategory ?? ''] ?? 'default-ts-piot';
const cpaBanner = CPA_BANNERS[cpaBannerId] ?? CPA_BANNERS['default-ts-piot'];

/* Второй CPA-баннер (только если определён для категории) */
const cpaBanner2Id = CATEGORY_DEFAULT_CPA2[primaryCategory ?? ''];
const cpaBanner2 = cpaBanner2Id ? CPA_BANNERS[cpaBanner2Id] : null;

const catAccent =
	primaryCategory === 'ts-piot' ? '#111' :
	primaryCategory === 'markirovka' ? '#9E2B4F' :
	primaryCategory === 'zakonodatelstvo' ? '#1E4A7A' : '#111';
const catAccentText = '#fff';

/* Background letter from title abbreviation */
function abbrev(t: string): string {
	const words = t.replace(/[«»"']/g, '').split(/\s+/).filter((w) => w.length > 2);
	if (words.length >= 2) return (words[0][0] + words[1][0]).toUpperCase();
	return t.slice(0, 2).toUpperCase();
}
const bgLetter = abbrev(title);

const ogImage = heroImage ?? (currentSlug ? `/og/${currentSlug}.png` : undefined);
const shareUrl = encodeURIComponent(canonical);
const shareTitle = encodeURIComponent(title);
---

<html lang="ru">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={ogImage}
			type="article"
			publishedTime={pubDate.toISOString()}
			modifiedTime={updatedDate?.toISOString()}
			keywords={keywords}
			noindex={seo?.noindex}
			jsonLd={[articleJsonLd, breadcrumbsJsonLd]}
		/>
	</head>

	<body>
		<!-- Reading progress bar -->
		<div id="rp-bar" aria-hidden="true"></div>

		<Header />

		<article
			data-pagefind-body
			data-pagefind-meta={`type:article${categoryMeta ? `,category:${categoryMeta.title}` : ''}`}
			data-pagefind-filter={`type:Статья${categoryMeta ? `,category:${categoryMeta.title}` : ''}`}
		>

			<!-- ═══ HERO: 58% image / 42% text ═══ -->
			<section class="art-hero">
				<div class="art-hero-img" style={`background:${catAccent}`}>
					{categoryMeta && (
						<span class="art-hero-cat" style={`background:#9E2B4F;color:#fff`}>
							{categoryMeta.title}
						</span>
					)}
					{heroImage ? (
						<img
							src={u(heroImage)}
							alt={title}
							loading="eager"
							class="art-hero-photo"
						/>
					) : (
						<span class="art-hero-bg-letter" aria-hidden="true">{bgLetter}</span>
					)}
				</div>
				<div class="art-hero-info">
					<!-- Breadcrumbs in hero -->
					<nav class="art-hero-breadcrumbs" aria-label="Хлебные крошки">
						<a href={u('/')}>Главная</a><span>/</span>
						<a href={u('/blog/')}>Статьи</a>
						{categoryMeta && (
							<><span>/</span><a href={u(`/category/${primaryCategory}/`)}>{categoryMeta.title}</a></>
						)}
					</nav>

					<div class="art-hero-top">
						{updatedDate && (
							<span class="art-updated-badge">Актуально на <FormattedDate date={updatedDate} /></span>
						)}
						{!updatedDate && <FormattedDate date={pubDate} />}
						{readingTime && <span class="art-hero-readtime">{readingTime} мин</span>}
					</div>
					<h1 class="art-h1">{title}</h1>
					<div class="art-hero-bottom">
						<p class="art-lead">{description}</p>
					</div>
				</div>
			</section>

			<!-- ═══ BODY: 28% sidebar / 72% content ═══ -->
			<div class="art-body">

				<!-- Sticky sidebar -->
				<aside class="art-sidebar" data-pagefind-ignore>
					<div class="art-banner">
						<div class="art-banner-strip" style={`background:${catAccent}`} aria-hidden="true"></div>
						<span class="art-banner-eyebrow">{SIDEBAR_BANNER.eyebrow}</span>
						<div class="art-banner-title">{SIDEBAR_BANNER.title}</div>
						<p class="art-banner-desc">{SIDEBAR_BANNER.description}</p>
						<a href={SIDEBAR_BANNER.ctaHref} class="art-banner-cta" target="_blank" rel="noopener noreferrer">
							{SIDEBAR_BANNER.cta}
						</a>
					</div>
				</aside>

				<!-- Main content -->
				<main class="art-content">

					{(tocHeadings.length >= 4 || (wordCount && wordCount >= 2000 && tocHeadings.length >= 2)) && (
						<details class="toc" data-pagefind-ignore open={(wordCount ?? 0) >= 2000}>
							<summary>Содержание</summary>
							<nav>
								<ol class="toc-list">
									{tocHeadings.map((h) => (
										<li class={`toc-item toc-depth-${h.depth}`}>
											<a href={`#${h.slug}`}>{h.text}</a>
										</li>
									))}
								</ol>
							</nav>
						</details>
					)}

					<div class="prose">
						<slot />
					</div>

					<!-- CPA врезка -->
					<div class="cpa-block" data-pagefind-ignore>
						<div class="cpa-visual" style={`background:${cpaBanner.visual.bg}`}>
							<span class="cpa-visual-letter">{cpaBanner.visual.abbrev}</span>
						</div>
						<div class="cpa-body">
							<div class="cpa-eyebrow">{cpaBanner.eyebrow}</div>
							<div class="cpa-title">{cpaBanner.title}</div>
							<p class="cpa-desc">{cpaBanner.description}</p>
						</div>
						<div class="cpa-action">
							<a href={cpaBanner.ctaHref} class="cpa-btn" target="_blank" rel="noopener noreferrer sponsored">
								{cpaBanner.cta}
							</a>
						</div>
						{cpaBanner.erid && (
							<div class="cpa-erid">Реклама · erid: {cpaBanner.erid}</div>
						)}
					</div>

					<!-- Второй CPA-баннер (только для ts-piot) -->
					{cpaBanner2 && (
						<div class="cpa-block" data-pagefind-ignore>
							<div class="cpa-visual" style={`background:${cpaBanner2.visual.bg}`}>
								<span class="cpa-visual-letter">{cpaBanner2.visual.abbrev}</span>
							</div>
							<div class="cpa-body">
								<div class="cpa-eyebrow">{cpaBanner2.eyebrow}</div>
								<div class="cpa-title">{cpaBanner2.title}</div>
								<p class="cpa-desc">{cpaBanner2.description}</p>
							</div>
							<div class="cpa-action">
								<a href={cpaBanner2.ctaHref} class="cpa-btn">
									{cpaBanner2.cta}
								</a>
							</div>
							{cpaBanner2.erid && (
								<div class="cpa-erid">Реклама · erid: {cpaBanner2.erid}</div>
							)}
						</div>
					)}

					<!-- Share -->
					<div class="art-share" data-pagefind-ignore>
						<span class="share-label">Поделиться</span>
						<a
							class="share-btn"
							href={`https://t.me/share/url?url=${shareUrl}&text=${shareTitle}`}
							target="_blank"
							rel="noopener noreferrer"
						>Telegram</a>
						<a
							class="share-btn"
							href={`https://vk.com/share.php?url=${shareUrl}`}
							target="_blank"
							rel="noopener noreferrer"
						>ВКонтакте</a>
					</div>

					<!-- Читайте также — адаптивный макет -->
					{relatedLayout && (
						<aside class="related" aria-label="Читайте также" data-pagefind-ignore>
							<span class="related-eyebrow">Читайте также</span>

							{/* A2: две равные карточки */}
							{relatedLayout === 'A2' && (
								<div class="related-grid related-grid--a2">
									{related.map((post) => {
										const cat = post.data.categories?.[0] as keyof typeof CATEGORIES | undefined;
										const accent = cat === 'markirovka' ? '#9E2B4F' : cat === 'zakonodatelstvo' ? '#1E4A7A' : '#111';
										const catLabel = cat ? CATEGORIES[cat]?.title : null;
										const img = post.data.previewImage ?? post.data.heroImage ?? `/og/${post.id}.png`;
										return (
											<a href={u(`/blog/${post.id}/`)} class="r-card">
												<div class="r-card-img" style={`background:${accent}`}>
													{img && <img src={u(img)} alt="" loading="lazy" />}
												</div>
												<div class="r-card-body">
													{catLabel && <span class="r-card-pill" style={`background:${accent};color:#fff`}>{catLabel}</span>}
													<h3>{post.data.title}</h3>
													{post.data.description && <p>{post.data.description}</p>}
													<span class="r-card-read">Читать →</span>
												</div>
											</a>
										);
									})}
								</div>
							)}

							{/* A3: 1 большая + 2 компактных */}
							{relatedLayout === 'A3' && (
								<div class="related-grid related-grid--a3">
									{related.map((post, i) => {
										const cat = post.data.categories?.[0] as keyof typeof CATEGORIES | undefined;
										const accent = cat === 'markirovka' ? '#9E2B4F' : cat === 'zakonodatelstvo' ? '#1E4A7A' : '#111';
										const catLabel = cat ? CATEGORIES[cat]?.title : null;
										const img = post.data.previewImage ?? post.data.heroImage ?? `/og/${post.id}.png`;
										return (
											<a href={u(`/blog/${post.id}/`)} class={i === 0 ? 'r-card r-card--main' : 'r-card r-card--side'}>
												<div class="r-card-img" style={`background:${accent}`}>
													{img && <img src={u(img)} alt="" loading="lazy" />}
												</div>
												<div class="r-card-body">
													{catLabel && <span class="r-card-pill" style={`background:${accent};color:#fff`}>{catLabel}</span>}
													<h3>{post.data.title}</h3>
													{i === 0 && post.data.description && <p>{post.data.description}</p>}
													<span class="r-card-read">Читать →</span>
												</div>
											</a>
										);
									})}
								</div>
							)}

							{/* B: 2 стандартных + 1 горизонтальная */}
							{relatedLayout === 'B' && (
								<div class="related-grid related-grid--b">
									{related.map((post, i) => {
										const cat = post.data.categories?.[0] as keyof typeof CATEGORIES | undefined;
										const accent = cat === 'markirovka' ? '#9E2B4F' : cat === 'zakonodatelstvo' ? '#1E4A7A' : '#111';
										const catLabel = cat ? CATEGORIES[cat]?.title : null;
										const img = post.data.previewImage ?? post.data.heroImage ?? `/og/${post.id}.png`;
										return (
											<a href={u(`/blog/${post.id}/`)} class={i === 2 ? 'r-card r-card--wide' : 'r-card'}>
												<div class="r-card-img" style={`background:${accent}`}>
													{img && <img src={u(img)} alt="" loading="lazy" />}
												</div>
												<div class="r-card-body">
													{catLabel && <span class="r-card-pill" style={`background:${accent};color:#fff`}>{catLabel}</span>}
													<h3>{post.data.title}</h3>
													{post.data.description && <p>{post.data.description}</p>}
													<span class="r-card-read">Читать →</span>
												</div>
											</a>
										);
									})}
								</div>
							)}

							{/* C: 1 большая + 3 компактных без описания */}
							{relatedLayout === 'C' && (
								<div class="related-grid related-grid--c">
									{related.slice(0, 4).map((post, i) => {
										const cat = post.data.categories?.[0] as keyof typeof CATEGORIES | undefined;
										const accent = cat === 'markirovka' ? '#9E2B4F' : cat === 'zakonodatelstvo' ? '#1E4A7A' : '#111';
										const catLabel = cat ? CATEGORIES[cat]?.title : null;
										const img = post.data.previewImage ?? post.data.heroImage ?? `/og/${post.id}.png`;
										return (
											<a href={u(`/blog/${post.id}/`)} class="r-card">
												<div class="r-card-img" style={`background:${accent}`}>
													{img && <img src={u(img)} alt="" loading="lazy" />}
												</div>
												<div class="r-card-body">
													{catLabel && <span class="r-card-pill" style={`background:${accent};color:#fff`}>{catLabel}</span>}
													<h3>{post.data.title}</h3>
													<span class="r-card-read">Читать →</span>
												</div>
											</a>
										);
									})}
								</div>
							)}

							<div class="related-more"><a href={u('/blog/')}>Все статьи →</a></div>
						</aside>
					)}

					<footer class="art-foot" data-pagefind-ignore>
						<p class="disclaimer">
							Материал носит информационный характер и не является юридической
							или налоговой консультацией. Перед принятием решений сверяйтесь
							с действующей редакцией нормативных актов.
						</p>
					</footer>
				</main>
			</div>
		</article>

		<Footer />

		<!-- Back to top button -->
		<button id="back-to-top" aria-label="Наверх" title="Наверх">↑</button>

		<script>
			/* Reading progress */
			const bar = document.getElementById('rp-bar');
			if (bar) {
				const update = () => {
					const s = document.documentElement.scrollTop;
					const t = document.documentElement.scrollHeight - window.innerHeight;
					bar.style.width = t > 0 ? `${(s / t) * 100}%` : '0%';
				};
				window.addEventListener('scroll', update, { passive: true });
				update();
			}

			/* Back to top */
			const btt = document.getElementById('back-to-top');
			if (btt) {
				window.addEventListener('scroll', () => {
					btt.classList.toggle('visible', window.scrollY > 400);
				}, { passive: true });
				btt.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
			}

		</script>

		<style>
			/* Reading progress */
			#rp-bar { position: fixed; top: 0; left: 0; height: 3px; width: 0%; background: #9E2B4F; z-index: 200; transition: width .1s linear; pointer-events: none; }

			/* ── Hero breadcrumbs ── */
			.art-hero-breadcrumbs { font-size: .65rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: #aaa; display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
			.art-hero-breadcrumbs a { color: #aaa; text-decoration: none; }
			.art-hero-breadcrumbs a:hover { color: #111; }
			.art-hero-breadcrumbs span { color: #ccc; }

			/* ── Hero ── */
			.art-hero { display: grid; grid-template-columns: 58fr 42fr; height: calc(100vh - 56px); min-height: 480px; }
			.art-hero-img { position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; }
			.art-hero-cat { position: absolute; top: 20px; left: 20px; font-size: .65rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; padding: .3em .85em; z-index: 2; }
			.art-hero-photo { width: 100%; height: 100%; object-fit: cover; display: block; }
			.art-hero-bg-letter { font-family: 'Bebas Neue', sans-serif; font-size: 24rem; color: #AFCC00; opacity: .15; line-height: 1; letter-spacing: -.03em; pointer-events: none; user-select: none; }
			.art-hero-info { padding: 32px 48px; display: flex; flex-direction: column; justify-content: space-between; background: #EDE8DF; overflow: auto; }
			.art-hero-top { display: flex; align-items: center; flex-wrap: wrap; gap: 10px; }
			.art-updated-badge { background: #AFCC00; color: #111; font-size: .6rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: .2em .6em; }
			.art-hero-readtime { font-size: .75rem; font-weight: 600; color: #999; letter-spacing: .04em; }
			.art-h1 { font-family: 'Bebas Neue', sans-serif; font-size: 3.2rem; line-height: 1; letter-spacing: .02em; color: #111; margin: 0; }
			.art-hero-bottom { border-top: 2px solid #111; padding-top: 20px; }
			.art-lead { font-size: 1rem; color: #444; line-height: 1.65; font-style: italic; margin: 0; }

			/* ── Body grid ── */
			.art-body { display: grid; grid-template-columns: 28fr 72fr; }

			/* ── Sidebar ── */
			.art-sidebar { padding: 16px; }
			.art-banner { position: sticky; top: calc(56px + 16px); background: #111; color: #fff; overflow: hidden; }
			.art-banner-strip { width: 100%; height: 6px; }
			.art-banner-eyebrow { font-size: .6rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: #AFCC00; display: block; padding: 14px 14px 6px; }
			.art-banner-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; line-height: 1.05; letter-spacing: .03em; text-transform: uppercase; color: #fff; padding: 0 14px 8px; }
			.art-banner-desc { font-size: .78rem; color: #8A8A8A; line-height: 1.5; padding: 0 14px 14px; margin: 0; }
			.art-banner-cta { display: block; margin: 0 14px 14px; background: #9E2B4F; color: #fff; font-size: .7rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: 10px 14px; text-decoration: none; text-align: center; transition: background .15s; }
			.art-banner-cta:hover { background: #7d2240; }

			/* ── Content column ── */
			.art-content { padding: 40px 48px 80px; border-left: 1px solid rgba(0,0,0,.08); min-height: 100vh; }

			/* TOC */
			.toc { border-left: 3px solid #9E2B4F; background: #F6F4F0; padding: 1rem 1.2rem; margin-bottom: 2rem; }
			.toc summary { cursor: pointer; font-family: 'Bebas Neue', sans-serif; font-size: 1.1rem; letter-spacing: .06em; color: #111; list-style: none; display: flex; justify-content: space-between; align-items: center; user-select: none; }
			.toc summary::-webkit-details-marker { display: none; }
			.toc summary::after { content: '▸'; font-size: .8rem; color: #9E2B4F; transition: transform .15s; }
			.toc[open] summary::after { transform: rotate(90deg); }
			.toc-list { margin: .8rem 0 0; padding-left: 1rem; list-style: none; }
			.toc-item { margin-bottom: .3rem; line-height: 1.4; }
			.toc-depth-3 { padding-left: 1rem; }
			.toc-item a { color: #444; text-decoration: none; font-size: .88rem; }
			.toc-item a:hover { color: #9E2B4F; }

			/* Prose */
			.prose { font-size: 1rem; line-height: 1.75; color: #1a1a1a; }

			/* ── CPA-врезка ── */
			.cpa-block { display: grid; grid-template-columns: 120px 1fr auto; grid-template-rows: auto auto; align-items: stretch; margin: 2.5rem 0; border: 2px solid #111; overflow: hidden; }
			.cpa-visual { display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative; }
			.cpa-visual-letter { font-family: 'Bebas Neue', sans-serif; font-size: 4rem; color: #AFCC00; line-height: 1; letter-spacing: -.03em; }
			.cpa-body { padding: 18px 22px; background: #fff; }
			.cpa-eyebrow { font-size: .6rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: #888; margin-bottom: 4px; }
			.cpa-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.3rem; letter-spacing: .03em; text-transform: uppercase; color: #111; line-height: 1.1; margin-bottom: 5px; }
			.cpa-desc { font-size: .82rem; color: #555; line-height: 1.55; margin: 0; }
			.cpa-action { padding: 0 22px; background: #fff; border-left: 1px solid rgba(0,0,0,.08); display: flex; align-items: center; }
			.cpa-btn { display: inline-block; background: #9E2B4F; color: #fff; font-size: .72rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: 12px 18px; text-decoration: none; white-space: nowrap; transition: background .15s; }
			.cpa-btn:hover { background: #7d2240; }
			.cpa-erid { grid-column: 1 / -1; padding: 4px 12px; background: rgba(0,0,0,.04); font-size: .62rem; color: #999; letter-spacing: .04em; border-top: 1px solid rgba(0,0,0,.07); }

			/* ── Share ── */
			.art-share { display: flex; align-items: center; gap: 8px; padding: 1.2rem 0; border-top: 1px solid rgba(0,0,0,.1); border-bottom: 1px solid rgba(0,0,0,.1); }
			.share-label { font-size: .72rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: #888; margin-right: 4px; }
			.share-btn { display: inline-block; padding: 6px 14px; font-size: .72rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; text-decoration: none; background: #111; color: #EDE8DF; transition: background .15s; }
			.share-btn:hover { background: #9E2B4F; color: #fff; }

			/* ── Читайте также ── */
			.related { margin-top: 2.5rem; }
			.related-eyebrow { font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; letter-spacing: .03em; color: #111; display: block; margin-bottom: 12px; }
			.related-more { display: flex; justify-content: flex-end; margin-top: 10px; }
			.related-more a { font-size: .72rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: #888; text-decoration: none; transition: color .15s; }
			.related-more a:hover { color: #9E2B4F; }

			/* Базовая карточка */
			.r-card { display: flex; flex-direction: column; background: #fff; text-decoration: none; color: inherit; overflow: hidden; border: 1px solid rgba(0,0,0,.08); transition: box-shadow .15s, transform .15s; }
			.r-card:hover { transform: translateY(-2px); box-shadow: 0 4px 20px rgba(0,0,0,.1); }
			.r-card-img { width: 100%; aspect-ratio: 16/9; overflow: hidden; flex-shrink: 0; }
			.r-card-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
			.r-card-body { padding: 14px 16px 18px; flex: 1; display: flex; flex-direction: column; gap: 6px; }
			.r-card-pill { font-size: .6rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; padding: 2px 7px; display: inline-block; align-self: flex-start; }
			.r-card-body h3 { font-family: 'Bebas Neue', sans-serif; letter-spacing: .02em; color: #111; line-height: 1.15; margin: 0; }
			.r-card-body p { font-size: .82rem; color: #666; line-height: 1.5; margin: 0; }
			.r-card-read { font-size: .68rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: #9E2B4F; margin-top: auto; padding-top: 4px; }

			/* A2: две равные */
			.related-grid--a2 { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
			.related-grid--a2 .r-card-body h3 { font-size: 1.15rem; }

			/* A3: 1 большая + 2 компактных */
			.related-grid--a3 { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: auto auto; gap: 8px; }
			.related-grid--a3 .r-card--main { grid-row: 1/3; }
			.related-grid--a3 .r-card--main .r-card-body h3 { font-size: 1.4rem; }
			.related-grid--a3 .r-card--side .r-card-img { aspect-ratio: 4/3; }
			.related-grid--a3 .r-card--side .r-card-body h3 { font-size: 1rem; }

			/* B: 2 стандартных + 1 горизонтальная */
			.related-grid--b { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
			.related-grid--b .r-card-body h3 { font-size: 1.1rem; }
			.related-grid--b .r-card--wide { grid-column: 1/3; flex-direction: row; }
			.related-grid--b .r-card--wide .r-card-img { width: 220px; aspect-ratio: unset; flex-shrink: 0; }
			.related-grid--b .r-card--wide .r-card-body { justify-content: center; }
			.related-grid--b .r-card--wide .r-card-body h3 { font-size: 1.3rem; }

			/* C: 1 большая + 3 компактных без описания */
			.related-grid--c { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
			.related-grid--c .r-card-body h3 { font-size: 1rem; }
			.related-grid--c .r-card-body p { display: none; }
			.related-grid--c .r-card-img { aspect-ratio: 4/3; }

			/* Disclaimer */
			.art-foot { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid rgba(0,0,0,.1); }
			.disclaimer { font-size: .82rem; color: #999; font-style: italic; margin: 0; }

			/* Back to top */
			#back-to-top { position: fixed; bottom: 24px; right: 24px; width: 40px; height: 40px; background: #111; color: #EDE8DF; border: none; font-size: 1rem; cursor: pointer; opacity: 0; pointer-events: none; transition: opacity .2s, background .15s; z-index: 90; display: flex; align-items: center; justify-content: center; }
			#back-to-top.visible { opacity: 1; pointer-events: auto; }
			#back-to-top:hover { background: #9E2B4F; }

			/* ── Responsive ── */
			@media (max-width: 1024px) {
				.art-body { grid-template-columns: 1fr; }
				.art-sidebar { display: none; }
				.art-content { padding: 32px 32px 60px; border-left: none; }
			}
			@media (max-width: 820px) {
				.art-hero { grid-template-columns: 1fr; height: auto; }
				.art-hero-img { height: 280px; }
				.art-hero-info { padding: 24px; }
				.art-h1 { font-size: 2.4rem; }
				.art-content { padding: 24px 20px 48px; }
				.related-grid--a2,
				.related-grid--a3,
				.related-grid--b { grid-template-columns: 1fr; grid-template-rows: auto; }
				.related-grid--c { grid-template-columns: 1fr 1fr; }
				.related-grid--a3 .r-card--main { grid-row: auto; }
				.related-grid--b .r-card--wide { flex-direction: column; grid-column: auto; }
				.related-grid--b .r-card--wide .r-card-img { width: 100%; aspect-ratio: 16/9; }
				.cpa-block { grid-template-columns: 1fr; }
				.cpa-visual { height: 80px; }
				.cpa-action { border-left: none; border-top: 1px solid rgba(0,0,0,.08); padding: 14px 22px; }
			}
			@media (max-width: 560px) {
				.art-h1 { font-size: 2rem; }
				.art-content { padding: 20px 16px 40px; }
			}
		</style>
	</body>
</html>
