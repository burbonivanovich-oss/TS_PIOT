---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_TITLE, SITE_AUTHOR, SITE_LOCALE } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & {
	slug?: string;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	categories = [],
	tags = [],
	author = SITE_AUTHOR,
	seo,
} = Astro.props;

const canonical = seo?.canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const keywords = [...new Set([...tags, ...(seo?.keywords ?? [])])];

const articleJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	inLanguage: SITE_LOCALE,
	author: {
		'@type': 'Organization',
		name: author,
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		logo: {
			'@type': 'ImageObject',
			url: new URL('/favicon.svg', Astro.site).toString(),
		},
	},
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	mainEntityOfPage: canonical,
	keywords: keywords.join(', '),
	articleSection: categories.map((c) => CATEGORIES[c as keyof typeof CATEGORIES]?.title ?? c),
};

const breadcrumbsJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Главная',
			item: new URL('/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Статьи',
			item: new URL('/blog/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: title,
			item: canonical,
		},
	],
};

const primaryCategory = categories[0] as keyof typeof CATEGORIES | undefined;
const categoryMeta = primaryCategory ? CATEGORIES[primaryCategory] : null;
---

<html lang="ru">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			type="article"
			publishedTime={pubDate.toISOString()}
			modifiedTime={updatedDate?.toISOString()}
			keywords={keywords}
			noindex={seo?.noindex}
			jsonLd={[articleJsonLd, breadcrumbsJsonLd]}
		/>
	</head>

	<body>
		<Header />
		<main>
			<article class="article">
				<nav class="breadcrumbs" aria-label="Хлебные крошки">
					<a href="/">Главная</a>
					<span>›</span>
					<a href="/blog/">Статьи</a>
					{categoryMeta && (
						<>
							<span>›</span>
							<a href={`/category/${primaryCategory}/`}>{categoryMeta.title}</a>
						</>
					)}
				</nav>

				<header class="article-head">
					<h1>{title}</h1>
					<p class="lead">{description}</p>
					<div class="meta">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="updated">
								· обновлено <FormattedDate date={updatedDate} />
							</span>
						)}
					</div>
					{tags.length > 0 && (
						<div class="tags">
							{tags.map((tag) => (
								<span class="tag">#{tag}</span>
							))}
						</div>
					)}
				</header>

				{heroImage && (
					<div class="hero-image">
						<Image width={1100} height={550} src={heroImage} alt={title} loading="eager" />
					</div>
				)}

				<div class="prose">
					<slot />
				</div>

				<footer class="article-foot">
					<p class="disclaimer">
						Материал носит информационный характер. Перед принятием решений
						сверяйтесь с действующей редакцией нормативных актов и при необходимости
						проконсультируйтесь со специалистом.
					</p>
				</footer>
			</article>
		</main>
		<Footer />

		<style>
			.article {
				max-width: 760px;
				margin: 0 auto;
			}
			.breadcrumbs {
				font-size: 0.88rem;
				color: rgb(var(--gray));
				margin-bottom: 1.2rem;
			}
			.breadcrumbs a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumbs a:hover {
				color: var(--accent);
			}
			.breadcrumbs span {
				margin: 0 0.4em;
			}
			.article-head h1 {
				margin-bottom: 0.8rem;
			}
			.lead {
				font-size: 1.15rem;
				color: rgb(var(--gray-dark));
				margin-bottom: 1rem;
			}
			.meta {
				color: rgb(var(--gray));
				font-size: 0.95rem;
				margin-bottom: 1rem;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				margin-bottom: 1.5rem;
			}
			.tag {
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				padding: 0.2em 0.7em;
				border-radius: 999px;
				font-size: 0.82rem;
			}
			.hero-image {
				margin: 1.5rem 0 2rem;
			}
			.hero-image img {
				border-radius: 10px;
				box-shadow: var(--box-shadow);
			}
			.article-foot {
				margin-top: 3rem;
				padding-top: 1.5rem;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.disclaimer {
				font-size: 0.9rem;
				color: rgb(var(--gray));
				font-style: italic;
			}
		</style>
	</body>
</html>
