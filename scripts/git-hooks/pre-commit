#!/usr/bin/env bash
# Запускает гейты перед коммитом:
# - factcheck-guard: маркер .claude/factchecked/<slug> для draft: false
# - social-guard:    соцпосты в wiki/social или content/social
# Для других проверок (lint, typecheck) — добавлять отдельные блоки ниже.

set -e

ROOT="$(git rev-parse --show-toplevel)"
node "$ROOT/scripts/git-hooks/pre-commit-factcheck-guard.mjs"
node "$ROOT/scripts/git-hooks/pre-commit-social-guard.mjs"
