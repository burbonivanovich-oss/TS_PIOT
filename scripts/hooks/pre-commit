#!/usr/bin/env bash
# pre-commit hook: проверяет quality gates перед публикацией статьи.
# Установка: bash scripts/install-hooks.sh

set -euo pipefail

BLOG_PREFIX="src/content/blog/"
FACTCHECK_DIR=".claude/factchecked"
ERRORS=0

# Список blog-файлов, которые идут в этот коммит
staged_blog=$(git diff --cached --name-only | grep "^${BLOG_PREFIX}" | grep '\.md$' || true)

if [ -z "$staged_blog" ]; then
  exit 0
fi

for file in $staged_blog; do
  # Читаем staged-версию файла (не рабочую копию)
  content=$(git show ":${file}" 2>/dev/null || true)
  [ -z "$content" ] && continue

  # Проверяем только статьи с draft: false
  if ! echo "$content" | grep -qE '^draft:\s*false'; then
    continue
  fi

  slug=$(basename "$file" .md)

  # 1. Фактчекинг — ищем маркер .claude/factchecked/<slug>
  if [ ! -f "${FACTCHECK_DIR}/${slug}" ]; then
    echo ""
    echo "  БЛОКИРОВКА: ${file}"
    echo "  Статья снята с draft, но фактчекинг не подтверждён."
    echo "  Запустите: /blog factcheck ${file}"
    echo "  После прохождения создайте маркер:"
    echo "    mkdir -p ${FACTCHECK_DIR} && touch ${FACTCHECK_DIR}/${slug}"
    echo ""
    ERRORS=$((ERRORS + 1))
  fi

  # 2. Предупреждение о каннибализации (не блокируем, только напоминаем)
  echo ""
  echo "  НАПОМИНАНИЕ: перед публикацией «${slug}» убедитесь,"
  echo "  что запущена проверка: /blog cannibalization src/content/blog/"
  echo ""
done

if [ "$ERRORS" -gt 0 ]; then
  echo "Коммит заблокирован: ${ERRORS} статья(и) не прошли quality gates."
  echo "Исправьте ошибки выше или оставьте draft: true до завершения проверки."
  exit 1
fi

exit 0
